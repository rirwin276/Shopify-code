    {
      "type": "color",
      "id": "button_secondary_border_color",
      "label": "Border",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_secondary_hover_background",
      "label": "Hover background",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "button_secondary_hover_text_color",
      "label": "Hover text",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "button_secondary_hover_border_color",
      "label": "Hover border",
      "default": "#333333"
    }
  ],
  "presets": [
    {
      "name": "Call to action text"
    }
  ]
}
{% endschema %}