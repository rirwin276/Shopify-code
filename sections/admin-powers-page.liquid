{% comment %}
  ADMIN POWERS — V12 (SECTION FILE)
  - V12: Mobile-first single-dashboard redesign with tab navigation.
  - Tabs: Overview | Members | Products | Danger
  - Products tab: list, hide/show, delete via Railway API.
  - All existing functionality preserved.
{% endcomment %}

{%- assign dashboard_url = '/pages/portal' -%}
{%- assign join_path = '/pages/join-store' -%}

{%- comment %} 1. GET SHOP HANDLE {% endcomment -%}
{%- assign shop_handle = request.params.shop | default: '' | strip -%}
{%- if shop_handle == blank -%}
  {%- assign _cfh = content_for_header -%}
  {%- assign _url_part = _cfh | split: '"pageurl":"' | last | split: '"' | first -%}
  {%- assign _url_part = _url_part | replace: '\u0026', '&' -%}
  {%- if _url_part contains '?' -%}
    {%- assign _qs = _url_part | split: '?' | last -%}
    {%- assign _pairs = _qs | split: '&' -%}
    {%- for p in _pairs -%}
      {%- assign kv = p | split: '=' -%}
      {%- if kv[0] == 'shop' -%}{%- assign shop_handle = kv[1] | default: '' | strip -%}{%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endif -%}
{%- assign shop_handle = shop_handle | replace: '%2D', '-' | replace: '%5F', '_' | strip | downcase -%}

{%- comment %} 2. PERMISSIONS CHECK {% endcomment -%}
{%- assign required_admin_tag = 'storefront-admin--' | append: shop_handle -%}
{%- assign is_admin_for_shop = false -%}
{%- assign is_super_admin = false -%}

{%- if customer and shop_handle != blank -%}
  {%- if customer.email == 'ryan.irwin@stellaandsagecompany.com' -%}
    {%- assign is_super_admin = true -%}
    {%- assign is_admin_for_shop = true -%}
  {%- endif -%}
  {%- for t in customer.tags -%}
    {%- assign tag_down = t | downcase | strip -%}
    {%- if tag_down == 'super-admin' -%}
      {%- assign is_super_admin = true -%}
      {%- assign is_admin_for_shop = true -%}
    {%- endif -%}
    {%- if tag_down == required_admin_tag -%}{%- assign is_admin_for_shop = true -%}{%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- style -%}
  :root {
    --ap-bg: #f0f4f8;
    --ap-card: #ffffff;
    --ap-text: #0f172a;
    --ap-gray: #64748b;
    --ap-border: #e2e8f0;
    --ap-accent: #0f172a;
    --ap-accent2: #6366f1;
    --ap-success: #10b981;
    --ap-danger: #ef4444;
    --ap-shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --ap-shadow: 0 4px 16px rgba(15,23,42,0.08), 0 1px 3px rgba(15,23,42,0.04);
    --ap-shadow-lg: 0 20px 40px rgba(15,23,42,0.12);
    --ap-radius: 18px;
    --ap-font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Inter", sans-serif;
  }

  /* ── AUTH SCREENS ──────────────────────────────────────── */
  .ap-auth-wrap { max-width: 420px; margin: 80px auto; padding: 20px; text-align: center; font-family: var(--ap-font); }
  .ap-auth-card { background: var(--ap-card); padding: 48px 40px; border-radius: var(--ap-radius); border: 1px solid var(--ap-border); box-shadow: var(--ap-shadow); }
  .ap-auth-icon { font-size: 36px; width: 72px; height: 72px; line-height: 72px; background: #f1f5f9; border-radius: 50%; margin: 0 auto 24px; display: block; }
  .ap-auth-card h2 { margin: 0 0 10px; font-size: 22px; font-weight: 800; }
  .ap-auth-card p { margin: 0 0 24px; color: var(--ap-gray); font-size: 15px; }

  /* ── MAIN LAYOUT ───────────────────────────────────────── */
  .ap-wrap { max-width: 800px; margin: 0 auto; padding: 32px 20px 80px; font-family: var(--ap-font); color: var(--ap-text); }

  /* ── HERO HEADER ───────────────────────────────────────── */
  .ap-hero {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #312e81 100%);
    border-radius: var(--ap-radius); padding: 22px 24px; margin-bottom: 14px;
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 14px; position: relative; overflow: hidden;
    box-shadow: var(--ap-shadow-lg);
  }
  .ap-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle at 80% 20%, rgba(99,102,241,0.3) 0%, transparent 60%);
  }
  .ap-hero-left { position: relative; z-index: 1; }
  .ap-hero-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.9); font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    padding: 4px 10px; border-radius: 99px; margin-bottom: 8px;
    backdrop-filter: blur(10px);
  }
  .ap-hero-badge .dot {
    width: 6px; height: 6px; border-radius: 50%; background: #10b981;
    box-shadow: 0 0 6px #10b981; animation: pulse-dot 2s infinite;
  }
  .ap-hero-badge.status--sleeping .dot { background: #6366f1; box-shadow: 0 0 6px #6366f1; }
  .ap-hero-badge.status--waking .dot { background: #f59e0b; box-shadow: 0 0 6px #f59e0b; }
  .ap-hero-badge.status--building .dot { background: #8b5cf6; box-shadow: 0 0 6px #8b5cf6; }
  @keyframes pulse-dot { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
  @media (prefers-reduced-motion: reduce) { .ap-hero-badge .dot { animation: none; } }
  .ap-hero h1 { margin: 0 0 3px; font-size: clamp(20px, 4vw, 28px); font-weight: 900; color: #fff; letter-spacing: -0.03em; line-height: 1.1; }
  .ap-hero-sub { color: rgba(255,255,255,0.55); font-size: 12px; margin: 0; }
  .ap-hero-actions { display: flex; gap: 8px; position: relative; z-index: 1; align-items: center; flex-wrap: wrap; }

  /* ── ICON BUTTONS (HERO QUICK ACTIONS) ───────────────────── */
  .ap-icon-btn {
    width: 44px; height: 44px; border-radius: 10px;
    background: rgba(255,255,255,0.12); backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.2); color: #fff;
    cursor: pointer; font-size: 18px;
    display: inline-flex; align-items: center; justify-content: center;
    transition: all 0.2s; flex-shrink: 0;
  }
  .ap-icon-btn:hover { background: rgba(255,255,255,0.22); }
  .ap-icon-btn--danger { background: rgba(239,68,68,0.2); border-color: rgba(239,68,68,0.35); }
  .ap-icon-btn--danger:hover { background: rgba(239,68,68,0.38); }

  /* ── BUTTONS ───────────────────────────────────────────── */
  .ap-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    padding: 10px 20px; border-radius: 10px; font-weight: 700; font-size: 14px;
    cursor: pointer; transition: all 0.2s; border: none; text-decoration: none;
    font-family: var(--ap-font); white-space: nowrap; min-height: 44px;
  }
  .ap-btn--primary { background: var(--ap-accent); color: #fff; }
  .ap-btn--primary:hover { background: #1e293b; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(15,23,42,0.3); }
  .ap-btn--glass { background: rgba(255,255,255,0.12); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.2); color: #fff; }
  .ap-btn--glass:hover { background: rgba(255,255,255,0.22); color: #fff; }
  .ap-btn--outline { background: transparent; border: 1px solid var(--ap-border); color: var(--ap-text); }
  .ap-btn--outline:hover { background: #f8fafc; border-color: #94a3b8; }
  .ap-btn--danger { background: #fee2e2; color: #991b1b; }
  .ap-btn--danger:hover { background: #fecaca; }
  .ap-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none !important; }
  .ap-btn-full { width: 100%; }

  /* ── TAB BAR ──────────────────────────────────────────────── */
  .ap-tab-bar {
    display: flex; gap: 4px; margin-bottom: 20px;
    background: #f1f5f9; border-radius: 14px; padding: 4px;
    position: sticky; top: 0; z-index: 100; box-shadow: var(--ap-shadow-sm);
  }
  .ap-tab {
    flex: 1; padding: 10px 8px; border: none; background: transparent;
    border-radius: 10px; font-weight: 700; font-size: 13px;
    color: var(--ap-gray); cursor: pointer; transition: all 0.2s;
    font-family: var(--ap-font); min-height: 44px; line-height: 1.2;
  }
  .ap-tab.active { background: #fff; color: var(--ap-text); box-shadow: var(--ap-shadow-sm); }
  .ap-tab:hover:not(.active) { background: rgba(255,255,255,0.6); color: var(--ap-text); }

  /* ── TAB PANELS ──────────────────────────────────────────── */
  .ap-tab-panel { display: none; }
  .ap-tab-panel.active { display: block; }

  /* ── CARDS ─────────────────────────────────────────────── */
  .ap-card {
    background: var(--ap-card); border: 1px solid var(--ap-border);
    border-radius: var(--ap-radius); padding: 24px;
    box-shadow: var(--ap-shadow); transition: box-shadow 0.2s;
  }
  .ap-card + .ap-card { margin-top: 16px; }
  .ap-card-head { margin-bottom: 20px; }
  .ap-card-head h3 { margin: 0 0 4px; font-size: 16px; font-weight: 800; letter-spacing: -0.01em; }
  .ap-card-head p { margin: 0; font-size: 13px; color: var(--ap-gray); line-height: 1.4; }

  /* ── FORM ELEMENTS ─────────────────────────────────────── */
  .ap-form-group { margin-bottom: 16px; }
  .ap-label { display: block; font-size: 11px; font-weight: 800; margin-bottom: 6px; color: var(--ap-gray); text-transform: uppercase; letter-spacing: 0.08em; }
  .ap-input, .ap-textarea, .ap-select {
    width: 100%; padding: 10px 14px; border: 1.5px solid var(--ap-border);
    border-radius: 10px; font-size: 14px; font-family: var(--ap-font);
    transition: 0.2s; background: #fff; color: var(--ap-text); box-sizing: border-box;
  }
  .ap-input:focus, .ap-textarea:focus, .ap-select:focus { outline: none; border-color: var(--ap-accent2); box-shadow: 0 0 0 3px rgba(99,102,241,0.12); }
  .ap-textarea { min-height: 100px; resize: vertical; }
  .ap-input-mono { font-family: monospace; background: #f8fafc; color: #475569; }
  .ap-helper { font-size: 12px; color: var(--ap-gray); margin: 6px 0 0; }

  /* ── RADIO GROUP ───────────────────────────────────────── */
  .ap-radio-group { display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px; }
  .ap-radio { display: flex; align-items: flex-start; gap: 12px; padding: 12px 14px; border: 1.5px solid var(--ap-border); border-radius: 12px; cursor: pointer; transition: all 0.2s; background: #fafafa; }
  .ap-radio:hover { border-color: #94a3b8; background: #f8fafc; }
  .ap-radio.selected { border-color: var(--ap-accent2); background: #eef2ff; }
  .ap-radio input[type="radio"] { margin-top: 3px; accent-color: var(--ap-accent2); }
  .ap-radio-title { display: block; font-weight: 700; font-size: 14px; margin-bottom: 2px; }
  .ap-radio-desc { display: block; font-size: 12px; color: var(--ap-gray); }

  /* ── DIVIDER ───────────────────────────────────────────── */
  .ap-divider { height: 1px; background: var(--ap-border); margin: 16px 0; }

  /* ── COPY ROW ──────────────────────────────────────────── */
  .ap-copy-row { display: flex; gap: 8px; }
  .ap-copy-row .ap-input { flex: 1; }

  /* ── QR ────────────────────────────────────────────────── */
  .ap-qr-box { display: flex; flex-direction: column; align-items: center; padding: 20px; background: #f8fafc; border-radius: 14px; border: 1px solid var(--ap-border); text-align: center; margin-top: 16px; }
  #ap-qrcode { margin: 0 auto 12px; }
  #ap-qrcode img, #ap-qrcode canvas { display: block; margin: 0 auto; }

  /* ── BTN ROW ───────────────────────────────────────────── */
  .ap-btn-row { display: flex; gap: 8px; margin-top: 4px; flex-wrap: wrap; }
  .ap-btn-row .ap-btn { flex: 1; min-width: 100px; }

  /* ── STATUS ────────────────────────────────────────────── */
  .ap-status { margin-top: 12px; font-size: 13px; font-weight: 600; min-height: 20px; border-radius: 8px; padding: 0; transition: all 0.2s; }
  .ap-status:not(:empty) { padding: 10px 14px; }
  .ap-status.ok { background: #ecfdf5; color: #065f46; }
  .ap-status.err { background: #fef2f2; color: #991b1b; }

  /* ── ANIMATIONS ─────────────────────────────────────────── */
  @keyframes ap-fadeIn { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }
  .ap-public-block { animation: ap-fadeIn 0.2s ease-out; }

  /* ── SLEEP CARD ────────────────────────────────────────── */
  .ap-sleep-card {
    background: #fffbeb; border: 1.5px solid rgba(245,158,11,0.3);
    border-radius: var(--ap-radius); padding: 24px; box-shadow: var(--ap-shadow);
  }
  .ap-sleep-card h3 { margin: 0 0 4px; font-size: 16px; font-weight: 800; }
  .ap-sleep-card > p { margin: 0 0 14px; font-size: 13px; color: #6b7280; line-height: 1.5; }

  /* ── DANGER ZONE CARD ──────────────────────────────────── */
  .ap-danger-card {
    background: #fff5f5; border: 1.5px solid rgba(239,68,68,0.3);
    border-radius: var(--ap-radius); padding: 24px;
    box-shadow: var(--ap-shadow); margin-top: 16px;
  }
  .ap-danger-card h3 { margin: 0 0 4px; font-size: 16px; font-weight: 800; color: #dc2626; }
  .ap-danger-card > p { margin: 0 0 14px; font-size: 13px; color: #6b7280; line-height: 1.5; }
  .ap-btn--nuke { background: #ef4444; color: #fff; width: 100%; margin-top: 4px; }
  .ap-btn--nuke:hover { background: #dc2626; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(239,68,68,0.4); }

  /* ── NUKE MODAL ────────────────────────────────────────── */
  .ap-nuke-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.55); z-index: 9999;
    align-items: center; justify-content: center; padding: 20px;
    backdrop-filter: blur(4px);
  }
  .ap-nuke-overlay.open { display: flex; }
  .ap-nuke-dialog {
    width: min(520px, 100%); background: #fff;
    border-radius: var(--ap-radius); border: 1px solid rgba(0,0,0,0.1);
    box-shadow: 0 32px 80px rgba(0,0,0,0.28); padding: 32px;
    animation: ap-fadeIn 0.2s ease-out;
  }
  .ap-nuke-dialog__icon { font-size: 36px; margin-bottom: 10px; }
  .ap-nuke-dialog__title { font-weight: 900; font-size: 20px; color: #dc2626; margin: 0 0 8px; letter-spacing: -0.02em; }
  .ap-nuke-dialog__warning { font-size: 14px; line-height: 1.55; color: #374151; margin: 0 0 16px; }
  .ap-nuke-confirm-input {
    width: 100%; padding: 11px 14px; margin-bottom: 16px;
    border: 1.5px solid rgba(239,68,68,0.4); border-radius: 10px;
    font-size: 14px; font-family: var(--ap-font); color: #0f172a;
    background: #fff; box-sizing: border-box;
  }
  .ap-nuke-confirm-input:focus { outline: none; border-color: #ef4444; box-shadow: 0 0 0 3px rgba(239,68,68,0.15); }
  .ap-nuke-actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .ap-nuke-actions .ap-btn { flex: 1; min-width: 120px; }
  .ap-nuke-log {
    margin-top: 16px; padding: 14px;
    background: #0f172a; color: #94a3b8;
    border-radius: 10px; font-size: 11px;
    font-family: monospace; white-space: pre-wrap;
    max-height: 180px; overflow-y: auto; display: none;
    line-height: 1.6;
  }

  /* ── PRODUCT ROWS ────────────────────────────────────────── */
  .ap-product-row { display: flex; align-items: center; gap: 10px; padding: 12px 0; border-bottom: 1px solid var(--ap-border); }
  .ap-product-row:last-child { border-bottom: none; }
  .ap-product-title { flex: 1; font-size: 14px; font-weight: 600; line-height: 1.3; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .ap-product-badge { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; padding: 3px 8px; border-radius: 99px; flex-shrink: 0; }
  .ap-product-badge--visible { background: #dcfce7; color: #166534; }
  .ap-product-badge--hidden { background: #f1f5f9; color: #64748b; }
  .ap-product-actions { display: flex; gap: 6px; flex-shrink: 0; }
  .ap-icon-action {
    width: 44px; height: 44px; border: 1px solid var(--ap-border);
    border-radius: 8px; background: #fff; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; transition: all 0.15s;
  }
  .ap-icon-action:hover { background: #f8fafc; border-color: #94a3b8; }
  .ap-icon-action--danger:hover { background: #fef2f2; border-color: #fca5a5; }
  .ap-empty-state { color: var(--ap-gray); font-size: 14px; padding: 20px 0; text-align: center; }
  .ap-error-state { color: #991b1b; font-size: 14px; padding: 20px 0; }

  /* ── SPINNER ──────────────────────────────────────────────── */
  .ap-spinner { display: flex; align-items: center; justify-content: center; padding: 40px; color: var(--ap-gray); font-size: 14px; gap: 10px; }
  .ap-spinner::before {
    content: ''; width: 20px; height: 20px; border: 2px solid var(--ap-border);
    border-top-color: var(--ap-accent2); border-radius: 50%;
    animation: ap-spin 0.8s linear infinite; flex-shrink: 0;
  }
  @keyframes ap-spin { to { transform: rotate(360deg); } }
  @media (prefers-reduced-motion: reduce) { .ap-spinner::before { animation: none; border-top-color: var(--ap-accent2); } }

  /* ── MOBILE ────────────────────────────────────────────────── */
  @media(max-width: 600px) {
    .ap-card { padding: 16px; }
    .ap-sleep-card { padding: 16px; }
    .ap-danger-card { padding: 16px; }
    .ap-wrap { padding: 16px 12px 60px; }
    .ap-hero { padding: 16px 18px; }
    .ap-tab { font-size: 12px; padding: 8px 6px; }
    .ap-btn { min-height: 44px; }
    .ap-hero h1 { font-size: 20px; }
  }
{%- endstyle -%}

{%- if customer == nil -%}

<div class="ap-auth-wrap">
  <div class="ap-auth-card">
    <span class="ap-auth-icon">🔒</span>
    <h2>Please Sign In</h2>
    <p>You must be signed in to access Admin Powers.</p>
    <a href="{{ routes.account_login_url }}?return_url={{ request.path | append: '?shop=' | append: shop_handle | url_encode }}" class="ap-btn ap-btn--primary">Sign In →</a>
  </div>
</div>

{%- elsif is_admin_for_shop == false -%}

<div class="ap-auth-wrap">
  <div class="ap-auth-card">
    <span class="ap-auth-icon">🚫</span>
    <h2>Access Denied</h2>
    <p>You don't have permission to manage <strong>{{ shop_handle }}</strong>.</p>
    <a href="{{ dashboard_url }}" class="ap-btn ap-btn--outline">← Back to Dashboard</a>
  </div>
</div>

{%- else -%}

{%- assign shop_meta = shop.metaobjects.custom_shop[shop_handle] -%}
{%- assign join_mode = 'secure' -%}
{%- assign collection_handle = shop_handle -%}
{%- assign store_name = shop_handle -%}
{%- assign ap_store_status = 'active' -%}

{%- if shop_meta -%}
  {%- assign raw_jm = shop_meta.join_mode.value | default: shop_meta.join_mode -%}
  {%- assign jm = raw_jm | strip | downcase -%}
  {%- if jm == 'public' -%}{%- assign join_mode = 'public' -%}{%- endif -%}
  {%- assign join_code = shop_meta.join_code.value | default: shop_meta.join_code | default: '' | strip -%}
  {%- assign ch = shop_meta.collection_handle.value | default: shop_meta.collection_handle | default: '' | strip -%}
  {%- if ch != blank -%}{%- assign collection_handle = ch -%}{%- endif -%}
  {%- assign sn = shop_meta.name.value | default: shop_meta.name -%}
  {%- if sn != blank -%}{%- assign store_name = sn -%}{%- endif -%}
  {%- assign _raw_status = shop_meta.status.value | default: shop_meta.status | default: '' | strip | downcase -%}
  {%- if _raw_status == 'sleeping' or _raw_status == 'waking' or _raw_status == 'active' -%}
    {%- assign ap_store_status = _raw_status -%}
  {%- endif -%}
{%- endif -%}

{%- assign join_link = shop.url | append: join_path | append: '?shop=' | append: collection_handle -%}
{%- if join_code != blank -%}
  {%- assign join_link = join_link | append: '&code=' | append: join_code -%}
{%- endif -%}

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<div class="ap-wrap">

  <script>
    window.SSAP = window.SSAP || {};
    SSAP.collectionHandle = {{ collection_handle | json }};
    SSAP.shopHandle = {{ shop_handle | json }};
    SSAP.railwayUrl = "https://studio-uploader-production.up.railway.app";
  </script>

  <!-- HERO HEADER -->
  <div class="ap-hero">
    <div class="ap-hero-left">
      {%- assign _safe_status = '' -%}
      {%- if ap_store_status == 'active' or ap_store_status == 'sleeping' or ap_store_status == 'waking' or ap_store_status == 'building' -%}
        {%- assign _safe_status = ap_store_status -%}
      {%- endif -%}
      <div class="ap-hero-badge{% if _safe_status != '' %} status--{{ _safe_status }}{% endif %}">
        <span class="dot"></span>
        {{ _safe_status | default: 'active' | upcase }}
      </div>
      <h1>{{ store_name | capitalize }}</h1>
      <p class="ap-hero-sub">{{ shop_handle }} &middot; {% if is_super_admin %}God Mode{% else %}Admin{% endif %}</p>
    </div>
    <div class="ap-hero-actions">
      <button class="ap-icon-btn" id="apQuickQR" title="View QR Code" aria-label="View QR Code">🔗</button>
      <button class="ap-icon-btn" id="apQuickSleep" title="Sleep / Wake Store" aria-label="Sleep or Wake Store">💤</button>
      <button class="ap-icon-btn ap-icon-btn--danger" id="apQuickNuke" title="Nuke Store" aria-label="Nuke Store">☠️</button>
      <a href="/collections/{{ collection_handle }}" class="ap-btn ap-btn--glass">View ↗</a>
      <a href="{{ dashboard_url }}" class="ap-btn ap-btn--glass">← Back</a>
    </div>
  </div>

  <!-- TAB BAR -->
  <div class="ap-tab-bar" role="tablist" aria-label="Admin sections">
    <button class="ap-tab active" data-tab="overview" role="tab" aria-selected="true" aria-controls="apPanel-overview">Overview</button>
    <button class="ap-tab" data-tab="members" role="tab" aria-selected="false" aria-controls="apPanel-members">Members</button>
    <button class="ap-tab" data-tab="products" role="tab" aria-selected="false" aria-controls="apPanel-products">Products</button>
    <button class="ap-tab" data-tab="danger" role="tab" aria-selected="false" aria-controls="apPanel-danger">Danger</button>
  </div>

  <!-- ── OVERVIEW TAB ───────────────────────────────────── -->
  <div class="ap-tab-panel active" id="apPanel-overview" role="tabpanel">
    <div class="ap-card">
      <div class="ap-card-head">
        <h3>🔗 Invite &amp; Access</h3>
        <p>Control how people enter this storefront.</p>
      </div>

      <div class="ap-radio-group">
        <label class="ap-radio {% if join_mode == 'secure' %}selected{% endif %}">
          <input type="radio" name="ap-joinmode" value="secure" {% if join_mode == 'secure' %}checked{% endif %}>
          <div>
            <span class="ap-radio-title">🔒 Secure (Invite Only)</span>
            <span class="ap-radio-desc">Only people you add can access.</span>
          </div>
        </label>
        <label class="ap-radio {% if join_mode == 'public' %}selected{% endif %}">
          <input type="radio" name="ap-joinmode" value="public" {% if join_mode == 'public' %}checked{% endif %}>
          <div>
            <span class="ap-radio-title">🌐 Public (Shareable Link)</span>
            <span class="ap-radio-desc">Anyone with the link or QR code can join.</span>
          </div>
        </label>
      </div>

      <button id="apBtnSaveMode" class="ap-btn ap-btn--primary ap-btn-full">Save Settings</button>
      <div id="apStatusMode" class="ap-status"></div>

      <div id="apBlockPublic" class="ap-public-block" {% if join_mode != 'public' %}style="display:none"{% endif %}>
        <div class="ap-divider"></div>
        <div class="ap-form-group">
          <label class="ap-label">Join Link</label>
          <div class="ap-copy-row">
            <input id="apInputJoinLink" class="ap-input ap-input-mono" value="{{ join_link | escape }}" readonly>
            <button id="apBtnCopy" class="ap-btn ap-btn--outline">Copy</button>
          </div>
          <p class="ap-helper">Share this link with your team via chat or email.</p>
        </div>
        <div class="ap-qr-box">
          <div id="ap-qrcode"></div>
          <p class="ap-helper">Print for flyers or let people scan in person.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- ── MEMBERS TAB ────────────────────────────────────── -->
  <div class="ap-tab-panel" id="apPanel-members" role="tabpanel">
    <div class="ap-card">
      <div class="ap-card-head">
        <h3>👥 Manage Roster</h3>
        <p>Add or remove people from this storefront.</p>
      </div>

      <div class="ap-form-group">
        <label class="ap-label">Member Emails</label>
        <textarea id="apInputEmails" class="ap-textarea" placeholder="alice@example.com, bob@example.com..."></textarea>
        <p class="ap-helper">Separate multiple emails with commas.</p>
      </div>

      <div class="ap-form-group">
        <label class="ap-label">Access Level</label>
        <select id="apInputRole" class="ap-select">
          <option value="member" selected>Member (Can Shop)</option>
          <option value="admin">Admin (Can Edit Settings)</option>
        </select>
      </div>

      <div class="ap-btn-row">
        <button id="apBtnAdd" class="ap-btn ap-btn--primary">+ Add Members</button>
        <button id="apBtnRemove" class="ap-btn ap-btn--danger">Remove</button>
      </div>
      <div id="apStatusMembers" class="ap-status"></div>
    </div>
  </div>

  <!-- ── PRODUCTS TAB ───────────────────────────────────── -->
  <div class="ap-tab-panel" id="apPanel-products" role="tabpanel">
    <div class="ap-card">
      <div class="ap-card-head">
        <h3>📦 Products</h3>
        <p>Manage products visible in this storefront.</p>
      </div>
      <div id="apProductsContent">
        <div class="ap-spinner">Loading products&hellip;</div>
      </div>
      <div id="apStatusProducts" class="ap-status"></div>
    </div>
  </div>

  <!-- ── DANGER TAB ─────────────────────────────────────── -->
  <div class="ap-tab-panel" id="apPanel-danger" role="tabpanel">

    <!-- Sleep / Wake -->
    <div class="ap-sleep-card" id="apSleepModeCard">
      <h3>💤 Sleep Mode</h3>
      <p>Put this store to sleep. All products will be deleted. Member tags and store data are preserved. You can wake the store back up at any time to rebuild products.</p>

      {% if ap_store_status == 'sleeping' %}
        <p style="font-size:13px; color:#065f46; background:#ecfdf5; border:1px solid #a7f3d0; border-radius:10px; padding:10px 14px; margin:0 0 14px;">
          💤 This store is currently sleeping. Wake it up to rebuild all products via Printful.
        </p>
        <button id="apBtnWakeStore" class="ap-btn ap-btn-full" style="background:#10b981; color:#fff;">☀️ Wake Up Store</button>
      {% elsif ap_store_status == 'waking' %}
        <p style="font-size:13px; color:#1e40af; background:#eff6ff; border:1px solid #bfdbfe; border-radius:10px; padding:10px 14px; margin:0 0 14px;">
          ⏳ This store is currently waking up. Products are being rebuilt. Please wait.
        </p>
        <button class="ap-btn ap-btn-full" disabled style="opacity:0.5; cursor:not-allowed; background:#6366f1; color:#fff;">⏳ Waking Up&hellip;</button>
      {% else %}
        <button id="apBtnSleepStore" class="ap-btn ap-btn-full" style="background:#ef4444; color:#fff;">💤 Put Store to Sleep</button>
      {% endif %}
      <div id="apStatusSleep" class="ap-status"></div>
    </div>

    <!-- Nuke -->
    <div class="ap-danger-card">
      <h3>☢️ Danger Zone</h3>
      <p>
        Permanently delete the <strong>{{ store_name }}</strong> store.
        All products, members, logos, and settings will be removed forever.
        <strong>This cannot be undone.</strong>
      </p>
      <button id="apNukeBtn" class="ap-btn ap-btn--nuke">☢️ Nuke This Store</button>
    </div>

  </div><!-- /.ap-tab-panel danger -->

  <!-- NUKE CONFIRMATION MODAL -->
  <div class="ap-nuke-overlay" id="apNukeOverlay">
    <div class="ap-nuke-dialog" role="dialog" aria-modal="true" aria-labelledby="apNukeTitle">
      <div class="ap-nuke-dialog__icon">☢️</div>
      <p class="ap-nuke-dialog__title" id="apNukeTitle">Permanently Destroy This Store?</p>
      <p class="ap-nuke-dialog__warning">
        You are about to permanently delete <strong>{{ store_name }}</strong>.
        This store and everything in it — all products, members, photos, and settings — will be gone forever.
        <strong>This cannot be undone.</strong>
      </p>
      <input
        type="text"
        class="ap-nuke-confirm-input"
        id="apNukeInput"
        placeholder="Type &quot;gone&quot; to confirm"
        autocomplete="off">
      <div class="ap-nuke-actions">
        <button id="apNukeDestroy" class="ap-btn ap-btn--nuke" disabled>Destroy Store</button>
        <button id="apNukeCancel" class="ap-btn ap-btn--outline">Cancel</button>
      </div>
      <pre class="ap-nuke-log" id="apNukeLog"></pre>
    </div>
  </div>

</div><!-- /.ap-wrap -->

<script>
(function(){
  var AP_RAILWAY_URL = SSAP.railwayUrl;
  var AP_ADMIN_SECRET = 'stellasage-god-mode-2026-xK9mP';
  var AP_HANDLE = String(SSAP.shopHandle || '');

  // ── TAB SWITCHING ──────────────────────────────────────────
  function showTab(tabName) {
    document.querySelectorAll('.ap-tab').forEach(function(t) {
      var isActive = t.getAttribute('data-tab') === tabName;
      t.classList.toggle('active', isActive);
      t.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
    document.querySelectorAll('.ap-tab-panel').forEach(function(p) {
      p.classList.toggle('active', p.id === 'apPanel-' + tabName);
    });
    if (tabName === 'products' && !apProductsLoaded) {
      apProductsLoaded = true;
      loadProducts();
    }
  }

  document.querySelectorAll('.ap-tab').forEach(function(tab) {
    tab.addEventListener('click', function() {
      showTab(tab.getAttribute('data-tab'));
    });
  });

  // ── QUICK ACTION BUTTONS ────────────────────────────────────
  document.getElementById('apQuickQR').addEventListener('click', function() {
    showTab('overview');
    var block = document.getElementById('apBlockPublic');
    var currentMode = document.querySelector('input[name="ap-joinmode"]:checked');
    // Only reveal the block when the store is in public mode; otherwise let user see the toggle
    if (block && currentMode && currentMode.value === 'public') {
      block.style.display = 'block';
      setTimeout(function() {
        var qr = document.getElementById('ap-qrcode');
        if (qr) qr.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 50);
    }
  });

  document.getElementById('apQuickSleep').addEventListener('click', function() {
    showTab('danger');
  });

  document.getElementById('apQuickNuke').addEventListener('click', function() {
    apNukeInput.value = '';
    apNukeDestroy.disabled = true;
    apNukeLog.textContent = '';
    apNukeLog.style.display = 'none';
    apNukeOverlay.classList.add('open');
  });

  // ── RADIO SYNC ──────────────────────────────────────────────
  document.addEventListener('change', function(e) {
    if (e.target && e.target.name === 'ap-joinmode') {
      document.querySelectorAll('.ap-radio').forEach(function(r) { r.classList.remove('selected'); });
      e.target.closest('.ap-radio').classList.add('selected');
      document.getElementById('apBlockPublic').style.display = (e.target.value === 'public') ? 'block' : 'none';
    }
  });

  // ── QR CODE ─────────────────────────────────────────────────
  if (typeof QRCode !== 'undefined') {
    new QRCode(document.getElementById('ap-qrcode'), {
      text: {{ join_link | json }},
      width: 160, height: 160,
      colorDark: '#0f172a', colorLight: '#ffffff',
      correctLevel: QRCode.CorrectLevel.H
    });
  }

  // ── apPost HELPER ─────────────────────────────────────────────
  async function apPost(action, payload) {
    var body = Object.assign({
      action: action,
      shop_handle: String(SSAP.collectionHandle || ''),
      requested_by_customer_id: {{ customer.id | json }},
      requested_by_email: {{ customer.email | json }}
    }, payload || {});
    return fetch(AP_RAILWAY_URL + '/api/admin-action', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
  }

  function setStatus(el, msg, type) {
    if (!el) return;
    el.textContent = msg;
    el.className = 'ap-status ' + (type || '');
  }

  // ── SAVE MODE ─────────────────────────────────────────────────
  document.getElementById('apBtnSaveMode').addEventListener('click', async function() {
    var btn = this;
    var mode = document.querySelector('input[name="ap-joinmode"]:checked').value;
    btn.disabled = true; btn.textContent = 'Saving\u2026';
    setStatus(document.getElementById('apStatusMode'), '', '');
    try {
      var res = await apPost('set_join_mode', { join_mode: mode });
      if (!res.ok) throw new Error();
      setStatus(document.getElementById('apStatusMode'), '\u2705 Settings saved!', 'ok');
    } catch(e) {
      setStatus(document.getElementById('apStatusMode'), '\u274C Error saving settings.', 'err');
    } finally {
      btn.disabled = false; btn.textContent = 'Save Settings';
    }
  });

  // ── COPY LINK ─────────────────────────────────────────────────
  document.getElementById('apBtnCopy').addEventListener('click', function() {
    var btn = this;
    var link = document.getElementById('apInputJoinLink').value;
    if (navigator.clipboard && window.isSecureContext) {
      navigator.clipboard.writeText(link).then(function() {
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = 'Copy'; }, 1600);
      }).catch(function() {
        btn.textContent = 'Copy manually';
        setTimeout(function() { btn.textContent = 'Copy'; }, 2400);
      });
    } else {
      document.getElementById('apInputJoinLink').select();
      btn.textContent = 'Select & copy';
      setTimeout(function() { btn.textContent = 'Copy'; }, 2400);
    }
  });

  // ── ADD / REMOVE MEMBERS ──────────────────────────────────────
  async function handleMemberAction(action) {
    var rawText = document.getElementById('apInputEmails').value;
    var emails = rawText.split(/[\s,;]+/).map(function(e) { return e.trim().toLowerCase(); }).filter(function(e) { return e.length > 0; });
    var role = document.getElementById('apInputRole').value;
    var statusEl = document.getElementById('apStatusMembers');
    var btnAdd = document.getElementById('apBtnAdd');
    var btnRemove = document.getElementById('apBtnRemove');

    if (emails.length === 0) {
      setStatus(statusEl, '\u26A0\uFE0F Please enter at least one email.', 'err');
      return;
    }
    if (action === 'remove' && !confirm('Remove ' + emails.length + ' member(s)?')) return;

    setStatus(statusEl, 'Processing\u2026', '');
    btnAdd.disabled = true; btnRemove.disabled = true;

    try {
      var res = await apPost(action === 'add' ? 'add_members_bulk' : 'remove_members_bulk', { emails: emails, role: role });
      if (res.ok) {
        setStatus(statusEl, '\u2705 Roster updated successfully!', 'ok');
        document.getElementById('apInputEmails').value = '';
      } else {
        throw new Error();
      }
    } catch(e) {
      setStatus(statusEl, '\u274C Could not process request.', 'err');
    } finally {
      btnAdd.disabled = false; btnRemove.disabled = false;
    }
  }

  document.getElementById('apBtnAdd').addEventListener('click', function() { handleMemberAction('add'); });
  document.getElementById('apBtnRemove').addEventListener('click', function() { handleMemberAction('remove'); });

  // ── PRODUCTS ─────────────────────────────────────────────────
  var apProductsLoaded = false;

  function buildProductRow(p) {
    var isHidden = p.hidden === true;
    var encodedId = encodeURIComponent(p.id);

    var row = document.createElement('div');
    row.className = 'ap-product-row';
    row.setAttribute('data-product-id', encodedId);

    var titleSpan = document.createElement('span');
    titleSpan.className = 'ap-product-title';
    titleSpan.textContent = p.title || '';
    titleSpan.title = p.title || '';
    row.appendChild(titleSpan);

    var badge = document.createElement('span');
    badge.className = 'ap-product-badge ' + (isHidden ? 'ap-product-badge--hidden' : 'ap-product-badge--visible');
    badge.textContent = isHidden ? 'HIDDEN' : 'VISIBLE';
    row.appendChild(badge);

    var actions = document.createElement('div');
    actions.className = 'ap-product-actions';

    var toggleBtn = document.createElement('button');
    toggleBtn.className = 'ap-icon-action';
    toggleBtn.setAttribute('data-action', 'toggle');
    toggleBtn.setAttribute('data-id', encodedId);
    toggleBtn.setAttribute('data-hidden', String(isHidden));
    toggleBtn.title = isHidden ? 'Show product' : 'Hide product';
    toggleBtn.setAttribute('aria-label', isHidden ? 'Show product' : 'Hide product');
    toggleBtn.textContent = '\uD83D\uDC41\uFE0F';
    actions.appendChild(toggleBtn);

    var deleteBtn = document.createElement('button');
    deleteBtn.className = 'ap-icon-action ap-icon-action--danger';
    deleteBtn.setAttribute('data-action', 'delete');
    deleteBtn.setAttribute('data-id', encodedId);
    deleteBtn.title = 'Delete product';
    deleteBtn.setAttribute('aria-label', 'Delete product');
    deleteBtn.textContent = '\uD83D\uDDD1\uFE0F';
    actions.appendChild(deleteBtn);

    row.appendChild(actions);
    return row;
  }

  async function loadProducts() {
    var content = document.getElementById('apProductsContent');
    var statusEl = document.getElementById('apStatusProducts');
    setStatus(statusEl, '', '');
    content.innerHTML = '<div class="ap-spinner">Loading products\u2026</div>';
    try {
      var res = await fetch(AP_RAILWAY_URL + '/admin/store/' + encodeURIComponent(AP_HANDLE) + '/products', {
        headers: { 'X-Admin-Secret': AP_ADMIN_SECRET }
      });
      if (!res.ok) throw new Error('Failed to load products: HTTP ' + res.status);
      var products = await res.json();
      if (!Array.isArray(products) || !products.length) {
        content.innerHTML = '';
        var empty = document.createElement('p');
        empty.className = 'ap-empty-state';
        empty.textContent = 'No products found for this store.';
        content.appendChild(empty);
        return;
      }

      var list = document.createElement('div');
      products.forEach(function(p) {
        list.appendChild(buildProductRow(p));
      });
      content.innerHTML = '';
      content.appendChild(list);

      content.querySelectorAll('[data-action="toggle"]').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          var encodedId = btn.getAttribute('data-id');
          var isHidden = btn.getAttribute('data-hidden') === 'true';
          btn.disabled = true;
          try {
            var response = await fetch(AP_RAILWAY_URL + '/admin/store/' + encodeURIComponent(AP_HANDLE) + '/products/' + encodedId + '/hide', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json', 'X-Admin-Secret': AP_ADMIN_SECRET },
              body: JSON.stringify({ hidden: !isHidden })
            });
            if (!response.ok) throw new Error('HTTP ' + response.status);
            try {
              await loadProducts();
            } catch(refreshErr) {
              setStatus(statusEl, '\u2705 Product updated, but failed to refresh list.', 'ok');
            }
          } catch(e) {
            setStatus(statusEl, '\u274C Could not update product: ' + (e.message || 'unknown'), 'err');
            btn.disabled = false;
          }
        });
      });

      content.querySelectorAll('[data-action="delete"]').forEach(function(btn) {
        btn.addEventListener('click', async function() {
          if (!confirm('Delete this product? This cannot be undone.')) return;
          var encodedId = btn.getAttribute('data-id');
          btn.disabled = true;
          try {
            var response = await fetch(AP_RAILWAY_URL + '/admin/store/' + encodeURIComponent(AP_HANDLE) + '/products/' + encodedId, {
              method: 'DELETE',
              headers: { 'X-Admin-Secret': AP_ADMIN_SECRET }
            });
            if (!response.ok) throw new Error('HTTP ' + response.status);
            try {
              await loadProducts();
            } catch(refreshErr) {
              setStatus(statusEl, '\u2705 Product deleted, but failed to refresh list.', 'ok');
            }
          } catch(e) {
            setStatus(statusEl, '\u274C Could not delete product: ' + (e.message || 'unknown'), 'err');
            btn.disabled = false;
          }
        });
      });

    } catch(e) {
      content.innerHTML = '';
      var errEl = document.createElement('p');
      errEl.className = 'ap-error-state';
      errEl.textContent = '\u274C Failed to load products: ' + (e.message || 'unknown error');
      content.appendChild(errEl);
    }
  }

  // ── SLEEP / WAKE STORE ─────────────────────────────────────
  var apStatusSleep = document.getElementById('apStatusSleep');

  function apSleepStatus(msg, type) {
    if (!apStatusSleep) return;
    apStatusSleep.textContent = msg;
    apStatusSleep.className = 'ap-status ' + (type || '');
  }

  var apBtnSleepStore = document.getElementById('apBtnSleepStore');
  if (apBtnSleepStore) {
    apBtnSleepStore.addEventListener('click', async function() {
      if (!confirm('Put "' + (AP_HANDLE || 'this store') + '" to sleep? All products will be deleted. Member tags are preserved.')) return;
      apBtnSleepStore.disabled = true;
      apBtnSleepStore.textContent = 'Putting to sleep\u2026';
      apSleepStatus('', '');
      try {
        var res = await fetch(AP_RAILWAY_URL + '/admin/store/' + encodeURIComponent(AP_HANDLE) + '/sleep', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Admin-Secret': AP_ADMIN_SECRET }
        });
        var data = await res.json();
        if (data.job_id || data.status === 'ok' || res.ok) {
          apSleepStatus('\u2705 Store is going to sleep. Reloading\u2026', 'ok');
          setTimeout(function() { window.location.reload(); }, 2000);
        } else {
          apSleepStatus('\u274C ' + (data.error || 'Failed'), 'err');
          apBtnSleepStore.disabled = false;
          apBtnSleepStore.textContent = '\uD83D\uDCA4 Put Store to Sleep';
        }
      } catch(e) {
        apSleepStatus('\u274C Network error: ' + (e.message || 'unknown'), 'err');
        apBtnSleepStore.disabled = false;
        apBtnSleepStore.textContent = '\uD83D\uDCA4 Put Store to Sleep';
      }
    });
  }

  var apBtnWakeStore = document.getElementById('apBtnWakeStore');
  if (apBtnWakeStore) {
    apBtnWakeStore.addEventListener('click', async function() {
      if (!confirm('Wake up "' + (AP_HANDLE || 'this store') + '"? Printful will rebuild all products.')) return;
      apBtnWakeStore.disabled = true;
      apBtnWakeStore.textContent = 'Waking up\u2026';
      apSleepStatus('', '');
      try {
        var res = await fetch(AP_RAILWAY_URL + '/admin/store/' + encodeURIComponent(AP_HANDLE) + '/wakeup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Admin-Secret': AP_ADMIN_SECRET }
        });
        var data = await res.json();
        if (data.job_id || data.status === 'ok' || res.ok) {
          apSleepStatus('\u2705 Store is waking up! Products are being rebuilt. Reloading\u2026', 'ok');
          setTimeout(function() { window.location.reload(); }, 2000);
        } else {
          apSleepStatus('\u274C ' + (data.error || 'Failed'), 'err');
          apBtnWakeStore.disabled = false;
          apBtnWakeStore.textContent = '\u2600\uFE0F Wake Up Store';
        }
      } catch(e) {
        apSleepStatus('\u274C Network error: ' + (e.message || 'unknown'), 'err');
        apBtnWakeStore.disabled = false;
        apBtnWakeStore.textContent = '\u2600\uFE0F Wake Up Store';
      }
    });
  }

  // ── NUKE STORE ─────────────────────────────────────────────
  var apNukeBtn = document.getElementById('apNukeBtn');
  var apNukeOverlay = document.getElementById('apNukeOverlay');
  var apNukeInput = document.getElementById('apNukeInput');
  var apNukeDestroy = document.getElementById('apNukeDestroy');
  var apNukeCancel = document.getElementById('apNukeCancel');
  var apNukeLog = document.getElementById('apNukeLog');

  function appendNukeLog(msg) {
    apNukeLog.style.display = 'block';
    apNukeLog.textContent += msg + '\n';
    apNukeLog.scrollTop = apNukeLog.scrollHeight;
  }

  apNukeBtn && apNukeBtn.addEventListener('click', function() {
    apNukeInput.value = '';
    apNukeDestroy.disabled = true;
    apNukeLog.textContent = '';
    apNukeLog.style.display = 'none';
    apNukeOverlay.classList.add('open');
  });

  apNukeCancel && apNukeCancel.addEventListener('click', function() {
    apNukeOverlay.classList.remove('open');
  });

  apNukeOverlay && apNukeOverlay.addEventListener('click', function(e) {
    if (e.target === apNukeOverlay) apNukeOverlay.classList.remove('open');
  });

  apNukeInput && apNukeInput.addEventListener('input', function() {
    apNukeDestroy.disabled = (apNukeInput.value.trim() !== 'gone');
  });

  apNukeDestroy && apNukeDestroy.addEventListener('click', async function() {
    if (apNukeInput.value.trim() !== 'gone') return;
    if (!AP_RAILWAY_URL) {
      appendNukeLog('ERROR: No backend URL configured.');
      return;
    }
    apNukeDestroy.disabled = true;
    apNukeCancel.disabled = true;
    appendNukeLog('Starting nuke for "' + AP_HANDLE + '"\u2026');

    try {
      var res = await fetch(AP_RAILWAY_URL + '/api/storefront/' + encodeURIComponent(AP_HANDLE) + '/nuke', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });

      if (!res.ok) {
        appendNukeLog('ERROR: ' + res.status + ' ' + res.statusText);
        apNukeDestroy.disabled = false;
        apNukeCancel.disabled = false;
        return;
      }

      var data = await res.json();
      var jobId = data.job_id;
      if (!jobId) {
        appendNukeLog('ERROR: No job_id in response.');
        apNukeDestroy.disabled = false;
        apNukeCancel.disabled = false;
        return;
      }
      appendNukeLog('Job started: ' + jobId);

      var lastLog = 0;
      var pollInterval = setInterval(async function() {
        try {
          var pollRes = await fetch(AP_RAILWAY_URL + '/api/job/' + encodeURIComponent(jobId));
          if (!pollRes.ok) { appendNukeLog('Poll error: ' + pollRes.status); return; }
          var job = await pollRes.json();
          var lines = job.log || [];
          for (var i = lastLog; i < lines.length; i++) { appendNukeLog(lines[i]); }
          lastLog = lines.length;

          if (job.status === 'done') {
            clearInterval(pollInterval);
            appendNukeLog('\u2705 Store destroyed. Redirecting\u2026');
            setTimeout(function() { window.location.href = {{ dashboard_url | json }}; }, 2000);
          } else if (job.status === 'error') {
            clearInterval(pollInterval);
            appendNukeLog('\u274C Error: ' + (job.error || 'Unknown error'));
            apNukeCancel.disabled = false;
          }
        } catch(pollErr) {
          appendNukeLog('Poll network error: ' + (pollErr.message || 'unknown'));
        }
      }, 2000);

    } catch(err) {
      appendNukeLog('Network error: ' + (err.message || 'unknown'));
      apNukeDestroy.disabled = false;
      apNukeCancel.disabled = false;
    }
  });
})();
</script>

{%- endif -%}

