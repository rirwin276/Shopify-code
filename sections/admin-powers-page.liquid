  /* ══════════════════════════════════════════════════════════
     FUNDRAISING WIZARD — complete style system
     ══════════════════════════════════════════════════════════ */

  /* Hero fundraise button */
  .ap-btn--fundraise {
    background: linear-gradient(135deg, #14532d, #16a34a);
    color: #fff; border: none; font-weight: 700;
    display: inline-flex; align-items: center; gap: 6px;
    transition: opacity 0.18s, transform 0.15s;
  }
  .ap-btn--fundraise:hover { opacity: 0.9; transform: translateY(-1px); color: #fff; }

  /* Active fundraiser status card (compact, shown on Products panel) */
  .ap-fr-active-card {
    display: flex; align-items: center; gap: 16px;
    background: linear-gradient(135deg, rgba(20,83,45,0.06), rgba(34,197,94,0.04));
    border: 1px solid rgba(34,197,94,0.22); border-radius: 14px;
    padding: 16px 20px; margin-bottom: 20px; flex-wrap: wrap;
  }
  .ap-fr-pulse {
    width: 10px; height: 10px; border-radius: 50%; background: #22c55e; flex-shrink: 0;
    box-shadow: 0 0 0 3px rgba(34,197,94,0.2);
    animation: frPulse 2.2s ease-in-out infinite;
  }
  @keyframes frPulse {
    0%,100% { box-shadow: 0 0 0 3px rgba(34,197,94,0.18); }
    50%      { box-shadow: 0 0 0 7px rgba(34,197,94,0.06); }
  }
  .ap-fr-active-info { flex: 1; min-width: 140px; }
  .ap-fr-active-title { margin: 0 0 2px; font-size: 13px; font-weight: 800; color: #14532d; }
  .ap-fr-active-sub   { margin: 0; font-size: 12px; color: #4b7a5c; }
  .ap-fr-active-stats { display: flex; gap: 20px; flex-wrap: wrap; }
  .ap-fr-stat { text-align: center; }
  .ap-fr-stat-val { font-size: 20px; font-weight: 900; color: #15803d; letter-spacing: -0.03em; line-height: 1.1; }
  .ap-fr-stat-lbl { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; color: #4b7a5c; margin-top: 1px; }
  .ap-fr-active-edit { font-size: 12px; font-weight: 700; color: #16a34a; background: none; border: 1px solid rgba(34,197,94,0.3); border-radius: 7px; padding: 5px 12px; cursor: pointer; white-space: nowrap; transition: background 0.15s; }
  .ap-fr-active-edit:hover { background: rgba(34,197,94,0.08); }

  /* Settings panel minimal edit row (shown when fundraiser already active) */
  .ap-fr-settings-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 20px; background: #f0fdf4; border: 1px solid #bbf7d0;
    border-radius: 12px; margin-bottom: 20px;
  }
  .ap-fr-settings-row-left h4 { margin: 0 0 2px; font-size: 14px; font-weight: 800; color: #14532d; }
  .ap-fr-settings-row-left p  { margin: 0; font-size: 12px; color: #4b7a5c; }

  /* ── WIZARD MODAL OVERLAY ─────────────────────────── */
  .ap-frw-overlay {
    position: fixed; inset: 0; z-index: 10000;
    background: rgba(0,0,0,0.72); backdrop-filter: blur(6px) saturate(0.8);
    display: flex; align-items: center; justify-content: center; padding: 16px;
    opacity: 0; pointer-events: none; transition: opacity 0.22s;
  }
  .ap-frw-overlay.open { opacity: 1; pointer-events: all; }

  .ap-frw-modal {
    background: #fff; border-radius: 24px; width: 100%; max-width: 580px;
    max-height: 92vh; overflow: hidden; display: flex; flex-direction: column;
    box-shadow: 0 40px 100px rgba(0,0,0,0.35), 0 0 0 1px rgba(0,0,0,0.06);
    transform: translateY(24px) scale(0.97); transition: transform 0.28s cubic-bezier(0.34,1.56,0.64,1);
  }
  .ap-frw-overlay.open .ap-frw-modal { transform: translateY(0) scale(1); }

  /* Modal hero */
  .ap-frw-hero {
    background: linear-gradient(135deg, #0a1628 0%, #0d2d1a 60%, #0a1628 100%);
    padding: 28px 32px 24px; position: relative; flex-shrink: 0;
  }
  .ap-frw-close {
    position: absolute; top: 14px; right: 14px;
    width: 30px; height: 30px; border-radius: 15px;
    background: rgba(255,255,255,0.1); border: none; color: rgba(255,255,255,0.7);
    font-size: 15px; cursor: pointer; display: flex; align-items: center; justify-content: center;
    transition: background 0.15s;
  }
  .ap-frw-close:hover { background: rgba(255,255,255,0.2); color: #fff; }
  .ap-frw-step-pills {
    display: flex; gap: 5px; margin-bottom: 16px;
  }
  .ap-frw-pill {
    height: 4px; border-radius: 2px; flex: 1;
    background: rgba(255,255,255,0.15); transition: background 0.3s;
  }
  .ap-frw-pill.done    { background: #22c55e; }
  .ap-frw-pill.active  { background: rgba(255,255,255,0.6); }
  .ap-frw-hero-label {
    font-size: 11px; font-weight: 700; letter-spacing: 0.08em;
    text-transform: uppercase; color: rgba(134,239,172,0.8); margin: 0 0 6px;
  }
  .ap-frw-hero h2 {
    margin: 0 0 4px; font-size: 22px; font-weight: 900; color: #fff; letter-spacing: -0.02em;
  }
  .ap-frw-hero p { margin: 0; font-size: 13px; color: rgba(255,255,255,0.5); }

  /* Tab nav (for Learn More / Legal) */
  .ap-frw-tabs { display: flex; border-bottom: 1px solid #e2e8f0; flex-shrink: 0; background: #fff; }
  .ap-frw-tab {
    padding: 13px 20px; font-size: 13px; font-weight: 700; color: #94a3b8;
    background: none; border: none; border-bottom: 2px solid transparent;
    cursor: pointer; margin-bottom: -1px; transition: color 0.15s, border-color 0.15s;
  }
  .ap-frw-tab.active { color: #0f172a; border-bottom-color: #16a34a; }
  .ap-frw-tab-panel { display: none; }
  .ap-frw-tab-panel.active { display: block; }

  /* Scrollable content area */
  .ap-frw-body { padding: 24px 32px; overflow-y: auto; flex: 1; }
  @media (max-width: 600px) { .ap-frw-body { padding: 20px 20px; } .ap-frw-hero { padding: 24px 20px 20px; } }

  /* Feature rows in learn more */
  .ap-frw-feature {
    display: flex; gap: 16px; padding: 16px 0;
    border-bottom: 1px solid #f1f5f9;
  }
  .ap-frw-feature:last-child { border-bottom: none; }
  .ap-frw-feature-icon {
    width: 42px; height: 42px; border-radius: 12px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; font-size: 19px;
  }
  .ap-frw-fi--green  { background: #dcfce7; }
  .ap-frw-fi--blue   { background: #dbeafe; }
  .ap-frw-fi--amber  { background: #fef9c3; }
  .ap-frw-fi--purple { background: #ede9fe; }
  .ap-frw-fi--slate  { background: #f1f5f9; }
  .ap-frw-feature-copy h4 { margin: 0 0 4px; font-size: 14px; font-weight: 800; color: #0f172a; }
  .ap-frw-feature-copy p  { margin: 0; font-size: 13px; color: #64748b; line-height: 1.6; }
  .ap-frw-feature-copy strong { color: #0f172a; }

  /* Highlight banner inside body */
  .ap-frw-highlight {
    background: linear-gradient(135deg, #f0fdf4, #dcfce7);
    border: 1px solid #86efac; border-radius: 12px;
    padding: 16px 18px; margin: 16px 0; display: flex; gap: 12px; align-items: flex-start;
  }
  .ap-frw-highlight-icon { font-size: 22px; flex-shrink: 0; line-height: 1; }
  .ap-frw-highlight-copy { font-size: 13px; color: #14532d; line-height: 1.6; }
  .ap-frw-highlight-copy strong { font-weight: 800; }

  /* Legal content */
  .ap-frw-legal { font-size: 13px; color: #374151; line-height: 1.75; }
  .ap-frw-legal h4 { font-size: 13px; font-weight: 800; color: #0f172a; margin: 18px 0 4px; }
  .ap-frw-legal p  { margin: 0 0 10px; }
  .ap-frw-legal ul { margin: 6px 0 12px 18px; padding: 0; }
  .ap-frw-legal li { margin-bottom: 5px; }

  /* Wizard form fields */
  .ap-frw-field { margin-bottom: 20px; }
  .ap-frw-label {
    display: block; font-size: 11px; font-weight: 800;
    letter-spacing: 0.07em; text-transform: uppercase;
    color: #64748b; margin-bottom: 7px;
  }
  .ap-frw-input {
    width: 100%; box-sizing: border-box;
    border: 1.5px solid #e2e8f0; border-radius: 10px;
    padding: 11px 14px; font-size: 14px; color: #0f172a;
    background: #fff; outline: none; font-family: inherit;
    transition: border-color 0.18s, box-shadow 0.18s;
  }
  .ap-frw-input:focus { border-color: #22c55e; box-shadow: 0 0 0 3px rgba(34,197,94,0.12); }
  .ap-frw-input-row { display: flex; gap: 8px; align-items: center; }
  .ap-frw-input-prefix { font-size: 18px; font-weight: 700; color: #94a3b8; }
  .ap-frw-input--amount { width: 80px !important; text-align: center; font-size: 20px; font-weight: 800; }
  .ap-frw-helper { font-size: 12px; color: #94a3b8; margin-top: 5px; }
  .ap-frw-calc-row {
    display: flex; align-items: center; gap: 8px; margin-top: 10px;
    padding: 10px 14px; background: #f0fdf4; border: 1px solid #bbf7d0; border-radius: 9px;
    font-size: 13px;
  }
  .ap-frw-calc-label { color: #4b7a5c; }
  .ap-frw-calc-val   { font-size: 15px; font-weight: 800; color: #15803d; margin-left: auto; }
  .ap-frw-goal-row   { display: flex; gap: 12px; }
  .ap-frw-goal-row .ap-frw-field { flex: 1; }

  /* Toggle row for visibility step */
  .ap-frw-toggle-row {
    display: flex; align-items: flex-start; gap: 16px;
    padding: 18px; background: #f8fafc; border: 1.5px solid #e2e8f0;
    border-radius: 12px; margin-bottom: 14px; cursor: pointer;
    transition: border-color 0.18s, background 0.18s;
  }
  .ap-frw-toggle-row.selected { background: #f0fdf4; border-color: #86efac; }
  .ap-frw-toggle-icon { font-size: 24px; flex-shrink: 0; margin-top: 1px; }
  .ap-frw-toggle-copy h4 { margin: 0 0 3px; font-size: 14px; font-weight: 800; color: #0f172a; }
  .ap-frw-toggle-copy p  { margin: 0; font-size: 12px; color: #64748b; line-height: 1.55; }
  .ap-frw-toggle-check { margin-left: auto; flex-shrink: 0; margin-top: 3px; }
  .ap-frw-toggle-check input { width: 18px; height: 18px; accent-color: #16a34a; cursor: pointer; }

  /* Terms checkbox */
  .ap-frw-terms-row {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 14px 16px; background: #fffbeb; border: 1px solid #fde68a;
    border-radius: 10px; margin-top: 16px; cursor: pointer;
  }
  .ap-frw-terms-row input { width: 16px; height: 16px; margin-top: 2px; accent-color: #16a34a; cursor: pointer; flex-shrink: 0; }
  .ap-frw-terms-copy { font-size: 12px; color: #78350f; line-height: 1.6; }
  .ap-frw-terms-copy strong { font-weight: 800; }

  /* Footer / nav buttons */
  .ap-frw-footer {
    padding: 16px 32px 24px; border-top: 1px solid #f1f5f9;
    display: flex; gap: 10px; align-items: center; flex-shrink: 0; background: #fff;
  }
  @media (max-width: 600px) { .ap-frw-footer { padding: 14px 20px 20px; } }
  .ap-frw-back-btn {
    background: none; border: 1.5px solid #e2e8f0; border-radius: 10px;
    padding: 11px 18px; font-size: 14px; font-weight: 700; color: #64748b;
    cursor: pointer; transition: border-color 0.15s, color 0.15s;
  }
  .ap-frw-back-btn:hover { border-color: #94a3b8; color: #0f172a; }
  .ap-frw-next-btn {
    flex: 1; padding: 13px; border: none; border-radius: 10px;
    background: linear-gradient(135deg, #16a34a, #15803d);
    color: #fff; font-size: 15px; font-weight: 800; cursor: pointer;
    transition: opacity 0.18s, transform 0.14s; letter-spacing: -0.01em;
  }
  .ap-frw-next-btn:hover { opacity: 0.92; transform: translateY(-1px); }
  .ap-frw-next-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

  /* Stripe connect step */
  .ap-frw-stripe-card {
    border: 1.5px solid #e2e8f0; border-radius: 14px; padding: 22px 24px;
    text-align: center; margin-bottom: 16px;
  }
  .ap-frw-stripe-logo { font-size: 32px; margin-bottom: 12px; }
  .ap-frw-stripe-card h3 { margin: 0 0 8px; font-size: 17px; font-weight: 800; color: #0f172a; }
  .ap-frw-stripe-card p  { margin: 0 0 18px; font-size: 13px; color: #64748b; line-height: 1.6; }
  .ap-frw-stripe-btn {
    display: inline-flex; align-items: center; gap: 8px;
    padding: 12px 24px; background: #635bff; color: #fff;
    border: none; border-radius: 9px; font-size: 14px; font-weight: 700; cursor: pointer;
    transition: opacity 0.15s;
  }
  .ap-frw-stripe-btn:hover { opacity: 0.9; }
  .ap-frw-stripe-test-note {
    font-size: 12px; color: #94a3b8; margin-top: 10px; font-style: italic;
  }
  .ap-frw-stripe-connected {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 16px; background: #f0fdf4; border: 1px solid #86efac; border-radius: 10px;
    font-size: 13px; font-weight: 700; color: #14532d;
  }

  /* ── Fundraising Zone (between hero and tabs) ── */
  .ap-fr-zone {
    margin: 0 0 20px;
  }
  /* Empty state — no fundraiser */
  .ap-fr-zone-empty {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 18px 24px;
    background: #f8fafc;
    border: 1.5px dashed #cbd5e1;
    border-radius: 16px;
    gap: 14px;
  }
  .ap-fr-zone-empty-icon { font-size: 24px; flex-shrink: 0; }
  .ap-fr-zone-empty-copy { flex: 1; }
  .ap-fr-zone-empty-copy p {
    margin: 0; font-size: 13px; color: #64748b;
  }
  .ap-fr-zone-empty-copy strong {
    display: block; font-size: 15px; color: #1e293b; font-weight: 700; margin-bottom: 2px;
  }
  .ap-btn--fr-start {
    background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    color: #fff; border: none; border-radius: 10px;
    padding: 10px 18px; font-size: 13px; font-weight: 700;
    cursor: pointer; white-space: nowrap; flex-shrink: 0;
    transition: opacity 0.15s;
  }
  .ap-btn--fr-start:hover { opacity: 0.88; }
  /* Active state — fundraiser running */
  .ap-fr-zone-active {
    display: flex; align-items: center; gap: 16px;
    padding: 16px 20px;
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
    border: 1.5px solid #86efac; border-radius: 16px;
  }
  .ap-fr-zone-pulse {
    width: 10px; height: 10px; border-radius: 50%;
    background: #22c55e; flex-shrink: 0;
    box-shadow: 0 0 0 0 rgba(34,197,94,0.4);
    animation: apFrPulse 2s infinite;
  }
  @keyframes apFrPulse {
    0%   { box-shadow: 0 0 0 0 rgba(34,197,94,0.4); }
    70%  { box-shadow: 0 0 0 8px rgba(34,197,94,0); }
    100% { box-shadow: 0 0 0 0 rgba(34,197,94,0); }
  }
  .ap-fr-zone-info { flex: 1; min-width: 0; }
  .ap-fr-zone-title {
    font-size: 14px; font-weight: 700; color: #14532d; margin: 0 0 2px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .ap-fr-zone-sub {
    font-size: 12px; color: #166534; margin: 0;
  }
  .ap-fr-zone-stats {
    display: flex; gap: 16px; flex-shrink: 0;
  }
  .ap-fr-zone-stat { text-align: center; }
  .ap-fr-zone-stat-val { font-size: 16px; font-weight: 800; color: #14532d; }
  .ap-fr-zone-stat-lbl { font-size: 10px; color: #16a34a; text-transform: uppercase; letter-spacing: 0.05em; }
  .ap-btn--fr-details {
    background: #fff; color: #16a34a;
    border: 1.5px solid #86efac; border-radius: 10px;
    padding: 8px 14px; font-size: 12px; font-weight: 700;
    cursor: pointer; white-space: nowrap; flex-shrink: 0;
    transition: background 0.15s;
  }
  .ap-btn--fr-details:hover { background: #f0fdf4; }
  /* Details modal */
  .ap-frd-overlay {
    position: fixed; inset: 0; z-index: 9999;
    background: rgba(15,23,42,0.55);
    backdrop-filter: blur(6px);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none;
    transition: opacity 0.2s;
  }
  .ap-frd-overlay.open { opacity: 1; pointer-events: all; }
  .ap-frd-modal {
    background: #fff; border-radius: 20px;
    max-width: 520px; width: calc(100% - 32px);
    max-height: 85vh; overflow-y: auto;
    box-shadow: 0 24px 60px rgba(0,0,0,0.22);
    transform: translateY(24px) scale(0.97);
    transition: transform 0.25s cubic-bezier(0.34,1.56,0.64,1), opacity 0.2s;
    padding: 0;
  }
  .ap-frd-overlay.open .ap-frd-modal { transform: translateY(0) scale(1); }
  .ap-frd-header {
    background: linear-gradient(135deg, #14532d 0%, #166534 100%);
    padding: 24px 24px 20px;
    border-radius: 20px 20px 0 0;
    position: relative;
  }
  .ap-frd-close {
    position: absolute; top: 16px; right: 16px;
    background: rgba(255,255,255,0.15); border: none; border-radius: 50%;
    width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;
    color: #fff; font-size: 16px; cursor: pointer; line-height: 1;
  }
  .ap-frd-close:hover { background: rgba(255,255,255,0.25); }
  .ap-frd-header-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(255,255,255,0.15); border-radius: 20px;
    padding: 4px 10px; font-size: 11px; font-weight: 700; color: #bbf7d0;
    margin-bottom: 10px;
  }
  .ap-frd-header-badge .dot { width: 6px; height: 6px; border-radius: 50%; background: #4ade80; }
  .ap-frd-header h3 { color: #fff; font-size: 20px; font-weight: 800; margin: 0 0 4px; }
  .ap-frd-header p  { color: #bbf7d0; font-size: 13px; margin: 0; }
  .ap-frd-stats-row {
    display: flex; gap: 0; border-bottom: 1px solid #e2e8f0;
  }
  .ap-frd-stat-cell {
    flex: 1; padding: 16px; text-align: center;
    border-right: 1px solid #e2e8f0;
  }
  .ap-frd-stat-cell:last-child { border-right: none; }
  .ap-frd-stat-cell-val { font-size: 22px; font-weight: 800; color: #14532d; }
  .ap-frd-stat-cell-lbl { font-size: 11px; color: #64748b; text-transform: uppercase; letter-spacing: 0.05em; margin-top: 2px; }
  .ap-frd-body { padding: 20px 24px; }
  .ap-frd-row {
    display: flex; align-items: flex-start; gap: 10px;
    padding: 12px 0; border-bottom: 1px solid #f1f5f9;
  }
  .ap-frd-row:last-child { border-bottom: none; }
  .ap-frd-row-icon { font-size: 18px; flex-shrink: 0; width: 24px; }
  .ap-frd-row-label { font-size: 11px; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px; }
  .ap-frd-row-val { font-size: 14px; color: #1e293b; font-weight: 600; }
  .ap-frd-footer { padding: 16px 24px 20px; display: flex; gap: 10px; }
  .ap-btn--fr-edit-wizard {
    flex: 1; background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
    color: #fff; border: none; border-radius: 10px;
    padding: 11px; font-size: 14px; font-weight: 700; cursor: pointer;
    transition: opacity 0.15s;
  }
  .ap-btn--fr-edit-wizard:hover { opacity: 0.88; }
  .ap-btn--fr-stop {
    background: #fff; color: #dc2626; border: 1.5px solid #fca5a5;
    border-radius: 10px; padding: 11px 16px; font-size: 13px; font-weight: 700;
    cursor: pointer; transition: background 0.15s;
  }
  .ap-btn--fr-stop:hover { background: #fff1f2; }
  /* Progress bar */
  .ap-frd-progress-wrap { margin: 0 24px 16px; }
  .ap-frd-progress-bar { height: 8px; background: #e2e8f0; border-radius: 99px; overflow: hidden; }
  .ap-frd-progress-fill { height: 100%; background: linear-gradient(90deg, #22c55e, #16a34a); border-radius: 99px; transition: width 0.6s; }
  .ap-frd-progress-label { font-size: 11px; color: #64748b; margin-top: 5px; text-align: right; }
  @media (max-width: 600px) {
    .ap-fr-zone-stats { display: none; }
    .ap-fr-zone-active { flex-wrap: wrap; }
    .ap-fr-zone-empty { flex-direction: column; text-align: center; }
    .ap-frd-stats-row { flex-wrap: wrap; }
    .ap-frd-stat-cell { flex: 0 0 50%; }
  }

  /* ── FUNDRAISING WIZARD — Redesign v2 ── */

  /* Step 1: benefit cards */
  .ap-frw-benefit-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 18px; }
  .ap-frw-benefit-item {
    display: grid; grid-template-columns: 48px 1fr; gap: 14px; align-items: center;
    padding: 14px; border-radius: 18px; border: 1px solid rgba(17,16,14,.08);
    background: #fff; box-shadow: 0 8px 22px rgba(17,16,14,.045);
  }
  .ap-frw-benefit-icon {
    width: 48px; height: 48px; border-radius: 15px; display: flex; align-items: center;
    justify-content: center; font-size: 22px; flex-shrink: 0;
  }
  .ap-frw-benefit-text strong {
    display: block; font-size: 14px; font-weight: 900; color: #11100e;
    margin-bottom: 3px; letter-spacing: -.02em; line-height: 1.2;
  }
  .ap-frw-benefit-text span { font-size: 13px; color: rgba(17,16,14,.62); line-height: 1.55; }

  /* Step 1: legal agreement box */
  .ap-frw-legal-box {
    border-radius: 20px; border: 1px solid rgba(17,16,14,.08);
    background: #fafaf8; padding: 18px;
  }
  .ap-frw-legal-intro {
    font-size: 11px; font-weight: 950; letter-spacing: .07em; text-transform: uppercase;
    color: rgba(17,16,14,.46); margin: 0 0 12px;
  }
  .ap-frw-legal-points { display: flex; flex-direction: column; gap: 7px; margin-bottom: 14px; }
  .ap-frw-legal-point {
    font-size: 12px; color: rgba(17,16,14,.68); line-height: 1.6;
    padding: 10px 12px 10px 28px; background: #fff; border-radius: 12px;
    border: 1px solid rgba(17,16,14,.06); position: relative;
  }
  .ap-frw-legal-point::before {
    content: ""; position: absolute; left: 12px; top: 18px;
    width: 5px; height: 5px; border-radius: 999px; background: rgba(183,163,106,.8);
  }
  .ap-frw-terms-label {
    display: flex; align-items: flex-start; gap: 12px; padding: 13px;
    border-radius: 14px; background: #fff; border: 1px solid rgba(17,16,14,.10); cursor: pointer;
  }
  .ap-frw-terms-label input { width: 17px; height: 17px; flex-shrink: 0; margin-top: 2px; accent-color: #2f5844; cursor: pointer; }
  .ap-frw-terms-label span { font-size: 13px; color: rgba(17,16,14,.70); line-height: 1.6; }
  .ap-frw-terms-label strong { color: #11100e; font-weight: 900; }

  /* Step 3: amount stepper */
  .ap-frw-amount-row {
    display: flex; align-items: center; width: fit-content;
    border: 1.5px solid rgba(17,16,14,.13); border-radius: 16px; overflow: hidden;
    background: #fff; margin-bottom: 10px;
  }
  .ap-frw-amt-btn {
    width: 52px; height: 52px; border: 0; background: rgba(17,16,14,.04);
    color: #11100e; font-size: 26px; font-weight: 300; cursor: pointer; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; transition: background .14s;
    line-height: 1;
  }
  .ap-frw-amt-btn:hover { background: rgba(17,16,14,.09); }
  .ap-frw-amt-btn:active { background: rgba(17,16,14,.15); }
  .ap-frw-amt-display {
    min-width: 80px; text-align: center; font-size: 28px; font-weight: 900;
    color: #11100e; letter-spacing: -.04em;
  }

  /* Step 3: goal/date with $ prefix */
  .ap-frw-input-icon-wrap { position: relative; display: flex; align-items: center; }
  .ap-frw-input-pre {
    position: absolute; left: 14px; font-size: 16px; font-weight: 700;
    color: rgba(17,16,14,.45); pointer-events: none; z-index: 1;
  }
  .ap-frw-input--icon-pre { padding-left: 28px; }

  .ap-frw-helper { font-size: 12px; color: rgba(17,16,14,.50); margin: 6px 0 0; line-height: 1.45; }

{%- endstyle -%}

