{% comment %}
  ADMIN POWERS — V14 PREMIUM CONTROL CENTER (SECTION FILE)
  - Self-contained section (no Custom Liquid block needed).
  - V12: Mobile-first single-dashboard redesign with tab navigation.
    Single card with tabs (Overview | Members | Products | Danger).
    Product thumbnails (52×52px) pulled from featured_image / image / images[0].src
    with 🖼️ placeholder. Products lazy-load when tab is clicked.
  - V11: Route all calls to Railway (remove Mechanic URL). Remove credentials:include from fetches.
  - God Mode: Ryan Irwin hardcoded + super-admin tag.
  - QR code, public toggle, invite/remove members.
  - V13: Wider desktop layout, Products-first tabs, hero Share Store modal, split Main vs Custom/Pro products, single editor button, silent product refresh.
  - Premium design upgrade.
  - V14: Stella & Sage gold/cream Apple-grade control center theme, wider desktop, cleaner mobile, sticky mobile tabs, refined product cards, safer hover-only tooltips.
{% endcomment %}

{%- assign dashboard_url = '/pages/portal' -%}
{%- assign join_path = '/pages/join-store' -%}

{%- comment %} 1. GET SHOP HANDLE {% endcomment -%}
{%- assign shop_handle = request.params.shop | default: '' | strip -%}
{%- if shop_handle == blank -%}
  {%- assign _cfh = content_for_header -%}
  {%- assign _url_part = _cfh | split: '"pageurl":"' | last | split: '"' | first -%}
  {%- assign _url_part = _url_part | replace: '\u0026', '&' -%}
  {%- if _url_part contains '?' -%}
    {%- assign _qs = _url_part | split: '?' | last -%}
    {%- assign _pairs = _qs | split: '&' -%}
    {%- for p in _pairs -%}
      {%- assign kv = p | split: '=' -%}
      {%- if kv[0] == 'shop' -%}{%- assign shop_handle = kv[1] | default: '' | strip -%}{%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endif -%}
{%- assign shop_handle = shop_handle | replace: '%2D', '-' | replace: '%5F', '_' | strip | downcase -%}

{%- comment %}
  2. ADMIN ACCESS CHECK

  Access rules:
  - Founder access: customer tag `super-admin` can manage every storefront.
  - Store admin access: customer tag `storefront-admin--<shop_handle>` can manage only that storefront.
  - Temporary safety fallback: Ryan's owner email still gets founder access until the `super-admin`
    tag is confirmed on the live Shopify customer account.

  Do not remove the email fallback until owner access has been tested through the `super-admin` tag.
{%- endcomment -%}
{%- assign required_admin_tag = 'storefront-admin--' | append: shop_handle -%}
{%- assign founder_access_tag = 'super-admin' -%}
{%- assign owner_email_fallback = 'ryan.irwin@stellaandsagecompany.com' -%}
{%- assign is_admin_for_shop = false -%}
{%- assign is_super_admin = false -%}

{%- if customer and shop_handle != blank -%}
  {%- assign customer_email_down = customer.email | default: '' | downcase | strip -%}

  {%- if customer_email_down == owner_email_fallback -%}
    {%- assign is_super_admin = true -%}
    {%- assign is_admin_for_shop = true -%}
  {%- endif -%}

  {%- for t in customer.tags -%}
    {%- assign tag_down = t | downcase | strip -%}

    {%- if tag_down == founder_access_tag -%}
      {%- assign is_super_admin = true -%}
      {%- assign is_admin_for_shop = true -%}
    {%- endif -%}

    {%- if tag_down == required_admin_tag -%}
      {%- assign is_admin_for_shop = true -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{{ 'ss-admin-powers.css' | asset_url | stylesheet_tag }}


{%- if customer == nil -%}

<div class="ap-auth-wrap">
  <div class="ap-auth-card">
    <span class="ap-auth-icon">🔒</span>
    <h2>Please Sign In</h2>
    <p>You must be signed in to access Admin Powers.</p>
    <a href="{{ routes.storefront_login_url }}?return_to={{ '/pages/portal' | url_encode }}" class="ap-btn ap-btn--primary" onclick="try{localStorage.setItem('sf_pending_signin_v1',JSON.stringify({return_path:'/pages/portal',_saved_at:Date.now()}))}catch(e){}">Sign In →</a>
  </div>
</div>

{%- elsif is_admin_for_shop == false and is_super_admin == false -%}

<div class="ap-auth-wrap">
  <div class="ap-auth-card">
    <span class="ap-auth-icon">🚫</span>
    <h2>Access Denied</h2>
    <p>You don't have permission to manage <strong>{{ shop_handle }}</strong>.</p>
    <a href="{{ dashboard_url }}" class="ap-btn ap-btn--outline">← Back to Dashboard</a>
  </div>
</div>

{%- else -%}

{%- assign shop_meta = shop.metaobjects.custom_shop[shop_handle] -%}
{%- assign join_mode = 'secure' -%}
{%- assign collection_handle = shop_handle -%}
{%- assign store_name = shop_handle -%}
{%- assign ap_store_status = 'active' -%}

{%- if shop_meta -%}
  {%- assign raw_jm = shop_meta.join_mode.value | default: shop_meta.join_mode -%}
  {%- assign jm = raw_jm | strip | downcase -%}
  {%- if jm == 'public' -%}{%- assign join_mode = 'public' -%}{%- endif -%}
  {%- assign join_code = shop_meta.join_code.value | default: shop_meta.join_code | default: '' | strip -%}
  {%- assign ch = shop_meta.collection_handle.value | default: shop_meta.collection_handle | default: '' | strip -%}
  {%- if ch != blank -%}{%- assign collection_handle = ch -%}{%- endif -%}
  {%- assign sn = shop_meta.name.value | default: shop_meta.name -%}
  {%- if sn != blank -%}{%- assign store_name = sn -%}{%- endif -%}
  {%- assign _raw_status = shop_meta.status.value | default: shop_meta.status | default: '' | strip | downcase -%}
  {%- if _raw_status == 'sleeping' or _raw_status == 'waking' or _raw_status == 'active' -%}
    {%- assign ap_store_status = _raw_status -%}
  {%- endif -%}
{%- endif -%}

{%- comment %}
  BACKEND + EDITOR CONFIG

  Studio Uploader handles member/admin actions, store settings, sleep/wake, and store maintenance actions.
  Printful Automation handles placement editors, custom product builders, rebuild jobs, and apply-status polling.

  Editor URLs are built from a single base URL so backend changes are easier to make safely.
{%- endcomment -%}
{%- assign studio_uploader_base_url = 'https://studio-uploader-production.up.railway.app' -%}
{%- assign printful_automation_base_url = 'https://printfulautomation-production.up.railway.app' -%}

{%- assign editor_base_url = printful_automation_base_url | append: '/editor/bc3413' -%}
{%- assign editor_bc3001y_base_url = printful_automation_base_url | append: '/editor/bc3001y' -%}
{%- assign editor_nl6733_base_url = printful_automation_base_url | append: '/editor/nl6733' -%}
{%- assign editor_mc1790_base_url = printful_automation_base_url | append: '/editor/mc1790' -%}
{%- assign editor_m2580_base_url = printful_automation_base_url | append: '/editor/m2580' -%}
{%- assign editor_cc1467y_base_url = printful_automation_base_url | append: '/editor/cc1467y' -%}
{%- assign editor_bc3413_back_base_url = printful_automation_base_url | append: '/editor/bc3413_back' -%}
{%- assign editor_pro_shirt_bc3413_base_url = printful_automation_base_url | append: '/editor/pro-shirt/bc3413' -%}
{%- assign editor_pro_shirt_bc3001y_base_url = printful_automation_base_url | append: '/editor/pro-shirt/bc3001y' -%}
{%- assign editor_pro_shirt_m2580_base_url = printful_automation_base_url | append: '/editor/pro-shirt/m2580' -%}
{%- assign editor_pro_shirt_zip_hoodie_base_url = section.settings.editor_pro_shirt_zip_hoodie_base_url | default: '' -%}
{%- comment %} The live secret comes from the shop metafield custom.editor_secret
   (set it in Shopify admin → Settings → Custom data → Shop). Keeping the real
   secret in a Shopify metafield — never in this public repo — is what lets the
   leaked value be rotated out. The hardcoded string is only a legacy fallback
   for when the metafield is unset; it must match a value EDITOR_SECRET still
   accepts in Printful_Automation, or admin buttons won't authenticate.
   This mirrors sections/price-editor-page.liquid. {% endcomment -%}
{%- assign fallback_editor_secret = 'stellasage-god-mode-2026-xK9mP' -%}
{%- assign mf_editor_secret = shop.metafields.custom.editor_secret.value | default: shop.metafields.custom.editor_secret -%}
{%- assign editor_secret = mf_editor_secret | default: fallback_editor_secret -%}

{%- assign ap_shop_logo_src = '' -%}
{%- if shop_meta -%}
  {%- assign _logo_field = shop_meta.logo -%}
  {%- if _logo_field != blank -%}
    {%- assign _logo_obj = _logo_field.value | default: _logo_field -%}
    {%- comment %} Only call image_url if it looks like a real image object (has src or is a media object) {% endcomment -%}
    {%- if _logo_obj.src or _logo_obj.preview_image -%}
      {%- assign ap_shop_logo_src = _logo_obj | image_url: width: 3000 -%}
    {%- elsif _logo_obj != blank and _logo_obj.url -%}
      {%- assign ap_shop_logo_src = _logo_obj.url -%}
    {%- endif -%}
  {%- endif -%}
{%- endif -%}

{%- assign join_link = shop.url | append: join_path | append: '?shop=' | append: collection_handle -%}
{%- if join_code != blank -%}
  {%- assign join_link = join_link | append: '&code=' | append: join_code -%}
{%- endif -%}

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<div class="ap-wrap">

  <script>
    window.SSAP = window.SSAP || {};
    SSAP.collectionHandle = {{ collection_handle | json }};
    SSAP.shopHandle = {{ shop_handle | json }};
    SSAP.isSuperAdmin = {{ is_super_admin | json }};
    SSAP.railwayUrl = {{ studio_uploader_base_url | json }};
    SSAP.editorBaseUrl = {{ editor_base_url | json }};
    SSAP.editorBc3001yBaseUrl = {{ editor_bc3001y_base_url | json }};
    SSAP.editorNl6733BaseUrl = {{ editor_nl6733_base_url | json }};
    SSAP.editorMc1790BaseUrl = {{ editor_mc1790_base_url | json }};
    SSAP.editorM2580BaseUrl = {{ editor_m2580_base_url | json }};
    SSAP.editorCc1467yBaseUrl = {{ editor_cc1467y_base_url | json }};
    SSAP.editorBc3413BackBaseUrl = {{ editor_bc3413_back_base_url | json }};
    SSAP.editorProShirtBc3413BaseUrl = {{ editor_pro_shirt_bc3413_base_url | json }};
    SSAP.editorProShirtBc3001yBaseUrl = {{ editor_pro_shirt_bc3001y_base_url | json }};
    SSAP.editorProShirtM2580BaseUrl = {{ editor_pro_shirt_m2580_base_url | json }};
    SSAP.editorProShirtZipHoodieBaseUrl = {{ editor_pro_shirt_zip_hoodie_base_url | json }};
    SSAP.editorSecret = {{ editor_secret | json }};
    SSAP.shopLogoSrc = {{ ap_shop_logo_src | json }};
    SSAP.joinLink = {{ join_link | json }};
    SSAP.customerId = {{ customer.id | json }};
    SSAP.customerEmail = {{ customer.email | json }};
    SSAP.dashboardUrl = {{ dashboard_url | json }};
    SSAP.storeName = {{ store_name | json }};
  </script>

  <!-- HERO HEADER -->
  <div class="ap-hero">
    <div class="ap-hero-logo">
      {%- if ap_shop_logo_src != '' -%}
        <img src="{{ ap_shop_logo_src }}" alt="{{ store_name | escape }} logo" loading="lazy">
      {%- else -%}
        <span>{{ store_name | slice: 0, 1 | upcase }}</span>
      {%- endif -%}
    </div>

    <div class="ap-hero-info">
      <div class="ap-hero-badge">
        <span class="dot"></span>
        {% if is_super_admin %}Founder Control Center{% else %}Store Admin{% endif %}
      </div>
      <h1>{{ store_name | capitalize }}</h1>
      <div class="ap-hero-meta" aria-label="Store details">
        <span class="ap-hero-pill">{{ shop_handle }}</span>
        <span class="ap-hero-pill ap-hero-pill--status">{{ ap_store_status | capitalize }}</span>
        <span class="ap-hero-pill">Member Storefront</span>
      </div>
    </div>

    <div class="ap-hero-actions">
      <span class="ap-share-help">
        <button
          id="apBtnShareStore"
          type="button"
          class="ap-btn ap-btn--share-primary"
          aria-describedby="apShareHelpBubble"
        >🔗 Share Store</button>
        <span class="ap-share-help-bubble" id="apShareHelpBubble" role="tooltip">
          <strong>Share member access</strong>
          Send this link to parents, players, or group members. They will sign in or create an account, then this store will appear on their dashboard. They can shop, but they cannot manage products, members, or settings.
          <span class="ap-smart-tooltip-arrow" aria-hidden="true"></span>
        </span>
      </span>
      <a href="/collections/{{ collection_handle }}" class="ap-btn ap-btn--glass">Shop Store ↗</a>
      <a href="{{ dashboard_url }}" class="ap-btn ap-btn--glass">← Dashboard</a>

      <!-- FUNDRAISING ZONE — last action in the hero button stack -->
      <div class="ap-fr-zone" id="apFrZone">
        <!-- Empty state — visible by default; JS hides it when an active fundraiser is running -->
        <div class="ap-fr-zone-empty" id="apFrZoneEmpty">
          <button id="apFrLaunchBtn" type="button" class="ap-btn ap-btn--fr-start">💚 Start a Fundraiser</button>
        </div>
        <!-- Active state (shown when fundraiser is running) -->
        <div class="ap-fr-zone-active" id="apFrZoneActive" style="display:none;">
          <div class="ap-fr-zone-active-top">
            <div class="ap-fr-zone-info">
              <span class="ap-fr-zone-badge"><span class="ap-fr-zone-pulse"></span>Active Fundraiser</span>
              <p class="ap-fr-zone-title" id="apFrZoneTitle">Your Fundraiser</p>
              <p class="ap-fr-zone-sub" id="apFrZoneSub">Loading…</p>
            </div>
          </div>
          <div class="ap-fr-zone-progress" id="apFrZoneProgressWrap" style="display:none;">
            <div class="ap-fr-zone-bar"><div class="ap-fr-zone-bar-fill" id="apFrZoneBarFill"></div></div>
            <div class="ap-fr-zone-progress-meta">
              <span><strong id="apFrZoneRaised">$0</strong> raised</span>
              <span id="apFrZoneGoal"></span>
            </div>
          </div>
          <button type="button" class="ap-btn--fr-details" id="apFrDetailsBtn">View Details</button>
        </div>
      </div>
    </div>
  </div>

  <!-- SHARE STORE MODAL -->
  <div class="ap-share-overlay" id="apShareOverlay" aria-hidden="true">
    <div class="ap-share-dialog" role="dialog" aria-modal="true" aria-labelledby="apShareTitle">
      <button id="apShareClose" type="button" class="ap-share-close" aria-label="Close share options">✕</button>
      <div class="ap-share-head">
        <h3 id="apShareTitle">Share this store</h3>
        <p>Copy the link or show the QR code. New members can join from their phone, sign in or create an account, and this store will appear on their dashboard as a member-only storefront.</p>
      </div>
      <div class="ap-tabs">
        <button class="ap-tab-btn active" data-tab="apTabLink">🔗 Copy Link</button>
        <button class="ap-tab-btn" data-tab="apTabQR">📱 QR Code</button>
      </div>
      <div id="apTabLink" class="ap-tab-content">
        <div class="ap-copy-row">
          <input id="apInputJoinLink" class="ap-input ap-input-mono" value="{{ join_link | escape }}" readonly>
          <button id="apBtnCopy" class="ap-btn ap-btn--primary">Copy</button>
        </div>
        <p class="ap-helper">Member access only: they can shop and reorder, but they cannot manage products, settings, or other members.</p>
      </div>
      <div id="apTabQR" class="ap-tab-content" style="display:none;">
        <div class="ap-qr-box">
          <div id="ap-qrcode"></div>
          <p class="ap-helper">Best for flyers, team meetings, sign-up tables, or handing your phone to a parent. QR access is member-only.</p>
        </div>
      </div>
    </div>
  </div>


  <!-- ══════════════════════════════════════════════════════
       FUNDRAISING WIZARD MODAL — 4-step setup flow
       ══════════════════════════════════════════════════════ -->
  <div class="ap-frw-overlay" id="apFrwOverlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="apFrwTitle">
    <div class="ap-frw-modal" id="apFrwModal">

      <!-- HERO (step indicator + dynamic title) -->
      <div class="ap-frw-hero">
        <button class="ap-frw-close" id="apFrwClose" aria-label="Close">✕</button>
        <div class="ap-frw-step-pills">
          <div class="ap-frw-pill active" id="apFrwPill1"></div>
          <div class="ap-frw-pill" id="apFrwPill2"></div>
          <div class="ap-frw-pill" id="apFrwPill3"></div>
          <div class="ap-frw-pill" id="apFrwPill4"></div>
          <div class="ap-frw-pill" id="apFrwPill5"></div>
        </div>
        <p class="ap-frw-hero-label" id="apFrwStepLabel">Step 1 of 5</p>
        <h2 id="apFrwTitle">Fundraising for your team store</h2>
        <p id="apFrwSubtitle">The most seamless way to raise money — set up in under 5 minutes.</p>
      </div>

      <!-- STEP 1: How It Works + Agreement -->
      <div id="apFrwStep1" class="ap-frw-step-content">
        <div class="ap-frw-body">

          <div class="ap-frw-benefit-list">
            <div class="ap-frw-benefit-item">
              <div class="ap-frw-benefit-icon" style="background:#f0fdf4">🏆</div>
              <div class="ap-frw-benefit-text">
                <strong>Every sale raises money — automatically</strong>
                <span>Add $1–$8 per item. The donation is built into your prices when you launch. Flip it on once and every product in your catalog raises money without any ongoing effort.</span>
              </div>
            </div>
            <div class="ap-frw-benefit-item">
              <div class="ap-frw-benefit-icon" style="background:#eff6ff">🏦</div>
              <div class="ap-frw-benefit-text">
                <strong>Funds go straight to the cause's bank</strong>
                <span>Stripe deposits fundraising dollars directly to the recipient's account after a 7-day hold. No invoices. No checks. No middleman — the money moves itself.</span>
              </div>
            </div>
            <div class="ap-frw-benefit-item">
              <div class="ap-frw-benefit-icon" style="background:#fefce8">📈</div>
              <div class="ap-frw-benefit-text">
                <strong>A live goal bar turns browsers into buyers</strong>
                <span>Show shoppers how close you are in real time. "We're at $340 of our $500 goal" creates urgency — people who were on the fence buy because they want to help push it over the line.</span>
              </div>
            </div>
          </div>

          <div class="ap-frw-legal-box">
            <span class="ap-frw-legal-intro">Read before you continue</span>
            <div class="ap-frw-legal-points">
              <div class="ap-frw-legal-point">Stella &amp; Sage Co. is a technology intermediary only — we do not hold, control, or distribute fundraising funds. All payments move directly through Stripe, Inc.</div>
              <div class="ap-frw-legal-point">As the Fundraiser Manager you are solely responsible for the lawful use of funds and compliance with all applicable laws, including charitable solicitation requirements.</div>
              <div class="ap-frw-legal-point">A $1 per-item processing fee is added on top of your set amount and disclosed to customers. Your cause always receives exactly the amount you set.</div>
              <div class="ap-frw-legal-point">This feature does not constitute a charitable donation and should not be represented as tax-deductible unless the receiving organization is a registered 501(c)(3).</div>
            </div>
            <label class="ap-frw-terms-label" for="apFrwTermsCheck">
              <input type="checkbox" id="apFrwTermsCheck" />
              <span><strong>I've read and agree to these terms.</strong> I understand Stella &amp; Sage Co. is not responsible for how funds are used after transfer, and I'm solely responsible for legal compliance.</span>
            </label>
          </div>

        </div>
        <div class="ap-frw-footer">
          <button class="ap-frw-next-btn" id="apFrwStep1Next">Got it — How does payment work? →</button>
        </div>
      </div>

      <!-- STEP 2: About Stripe -->
      <div id="apFrwStep2" class="ap-frw-step-content" style="display:none;">
        <div class="ap-frw-body">

          <div class="ap-frw-stripe-intro">
            <div class="ap-frw-stripe-intro-header">
              <div class="ap-frw-stripe-intro-icon">🏦</div>
              <div>
                <div class="ap-frw-stripe-intro-title">What is Stripe?</div>
                <div class="ap-frw-stripe-intro-sub">The payment infrastructure behind millions of businesses</div>
              </div>
            </div>
            <div class="ap-frw-stripe-intro-body">Stripe is the payment platform behind Apple Pay, Shopify, Lyft, and hundreds of thousands of small businesses. When you run a fundraiser here, Stripe handles every transfer from your store to the cause's bank — automatically, on a weekly schedule. You set it up once and walk away.</div>
          </div>

          <div class="ap-frw-info-card">
            <span class="ap-frw-info-card-label">What the recipient needs to open their account</span>
            <div class="ap-frw-info-row">
              <div class="ap-frw-info-dot"></div>
              <span><strong>Legal name</strong> — the individual or organization name as it appears on their bank account</span>
            </div>
            <div class="ap-frw-info-row">
              <div class="ap-frw-info-dot"></div>
              <span><strong>Date of birth</strong> — for identity verification</span>
            </div>
            <div class="ap-frw-info-row">
              <div class="ap-frw-info-dot"></div>
              <span><strong>Last 4 of SSN or full EIN</strong> — depends on payout volume</span>
            </div>
            <div class="ap-frw-info-row">
              <div class="ap-frw-info-dot"></div>
              <span><strong>Bank account + routing number</strong> — where their deposits land</span>
            </div>
            <span class="ap-frw-info-card-note">Setup takes about 5 minutes — similar to any banking app. They only do it once. After that, Stripe handles every deposit automatically.</span>
          </div>

          <div class="ap-frw-info-callout">
            <strong>Who does this?</strong> Not you — the coach, booster club treasurer, or team parent who will receive the funds. They'll click "Connect with Stripe" on the next screen and walk through Stripe's guided setup. You never see or touch their banking information.
          </div>

        </div>
        <div class="ap-frw-footer">
          <button class="ap-frw-back-btn" id="apFrwStep2Back">← Back</button>
          <button class="ap-frw-next-btn" id="apFrwStep2Next">Connect the Cause →</button>
        </div>
      </div>

      <!-- STEP 3: Stripe Connect -->
      <div id="apFrwStep3" class="ap-frw-step-content" style="display:none;">
        <div class="ap-frw-body">
          <div class="ap-frw-stripe-card">
            <div class="ap-frw-stripe-logo">🏦</div>
            <h3>Connect the Cause's Stripe Account</h3>
            <p>Have the recipient — the coach, booster club treasurer, or team parent — click below to set up their free Stripe Express account. It takes about 5 minutes. They enter their banking information directly with Stripe. You never see it.</p>
            <p style="font-size:13px;color:#64748b;">Once connected, Stripe automatically deposits every fundraising dollar to their bank on a weekly basis. No action needed from either of you after setup.</p>
            <div id="apFrwStripeStatus">
              <button class="ap-frw-stripe-btn" id="apFrwStripeConnectBtn" type="button">
                Connect with Stripe
              </button>
              <p class="ap-frw-stripe-test-note" id="apFrwStripeTestNote">Test mode active — no real money moves. Switch to live after Stripe platform approval.</p>
            </div>
            <div id="apFrwStripeConnected" class="ap-frw-stripe-connected" style="display:none;">
              Connected — <span id="apFrwStripeAcctId"></span>
            </div>
          </div>
          <div class="ap-frw-highlight">
            <span class="ap-frw-highlight-icon">🔑</span>
            <div class="ap-frw-highlight-copy">
              <strong>This connects the recipient's bank, not yours.</strong> Once they complete setup, Stripe handles every deposit automatically — they never have to touch it again.
            </div>
          </div>
        </div>
        <div class="ap-frw-footer">
          <button class="ap-frw-back-btn" id="apFrwStep3Back">← Back</button>
          <button class="ap-frw-next-btn" id="apFrwStep3Next">Continue — Set Up Fundraiser →</button>
        </div>
      </div>

      <!-- STEP 4: Fundraiser Details -->
      <div id="apFrwStep4" class="ap-frw-step-content" style="display:none;">
        <div class="ap-frw-body">

          <div class="ap-frw-field">
            <label class="ap-frw-label" for="apFrwCause">Cause Name</label>
            <input class="ap-frw-input" type="text" id="apFrwCause" placeholder="e.g. Westview Youth Baseball" maxlength="80" autocomplete="off" />
            <p class="ap-frw-helper">Shown on the storefront — customers see exactly who they're supporting.</p>
          </div>

          <div class="ap-frw-field">
            <label class="ap-frw-label">Fundraising Amount Per Item</label>
            <div class="ap-frw-amount-row">
              <button type="button" class="ap-frw-amt-btn" id="apFrwAmtDown" aria-label="Decrease">−</button>
              <div class="ap-frw-amt-display">$<span id="apFrwAmtDisplay">4</span></div>
              <button type="button" class="ap-frw-amt-btn" id="apFrwAmtUp" aria-label="Increase">+</button>
              <input type="hidden" id="apFrwAmount" value="4" />
            </div>
            <div class="ap-frw-calc-row">
              <span class="ap-frw-calc-label">$<span id="apFrwAmtA">4</span> to cause + $1 fee</span>
              <span class="ap-frw-calc-val">= $<span id="apFrwAmtB">5</span> per item</span>
            </div>
            <p class="ap-frw-helper">$1–$8 range. Your cause receives exactly the amount you set — the $1 fee is disclosed to customers.</p>
          </div>

          <div class="ap-frw-goal-row">
            <div class="ap-frw-field">
              <label class="ap-frw-label" for="apFrwGoal">Fundraising Goal</label>
              <div class="ap-frw-input-icon-wrap">
                <span class="ap-frw-input-pre">$</span>
                <input class="ap-frw-input ap-frw-input--icon-pre" type="number" id="apFrwGoal" min="1" step="1" placeholder="500" />
              </div>
              <p class="ap-frw-helper">Optional — shown publicly to drive urgency.</p>
            </div>
            <div class="ap-frw-field">
              <label class="ap-frw-label" for="apFrwEndDate">End Date</label>
              <input class="ap-frw-input" type="date" id="apFrwEndDate" />
              <p class="ap-frw-helper">Optional. Max 1 year from today.</p>
            </div>
          </div>

        </div>
        <div class="ap-frw-footer">
          <button class="ap-frw-back-btn" id="apFrwStep4Back">← Back</button>
          <button class="ap-frw-next-btn" id="apFrwStep4Next">Continue — Display Settings →</button>
        </div>
      </div>

      <!-- STEP 5: Display Settings -->
      <div id="apFrwStep5" class="ap-frw-step-content" style="display:none;">
        <div class="ap-frw-body">
          <p style="font-size:14px;color:rgba(17,16,14,.62);margin:0 0 18px;line-height:1.65;"><strong style="color:#11100e;">Transparency drives sales.</strong> Stores that show their fundraiser progress publicly see significantly more purchases — supporters want to see the goal hit.</p>

          <div class="ap-frw-toggle-row selected" id="apFrwVisRow1" data-val="public">
            <div class="ap-frw-toggle-icon">🌐</div>
            <div class="ap-frw-toggle-copy">
              <h4>Show live progress to everyone</h4>
              <p>A banner on your storefront shows the cause name, goal, amount raised, and days left. People share it. Parents show it to neighbors. Social proof turns browsers into buyers.</p>
            </div>
            <div class="ap-frw-toggle-check"><input type="radio" name="apFrwVis" value="public" checked /></div>
          </div>

          <div class="ap-frw-toggle-row" id="apFrwVisRow2" data-val="admin_only">
            <div class="ap-frw-toggle-icon">🛡️</div>
            <div class="ap-frw-toggle-copy">
              <h4>Admin-only — I'll announce it myself</h4>
              <p>Fundraising is active and products are priced accordingly, but customers don't see a progress bar. You track it here in admin. Good for stores that prefer to reveal the total at the end.</p>
            </div>
            <div class="ap-frw-toggle-check"><input type="radio" name="apFrwVis" value="admin_only" /></div>
          </div>

          <div class="ap-frw-highlight" style="margin-top:16px;">
            <span class="ap-frw-highlight-icon">⭐</span>
            <div class="ap-frw-highlight-copy">
              <strong>Either way, shoppers always see "Active Fundraiser."</strong> Customers know a fundraiser is running and understand why prices include a contribution — even if they don't see the live total.
            </div>
          </div>
        </div>
        <div class="ap-frw-footer">
          <button class="ap-frw-back-btn" id="apFrwStep5Back">← Back</button>
          <button class="ap-frw-next-btn" id="apFrwStep5Launch">Launch Fundraiser</button>
        </div>
      </div>

    </div>
  </div>

  <!-- FUNDRAISER PRICING STATUS BANNER (persists through Stop; outside active zone) -->
  <div id="apFrPricingBanner" style="display:none;" aria-live="polite"></div>

  <!-- FUNDRAISER DETAILS MODAL -->
  <div class="ap-frd-overlay" id="apFrdOverlay" aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="apFrdTitle">
    <div class="ap-frd-modal">
      <div class="ap-frd-header">
        <button class="ap-frd-close" id="apFrdClose" aria-label="Close">✕</button>
        <div class="ap-frd-header-badge">Active</div>
        <h3 id="apFrdTitle">Fundraiser Details</h3>
        <p id="apFrdSubtitle">Your fundraiser is live — raising funds on every sale.</p>
      </div>
      <div class="ap-frd-stats-row">
        <div class="ap-frd-stat-cell">
          <div class="ap-frd-stat-cell-val" id="apFrdStatRaised">$0</div>
          <div class="ap-frd-stat-cell-lbl">Total Raised</div>
        </div>
        <div class="ap-frd-stat-cell" id="apFrdStatGoalCell" style="display:none;">
          <div class="ap-frd-stat-cell-val" id="apFrdStatGoal">—</div>
          <div class="ap-frd-stat-cell-lbl">Goal</div>
        </div>
        <div class="ap-frd-stat-cell" id="apFrdStatDaysCell" style="display:none;">
          <div class="ap-frd-stat-cell-val" id="apFrdStatDays">—</div>
          <div class="ap-frd-stat-cell-lbl">Days Left</div>
        </div>
        <div class="ap-frd-stat-cell">
          <div class="ap-frd-stat-cell-val" id="apFrdStatAmt">$4</div>
          <div class="ap-frd-stat-cell-lbl">Per Item</div>
        </div>
      </div>
      <div class="ap-frd-progress-wrap" id="apFrdProgressWrap" style="display:none;">
        <div class="ap-frd-progress-bar">
          <div class="ap-frd-progress-fill" id="apFrdProgressFill" style="width:0%"></div>
        </div>
        <p class="ap-frd-progress-label" id="apFrdProgressLabel">0% of goal</p>
      </div>
      <div class="ap-frd-body">
        <div class="ap-frd-row">
          <div class="ap-frd-row-icon">🎯</div>
          <div>
            <div class="ap-frd-row-label">Cause</div>
            <div class="ap-frd-row-val" id="apFrdCauseName">—</div>
          </div>
        </div>
        <div class="ap-frd-row" id="apFrdEndDateRow" style="display:none;">
          <div class="ap-frd-row-icon">📅</div>
          <div>
            <div class="ap-frd-row-label">End Date</div>
            <div class="ap-frd-row-val" id="apFrdEndDate">—</div>
          </div>
        </div>
        <div class="ap-frd-row">
          <div class="ap-frd-row-icon">💰</div>
          <div>
            <div class="ap-frd-row-label">How it works</div>
            <div class="ap-frd-row-val" id="apFrdHowItWorks">$4 per item donated → $1 processing fee → $4 goes to your cause</div>
          </div>
        </div>
        <div class="ap-frd-row">
          <div class="ap-frd-row-icon">👁️</div>
          <div>
            <div class="ap-frd-row-label">Public Progress Bar</div>
            <div class="ap-frd-row-val" id="apFrdVisibility">Visible to shoppers</div>
          </div>
        </div>
        <div class="ap-frd-row">
          <div class="ap-frd-row-icon">⏱️</div>
          <div>
            <div class="ap-frd-row-label">Payout</div>
            <div class="ap-frd-row-val">7-day hold, then automatic bank transfer via Stripe</div>
          </div>
        </div>
      </div>
      <div class="ap-frd-footer">
        <button type="button" class="ap-btn--fr-edit-wizard" id="apFrdEditBtn">Edit Fundraiser</button>
        <button type="button" class="ap-btn--fr-stop" id="apFrdStopBtn">End Fundraiser</button>
      </div>
    </div>
  </div>

  <!-- MAIN DASHBOARD CARD WITH TABS -->
  <div class="ap-main-card">

    <!-- MAIN PANEL TABS -->
    <div class="ap-main-tabs-wrap">
      <div class="ap-main-tabs" role="tablist">
        <button class="ap-main-tab-btn active" id="apTabBtnProducts" data-main-tab="apPanelProducts" role="tab" aria-selected="true" aria-controls="apPanelProducts"><span class="ap-tab-icon">📦</span><span class="ap-tab-label">Products</span></button>
        <button class="ap-main-tab-btn" id="apTabBtnAddProducts" data-main-tab="apPanelAddProducts" role="tab" aria-selected="false" aria-controls="apPanelAddProducts"><span class="ap-tab-icon">✨</span><span class="ap-tab-label">Add Products</span></button>
        <button class="ap-main-tab-btn" id="apTabBtnMembers" data-main-tab="apPanelMembers" role="tab" aria-selected="false" aria-controls="apPanelMembers"><span class="ap-tab-icon">👥</span><span class="ap-tab-label">Members</span></button>
        <button class="ap-main-tab-btn" id="apTabBtnSettings" data-main-tab="apPanelSettings" role="tab" aria-selected="false" aria-controls="apPanelSettings"><span class="ap-tab-icon">⚙️</span><span class="ap-tab-label">Settings</span></button>
        <button class="ap-main-tab-btn" id="apTabBtnDanger" data-main-tab="apPanelDanger" role="tab" aria-selected="false" aria-controls="apPanelDanger"><span class="ap-tab-icon">☠️</span><span class="ap-tab-label">Danger</span></button>
      </div>
    </div>

    <!-- MEMBERS PANEL -->
    <div id="apPanelMembers" class="ap-main-panel" role="tabpanel" aria-labelledby="apTabBtnMembers">
      <div class="ap-panel-head">
        <div>
          <span class="ap-panel-kicker">Access</span>
          <h2>Members</h2>
          <p>Add shoppers or admins. Members can buy from the store; admins can help manage it.</p>
        </div>
      </div>

      <div class="ap-form-group">
        <label class="ap-label">Member Emails</label>
        <textarea id="apInputEmails" class="ap-textarea" placeholder="alice@example.com, bob@example.com..."></textarea>
        <p class="ap-helper">Separate multiple emails with commas.</p>
      </div>

      <div class="ap-form-group">
        <label class="ap-label">Access Level</label>
        <select id="apInputRole" class="ap-select">
          <option value="member" selected>Member (Can Shop)</option>
          <option value="admin">Admin (Can Edit Settings)</option>
          <option value="remove-admin">Remove Admin Role (Keep as Member)</option>
        </select>
      </div>

      <div class="ap-btn-row">
        <button id="apBtnAdd" class="ap-btn ap-btn--primary">+ Add Members</button>
        <button id="apBtnRemove" class="ap-btn ap-btn--danger">Remove</button>
        <button id="apBtnRemoveAdmin" class="ap-btn">Remove Admin Role</button>
      </div>
      <div id="apStatusMembers" class="ap-status"></div>
    </div><!-- /apPanelMembers -->

    <!-- PRODUCTS PANEL -->
    <div id="apPanelProducts" class="ap-main-panel active" role="tabpanel" aria-labelledby="apTabBtnProducts">

      <div class="ap-panel-head ap-panel-head--products">
        <div>
          <span class="ap-panel-kicker">Store build</span>
          <h2>Products</h2>
          <p>Review your live products. Edit artwork and colors, hide items, or remove products you no longer need.</p>
        </div>
        <div class="ap-panel-head-right">
          <span class="ap-product-count" id="apAllProductCount">0</span>
          <a class="ap-panel-mini-link" href="/collections/{{ collection_handle }}">View live store ↗</a>
        </div>
      </div>

      <div id="apProductsSpinner" class="ap-products-spinner" style="display:none;">⏳ Loading products…</div>
      <div id="apProductsEmpty" class="ap-products-empty" style="display:none;">No products found for this store.</div>

      <div class="ap-products-grid" id="apProductsGrid">
        <div id="apProductsAllContainer" class="ap-product-list"></div>
      </div>

      <div id="apStatusProducts" class="ap-status"></div>
    </div><!-- /apPanelProducts -->

    <!-- ADD PRODUCTS PANEL -->
    <div id="apPanelAddProducts" class="ap-main-panel" role="tabpanel" aria-labelledby="apTabBtnAddProducts">
      <div class="ap-panel-head">
        <div>
          <span class="ap-panel-kicker">Build more</span>
          <h2>Add Products</h2>
          <p>Create premium custom products without scrolling through the current catalog. These build as separate products inside this store.</p>
        </div>
      </div>

      <section class="ap-product-box ap-product-box--builder">
        <div class="ap-product-box-head">
          <div>
            <h3 class="ap-product-box-title">Pro Builders</h3>
            <p class="ap-product-box-sub">Start with a product type, choose images/colors, then add it to the storefront.</p>
          </div>
          <span class="ap-product-count" id="apBuilderProductCount">0</span>
        </div>
        <div id="apCustomBuildersEmpty" class="ap-product-section-empty">Builders are loading. If nothing appears, refresh the page.</div>
        <div id="apCustomBuildersSection" class="ap-custom-builders-section" style="display:none;">
          <div id="apCustomBuildersContainer" class="ap-product-list ap-product-list--builders"></div>
        </div>
      </section>

      <div id="apStatusAddProducts" class="ap-status"></div>
    </div><!-- /apPanelAddProducts -->

    <!-- SETTINGS PANEL -->
    <div id="apPanelSettings" class="ap-main-panel" role="tabpanel" aria-labelledby="apTabBtnSettings">

      <!-- Fundraising row: shows active state or start prompt, no clutter -->
      <div id="apFrSettingsRow" class="ap-fr-settings-row" style="display:none;">
        <div class="ap-fr-settings-row-left">
          <h4 id="apFrSettingsRowTitle">💚 Fundraiser Active</h4>
          <p id="apFrSettingsRowSub">Loading fundraiser details…</p>
        </div>
        <button class="ap-fr-active-edit" id="apFrEditFromSettings">Edit / End →</button>
      </div>

      <div class="ap-panel-head" style="margin-top:0;">
        <div>
          <span class="ap-panel-kicker">Store identity</span>
          <h2>Settings</h2>
          <p>Update the storefront name or main logo. Logo changes rebuild the store.</p>
        </div>
      </div>

      <!-- Store display name -->
      <div class="ap-form-group">
        <label class="ap-label" for="apSettingsName">Store Display Name</label>
        <input id="apSettingsName" class="ap-input" type="text" value="{{ store_name | escape }}" placeholder="Store name" />
        <p class="ap-helper">Renames the store on the dashboard and storefront. No rebuild needed.</p>
      </div>

      <!-- Logo section -->
      <div class="ap-form-group">
        <label class="ap-label">Main Logo / Primary Image</label>
        <div id="apSettingsLogoPreview" style="margin-bottom:12px;">
          {% if ap_shop_logo_src != '' %}
            <img src="{{ ap_shop_logo_src }}" alt="Current logo" style="max-width:120px;max-height:80px;border-radius:8px;border:1px solid var(--ap-border);padding:4px;background:#fff;display:block;object-fit:contain;" />
          {% else %}
            <div style="width:120px;height:80px;background:#f1f5f9;border-radius:8px;border:1px solid var(--ap-border);display:flex;align-items:center;justify-content:center;font-size:28px;">🖼️</div>
          {% endif %}
        </div>
        <div id="apSettingsLogoStatus" style="font-size:12px;color:var(--ap-gray);margin-bottom:8px;min-height:16px;"></div>
        <button id="apBtnChangeLogo" class="ap-btn ap-btn--outline ap-btn--sm" type="button">🖼️ Change Logo</button>
        <p class="ap-helper">Changing the logo rebuilds the full product set with the new artwork (~5–10 min).</p>
      </div>

      <!-- Rebuild warning -->
      <div id="apSettingsRebuildWarning" style="display:none;margin-bottom:16px;padding:12px 14px;background:#fef9c3;border:1px solid #fde047;border-radius:10px;font-size:13px;color:#713f12;font-weight:600;">
        ⚠️ Logo changed. Saving will rebuild the current products with the new settings. This usually takes 5–10 minutes.
      </div>

      <button id="apBtnSaveSettings" class="ap-btn ap-btn--primary ap-btn-full">Save & Apply Settings</button>
      <div id="apStatusSettings" class="ap-status"></div>

    </div><!-- /apPanelSettings -->

    <!-- DANGER PANEL -->
    <div id="apPanelDanger" class="ap-main-panel" role="tabpanel" aria-labelledby="apTabBtnDanger">

      <div class="ap-panel-head ap-panel-head--danger">
        <div>
          <span class="ap-panel-kicker">Careful zone</span>
          <h2>Sleep & Delete</h2>
          <p>Use sleep mode when a store is inactive. Use nuke only when the store should be permanently removed.</p>
        </div>
      </div>

      <!-- Sleep Mode Card -->
      <div class="ap-card" style="margin-bottom:20px;border-color:rgba(239,68,68,0.2);background:#fff5f5;">
        <div class="ap-card-head">
          <div class="ap-card-icon ap-card-icon--red">💤</div>
          <h3>Sleep Mode</h3>
          <p>Hides this store by deleting live products while keeping the store record ready to wake up later.</p>
        </div>
        {% if ap_store_status == 'sleeping' %}
          <button id="apBtnWakeStore" class="ap-btn ap-btn--primary ap-btn-full" style="background:#10b981;">☀️ Wake Up Store</button>
        {% elsif ap_store_status == 'waking' %}
          <button class="ap-btn ap-btn-full" disabled style="background:#6366f1;color:#fff;opacity:0.6;cursor:not-allowed;">⏳ Waking…</button>
        {% else %}
          <button id="apBtnSleepStore" class="ap-btn ap-btn--danger ap-btn-full">💤 Sleep Store</button>
        {% endif %}
        <div id="apStatusSleep" class="ap-status"></div>
      </div>

      <!-- Danger Zone (Nuke) Card -->
      <div class="ap-danger-card">
        <div class="ap-card-head">
          <div class="ap-card-icon ap-card-icon--red">💣</div>
          <h3 style="color:#dc2626;">Danger Zone — Nuke Store</h3>
          <p>Permanently deletes the store record, products, collection, member access, and settings. <strong>This cannot be undone.</strong></p>
        </div>
        <button id="apNukeBtn" class="ap-btn ap-btn--nuke">Permanently Delete Store</button>
      </div>

    </div><!-- /apPanelDanger -->

  </div><!-- /.ap-main-card -->

  <!-- NUKE CONFIRMATION MODAL (position: fixed — outside sections) -->
  <div class="ap-nuke-overlay" id="apNukeOverlay">
    <div class="ap-nuke-dialog" role="dialog" aria-modal="true" aria-labelledby="apNukeTitle">
      <div class="ap-nuke-dialog__icon">☢️</div>
      <p class="ap-nuke-dialog__title" id="apNukeTitle">Permanently Delete This Store?</p>
      <p class="ap-nuke-dialog__warning">
        You are about to permanently delete <strong>{{ store_name }}</strong>.
        This store and everything in it — all products, members, photos, and settings — will be gone forever.
        <strong>This cannot be undone.</strong>
      </p>
      <input
        type="text"
        class="ap-nuke-confirm-input"
        id="apNukeInput"
        placeholder="Type &quot;gone&quot; to confirm"
        autocomplete="off">
      <div class="ap-nuke-actions">
        <button id="apNukeDestroy" class="ap-btn ap-btn--nuke" disabled>Destroy Store</button>
        <button id="apNukeCancel" class="ap-btn ap-btn--outline">Cancel</button>
      </div>
      <pre class="ap-nuke-log" id="apNukeLog"></pre>
    </div>
  </div>

  <!-- BC3413 EDITOR MODAL -->
  <div class="ap-editor-overlay" id="apEditorOverlay" aria-hidden="true">
    <div class="ap-editor-dialog" role="dialog" aria-modal="true" aria-labelledby="apEditorTitle">
      <div class="ap-editor-header">
        <span id="apEditorTitle">✏️ Edit Logo Placement</span>
        <button type="button" class="ap-editor-close" id="apEditorClose" aria-label="Close editor">✕</button>
      </div>
      <iframe id="apEditorIframe"
              class="ap-editor-iframe"
              title="BC3413 Placement Editor"
              allow="clipboard-write"></iframe>
    </div>
  </div>

  <!-- REBUILD IN PROGRESS MODAL -->
  <div class="ap-rebuild-overlay" id="apRebuildOverlay" aria-hidden="true">
    <div class="ap-rebuild-dialog" role="dialog" aria-modal="true" aria-labelledby="apRebuildTitle">
      <div class="ap-rebuild-icon">🔨</div>
      <h2 class="ap-rebuild-title" id="apRebuildTitle">Rebuilding Your Store</h2>
      <p class="ap-rebuild-body">
        We're applying your changes and rebuilding all of your store's products.
        This process takes about <strong>15–20 minutes</strong> to complete.
        When it's done, everything will be right back where you left it —
        all your products, members, and settings fully intact.
      </p>
      <p class="ap-rebuild-sub">Taking you back to your dashboard in a moment…</p>
      <div class="ap-rebuild-bar"><div class="ap-rebuild-bar-fill"></div></div>
    </div>
  </div>

</div><!-- /.ap-wrap -->

<script src="{{ 'ss-admin-powers-core.js' | asset_url }}" defer></script>
<script src="{{ 'ss-admin-fundraiser.js' | asset_url }}" defer></script>

{%- endif -%}

{% schema %}
{
  "name": "Admin Powers",
  "settings": [
    {
      "type": "text",
      "id": "editor_pro_shirt_zip_hoodie_base_url",
      "label": "Pro Shirt Editor — Zip Hoodie Base URL"
    }
  ],
  "presets": [
    { "name": "Admin Powers" }
  ]
}
{% endschema %}
