{% comment %}
  ADMIN POWERS — V12 (SECTION FILE)
  - Self-contained section (no Custom Liquid block needed).
  - V12: Mobile-first single-dashboard redesign with tab navigation.
    Single card with tabs (Overview | Members | Products | Danger).
    Product thumbnails (52×52px) pulled from featured_image / image / images[0].src
    with 🖼️ placeholder. Products lazy-load when tab is clicked.
  - V11: Route all calls to Railway (remove Mechanic URL). Remove credentials:include from fetches.
  - God Mode: Ryan Irwin hardcoded + super-admin tag.
  - QR code, public toggle, invite/remove members.
  - Premium design upgrade.
{% endcomment %}

{%- assign dashboard_url = '/pages/portal' -%}
{%- assign join_path = '/pages/join-store' -%}

{%- comment %} 1. GET SHOP HANDLE {% endcomment -%}
{%- assign shop_handle = request.params.shop | default: '' | strip -%}
{%- if shop_handle == blank -%}
  {%- assign _cfh = content_for_header -%}
  {%- assign _url_part = _cfh | split: '"pageurl":"' | last | split: '"' | first -%}
  {%- assign _url_part = _url_part | replace: '\u0026', '&' -%}
  {%- if _url_part contains '?' -%}
    {%- assign _qs = _url_part | split: '?' | last -%}
    {%- assign _pairs = _qs | split: '&' -%}
    {%- for p in _pairs -%}
      {%- assign kv = p | split: '=' -%}
      {%- if kv[0] == 'shop' -%}{%- assign shop_handle = kv[1] | default: '' | strip -%}{%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endif -%}
{%- assign shop_handle = shop_handle | replace: '%2D', '-' | replace: '%5F', '_' | strip | downcase -%}

{%- comment %} 2. PERMISSIONS CHECK {% endcomment -%}
{%- assign required_admin_tag = 'storefront-admin--' | append: shop_handle -%}
{%- assign is_admin_for_shop = false -%}
{%- assign is_super_admin = false -%}

{%- if customer and shop_handle != blank -%}
  {%- if customer.email == 'ryan.irwin@stellaandsagecompany.com' -%}
    {%- assign is_super_admin = true -%}
    {%- assign is_admin_for_shop = true -%}
  {%- endif -%}
  {%- for t in customer.tags -%}
    {%- assign tag_down = t | downcase | strip -%}
    {%- if tag_down == 'super-admin' -%}
      {%- assign is_super_admin = true -%}
      {%- assign is_admin_for_shop = true -%}
    {%- endif -%}
    {%- if tag_down == required_admin_tag -%}{%- assign is_admin_for_shop = true -%}{%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- style -%}
  :root {
    --ap-bg: #f0f4f8;
    --ap-card: #ffffff;
    --ap-text: #0f172a;
    --ap-gray: #64748b;
    --ap-border: #e2e8f0;
    --ap-accent: #0f172a;
    --ap-accent2: #6366f1;
    --ap-success: #10b981;
    --ap-danger: #ef4444;
    --ap-shadow-sm: 0 1px 3px rgba(0,0,0,0.06), 0 1px 2px rgba(0,0,0,0.04);
    --ap-shadow: 0 4px 16px rgba(15,23,42,0.08), 0 1px 3px rgba(15,23,42,0.04);
    --ap-shadow-lg: 0 20px 40px rgba(15,23,42,0.12);
    --ap-radius: 18px;
    --ap-font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Inter", sans-serif;
  }

  /* ── AUTH SCREENS ──────────────────────────────────────── */
  .ap-auth-wrap {
    max-width: 420px; margin: 80px auto; padding: 20px;
    text-align: center; font-family: var(--ap-font);
  }
  .ap-auth-card {
    background: var(--ap-card); padding: 48px 40px;
    border-radius: var(--ap-radius); border: 1px solid var(--ap-border);
    box-shadow: var(--ap-shadow);
  }
  .ap-auth-icon {
    font-size: 36px; width: 72px; height: 72px; line-height: 72px;
    background: #f1f5f9; border-radius: 50%; margin: 0 auto 24px; display: block;
  }
  .ap-auth-card h2 { margin: 0 0 10px; font-size: 22px; font-weight: 800; }
  .ap-auth-card p { margin: 0 0 24px; color: var(--ap-gray); font-size: 15px; }

  /* ── MAIN LAYOUT ───────────────────────────────────────── */
  .ap-wrap {
    max-width: 800px; margin: 0 auto; padding: 40px 20px 80px;
    font-family: var(--ap-font); color: var(--ap-text);
  }

  /* ── HERO HEADER ───────────────────────────────────────── */
  .ap-hero {
    background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #312e81 100%);
    border-radius: var(--ap-radius); padding: 36px 40px; margin-bottom: 32px;
    display: flex; justify-content: space-between; align-items: flex-end;
    flex-wrap: wrap; gap: 20px; position: relative; overflow: hidden;
    box-shadow: var(--ap-shadow-lg);
  }
  .ap-hero::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(circle at 80% 20%, rgba(99,102,241,0.3) 0%, transparent 60%);
  }
  .ap-hero-left { position: relative; z-index: 1; }
  .ap-hero-badge {
    display: inline-flex; align-items: center; gap: 6px;
    background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.9); font-size: 11px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.1em;
    padding: 5px 12px; border-radius: 99px; margin-bottom: 14px;
    backdrop-filter: blur(10px);
  }
  .ap-hero-badge .dot {
    width: 6px; height: 6px; border-radius: 50%; background: #10b981;
    box-shadow: 0 0 6px #10b981; animation: pulse-dot 2s infinite;
  }
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; } 50% { opacity: 0.4; }
  }
  @media (prefers-reduced-motion: reduce) {
    .ap-hero-badge .dot { animation: none; }
    .ap-public-block { animation: none; }
  }
  .ap-hero h1 {
    margin: 0 0 6px; font-size: clamp(26px, 4vw, 38px); font-weight: 900;
    color: #fff; letter-spacing: -0.03em; line-height: 1.1;
  }
  .ap-hero-sub { color: rgba(255,255,255,0.6); font-size: 14px; margin: 0; }
  .ap-hero-actions { display: flex; gap: 10px; position: relative; z-index: 1; flex-wrap: wrap; }

  /* ── BUTTONS ───────────────────────────────────────────── */
  .ap-btn {
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    padding: 10px 20px; border-radius: 10px; font-weight: 700; font-size: 14px;
    cursor: pointer; transition: all 0.2s; border: none; text-decoration: none;
    font-family: var(--ap-font); white-space: nowrap;
  }
  .ap-btn--primary { background: var(--ap-accent); color: #fff; }
  .ap-btn--primary:hover { background: #1e293b; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(15,23,42,0.3); }
  .ap-btn--glass {
    background: rgba(255,255,255,0.12); backdrop-filter: blur(10px);
    border: 1px solid rgba(255,255,255,0.2); color: #fff;
  }
  .ap-btn--glass:hover { background: rgba(255,255,255,0.22); color: #fff; }
  .ap-btn--outline { background: transparent; border: 1px solid var(--ap-border); color: var(--ap-text); }
  .ap-btn--outline:hover { background: #f8fafc; border-color: #94a3b8; }
  .ap-btn--danger { background: #fee2e2; color: #991b1b; }
  .ap-btn--danger:hover { background: #fecaca; }
  .ap-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none !important; }
  .ap-btn-full { width: 100%; }

  /* ── GRID ──────────────────────────────────────────────── */
  .ap-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  @media(max-width: 800px) { .ap-grid { grid-template-columns: 1fr; } }

  /* ── CARDS ─────────────────────────────────────────────── */
  .ap-card {
    background: var(--ap-card); border: 1px solid var(--ap-border);
    border-radius: var(--ap-radius); padding: 28px;
    box-shadow: var(--ap-shadow); transition: box-shadow 0.2s;
  }
  .ap-card:hover { box-shadow: var(--ap-shadow-lg); }
  .ap-card-head { margin-bottom: 22px; }
  .ap-card-head h3 { margin: 0 0 5px; font-size: 17px; font-weight: 800; letter-spacing: -0.01em; }
  .ap-card-head p { margin: 0; font-size: 13px; color: var(--ap-gray); line-height: 1.4; }
  .ap-card-icon {
    width: 40px; height: 40px; border-radius: 10px; margin-bottom: 14px;
    display: flex; align-items: center; justify-content: center; font-size: 20px;
  }
  .ap-card-icon--indigo { background: #eef2ff; }
  .ap-card-icon--emerald { background: #ecfdf5; }

  /* ── FORM ELEMENTS ─────────────────────────────────────── */
  .ap-form-group { margin-bottom: 20px; }
  .ap-label {
    display: block; font-size: 11px; font-weight: 800; margin-bottom: 8px;
    color: var(--ap-gray); text-transform: uppercase; letter-spacing: 0.08em;
  }
  .ap-input, .ap-textarea, .ap-select {
    width: 100%; padding: 11px 14px; border: 1.5px solid var(--ap-border);
    border-radius: 10px; font-size: 14px; font-family: var(--ap-font);
    transition: 0.2s; background: #fff; color: var(--ap-text);
    box-sizing: border-box;
  }
  .ap-input:focus, .ap-textarea:focus, .ap-select:focus {
    outline: none; border-color: var(--ap-accent2);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
  }
  .ap-textarea { min-height: 110px; resize: vertical; }
  .ap-input-mono { font-family: monospace; background: #f8fafc; color: #475569; }
  .ap-helper { font-size: 12px; color: var(--ap-gray); margin: 6px 0 0; }

  /* ── RADIO GROUP ───────────────────────────────────────── */
  .ap-radio-group { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
  .ap-radio {
    display: flex; align-items: flex-start; gap: 12px; padding: 14px 16px;
    border: 1.5px solid var(--ap-border); border-radius: 12px; cursor: pointer;
    transition: all 0.2s; background: #fafafa;
  }
  .ap-radio:hover { border-color: #94a3b8; background: #f8fafc; }
  .ap-radio.selected { border-color: var(--ap-accent2); background: #eef2ff; }
  .ap-radio input[type="radio"] { margin-top: 3px; accent-color: var(--ap-accent2); }
  .ap-radio-title { display: block; font-weight: 700; font-size: 14px; margin-bottom: 2px; }
  .ap-radio-desc { display: block; font-size: 12px; color: var(--ap-gray); }

  /* ── DIVIDER ───────────────────────────────────────────── */
  .ap-divider { height: 1px; background: var(--ap-border); margin: 22px 0; }

  /* ── TABS ──────────────────────────────────────────────── */
  .ap-tabs { display: flex; gap: 6px; margin-bottom: 16px; }
  .ap-tab-btn {
    background: none; border: none; font-size: 13px; font-weight: 700;
    color: var(--ap-gray); cursor: pointer; padding: 6px 14px;
    border-radius: 8px; transition: 0.15s;
  }
  .ap-tab-btn.active { background: #e2e8f0; color: var(--ap-text); }

  /* ── PRODUCT ROWS ──────────────────────────────────────────── */
  .ap-product-list { display: flex; flex-direction: column; gap: 10px; }
  .ap-product-row {
    display: flex; align-items: center; justify-content: space-between;
    gap: 12px; padding: 14px 18px;
    background: var(--ap-card); border: 1px solid var(--ap-border);
    border-radius: 12px; box-shadow: var(--ap-shadow-sm); transition: box-shadow 0.2s;
  }
  .ap-product-row:hover { box-shadow: var(--ap-shadow); }
  .ap-product-title {
    font-size: 14px; font-weight: 700; color: var(--ap-text);
    flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
  }
  .ap-product-actions { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  .ap-badge {
    display: inline-flex; align-items: center; font-size: 11px; font-weight: 800;
    letter-spacing: 0.06em; text-transform: uppercase; padding: 3px 10px; border-radius: 99px;
  }
  .ap-badge--visible { background: #ecfdf5; color: #065f46; }
  .ap-badge--hidden { background: #f1f5f9; color: #64748b; }
  .ap-btn--icon {
    padding: 7px 10px; min-width: unset; font-size: 14px;
    background: #f8fafc; border: 1px solid var(--ap-border); color: var(--ap-text);
    border-radius: 8px; cursor: pointer; transition: background 0.15s;
  }
  .ap-btn--icon:hover { background: #e2e8f0; }
  .ap-products-spinner { text-align: center; padding: 32px; color: var(--ap-gray); font-size: 14px; }
  .ap-products-empty { text-align: center; padding: 48px 20px; color: var(--ap-gray); font-size: 15px; }
  @media (max-width: 600px) {
    /* Bigger product thumbnails */
    .ap-product-thumb,
    .ap-product-thumb-empty {
      width: 72px;
      height: 72px;
      border-radius: 10px;
    }

    /* Stack product rows as cards */
    .ap-product-row {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
      gap: 12px;
      padding: 12px 14px;
      background: var(--ap-card);
      border: 1px solid var(--ap-border);
      border-radius: 14px;
      box-shadow: var(--ap-shadow-sm);
    }

    /* Title takes remaining width on top row next to thumbnail */
    .ap-product-title {
      flex: 1 1 auto;
      min-width: 0;
      font-size: 15px;
      white-space: normal;
      -webkit-line-clamp: 2;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    /* Action bar below thumbnail+title */
    .ap-product-row__actions,
    .ap-product-actions {
      width: 100%;
      display: flex;
      gap: 8px;
      justify-content: flex-start;
      align-items: stretch;
      margin-top: 4px;
      flex-wrap: nowrap;
    }

    /* Larger touch targets */
    .ap-btn--outline-sm,
    .ap-btn--danger-sm {
      flex: 1 1 0;
      min-height: 40px;
      font-size: 13px;
      padding: 10px 12px;
    }

    /* Edit Placement is the primary action — make it prominent */
    .ap-edit-placement-btn,
    .ap-edit-placement-btn--disabled {
      flex: 2 1 0;
      min-height: 40px;
      font-size: 13px;
      padding: 10px 14px;
      justify-content: center;
    }
  }

  /* ── COPY ROW ──────────────────────────────────────────── */
  .ap-copy-row { display: flex; gap: 10px; }
  .ap-copy-row .ap-input { flex: 1; }

  /* ── QR ────────────────────────────────────────────────── */
  .ap-qr-box {
    display: flex; flex-direction: column; align-items: center;
    padding: 20px; background: #fff; border-radius: 14px;
    border: 1px solid var(--ap-border); text-align: center;
  }
  #ap-qrcode { margin: 0 auto 12px; }
  #ap-qrcode img, #ap-qrcode canvas { display: block; margin: 0 auto; }

  /* ── BTN ROW ───────────────────────────────────────────── */
  .ap-btn-row { display: flex; gap: 10px; margin-top: 4px; flex-wrap: wrap; }
  .ap-btn-row .ap-btn { flex: 1; min-width: 100px; }

  /* ── STATUS ────────────────────────────────────────────── */
  .ap-status {
    margin-top: 14px; font-size: 13px; font-weight: 600;
    min-height: 20px; border-radius: 8px; padding: 0;
    transition: all 0.2s;
  }
  .ap-status:not(:empty) { padding: 10px 14px; }
  .ap-status.ok { background: #ecfdf5; color: #065f46; }
  .ap-status.err { background: #fef2f2; color: #991b1b; }

  /* ── PUBLIC BLOCK ──────────────────────────────────────── */
  .ap-public-block { animation: ap-fadeIn 0.2s ease-out; }
  @keyframes ap-fadeIn { from { opacity: 0; transform: translateY(-4px); } to { opacity: 1; transform: translateY(0); } }

  /* ── DANGER ZONE CARD ──────────────────────────────────── */
  .ap-danger-card {
    background: #fff5f5;
    border: 1.5px solid rgba(239,68,68,0.3);
    border-radius: var(--ap-radius); padding: 28px;
    box-shadow: var(--ap-shadow);
  }
  .ap-danger-card:hover { box-shadow: 0 8px 24px rgba(239,68,68,0.12); }
  .ap-card-icon--red { background: #fee2e2; }
  .ap-btn--nuke {
    background: #ef4444; color: #fff; width: 100%;
    margin-top: 4px;
  }
  .ap-btn--nuke:hover { background: #dc2626; transform: translateY(-1px); box-shadow: 0 4px 12px rgba(239,68,68,0.4); }

  /* ── NUKE MODAL ────────────────────────────────────────── */
  .ap-nuke-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(0,0,0,0.55); z-index: 9999;
    align-items: center; justify-content: center; padding: 20px;
    backdrop-filter: blur(4px);
  }
  .ap-nuke-overlay.open { display: flex; }
  .ap-nuke-dialog {
    width: min(520px, 100%); background: #fff;
    border-radius: var(--ap-radius); border: 1px solid rgba(0,0,0,0.1);
    box-shadow: 0 32px 80px rgba(0,0,0,0.28); padding: 32px;
    animation: ap-fadeIn 0.2s ease-out;
  }
  .ap-nuke-dialog__icon { font-size: 36px; margin-bottom: 10px; }
  .ap-nuke-dialog__title {
    font-weight: 900; font-size: 20px; color: #dc2626;
    margin: 0 0 8px; letter-spacing: -0.02em;
  }
  .ap-nuke-dialog__warning {
    font-size: 14px; line-height: 1.55; color: #374151; margin: 0 0 16px;
  }
  .ap-nuke-confirm-input {
    width: 100%; padding: 11px 14px; margin-bottom: 16px;
    border: 1.5px solid rgba(239,68,68,0.4); border-radius: 10px;
    font-size: 14px; font-family: var(--ap-font); color: #0f172a;
    background: #fff; box-sizing: border-box;
  }
  .ap-nuke-confirm-input:focus { outline: none; border-color: #ef4444; box-shadow: 0 0 0 3px rgba(239,68,68,0.15); }
  .ap-nuke-actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .ap-nuke-actions .ap-btn { flex: 1; min-width: 120px; }
  .ap-nuke-log {
    margin-top: 16px; padding: 14px;
    background: #0f172a; color: #94a3b8;
    border-radius: 10px; font-size: 11px;
    font-family: monospace; white-space: pre-wrap;
    max-height: 180px; overflow-y: auto; display: none;
    line-height: 1.6;
  }

  /* ── REBUILD MODAL ─────────────────────────────────────── */
  .ap-rebuild-overlay {
    display: none; position: fixed; inset: 0;
    background: rgba(15,23,42,0.75); z-index: 10000;
    align-items: center; justify-content: center; padding: 24px;
    backdrop-filter: blur(6px);
  }
  .ap-rebuild-overlay.open { display: flex; }
  .ap-rebuild-dialog {
    width: min(480px, 100%); background: #fff;
    border-radius: 20px; padding: 40px 36px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.32);
    text-align: center;
    animation: ap-fadeIn 0.3s ease-out;
  }
  .ap-rebuild-icon { font-size: 48px; margin-bottom: 16px; }
  .ap-rebuild-title {
    font-size: 22px; font-weight: 900; color: #0f172a;
    margin: 0 0 16px; letter-spacing: -0.02em;
  }
  .ap-rebuild-body {
    font-size: 15px; line-height: 1.6; color: #374151;
    margin: 0 0 20px;
  }
  .ap-rebuild-sub {
    font-size: 13px; color: #64748b; margin: 0 0 24px;
  }
  .ap-rebuild-bar {
    height: 6px; background: #e2e8f0; border-radius: 3px; overflow: hidden;
  }
  .ap-rebuild-bar-fill {
    height: 100%; width: 0%; background: linear-gradient(90deg, #6366f1, #10b981);
    border-radius: 3px;
    animation: ap-rebuild-drain 5s linear forwards;
  }
  @keyframes ap-rebuild-drain {
    from { width: 0%; }
    to   { width: 100%; }
  }
  @media(max-width:480px) {
    .ap-rebuild-dialog { padding: 28px 20px; }
    .ap-rebuild-title { font-size: 18px; }
  }

  /* ── MAIN TABS ─────────────────────────────────────────── */
  .ap-main-card {
    background: var(--ap-card); border: 1px solid var(--ap-border);
    border-radius: var(--ap-radius); box-shadow: var(--ap-shadow);
    overflow: hidden;
  }
  .ap-main-tabs {
    display: flex; gap: 0; border-bottom: 2px solid var(--ap-border);
    background: #f8fafc; overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .ap-main-tabs::-webkit-scrollbar { display: none; }
  .ap-main-tab-btn {
    flex: 1; min-width: 0; padding: 14px 10px;
    font-family: var(--ap-font); font-size: 13px; font-weight: 700;
    color: var(--ap-gray); background: none; border: none;
    border-bottom: 3px solid transparent; cursor: pointer;
    transition: all 0.15s; white-space: nowrap; text-align: center;
    margin-bottom: -2px; overflow: hidden; text-overflow: ellipsis;
  }
  .ap-main-tab-btn:hover { color: var(--ap-text); background: #f1f5f9; }
  .ap-main-tab-btn.active {
    color: #fff; background: var(--ap-accent);
    border-bottom-color: var(--ap-accent2);
  }
  .ap-main-panel { display: none; padding: 28px; }
  .ap-main-panel.active { display: block; }
  .ap-main-tabs-wrap { position: relative; }
  .ap-tab-icon { display: block; font-size: 16px; line-height: 1; }
  .ap-tab-label { display: block; font-size: 10px; font-weight: 700; margin-top: 2px; }
  @media(max-width:600px) {
    /* Outer wrap */
    .ap-wrap { padding: 16px 14px 60px; }
    /* Hero */
    .ap-hero { padding: 22px 18px; margin-bottom: 18px; }
    .ap-hero h1 { font-size: 22px; }
    .ap-hero-sub { font-size: 12px; }
    .ap-hero-actions { width: 100%; flex-direction: column; }
    .ap-hero-actions .ap-btn { width: 100%; justify-content: center; }
    /* Tabs — all 5 fit on screen, no scroll */
    .ap-main-tabs { overflow-x: hidden; -webkit-overflow-scrolling: auto; }
    .ap-main-tab-btn { flex: 1 1 0; min-width: 0; padding: 10px 4px; font-size: 11px; white-space: normal; line-height: 1.2; overflow: visible; text-overflow: clip; }
    /* Remove the scroll-hint fade gradient */
    .ap-main-tabs-wrap::after { display: none; }
    .ap-tab-icon { font-size: 18px; }
    .ap-tab-label { font-size: 9px; }
    /* Panel content */
    .ap-main-panel { padding: 16px; }
    .ap-danger-zone-body { padding: 4px 0 0; }
    /* Danger rows — stack vertically */
    .ap-danger-row { flex-direction: column; gap: 10px; }
    .ap-danger-row .ap-btn { width: 100%; justify-content: center; }
    /* Forms */
    .ap-radio { padding: 12px; }
    .ap-form-group { margin-bottom: 14px; }
    .ap-input, .ap-textarea, .ap-select { font-size: 16px; }
    /* Member rows */
    .ap-member-row { flex-wrap: wrap; gap: 8px; }
    .ap-member-row .ap-btn { font-size: 12px; padding: 7px 12px; }
    /* Product row action buttons */
    .ap-product-row__actions { flex-wrap: wrap; gap: 6px; }
  }
  @media(max-width:480px) {
    /* Auth card on tiny phones */
    .ap-auth-card { padding: 28px 18px; }
    .ap-auth-wrap { margin: 32px auto; }
  }

  /* ── DANGER ROW ──────────────────────────────────────────── */
  .ap-danger-zone-body { padding: 4px 28px 24px; }
  .ap-danger-row {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 20px; padding: 18px 0;
  }
  .ap-danger-row + .ap-danger-row { border-top: 1px solid rgba(239,68,68,0.2); }
  .ap-danger-row-left { display: flex; align-items: flex-start; gap: 14px; flex: 1; min-width: 0; }
  .ap-danger-row-icon { font-size: 22px; flex-shrink: 0; line-height: 1.2; }
  .ap-danger-row-title { font-size: 14px; font-weight: 800; color: var(--ap-text); margin-bottom: 4px; }
  .ap-danger-row-desc { font-size: 12px; color: var(--ap-gray); line-height: 1.5; }
  .ap-btn--sm {
    padding: 8px 16px; font-size: 13px; flex-shrink: 0;
    align-self: center; white-space: nowrap;
  }

  /* ── PRODUCT THUMB ───────────────────────────────────────── */
  .ap-product-thumb {
    width: 52px; height: 52px; border-radius: 8px; object-fit: cover;
    background: #f1f5f9; flex-shrink: 0; display: block;
  }
  .ap-product-thumb-empty {
    width: 52px; height: 52px; border-radius: 8px;
    background: #f1f5f9; flex-shrink: 0;
  }
  .ap-btn--outline-sm {
    background: transparent; border: 1px solid var(--ap-border); color: var(--ap-text);
    padding: 6px 12px; font-size: 12px; font-weight: 700; border-radius: 8px;
    cursor: pointer; transition: all 0.15s; font-family: var(--ap-font);
  }
  .ap-btn--outline-sm:hover { background: #f8fafc; border-color: #94a3b8; }
  .ap-btn--danger-sm {
    background: #fee2e2; color: #991b1b;
    padding: 6px 12px; font-size: 12px; font-weight: 700; border-radius: 8px;
    cursor: pointer; transition: all 0.15s; border: none; font-family: var(--ap-font);
  }
  .ap-btn--danger-sm:hover { background: #fecaca; }
  .ap-edit-placement-btn {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 6px 12px; background: #3b82f6; color: #ffffff;
    border-radius: 8px; font-size: 12px; font-weight: 700;
    text-decoration: none; border: none; cursor: pointer;
    transition: background 0.15s ease; font-family: var(--ap-font);
    white-space: nowrap; flex-shrink: 0;
  }
  .ap-edit-placement-btn:hover { background: #2563eb; color: #ffffff; text-decoration: none; }
  .ap-edit-placement-btn--disabled {
    background: #94a3b8; cursor: not-allowed; pointer-events: auto;
  }
  .ap-edit-placement-btn--disabled:hover { background: #94a3b8; }
  .ap-product-row__actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    justify-content: flex-start;
    flex-shrink: 0;
  }
  .ap-rebuilding-inline {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 200px;
    flex: 1;
    max-width: 320px;
  }
  .ap-rebuilding-inline__bar {
    height: 6px;
    background: #dbeafe;
    border-radius: 3px;
    overflow: hidden;
    position: relative;
  }
  .ap-rebuilding-inline__bar-fill {
    position: absolute;
    top: 0; left: -30%;
    width: 30%; height: 100%;
    background: linear-gradient(90deg, transparent, #3b82f6, transparent);
    animation: ap-rebuilding-inline-sweep 1.4s ease-in-out infinite;
  }
  @keyframes ap-rebuilding-inline-sweep {
    0%   { left: -30%; }
    100% { left: 100%; }
  }
  .ap-rebuilding-inline__label {
    font-size: 12px;
    color: #1e40af;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .ap-rebuilding-inline__step { color: #64748b; font-weight: 500; }
  .ap-rebuilding-inline.ap-rebuilding-inline--success .ap-rebuilding-inline__bar-fill {
    left: 0; width: 100%; animation: none; background: #10b981;
  }
  .ap-rebuilding-inline.ap-rebuilding-inline--success .ap-rebuilding-inline__label {
    color: #065f46;
  }
  .ap-rebuilding-inline.ap-rebuilding-inline--error .ap-rebuilding-inline__bar-fill {
    left: 0; width: 100%; animation: none; background: #ef4444;
  }
  .ap-rebuilding-inline.ap-rebuilding-inline--error .ap-rebuilding-inline__label {
    color: #991b1b;
  }
  @media (max-width: 600px) {
    .ap-rebuilding-inline { min-width: 100%; max-width: 100%; }
  }
  .ap-rebuilding-toast {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    max-width: min(540px, calc(100vw - 32px));
    padding: 16px 44px 16px 20px;
    background: #0f172a;
    color: #ffffff;
    border-radius: 12px;
    box-shadow: 0 12px 32px rgba(0,0,0,0.35);
    font-family: var(--ap-font);
    font-size: 14px;
    line-height: 1.45;
    z-index: 9999;
    animation: ap-rebuilding-toast-in 0.25s ease-out;
  }
  .ap-rebuilding-toast strong { color: #86efac; font-weight: 700; }
  .ap-rebuilding-toast__close {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 28px;
    height: 28px;
    border: none;
    background: transparent;
    color: #cbd5e1;
    font-size: 16px;
    cursor: pointer;
    border-radius: 6px;
  }
  .ap-rebuilding-toast__close:hover { background: rgba(255,255,255,0.08); color: #ffffff; }
  @keyframes ap-rebuilding-toast-in {
    from { opacity: 0; transform: translate(-50%, 12px); }
    to   { opacity: 1; transform: translate(-50%, 0); }
  }
  .ap-editor-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.65);
    z-index: 9998;
    align-items: stretch;
    justify-content: center;
    padding: 24px;
    backdrop-filter: blur(4px);
  }
  .ap-editor-overlay.open { display: flex; }
  .ap-editor-dialog {
    width: min(1080px, 100%);
    max-height: calc(100vh - 48px);
    background: #1a1a1a;
    border-radius: 16px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.55);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    animation: ap-editor-fadein 0.2s ease-out;
  }
  @keyframes ap-editor-fadein {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .ap-editor-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    background: #0f172a;
    color: #fff;
    font-family: var(--ap-font);
    font-weight: 700;
    font-size: 14px;
    border-bottom: 1px solid #2a2a2a;
    flex-shrink: 0;
  }
  .ap-editor-close {
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.15);
    color: #fff;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    font-size: 14px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .ap-editor-close:hover { background: rgba(255,255,255,0.18); }
  .ap-editor-iframe {
    flex: 1;
    width: 100%;
    border: 0;
    display: block;
    background: #1a1a1a;
    min-height: 640px;
  }
  @media (max-width: 900px) {
    .ap-editor-overlay { padding: 0; }
    .ap-editor-dialog {
      width: 100%;
      max-height: 100vh;
      border-radius: 0;
    }
  }
  body.ap-editor-open { overflow: hidden; }

  /* ── SETTINGS LOGO PREVIEW ─────────────────────────────── */
  .ap-settings-logo-new {
    max-width: 120px; max-height: 80px; border-radius: 8px;
    border: 2px solid var(--ap-success); padding: 4px; background: #fff;
    display: block; object-fit: contain; margin-bottom: 8px;
  }

{%- endstyle -%}

{%- if customer == nil -%}

<div class="ap-auth-wrap">
  <div class="ap-auth-card">
    <span class="ap-auth-icon">🔒</span>
    <h2>Please Sign In</h2>
    <p>You must be signed in to access Admin Powers.</p>
    <a href="{{ routes.account_login_url }}?return_url={{ request.path | append: '?shop=' | append: shop_handle | url_encode }}" class="ap-btn ap-btn--primary">Sign In →</a>
  </div>
</div>

{%- elsif is_admin_for_shop == false -%}

<div class="ap-auth-wrap">
  <div class="ap-auth-card">
    <span class="ap-auth-icon">🚫</span>
    <h2>Access Denied</h2>
    <p>You don't have permission to manage <strong>{{ shop_handle }}</strong>.</p>
    <a href="{{ dashboard_url }}" class="ap-btn ap-btn--outline">← Back to Dashboard</a>
  </div>
</div>

{%- else -%}

{%- assign shop_meta = shop.metaobjects.custom_shop[shop_handle] -%}
{%- assign join_mode = 'secure' -%}
{%- assign collection_handle = shop_handle -%}
{%- assign store_name = shop_handle -%}
{%- assign ap_store_status = 'active' -%}

{%- if shop_meta -%}
  {%- assign raw_jm = shop_meta.join_mode.value | default: shop_meta.join_mode -%}
  {%- assign jm = raw_jm | strip | downcase -%}
  {%- if jm == 'public' -%}{%- assign join_mode = 'public' -%}{%- endif -%}
  {%- assign join_code = shop_meta.join_code.value | default: shop_meta.join_code | default: '' | strip -%}
  {%- assign ch = shop_meta.collection_handle.value | default: shop_meta.collection_handle | default: '' | strip -%}
  {%- if ch != blank -%}{%- assign collection_handle = ch -%}{%- endif -%}
  {%- assign sn = shop_meta.name.value | default: shop_meta.name -%}
  {%- if sn != blank -%}{%- assign store_name = sn -%}{%- endif -%}
  {%- assign _raw_status = shop_meta.status.value | default: shop_meta.status | default: '' | strip | downcase -%}
  {%- if _raw_status == 'sleeping' or _raw_status == 'waking' or _raw_status == 'active' -%}
    {%- assign ap_store_status = _raw_status -%}
  {%- endif -%}
{%- endif -%}

{%- comment %} BC3413 placement editor — hardcoded config (no schema settings — see PR #59 RCA) {% endcomment -%}
{%- assign editor_base_url = 'https://printfulautomation-production.up.railway.app/editor/bc3413' -%}
{%- assign editor_bc3001y_base_url = 'https://printfulautomation-production.up.railway.app/editor/bc3001y' -%}
{%- assign editor_nl6733_base_url = 'https://printfulautomation-production.up.railway.app/editor/nl6733' -%}
{%- assign editor_mc1790_base_url = 'https://printfulautomation-production.up.railway.app/editor/mc1790' -%}
{%- assign editor_m2580_base_url = 'https://printfulautomation-production.up.railway.app/editor/m2580' -%}
{%- assign editor_cc1467y_base_url = 'https://printfulautomation-production.up.railway.app/editor/cc1467y' -%}
{%- comment %} Hardcoded to match EDITOR_SECRET fallback in Printful_Automation app.py.
   Not actually secret — it's already in the public repo, only gates the editor page,
   and is visible in rendered HTML whenever the button is clicked. {% endcomment -%}
{%- assign editor_secret = 'stellasage-god-mode-2026-xK9mP' -%}

{%- assign ap_shop_logo_src = '' -%}
{%- if shop_meta -%}
  {%- assign _logo_field = shop_meta.logo -%}
  {%- if _logo_field != blank -%}
    {%- assign _logo_obj = _logo_field.value | default: _logo_field -%}
    {%- comment %} Only call image_url if it looks like a real image object (has src or is a media object) {% endcomment -%}
    {%- if _logo_obj.src or _logo_obj.preview_image -%}
      {%- assign ap_shop_logo_src = _logo_obj | image_url: width: 3000 -%}
    {%- elsif _logo_obj != blank and _logo_obj.url -%}
      {%- assign ap_shop_logo_src = _logo_obj.url -%}
    {%- endif -%}
  {%- endif -%}
{%- endif -%}

{%- assign join_link = shop.url | append: join_path | append: '?shop=' | append: collection_handle -%}
{%- if join_code != blank -%}
  {%- assign join_link = join_link | append: '&code=' | append: join_code -%}
{%- endif -%}

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

<div class="ap-wrap">

  <script>
    window.SSAP = window.SSAP || {};
    SSAP.collectionHandle = {{ collection_handle | json }};
    SSAP.shopHandle = {{ shop_handle | json }};
    SSAP.railwayUrl = "https://studio-uploader-production.up.railway.app";
    SSAP.editorBaseUrl = {{ editor_base_url | json }};
    SSAP.editorBc3001yBaseUrl = {{ editor_bc3001y_base_url | json }};
    SSAP.editorNl6733BaseUrl = {{ editor_nl6733_base_url | json }};
    SSAP.editorMc1790BaseUrl = {{ editor_mc1790_base_url | json }};
    SSAP.editorM2580BaseUrl = {{ editor_m2580_base_url | json }};
    SSAP.editorCc1467yBaseUrl = {{ editor_cc1467y_base_url | json }};
    SSAP.editorSecret = {{ editor_secret | json }};
    SSAP.shopLogoSrc = {{ ap_shop_logo_src | json }};
  </script>

  <!-- HERO HEADER -->
  <div class="ap-hero">
    <div class="ap-hero-left">
      <div class="ap-hero-badge">
        <span class="dot"></span>
        {% if is_super_admin %}God Mode Active{% else %}Admin Access{% endif %}
      </div>
      <h1>{{ store_name | capitalize }}</h1>
      <p class="ap-hero-sub">Storefront Management Console · {{ shop_handle }}</p>
    </div>
    <div class="ap-hero-actions">
      <a href="/collections/{{ collection_handle }}" class="ap-btn ap-btn--glass">View Store ↗</a>
      <a href="{{ dashboard_url }}" class="ap-btn ap-btn--glass">← Dashboard</a>
    </div>
  </div>

  <!-- MAIN DASHBOARD CARD WITH TABS -->
  <div class="ap-main-card">

    <!-- MAIN PANEL TABS -->
    <div class="ap-main-tabs-wrap">
    <div class="ap-main-tabs" role="tablist">
      <button class="ap-main-tab-btn active" id="apTabBtnOverview" data-main-tab="apPanelOverview" role="tab" aria-selected="true" aria-controls="apPanelOverview"><span class="ap-tab-icon">🏠</span><span class="ap-tab-label">Overview</span></button>
      <button class="ap-main-tab-btn" id="apTabBtnMembers" data-main-tab="apPanelMembers" role="tab" aria-selected="false" aria-controls="apPanelMembers"><span class="ap-tab-icon">👥</span><span class="ap-tab-label">Members</span></button>
      <button class="ap-main-tab-btn" id="apTabBtnProducts" data-main-tab="apPanelProducts" role="tab" aria-selected="false" aria-controls="apPanelProducts"><span class="ap-tab-icon">📦</span><span class="ap-tab-label">Products</span></button>
      <button class="ap-main-tab-btn" id="apTabBtnSettings" data-main-tab="apPanelSettings" role="tab" aria-selected="false" aria-controls="apPanelSettings"><span class="ap-tab-icon">⚙️</span><span class="ap-tab-label">Settings</span></button>
      <button class="ap-main-tab-btn" id="apTabBtnDanger" data-main-tab="apPanelDanger" role="tab" aria-selected="false" aria-controls="apPanelDanger"><span class="ap-tab-icon">☠️</span><span class="ap-tab-label">Danger</span></button>
    </div>
    </div>

    <!-- OVERVIEW PANEL -->
    <div id="apPanelOverview" class="ap-main-panel active" role="tabpanel" aria-labelledby="apTabBtnOverview">

      <div class="ap-radio-group">
        <label class="ap-radio {% if join_mode == 'secure' %}selected{% endif %}">
          <input type="radio" name="ap-joinmode" value="secure" {% if join_mode == 'secure' %}checked{% endif %}>
          <div>
            <span class="ap-radio-title">🔒 Secure (Invite Only)</span>
            <span class="ap-radio-desc">Only people you add can access.</span>
          </div>
        </label>
        <label class="ap-radio {% if join_mode == 'public' %}selected{% endif %}">
          <input type="radio" name="ap-joinmode" value="public" {% if join_mode == 'public' %}checked{% endif %}>
          <div>
            <span class="ap-radio-title">🌐 Public (Shareable Link)</span>
            <span class="ap-radio-desc">Anyone with the link or QR code can join.</span>
          </div>
        </label>
      </div>

      <button id="apBtnSaveMode" class="ap-btn ap-btn--primary ap-btn-full">Save Settings</button>
      <div id="apStatusMode" class="ap-status"></div>

      <div id="apBlockPublic" class="ap-public-block" {% if join_mode != 'public' %}style="display:none"{% endif %}>
        <div class="ap-divider"></div>
        <div class="ap-tabs">
          <button class="ap-tab-btn active" data-tab="apTabLink">🔗 Copy Link</button>
          <button class="ap-tab-btn" data-tab="apTabQR">📱 QR Code</button>
        </div>
        <div id="apTabLink" class="ap-tab-content">
          <div class="ap-copy-row">
            <input id="apInputJoinLink" class="ap-input ap-input-mono" value="{{ join_link | escape }}" readonly>
            <button id="apBtnCopy" class="ap-btn ap-btn--outline">Copy</button>
          </div>
          <p class="ap-helper">Share this link with your team via chat or email.</p>
        </div>
        <div id="apTabQR" class="ap-tab-content" style="display:none;">
          <div class="ap-qr-box">
            <div id="ap-qrcode"></div>
            <p class="ap-helper">Print for flyers or let people scan in person.</p>
          </div>
        </div>
      </div>

    </div><!-- /apPanelOverview -->

    <!-- MEMBERS PANEL -->
    <div id="apPanelMembers" class="ap-main-panel" role="tabpanel" aria-labelledby="apTabBtnMembers">
      <p style="margin:0 0 16px;font-size:13px;color:var(--ap-gray);">Add or remove people from this storefront.</p>

      <div class="ap-form-group">
        <label class="ap-label">Member Emails</label>
        <textarea id="apInputEmails" class="ap-textarea" placeholder="alice@example.com, bob@example.com..."></textarea>
        <p class="ap-helper">Separate multiple emails with commas.</p>
      </div>

      <div class="ap-form-group">
        <label class="ap-label">Access Level</label>
        <select id="apInputRole" class="ap-select">
          <option value="member" selected>Member (Can Shop)</option>
          <option value="admin">Admin (Can Edit Settings)</option>
        </select>
      </div>

      <div class="ap-btn-row">
        <button id="apBtnAdd" class="ap-btn ap-btn--primary">+ Add Members</button>
        <button id="apBtnRemove" class="ap-btn ap-btn--danger">Remove</button>
      </div>
      <div id="apStatusMembers" class="ap-status"></div>
    </div><!-- /apPanelMembers -->

    <!-- PRODUCTS PANEL -->
    <div id="apPanelProducts" class="ap-main-panel" role="tabpanel" aria-labelledby="apTabBtnProducts">

      <div id="apProductsSpinner" class="ap-products-spinner" style="display:none;">⏳ Loading products…</div>
      <div id="apProductsEmpty" class="ap-products-empty" style="display:none;">No products found for this store.</div>
      <div id="apProductsContainer" class="ap-product-list"></div>
      <div id="apStatusProducts" class="ap-status"></div>
    </div><!-- /apPanelProducts -->

    <!-- SETTINGS PANEL -->
    <div id="apPanelSettings" class="ap-main-panel" role="tabpanel" aria-labelledby="apTabBtnSettings">

      <!-- Store display name -->
      <div class="ap-form-group">
        <label class="ap-label" for="apSettingsName">Store Display Name</label>
        <input id="apSettingsName" class="ap-input" type="text" value="{{ store_name | escape }}" placeholder="Store name" />
        <p class="ap-helper">Only changes the display name — no rebuild needed.</p>
      </div>

      <!-- Primary color -->
      <div class="ap-form-group">
        <label class="ap-label" for="apSettingsColor">Primary Color</label>
        <select id="apSettingsColor" class="ap-select">
          {%- assign _ap_color = shop_meta.primary_color.value | default: shop_meta.primary_color | default: 'No preference' -%}
          {%- assign _ap_colors = 'No preference,Black,White,Navy,Red,Royal Blue,Forest Green,Maroon,Purple,Orange,Grey,Vegas Gold,Pink,Light Blue,Brown,Tan' | split: ',' -%}
          {%- for _c in _ap_colors -%}
            <option value="{{ _c }}"{% if _c == _ap_color %} selected{% endif %}>{{ _c }}</option>
          {%- endfor -%}
        </select>
        <p class="ap-helper">Changing this will rebuild all products (~5–10 min).</p>
      </div>

      <!-- Logo section -->
      <div class="ap-form-group">
        <label class="ap-label">Main Logo / Primary Image</label>
        <div id="apSettingsLogoPreview" style="margin-bottom:12px;">
          {% if ap_shop_logo_src != '' %}
            <img src="{{ ap_shop_logo_src }}" alt="Current logo" style="max-width:120px;max-height:80px;border-radius:8px;border:1px solid var(--ap-border);padding:4px;background:#fff;display:block;object-fit:contain;" />
          {% else %}
            <div style="width:120px;height:80px;background:#f1f5f9;border-radius:8px;border:1px solid var(--ap-border);display:flex;align-items:center;justify-content:center;font-size:28px;">🖼️</div>
          {% endif %}
        </div>
        <div id="apSettingsLogoStatus" style="font-size:12px;color:var(--ap-gray);margin-bottom:8px;min-height:16px;"></div>
        <button id="apBtnChangeLogo" class="ap-btn ap-btn--outline ap-btn--sm" type="button">🖼️ Change Logo</button>
        <p class="ap-helper">Changing the logo will rebuild all products (~5–10 min).</p>
      </div>

      <!-- Rebuild warning -->
      <div id="apSettingsRebuildWarning" style="display:none;margin-bottom:16px;padding:12px 14px;background:#fef9c3;border:1px solid #fde047;border-radius:10px;font-size:13px;color:#713f12;font-weight:600;">
        ⚠️ You've changed the logo or color. Saving will delete all current products and rebuild them with the new settings. This takes 5–10 minutes.
      </div>

      <button id="apBtnSaveSettings" class="ap-btn ap-btn--primary ap-btn-full">Save Settings</button>
      <div id="apStatusSettings" class="ap-status"></div>

    </div><!-- /apPanelSettings -->

    <!-- DANGER PANEL -->
    <div id="apPanelDanger" class="ap-main-panel" role="tabpanel" aria-labelledby="apTabBtnDanger">

      <!-- Sleep Mode Card -->
      <div class="ap-card" style="margin-bottom:20px;border-color:rgba(239,68,68,0.2);background:#fff5f5;">
        <div class="ap-card-head">
          <div class="ap-card-icon ap-card-icon--red">💤</div>
          <h3>Sleep Mode</h3>
          <p>Deletes all products and sets the store to hibernation mode. The store can be re-woken at any time.</p>
        </div>
        {% if ap_store_status == 'sleeping' %}
          <button id="apBtnWakeStore" class="ap-btn ap-btn--primary ap-btn-full" style="background:#10b981;">☀️ Wake Up Store</button>
        {% elsif ap_store_status == 'waking' %}
          <button class="ap-btn ap-btn-full" disabled style="background:#6366f1;color:#fff;opacity:0.6;cursor:not-allowed;">⏳ Waking…</button>
        {% else %}
          <button id="apBtnSleepStore" class="ap-btn ap-btn--danger ap-btn-full">💤 Put Store to Sleep</button>
        {% endif %}
        <div id="apStatusSleep" class="ap-status"></div>
      </div>

      <!-- Danger Zone (Nuke) Card -->
      <div class="ap-danger-card">
        <div class="ap-card-head">
          <div class="ap-card-icon ap-card-icon--red">💣</div>
          <h3 style="color:#dc2626;">Danger Zone — Nuke Store</h3>
          <p>Permanently deletes the store, all products, the collection, all member tags, and the metaobject. <strong>This cannot be undone.</strong></p>
        </div>
        <button id="apNukeBtn" class="ap-btn ap-btn--nuke">💣 Nuke This Store</button>
      </div>

    </div><!-- /apPanelDanger -->

  </div><!-- /.ap-main-card -->

  <!-- NUKE CONFIRMATION MODAL (position: fixed — outside sections) -->
  <div class="ap-nuke-overlay" id="apNukeOverlay">
    <div class="ap-nuke-dialog" role="dialog" aria-modal="true" aria-labelledby="apNukeTitle">
      <div class="ap-nuke-dialog__icon">☢️</div>
      <p class="ap-nuke-dialog__title" id="apNukeTitle">Permanently Destroy This Store?</p>
      <p class="ap-nuke-dialog__warning">
        You are about to permanently delete <strong>{{ store_name }}</strong>.
        This store and everything in it — all products, members, photos, and settings — will be gone forever.
        <strong>This cannot be undone.</strong>
      </p>
      <input
        type="text"
        class="ap-nuke-confirm-input"
        id="apNukeInput"
        placeholder="Type &quot;gone&quot; to confirm"
        autocomplete="off">
      <div class="ap-nuke-actions">
        <button id="apNukeDestroy" class="ap-btn ap-btn--nuke" disabled>Destroy Store</button>
        <button id="apNukeCancel" class="ap-btn ap-btn--outline">Cancel</button>
      </div>
      <pre class="ap-nuke-log" id="apNukeLog"></pre>
    </div>
  </div>

  <!-- BC3413 EDITOR MODAL -->
  <div class="ap-editor-overlay" id="apEditorOverlay" aria-hidden="true">
    <div class="ap-editor-dialog" role="dialog" aria-modal="true" aria-labelledby="apEditorTitle">
      <div class="ap-editor-header">
        <span id="apEditorTitle">✏️ Edit Logo Placement</span>
        <button type="button" class="ap-editor-close" id="apEditorClose" aria-label="Close editor">✕</button>
      </div>
      <iframe id="apEditorIframe"
              class="ap-editor-iframe"
              title="BC3413 Placement Editor"
              allow="clipboard-write"></iframe>
    </div>
  </div>

  <!-- REBUILD IN PROGRESS MODAL -->
  <div class="ap-rebuild-overlay" id="apRebuildOverlay" aria-hidden="true">
    <div class="ap-rebuild-dialog" role="dialog" aria-modal="true" aria-labelledby="apRebuildTitle">
      <div class="ap-rebuild-icon">🔨</div>
      <h2 class="ap-rebuild-title" id="apRebuildTitle">Rebuilding Your Store</h2>
      <p class="ap-rebuild-body">
        We're applying your changes and rebuilding all of your store's products.
        This process takes about <strong>15–20 minutes</strong> to complete.
        When it's done, everything will be right back where you left it —
        all your products, members, and settings fully intact.
      </p>
      <p class="ap-rebuild-sub">Taking you back to your dashboard in a moment…</p>
      <div class="ap-rebuild-bar"><div class="ap-rebuild-bar-fill"></div></div>
    </div>
  </div>

</div><!-- /.ap-wrap -->

<script>
(function(){
  // ── REBUILDING TOAST ─────────────────────────────────────────
  function apShowRebuildingToast() {
    // If a toast is already on-screen, don't stack them
    if (document.querySelector('.ap-rebuilding-toast')) return;

    var toast = document.createElement('div');
    toast.className = 'ap-rebuilding-toast';
    toast.innerHTML =
      '<strong>✅ Placement saved — rebuilding product.</strong><br>' +
      'Allow 2–4 minutes, then refresh this page to see the updated mockups. ' +
      '<button type="button" class="ap-rebuilding-toast__close" aria-label="Dismiss">✕</button>';
    document.body.appendChild(toast);
    toast.querySelector('.ap-rebuilding-toast__close')
      .addEventListener('click', function(){ toast.remove(); });
  }

  (function apMaybeShowRebuildingToast(){
    try {
      var params = new URLSearchParams(window.location.search);
      if (params.get('rebuilding') !== '1') return;
      apShowRebuildingToast();
      // Clean ?rebuilding=1 from the URL so a page refresh doesn't re-show the toast
      if (window.history && window.history.replaceState) {
        var cleanParams = new URLSearchParams(window.location.search);
        cleanParams.delete('rebuilding');
        var qs = cleanParams.toString();
        var clean = window.location.origin + window.location.pathname + (qs ? '?' + qs : '') + window.location.hash;
        window.history.replaceState({}, document.title, clean);
      }
    } catch(_e){}
  })();

  // ── BC3413 EDITOR MODAL ─────────────────────────────────────
  var apEditorOverlay = document.getElementById('apEditorOverlay');
  var apEditorIframe  = document.getElementById('apEditorIframe');
  var apEditorClose   = document.getElementById('apEditorClose');
  var _apEditorKeydown = null;

  function apOpenEditorModal(url) {
    if (!apEditorOverlay || !apEditorIframe) {
      // Modal DOM missing — fall back to new tab so the user isn't stuck
      window.open(url, '_blank', 'noopener,noreferrer');
      return;
    }
    apEditorIframe.src = url;
    apEditorOverlay.classList.add('open');
    apEditorOverlay.setAttribute('aria-hidden', 'false');
    document.body.classList.add('ap-editor-open');
    _apEditorKeydown = function(e){ if (e.key === 'Escape') { e.preventDefault(); e.stopPropagation(); apCloseEditorModal(); } };
    document.addEventListener('keydown', _apEditorKeydown);
  }

  function apCloseEditorModal() {
    if (!apEditorOverlay || !apEditorIframe) return;
    apEditorOverlay.classList.remove('open');
    apEditorOverlay.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('ap-editor-open');
    // Clear iframe so the editor stops running (and next open starts fresh)
    apEditorIframe.src = 'about:blank';
    if (_apEditorKeydown) {
      document.removeEventListener('keydown', _apEditorKeydown);
      _apEditorKeydown = null;
    }
  }

  // Expose close + open for other scopes (render function attaches click handlers)
  window.apOpenEditorModal  = apOpenEditorModal;
  window.apCloseEditorModal = apCloseEditorModal;

  // Close button + backdrop click
  if (apEditorClose) {
    apEditorClose.addEventListener('click', apCloseEditorModal);
  }
  if (apEditorOverlay) {
    apEditorOverlay.addEventListener('click', function(e){
      // Only close on direct backdrop clicks, not on dialog content
      if (e.target === apEditorOverlay) apCloseEditorModal();
    });
  }

  // postMessage listener — editor signals save/close from inside the iframe
  window.addEventListener('message', function(e){
    var data = e && e.data;
    if (!data || typeof data !== 'object') return;
    // Validate origin against the known editor base URL to reject messages
    // from unrelated frames. Falls back to allowing the message if the base
    // URL is unavailable (shouldn't happen in practice).
    try {
      var _expectedOrigin = new URL(SSAP.editorBaseUrl || '').origin;
      var _railwayOrigin = new URL(SSAP.railwayUrl || '').origin;
      if (_expectedOrigin && e.origin !== _expectedOrigin && e.origin !== _railwayOrigin) return;
    } catch(_origErr){}
    if (data.type === 'bc3413_placement_saved') {
      apCloseEditorModal();
      var handle = data.product_handle;
      var jobId  = data.job_id;
      if (jobId && handle) {
        apStartInlineRebuilding(handle, jobId);
      } else {
        // Fallback: no job_id (old async flow or missing handle)
        apShowRebuildingToast();
      }
    } else if (data.type === 'bc3413_close') {
      apCloseEditorModal();
    } else if (data.type === 'bc3001y_placement_saved') {
      apCloseEditorModal();
      var bc3001yHandle = data.product_handle;
      var bc3001yJobId  = data.job_id;
      if (bc3001yJobId && bc3001yHandle) {
        apStartInlineRebuilding(bc3001yHandle, bc3001yJobId);
      } else {
        apShowRebuildingToast();
      }
    } else if (data.type === 'bc3001y_close') {
      apCloseEditorModal();
    } else if (data.type === 'nl6733_placement_saved') {
      apCloseEditorModal();
      var nl6733Handle = data.product_handle; var nl6733JobId = data.job_id;
      if (nl6733JobId && nl6733Handle) { apStartInlineRebuilding(nl6733Handle, nl6733JobId); } else { apShowRebuildingToast(); }
    } else if (data.type === 'nl6733_close') {
      apCloseEditorModal();
    } else if (data.type === 'mc1790_placement_saved') {
      apCloseEditorModal();
      var mc1790Handle = data.product_handle; var mc1790JobId = data.job_id;
      if (mc1790JobId && mc1790Handle) { apStartInlineRebuilding(mc1790Handle, mc1790JobId); } else { apShowRebuildingToast(); }
    } else if (data.type === 'mc1790_close') {
      apCloseEditorModal();
    } else if (data.type === 'm2580_placement_saved') {
      apCloseEditorModal();
      var m2580Handle = data.product_handle; var m2580JobId = data.job_id;
      if (m2580JobId && m2580Handle) { apStartInlineRebuilding(m2580Handle, m2580JobId); } else { apShowRebuildingToast(); }
    } else if (data.type === 'm2580_close') {
      apCloseEditorModal();
    } else if (data.type === 'cc1467y_placement_saved') {
      apCloseEditorModal();
      var cc1467yHandle = data.product_handle; var cc1467yJobId = data.job_id;
      if (cc1467yJobId && cc1467yHandle) { apStartInlineRebuilding(cc1467yHandle, cc1467yJobId); } else { apShowRebuildingToast(); }
    } else if (data.type === 'cc1467y_close') {
      apCloseEditorModal();
    } else if (data.type === 'studio-uploader:done' && data.slot === 'settings-logo' && data.session_id) {
      if (typeof window.apSettingsHandleLogoDone === 'function') {
        window.apSettingsHandleLogoDone(data);
      }
    }
  });

  // ── INLINE REBUILDING PROGRESS ───────────────────────────────
  function apCssEscape(s) {
    if (window.CSS && CSS.escape) return CSS.escape(s);
    return String(s).replace(/[^\w-]/g, function(c) { return '\\' + c; });
  }

  function apEscapeAttr(s) {
    return String(s).replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function apFindRowByEditButton(handle) {
    var btn = document.querySelector('.ap-edit-placement-btn[data-product-handle="' + apCssEscape(handle) + '"]');
    return btn ? btn.closest('.ap-product-row') : null;
  }

  function apStartInlineRebuilding(productHandle, jobId) {
    var row = document.querySelector('.ap-product-row[data-product-handle="' + apCssEscape(productHandle) + '"]')
           || apFindRowByEditButton(productHandle);
    if (!row) return;

    var actions = row.querySelector('.ap-product-row__actions');
    if (!actions) return;

    actions.dataset.apOriginalActions = actions.innerHTML;
    actions.innerHTML =
      '<div class="ap-rebuilding-inline" data-job-id="' + apEscapeAttr(jobId) + '" data-product-handle="' + apEscapeAttr(productHandle) + '">' +
        '<div class="ap-rebuilding-inline__bar"><div class="ap-rebuilding-inline__bar-fill"></div></div>' +
        '<div class="ap-rebuilding-inline__label">Rebuilding\u2026 <span class="ap-rebuilding-inline__step">starting</span></div>' +
      '</div>';

    apPollApplyStatus(productHandle, jobId, actions);
  }

  function apPollApplyStatus(handle, jobId, actionsEl) {
    var url = (SSAP.editorBaseUrl || '').replace(/\/editor\/bc3413\/?$/, '') +
              '/editor/bc3413/apply_status/' + encodeURIComponent(jobId) +
              '?secret=' + encodeURIComponent(SSAP.editorSecret || '');

    var tries = 0;
    var maxTries = 240;      // 240 × 3 s = 12 minute hard cap
    var intervalMs = 3000;   // poll every 3 s
    var consecutiveErrors = 0;

    function tick() {
      tries++;
      fetch(url).then(function(r){ return r.json(); }).then(function(j){
        consecutiveErrors = 0;
        var wrap = actionsEl.querySelector('.ap-rebuilding-inline');
        if (!wrap) return;
        var stepEl = wrap.querySelector('.ap-rebuilding-inline__step');

        if (j.status === 'succeeded') {
          wrap.classList.add('ap-rebuilding-inline--success');
          wrap.querySelector('.ap-rebuilding-inline__label').textContent = '✅ Rebuild complete — refreshing…';
          setTimeout(function(){ window.location.reload(); }, 1500);
          return;
        }
        if (j.status === 'failed') {
          wrap.classList.add('ap-rebuilding-inline--error');
          wrap.querySelector('.ap-rebuilding-inline__label').textContent =
            '❌ Rebuild failed: ' + (j.error || 'unknown error');
          setTimeout(function(){
            if (actionsEl.dataset.apOriginalActions) {
              actionsEl.innerHTML = actionsEl.dataset.apOriginalActions;
              delete actionsEl.dataset.apOriginalActions;
            }
          }, 6000);
          return;
        }
        if (stepEl) {
          stepEl.textContent = (j.progress || j.current_step || j.status || 'working') + '\u2026';
        }
        if (tries < maxTries) {
          setTimeout(tick, intervalMs);
        } else {
          if (stepEl) stepEl.textContent = 'taking longer than expected \u2014 check back soon';
        }
      }).catch(function(){
        consecutiveErrors++;
        var wrap = actionsEl.querySelector('.ap-rebuilding-inline');
        var stepEl = wrap && wrap.querySelector('.ap-rebuilding-inline__step');
        if (stepEl && consecutiveErrors >= 3) {
          stepEl.textContent = 'connection issues \u2014 retrying\u2026';
        }
        if (tries < maxTries) setTimeout(tick, intervalMs);
      });
    }

    tick();
  }

  // ── MAIN TAB SWITCHING ──────────────────────────────────────
  var apProductsLoaded = false;

  document.querySelectorAll('.ap-main-tab-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var targetId = btn.getAttribute('data-main-tab');
      // Deactivate all tabs and panels
      document.querySelectorAll('.ap-main-tab-btn').forEach(function(b){ b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
      document.querySelectorAll('.ap-main-panel').forEach(function(p){ p.classList.remove('active'); });
      // Activate clicked tab and its panel
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      var panel = document.getElementById(targetId);
      if(panel) panel.classList.add('active');
      // Lazy-load products when Products tab is first clicked
      if(targetId === 'apPanelProducts' && !apProductsLoaded){
        apProductsLoaded = true;
        apLoadProducts();
      }
    });
  });

  // TAB SWITCHING (inner tabs — Copy Link / QR Code)
  document.querySelectorAll('.ap-tab-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var targetId = btn.getAttribute('data-tab');
      var scope = btn.closest('.ap-main-panel') || btn.closest('.ap-card') || document;
      scope.querySelectorAll('.ap-tab-content').forEach(function(c){ c.style.display = 'none'; });
      scope.querySelectorAll('.ap-tab-btn').forEach(function(b){ b.classList.remove('active'); });
      document.getElementById(targetId).style.display = 'block';
      btn.classList.add('active');
    });
  });

  // RADIO SYNC
  document.addEventListener('change', function(e){
    if(e.target && e.target.name === 'ap-joinmode'){
      document.querySelectorAll('.ap-radio').forEach(function(r){ r.classList.remove('selected'); });
      e.target.closest('.ap-radio').classList.add('selected');
      document.getElementById('apBlockPublic').style.display = (e.target.value === 'public') ? 'block' : 'none';
    }
  });

  // QR CODE
  if(typeof QRCode !== 'undefined'){
    new QRCode(document.getElementById('ap-qrcode'), {
      text: {{ join_link | json }},
      width: 160, height: 160,
      colorDark: '#0f172a', colorLight: '#ffffff',
      correctLevel: QRCode.CorrectLevel.H
    });
  }

  async function apPost(action, payload){
    var body = Object.assign({
      action: action,
      shop_handle: String(SSAP.collectionHandle || ''),
      requested_by_customer_id: {{ customer.id | json }},
      requested_by_email: {{ customer.email | json }}
    }, payload || {});
    return fetch(SSAP.railwayUrl + '/api/admin-action', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body)
    });
  }

  function setStatus(el, msg, type){
    el.textContent = msg;
    el.className = 'ap-status ' + (type || '');
  }

  // SAVE MODE
  document.getElementById('apBtnSaveMode').addEventListener('click', async function(){
    var btn = this;
    var mode = document.querySelector('input[name="ap-joinmode"]:checked').value;
    btn.disabled = true; btn.textContent = 'Saving…';
    setStatus(document.getElementById('apStatusMode'), '', '');
    try {
      var res = await apPost('set_join_mode', { join_mode: mode });
      if(!res.ok) throw new Error();
      setStatus(document.getElementById('apStatusMode'), '✅ Settings saved!', 'ok');
    } catch(e) {
      setStatus(document.getElementById('apStatusMode'), '❌ Error saving settings.', 'err');
    } finally {
      btn.disabled = false; btn.textContent = 'Save Settings';
    }
  });

  // COPY LINK
  document.getElementById('apBtnCopy').addEventListener('click', function(){
    var btn = this;
    var link = document.getElementById('apInputJoinLink').value;
    if(navigator.clipboard && window.isSecureContext){
      navigator.clipboard.writeText(link).then(function(){
        btn.textContent = 'Copied!';
        setTimeout(function(){ btn.textContent = 'Copy'; }, 1600);
      }).catch(function(){
        btn.textContent = 'Copy manually';
        setTimeout(function(){ btn.textContent = 'Copy'; }, 2400);
      });
    } else {
      // Fallback for non-HTTPS or unsupported browsers
      document.getElementById('apInputJoinLink').select();
      btn.textContent = 'Select & copy';
      setTimeout(function(){ btn.textContent = 'Copy'; }, 2400);
    }
  });

  // ADD / REMOVE MEMBERS
  async function handleMemberAction(action){
    var rawText = document.getElementById('apInputEmails').value;
    var emails = rawText.split(/[\s,;]+/).map(function(e){ return e.trim().toLowerCase(); }).filter(function(e){ return e.length > 0; });
    var role = document.getElementById('apInputRole').value;
    var statusEl = document.getElementById('apStatusMembers');
    var btnAdd = document.getElementById('apBtnAdd');
    var btnRemove = document.getElementById('apBtnRemove');

    if(emails.length === 0){
      setStatus(statusEl, '⚠️ Please enter at least one email.', 'err');
      return;
    }
    if(action === 'remove' && !confirm('Remove ' + emails.length + ' member(s)?')) return;

    setStatus(statusEl, 'Processing…', '');
    btnAdd.disabled = true; btnRemove.disabled = true;

    try {
      var res = await apPost(action === 'add' ? 'add_members_bulk' : 'remove_members_bulk', { emails: emails, role: role });
      if(res.ok){
        setStatus(statusEl, '✅ Roster updated successfully!', 'ok');
        document.getElementById('apInputEmails').value = '';
      } else {
        throw new Error();
      }
    } catch(e) {
      setStatus(statusEl, '❌ Could not process request.', 'err');
    } finally {
      btnAdd.disabled = false; btnRemove.disabled = false;
    }
  }

  document.getElementById('apBtnAdd').addEventListener('click', function(){ handleMemberAction('add'); });
  document.getElementById('apBtnRemove').addEventListener('click', function(){ handleMemberAction('remove'); });

  // ── SLEEP / WAKE STORE ────────────────────────────────────
  var AP_RAILWAY_URL = SSAP.railwayUrl;
  var AP_ADMIN_SECRET = 'stellasage-god-mode-2026-xK9mP';
  var apStatusSleep = document.getElementById('apStatusSleep');

  function apSleepStatus(msg, type){
    if(!apStatusSleep) return;
    apStatusSleep.textContent = msg;
    apStatusSleep.className = 'ap-status ' + (type || '');
  }

  var apBtnSleepStore = document.getElementById('apBtnSleepStore');
  if(apBtnSleepStore){
    apBtnSleepStore.addEventListener('click', async function(){
      if(!confirm('Put "' + (SSAP.shopHandle || 'this store') + '" to sleep? All products will be deleted. Member tags are preserved.')) return;
      apBtnSleepStore.disabled = true;
      apBtnSleepStore.textContent = 'Putting to sleep\u2026';
      apSleepStatus('', '');
      try {
        var res = await fetch(AP_RAILWAY_URL + '/admin/store/' + encodeURIComponent(SSAP.shopHandle || '') + '/sleep', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Admin-Secret': AP_ADMIN_SECRET }
        });
        var data = await res.json();
        if(data.job_id || data.status === 'ok' || res.ok){
          apSleepStatus('\u2705 Store is going to sleep. Reloading\u2026', 'ok');
          setTimeout(function(){ window.location.reload(); }, 2000);
        } else {
          apSleepStatus('\u274C ' + (data.error || 'Failed'), 'err');
          apBtnSleepStore.disabled = false;
          apBtnSleepStore.textContent = '\ud83d\udca4 Put Store to Sleep';
        }
      } catch(e) {
        apSleepStatus('\u274C Network error: ' + (e.message || 'unknown'), 'err');
        apBtnSleepStore.disabled = false;
        apBtnSleepStore.textContent = '\ud83d\udca4 Put Store to Sleep';
      }
    });
  }

  var apBtnWakeStore = document.getElementById('apBtnWakeStore');
  if(apBtnWakeStore){
    apBtnWakeStore.addEventListener('click', async function(){
      if(!confirm('Wake up "' + (SSAP.shopHandle || 'this store') + '"? Printful will rebuild all products.')) return;
      apBtnWakeStore.disabled = true;
      apBtnWakeStore.textContent = 'Waking up\u2026';
      apSleepStatus('', '');
      try {
        var res = await fetch(AP_RAILWAY_URL + '/admin/store/' + encodeURIComponent(SSAP.shopHandle || '') + '/wakeup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'X-Admin-Secret': AP_ADMIN_SECRET }
        });
        var data = await res.json();
        if(data.job_id || data.status === 'ok' || res.ok){
          apSleepStatus('\u2705 Store is waking up! Products are being rebuilt. Reloading\u2026', 'ok');
          setTimeout(function(){ window.location.reload(); }, 2000);
        } else {
          apSleepStatus('\u274C ' + (data.error || 'Failed'), 'err');
          apBtnWakeStore.disabled = false;
          apBtnWakeStore.textContent = '\u2600\ufe0f Wake Up Store';
        }
      } catch(e) {
        apSleepStatus('\u274C Network error: ' + (e.message || 'unknown'), 'err');
        apBtnWakeStore.disabled = false;
        apBtnWakeStore.textContent = '\u2600\ufe0f Wake Up Store';
      }
    });
  }

  // ── NUKE STORE ────────────────────────────────────────────
  var NUKE_BACKEND_URL = SSAP.railwayUrl;
  var NUKE_HANDLE = String(SSAP.shopHandle || '');
  var apNukeBtn = document.getElementById('apNukeBtn');
  var apNukeOverlay = document.getElementById('apNukeOverlay');
  var apNukeInput = document.getElementById('apNukeInput');
  var apNukeDestroy = document.getElementById('apNukeDestroy');
  var apNukeCancel = document.getElementById('apNukeCancel');
  var apNukeLog = document.getElementById('apNukeLog');

  function appendNukeLog(msg){
    apNukeLog.style.display = 'block';
    apNukeLog.textContent += msg + '\n';
    apNukeLog.scrollTop = apNukeLog.scrollHeight;
  }

  apNukeBtn && apNukeBtn.addEventListener('click', function(){
    apNukeInput.value = '';
    apNukeDestroy.disabled = true;
    apNukeLog.textContent = '';
    apNukeLog.style.display = 'none';
    apNukeOverlay.classList.add('open');
  });

  apNukeCancel && apNukeCancel.addEventListener('click', function(){
    apNukeOverlay.classList.remove('open');
  });

  apNukeOverlay && apNukeOverlay.addEventListener('click', function(e){
    if(e.target === apNukeOverlay) apNukeOverlay.classList.remove('open');
  });

  apNukeInput && apNukeInput.addEventListener('input', function(){
    apNukeDestroy.disabled = (apNukeInput.value.trim() !== 'gone');
  });

  apNukeDestroy && apNukeDestroy.addEventListener('click', async function(){
    if(apNukeInput.value.trim() !== 'gone') return;
    if(!NUKE_BACKEND_URL){
      appendNukeLog('ERROR: No backend URL configured.');
      return;
    }
    apNukeDestroy.disabled = true;
    apNukeCancel.disabled = true;
    appendNukeLog('Starting nuke for "' + NUKE_HANDLE + '"…');

    try {
      var res = await fetch(NUKE_BACKEND_URL + '/api/storefront/' + encodeURIComponent(NUKE_HANDLE) + '/nuke', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      });

      if(!res.ok){
        appendNukeLog('ERROR: ' + res.status + ' ' + res.statusText);
        apNukeDestroy.disabled = false;
        apNukeCancel.disabled = false;
        return;
      }

      var data = await res.json();
      var jobId = data.job_id;
      if(!jobId){
        appendNukeLog('ERROR: No job_id in response.');
        apNukeDestroy.disabled = false;
        apNukeCancel.disabled = false;
        return;
      }
      appendNukeLog('Job started: ' + jobId);

      var lastLog = 0;
      var pollInterval = setInterval(async function(){
        try {
          var pollRes = await fetch(NUKE_BACKEND_URL + '/api/job/' + encodeURIComponent(jobId));
          if(!pollRes.ok){ appendNukeLog('Poll error: ' + pollRes.status); return; }
          var job = await pollRes.json();
          var lines = job.log || [];
          for(var i = lastLog; i < lines.length; i++){ appendNukeLog(lines[i]); }
          lastLog = lines.length;

          if(job.status === 'done'){
            clearInterval(pollInterval);
            appendNukeLog('✅ Store destroyed. Redirecting…');
            setTimeout(function(){ window.location.href = {{ dashboard_url | json }}; }, 2000);
          } else if(job.status === 'error'){
            clearInterval(pollInterval);
            appendNukeLog('❌ Error: ' + (job.error || 'Unknown error'));
            apNukeCancel.disabled = false;
          }
        } catch(pollErr){
          appendNukeLog('Poll network error: ' + (pollErr.message || 'unknown'));
        }
      }, 2000);

    } catch(err){
      appendNukeLog('Network error: ' + (err.message || 'unknown'));
      apNukeDestroy.disabled = false;
      apNukeCancel.disabled = false;
    }
  });

