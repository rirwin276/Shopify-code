{% comment %}
B2B Storefront Content
- Optional intro text
- Optional button to contact
- Optional featured collection grid (up to 6)
{% endcomment %}

<section style="max-width:1100px;margin:0 auto;padding:10px 16px 52px;">
  {% if section.settings.intro != blank %}
    <div style="max-width:820px;margin:0 auto 22px;text-align:center;color:rgba(0,0,0,.75);font-size:16px;line-height:1.55;">
      {{ section.settings.intro }}
    </div>
  {% endif %}

  {% if section.settings.cta_label != blank and section.settings.cta_link != blank %}
    <div style="text-align:center;margin:0 0 26px;">
      <a href="{{ section.settings.cta_link }}"
         style="display:inline-block;padding:12px 18px;border-radius:10px;background:#111;color:#fff;text-decoration:none;font-weight:800;">
        {{ section.settings.cta_label }}
      </a>
    </div>
  {% endif %}

  {% assign has_any = false %}
  {% if section.settings.collection_1 != blank %}{% assign has_any = true %}{% endif %}
  {% if section.settings.collection_2 != blank %}{% assign has_any = true %}{% endif %}
  {% if section.settings.collection_3 != blank %}{% assign has_any = true %}{% endif %}
  {% if section.settings.collection_4 != blank %}{% assign has_any = true %}{% endif %}
  {% if section.settings.collection_5 != blank %}{% assign has_any = true %}{% endif %}
  {% if section.settings.collection_6 != blank %}{% assign has_any = true %}{% endif %}

  {% if has_any %}
    <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px;">
      {% if section.settings.collection_1 != blank %}{% render 'b2b-collection-card', col: section.settings.collection_1 %}{% endif %}
      {% if section.settings.collection_2 != blank %}{% render 'b2b-collection-card', col: section.settings.collection_2 %}{% endif %}
      {% if section.settings.collection_3 != blank %}{% render 'b2b-collection-card', col: section.settings.collection_3 %}{% endif %}
      {% if section.settings.collection_4 != blank %}{% render 'b2b-collection-card', col: section.settings.collection_4 %}{% endif %}
      {% if section.settings.collection_5 != blank %}{% render 'b2b-collection-card', col: section.settings.collection_5 %}{% endif %}
      {% if section.settings.collection_6 != blank %}{% render 'b2b-collection-card', col: section.settings.collection_6 %}{% endif %}
    </div>

    <style>
      @media (max-width: 980px){
        section[style*="grid-template-columns:repeat(3"] div[style*="grid-template-columns:repeat(3"]{
          grid-template-columns:repeat(2,minmax(0,1fr)) !important;
        }
      }
      @media (max-width: 640px){
        section[style*="grid-template-columns:repeat(3"] div[style*="grid-template-columns:repeat(3"]{
          grid-template-columns:1fr !important;
        }
      }
    </style>
  {% endif %}
</section>

{% schema %}
{
  "name": "B2B Storefront Content",
  "settings": [
    {
      "type": "richtext",
      "id": "intro",
      "label": "Intro text",
      "default": "<p>Add a short welcome message for this customer storefront.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Request a custom quote"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Featured collection 1"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "Featured collection 2"
    },
    {
      "type": "collection",
      "id": "collection_3",
      "label": "Featured collection 3"
    },
    {
      "type": "collection",
      "id": "collection_4",
      "label": "Featured collection 4"
    },
    {
      "type": "collection",
      "id": "collection_5",
      "label": "Featured collection 5"
    },
    {
      "type": "collection",
      "id": "collection_6",
      "label": "Featured collection 6"
    }
  ],
  "presets": [
    { "name": "B2B Storefront Content" }
  ]
}
{% endschema %}
