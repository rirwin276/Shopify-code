      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<style>\n  /* --- 1. HIDE THE OLD FOOTER (The Sniper) --- */\n  /* This ensures your theme's default footer disappears so you don't have doubles */\n  .footer, #shopify-section-footer, .site-footer {\n    display: none !important;\n  }\n\n  /* --- 2. THE STUDIO FOOTER STYLES --- */\n  .ss-studio-footer {\n    width: 100%;\n    padding: 24px 40px;\n    background-color: #ffffff; /* Clean White */\n    border-top: 1px solid #e5e5e5; /* Subtle Divider */\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n    font-size: 12px;\n    color: #666;\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    flex-wrap: wrap;\n    gap: 20px;\n    margin-top: auto;\n  }\n\n  /* Left Side: Copyright & Badge */\n  .ss-footer-left {\n    display: flex;\n    align-items: center;\n    gap: 15px;\n  }\n\n  .ss-badge {\n    background: #f3f4f6;\n    color: #374151;\n    padding: 4px 8px;\n    border-radius: 6px;\n    font-weight: 600;\n    font-size: 10px;\n    letter-spacing: 0.5px;\n    text-transform: uppercase;\n    border: 1px solid #e5e7eb;\n  }\n\n  /* Center: System Status (The \"Tech\" Flex) */\n  .ss-footer-center {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  \n  .ss-status-dot {\n    width: 8px;\n    height: 8px;\n    background-color: #10b981; /* Emerald Green */\n    border-radius: 50%;\n    box-shadow: 0 0 0 2px rgba(16, 185, 129, 0.2);\n    animation: pulse 2s infinite;\n  }\n\n  /* Right Side: Links */\n  .ss-footer-right {\n    display: flex;\n    gap: 20px;\n  }\n\n  .ss-footer-link {\n    color: #666;\n    text-decoration: none;\n    transition: color 0.2s ease;\n  }\n\n  .ss-footer-link:hover {\n    color: #000;\n    text-decoration: underline;\n  }\n\n  /* Mobile Stack */\n  @media (max-width: 768px) {\n    .ss-studio-footer {\n      flex-direction: column;\n      text-align: center;\n      padding: 30px 20px;\n    }\n    .ss-footer-left, .ss-footer-right {\n      justify-content: center;\n      flex-wrap: wrap;\n    }\n  }\n\n  @keyframes pulse {\n    0% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.4); }\n    70% { box-shadow: 0 0 0 4px rgba(16, 185, 129, 0); }\n    100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }\n  }\n</style>\n\n<div class=\"ss-studio-footer\">\n  \n  <div class=\"ss-footer-left\">\n    <span>&copy; {{ 'now' | date: \"%Y\" }} Stella & Sage Co.</span>\n    <span class=\"ss-badge\">Studio v2.4</span>\n  </div>\n\n  <div class=\"ss-footer-center\">\n    <div class=\"ss-status-dot\"></div>\n    <span>Systems Operational</span>\n  </div>\n\n  <div class=\"ss-footer-right\">\n    <a href=\"/policies/privacy-policy\" class=\"ss-footer-link\">Privacy</a>\n    <a href=\"/policies/terms-of-service\" class=\"ss-footer-link\">Terms</a>\n    <a href=\"/pages/contact\" class=\"ss-footer-link\">Support</a>\n  </div>\n\n</div>",
