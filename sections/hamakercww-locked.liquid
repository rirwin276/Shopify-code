{% comment %}
Universal B2B Storefront Gate (NO LOGO) — New Customer Accounts

LIVE access:
- Requires customer tag: b2b-<handle>
  handle is derived from request.path (/pages/<handle>)

Redirect rules (LIVE only):
- Logged out -> /customer_authentication/login?return_to=/pages/portal
- Logged in but missing tag -> /pages/portal

Editor:
- No redirects, show banner + headline so you can design safely

Optional page metafield (only used if page exists):
- custom.storefront_name (single line text)
{% endcomment %}

{%- assign portal_path = '/pages/portal' -%}
{%- assign portal_return_to = portal_path | url_encode -%}

{%- assign parts = request.path | split: '/' -%}
{%- assign handle = parts | last -%}
{%- assign required_tag = 'b2b-' | append: handle -%}

{%- assign display_name = handle | replace: '-', ' ' | capitalize -%}
{%- if page != blank -%}
  {%- if page.title != blank -%}
    {%- assign display_name = page.title -%}
  {%- endif -%}
  {%- assign name_meta = page.metafields.custom.storefront_name.value -%}
  {%- if name_meta != blank -%}
    {%- assign display_name = name_meta -%}
  {%- endif -%}
{%- endif -%}

{%- assign allow_render = false -%}

{% if request.design_mode %}
  {%- assign allow_render = true -%}

  <div style="max-width:1100px;margin:12px auto 0;padding:10px 12px;border:1px dashed rgba(200,178,124,.85);background:#faf8f2;border-radius:12px;">
    <strong>Protected Storefront (Editor Preview)</strong><br>
    <span style="color:rgba(0,0,0,.65);font-size:13px;">
      Required live tag: <code>{{ required_tag }}</code> · Fallback: <code>{{ portal_path }}</code>
    </span>
  </div>

{% else %}

  {% if customer %}
    {% if customer.tags contains required_tag %}
      {%- assign allow_render = true -%}
    {% else %}
      <script>window.location.replace("{{ portal_path }}");</script>
    {% endif %}
  {% else %}
    <script>window.location.replace("/customer_authentication/login?return_to={{ portal_return_to }}");</script>
  {% endif %}

{% endif %}

{% if allow_render %}
  <section style="max-width:1100px;margin:0 auto;padding:42px 16px 18px;text-align:center;">
    <h1 style="margin:0;font-size:44px;line-height:1.1;font-weight:900;">
      {{ display_name }}
    </h1>

    {% if section.settings.subtitle != blank %}
      <p style="margin:10px auto 0;max-width:760px;color:rgba(0,0,0,.7);font-size:16px;line-height:1.45;">
        {{ section.settings.subtitle }}
      </p>
    {% endif %}
  </section>
{% endif %}

{% schema %}
{
  "name": "B2B Gate",
  "settings": [
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle (optional)",
      "default": "Wholesale portal and custom ordering."
    }
  ],
  "presets": [
    { "name": "B2B Gate" }
  ]
}
{% endschema %}
