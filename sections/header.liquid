      width: 34px !important;
      min-height: 34px !important;
      height: 34px !important;
      border-radius: 999px !important;
    }

    .ss-mobile-mini-nav {
      display: block;
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      z-index: 80;
    }

    .ss-mobile-mini-nav__button {
      width: 38px;
      height: 38px;
      padding: 0;
      border: 1px solid rgba(17, 16, 14, 0.08);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.86);
      box-shadow: 0 10px 28px rgba(17, 16, 14, 0.07);
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 4px;
      cursor: pointer;
      -webkit-tap-highlight-color: transparent;
    }

    .ss-mobile-mini-nav__button span {
      width: 15px;
      height: 2px;
      border-radius: 999px;
      background: #11100e;
      display: block;
    }

    .ss-mobile-mini-nav__panel {
      display: none;
      position: absolute;
      left: 0;
      top: calc(100% + 8px);
      width: min(226px, calc(100vw - 24px));
      padding: 8px;
      border-radius: 22px;
      background:
        radial-gradient(circle at 12% 0%, rgba(183, 163, 106, 0.10), transparent 32%),
        rgba(255, 255, 255, 0.96);
      border: 1px solid rgba(17, 16, 14, 0.08);
      box-shadow: 0 26px 70px rgba(17, 16, 14, 0.16);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
    }

    .ss-mobile-mini-nav.is-open .ss-mobile-mini-nav__panel {
      display: grid;
