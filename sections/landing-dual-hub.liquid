<script>
(function() {
  var root = document.getElementById('ss-home-{{ section.id }}');
  if (!root) return;

  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var revealEls = root.querySelectorAll('.ss-reveal');

  /* --- Animated count-up on the proof bar numbers --- */
  function animateCount(el) {
    var text = el.textContent;
    var match = text.match(/(\d[\d,.]*)/);
    if (!match) return;
    var target = parseFloat(match[1].replace(/,/g, ''));
    if (!isFinite(target) || target <= 0) return;
    var prefix = text.slice(0, match.index);
    var suffix = text.slice(match.index + match[1].length);
    var hasDecimal = match[1].indexOf('.') !== -1;
    var start = null;
    var duration = 1100;

    function frame(ts) {
      if (start === null) start = ts;
      var p = Math.min(1, (ts - start) / duration);
      var eased = 1 - Math.pow(1 - p, 3);
      var val = target * eased;
      el.textContent = prefix + (hasDecimal ? val.toFixed(1) : Math.round(val).toLocaleString()) + suffix;
      if (p < 1) requestAnimationFrame(frame);
      else el.textContent = text;
    }
    requestAnimationFrame(frame);
  }

  /* --- Gentle 3D tilt on the hero device mockup (desktop pointers only) --- */
  function wireTilt() {
    var visual = root.querySelector('.ss-hero-visual');
    var card = root.querySelector('.ss-device-card');
    if (!visual || !card) return;
    if (!window.matchMedia('(pointer: fine)').matches) return;

    visual.addEventListener('mousemove', function(e) {
      var rect = visual.getBoundingClientRect();
      var x = (e.clientX - rect.left) / rect.width - 0.5;
      var y = (e.clientY - rect.top) / rect.height - 0.5;
      card.style.transform = 'rotateY(' + (x * 7).toFixed(2) + 'deg) rotateX(' + (y * -7).toFixed(2) + 'deg)';
    });

    visual.addEventListener('mouseleave', function() {
      card.style.transform = '';
    });
  }

  /* --- Smooth FAQ open/close --- */
  function wireFaq() {
    root.querySelectorAll('.ss-faq-list details').forEach(function(details) {
      var summary = details.querySelector('summary');
      var body = details.querySelector('.ss-faq-body');
      if (!summary || !body || typeof body.animate !== 'function') return;
      var animating = false;

      summary.addEventListener('click', function(e) {
        e.preventDefault();
        if (animating) return;
        animating = true;

        if (details.open) {
          var h = body.offsetHeight;
          body.animate(
            [{ height: h + 'px', opacity: 1 }, { height: '0px', opacity: 0 }],
            { duration: 280, easing: 'ease' }
          ).onfinish = function() {
            details.open = false;
            animating = false;
          };
        } else {
          details.open = true;
          var h2 = body.offsetHeight;
          body.animate(
            [{ height: '0px', opacity: 0 }, { height: h2 + 'px', opacity: 1 }],
            { duration: 320, easing: 'ease' }
          ).onfinish = function() {
            animating = false;
          };
        }
      });
    });
  }

  if (prefersReducedMotion) {
    revealEls.forEach(function(el) {
      el.classList.add('is-visible');
    });
    return;
  }

  wireTilt();
  wireFaq();

  if ('IntersectionObserver' in window) {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;

        var delay = parseInt(entry.target.getAttribute('data-delay') || '0', 10);
        window.setTimeout(function() {
          entry.target.classList.add('is-visible');
        }, delay);

        if (entry.target.classList.contains('ss-proof-bar')) {
          entry.target.querySelectorAll('[data-ss-count]').forEach(animateCount);
        }

        io.unobserve(entry.target);
      });
    }, {
      threshold: 0.12,
      rootMargin: '0px 0px -40px 0px'
    });

    revealEls.forEach(function(el) {
      io.observe(el);
    });
  } else {
    revealEls.forEach(function(el) {
      el.classList.add('is-visible');
    });
  }
})();
</script>

