{% comment %}
  LANDING — Stella & Sage Premium Front Page (V14 editorial gold)
  - Built from V13 toned gold.
  - Keeps existing logged-in customer/store tag logic.
  - Logged-out: Premium hero → proof bar → pain/solution → process → example stores → dashboard preview → roles → trust/FAQ → final CTA → marquee.
  - Logged-in: Premium welcome → store links → second store CTA → marquee.
  - No backend required.
  - Existing schema IDs preserved so current theme settings keep working.
  - V14: serif display headlines (toggleable), editable accent color, all previously
    hardcoded copy (pain/examples/dashboard/roles/trust/FAQ/marquee/mockup) exposed
    as theme-editor settings with the original copy as defaults. Multi-item settings
    use one item per line, fields separated by " | ".
{% endcomment %}

{%- assign dashboard_url = section.settings.dashboard_url | default: '/pages/portal' -%}
{%- assign request_url = section.settings.request_url | default: '/pages/private-storefronts' -%}
{%- assign mo_type = section.settings.metaobject_type | default: 'storefront' | strip -%}
{%- assign ss_accent = section.settings.accent_color | default: '#b7a36a' -%}
{%- if section.settings.use_serif -%}{%- render 'ss-brand-font' -%}{%- endif -%}
{%- capture login_url -%}{{ routes.storefront_login_url }}?return_to={{ dashboard_url | url_encode }}{%- endcapture -%}

{%- comment -%}Logged-in: parse storefront tags & metaobjects, same core logic as previous homepage.{%- endcomment -%}
{%- assign has_storefront = false -%}
{%- assign store_count = 0 -%}
{%- assign storefront_tags = '' -%}
{%- assign admin_handles = '' -%}

{%- if customer -%}
  {%- for tag in customer.tags -%}
    {%- assign tag_down = tag | downcase | strip -%}
    {%- if tag_down contains 'b2b-admin-' -%}
      {%- assign ah = tag_down | remove: 'b2b-admin-' | strip -%}
      {%- if ah != blank -%}
        {%- assign admin_handles = admin_handles | append: '||' | append: ah | append: '||' -%}
      {%- endif -%}
    {%- elsif tag_down contains 'b2b-' -%}
      {%- assign has_storefront = true -%}
      {%- assign storefront_tags = storefront_tags | append: tag_down | append: '||' -%}
      {%- assign store_count = store_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- assign store_meta = blank -%}
{%- if shop.metaobjects[mo_type] and shop.metaobjects[mo_type].values != blank -%}
  {%- assign store_meta = shop.metaobjects[mo_type].values -%}
{%- endif -%}

{%- assign welcome_name = customer.first_name | strip -%}
{%- if welcome_name == blank and customer -%}
  {%- assign welcome_name = customer.email | split: '@' | first -%}
{%- endif -%}

<section class="ss-home" data-ss-home id="ss-home-{{ section.id }}">

  {%- if customer -%}

    {%- comment -%} =========================
      LOGGED-IN VIEW
    ========================== {%- endcomment -%}

    <div class="ss-bg-orb ss-bg-orb--one"></div>
    <div class="ss-bg-orb ss-bg-orb--two"></div>

    <section class="ss-member-hero ss-reveal">
      <div class="ss-wrap">
        <div class="ss-member-shell">
          <div class="ss-eyebrow">
            <span class="ss-eyebrow-dot"></span>
            {{ section.settings.member_eyebrow | default: 'STELLA & SAGE DASHBOARD' }}
          </div>

          <h1 class="ss-member-title">{{ section.settings.welcome_prefix | escape }}{{ welcome_name | escape }}.</h1>
          <p class="ss-member-sub">{{ section.settings.greeting_sub | escape }}</p>

          <div class="ss-action-row">
            {%- if has_storefront -%}
              {%- assign tags_arr = storefront_tags | split: '||' -%}
              {%- for t in tags_arr -%}
                {%- if t != blank -%}
                  {%- assign s_handle = t | remove: 'b2b-' | strip -%}
                  {%- assign s_url = '/pages/' | append: s_handle -%}
                  {%- assign s_name = s_handle | replace: '-', ' ' | capitalize -%}

                  {%- if store_meta != blank -%}
                    {%- for mo in store_meta -%}
                      {%- assign mo_page = mo.page.value | default: mo.page -%}
                      {%- assign mo_slug = mo.slug.value | default: mo.slug -%}
                      {%- assign mo_h = '' -%}

                      {%- if mo_page != blank and mo_page.handle != blank -%}
                        {%- assign mo_h = mo_page.handle | downcase | strip -%}
                      {%- elsif mo_slug != blank -%}
                        {%- assign mo_h = mo_slug | downcase | strip -%}
                      {%- endif -%}

                      {%- if mo_h == s_handle -%}
                        {%- assign mo_name = mo.display_name.value | default: mo.display_name -%}
                        {%- if mo_name != blank -%}{%- assign s_name = mo_name -%}{%- endif -%}
                        {%- if mo_page != blank and mo_page.url != blank -%}{%- assign s_url = mo_page.url -%}{%- endif -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}

                  <a class="ss-pill ss-pill--primary" href="{{ s_url }}">Open {{ s_name | escape }} →</a>
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}

            <a class="ss-pill ss-pill--glass" href="{{ dashboard_url }}?stay=1">{{ section.settings.dashboard_label | escape }}</a>
            <a class="ss-pill ss-pill--glass" href="{{ routes.account_url }}">{{ section.settings.orders_label | escape }}</a>
          </div>
        </div>
      </div>
    </section>

    <section class="ss-section ss-reveal">
      <div class="ss-wrap ss-wrap--narrow ss-center">
        <div class="ss-mini-kicker">{{ section.settings.second_store_kicker | default: 'CREATE ANOTHER STORE' }}</div>
        <h2 class="ss-h2">{{ section.settings.second_store_headline | escape }}</h2>
        <p class="ss-body">{{ section.settings.second_store_body | escape }}</p>
        <a class="ss-btn ss-btn--dark" href="{{ request_url }}">{{ section.settings.second_store_cta | escape }} →</a>
      </div>
    </section>

  {%- else -%}

    {%- comment -%} =========================
      LOGGED-OUT VIEW
    ========================== {%- endcomment -%}

    <div class="ss-bg-orb ss-bg-orb--one"></div>
    <div class="ss-bg-orb ss-bg-orb--two"></div>

    <section class="ss-hero ss-reveal">
      <div class="ss-wrap ss-hero-grid">
        <div class="ss-hero-copy">
          <div class="ss-eyebrow">
            <span class="ss-eyebrow-dot"></span>
            {{ section.settings.eyebrow_text | default: 'VETERAN OWNED · PRIVATE GROUP STORES' }}
          </div>

          {%- comment -%}Wrap *words* in the headline with a gold serif accent.{%- endcomment -%}
          {%- assign hero_raw = section.settings.hero_headline | escape | newline_to_br -%}
          {%- assign hero_parts = hero_raw | split: '*' -%}
          <h1 class="ss-hero-title">
            {%- for part in hero_parts -%}
              {%- assign part_idx = forloop.index0 | modulo: 2 -%}
              {%- if part_idx == 1 -%}<em class="ss-accent-word">{{ part }}</em>{%- else -%}{{ part }}{%- endif -%}
            {%- endfor -%}
          </h1>
          <p class="ss-hero-sub">{{ section.settings.hero_sub | escape }}</p>

          <div class="ss-hero-actions">
            <a class="ss-btn ss-btn--dark" href="{{ request_url }}">{{ section.settings.hero_cta_label | escape }}</a>
            <a class="ss-btn ss-btn--light" href="{{ login_url }}" onclick="try{localStorage.setItem('sf_pending_signin_v1',JSON.stringify({return_path:'{{ dashboard_url | escape }}',_saved_at:Date.now()}))}catch(e){}">{{ section.settings.hero_signin_label | escape }}</a>
          </div>

          <div class="ss-hero-proofline">
            <span>{{ section.settings.hero_caption | escape }}</span>
          </div>
        </div>

        <div class="ss-hero-visual ss-reveal" data-delay="120" aria-label="Private store dashboard preview">
          <div class="ss-device-card">
            <div class="ss-device-topbar">
              <span></span><span></span><span></span>
            </div>

            {%- assign mock_name = section.settings.mock_store_name | default: 'Vista Raptors' -%}
            {%- assign mock_logo = section.settings.mock_logo_initials | default: 'VR' -%}
            <div class="ss-dashboard-preview">
              <div class="ss-preview-head">
                <div>
                  <p>PRIVATE STORE</p>
                  <h3>{{ mock_name | escape }}</h3>
                </div>
                <div class="ss-live-badge"><span class="ss-live-dot"></span>Live</div>
              </div>

              <div class="ss-product-strip">
                <div class="ss-product-card">
                  <div class="ss-shirt ss-shirt--black">
                    <div class="ss-shirt-logo">{{ mock_logo | escape }}</div>
                  </div>
                  <p>Team Tee</p>
                </div>

                <div class="ss-product-card">
                  <div class="ss-shirt ss-shirt--sand">
                    <div class="ss-shirt-logo">{{ mock_logo | escape }}</div>
                  </div>
                  <p>Hoodie</p>
                </div>

                <div class="ss-product-card">
                  <div class="ss-hat">
                    <div class="ss-hat-logo">{{ mock_logo | escape }}</div>
                  </div>
                  <p>Hat</p>
                </div>
              </div>

              <div class="ss-dashboard-tools">
                <div class="ss-tool-row">
                  <span class="ss-tool-icon"></span>
                  <div>
                    <strong>Share one link</strong>
                    <small>Everyone orders direct.</small>
                  </div>
                </div>
                <div class="ss-tool-row">
                  <span class="ss-tool-icon"></span>
                  <div>
                    <strong>Edit placement</strong>
                    <small>Dial in colors and logo size.</small>
                  </div>
                </div>
                <div class="ss-tool-row">
                  <span class="ss-tool-icon"></span>
                  <div>
                    <strong>Manage products</strong>
                    <small>Hide, delete, or build more.</small>
                  </div>
                </div>
              </div>
            </div>
          </div>

          {%- assign float1 = section.settings.float1_text | default: '2 min | form' | split: '|' -%}
          {%- assign float2 = section.settings.float2_text | default: '~15 min | store build' | split: '|' -%}
          <div class="ss-floating-card ss-floating-card--top">
            <strong>{{ float1[0] | strip | escape }}</strong>
            <span>{{ float1[1] | strip | escape }}</span>
          </div>

          <div class="ss-floating-card ss-floating-card--bottom">
            <strong>{{ float2[0] | strip | escape }}</strong>
            <span>{{ float2[1] | strip | escape }}</span>
          </div>
        </div>
      </div>
    </section>

    <section class="ss-proof-bar ss-reveal">
      <div class="ss-wrap">
        <div class="ss-proof-grid">
          <div class="ss-proof-item">
            <strong data-ss-count>{{ section.settings.stat1_num | escape }}</strong>
            <span>{{ section.settings.stat1_label | escape }}</span>
          </div>
          <div class="ss-proof-item">
            <strong data-ss-count>{{ section.settings.stat2_num | escape }}</strong>
            <span>{{ section.settings.stat2_label | escape }}</span>
          </div>
          <div class="ss-proof-item">
            <strong data-ss-count>{{ section.settings.stat3_num | escape }}</strong>
            <span>{{ section.settings.stat3_label | escape }}</span>
          </div>
        </div>
      </div>
    </section>

    <section class="ss-section ss-pain-section ss-reveal">
      <div class="ss-wrap">
        <div class="ss-section-head">
          <div class="ss-mini-kicker">{{ section.settings.pain_kicker | default: 'THE REAL PROBLEM' }}</div>
          <h2 class="ss-h2">{{ section.settings.pain_headline | default: 'Stop being the unpaid shirt manager.' }}</h2>
          <p class="ss-body">{{ section.settings.pain_body | default: 'Group merch should not mean chasing sizes, collecting Venmo payments, tracking spreadsheets, and answering the same text over and over.' }}</p>
        </div>

        <div class="ss-compare-grid">
          <div class="ss-compare-card ss-compare-card--old">
            <div class="ss-card-label">{{ section.settings.pain_old_label | default: 'THE OLD WAY' }}</div>
            <h3>{{ section.settings.pain_old_title | default: 'One person gets stuck with everything.' }}</h3>
            <ul>
              {%- assign old_items = section.settings.pain_old_items | escape | newline_to_br | split: '<br />' -%}
              {%- for item in old_items -%}
                {%- assign item_clean = item | strip -%}
                {%- if item_clean != blank -%}<li>{{ item_clean }}</li>{%- endif -%}
              {%- endfor -%}
            </ul>
          </div>

          <div class="ss-compare-card ss-compare-card--new">
            <div class="ss-card-label">{{ section.settings.pain_new_label | default: 'THE STELLA & SAGE WAY' }}</div>
            <h3>{{ section.settings.pain_new_title | default: "Create the store. Share the link. You're done." }}</h3>
            <ul>
              {%- assign new_items = section.settings.pain_new_items | escape | newline_to_br | split: '<br />' -%}
              {%- for item in new_items -%}
                {%- assign item_clean = item | strip -%}
                {%- if item_clean != blank -%}<li>{{ item_clean }}</li>{%- endif -%}
              {%- endfor -%}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <section class="ss-section ss-process-section ss-reveal">
      <div class="ss-wrap">
        <div class="ss-section-head ss-center">
          <div class="ss-mini-kicker">HOW IT WORKS</div>
          <h2 class="ss-h2">{{ section.settings.steps_headline | escape }}</h2>
          <p class="ss-body">A private merch store without the slow meetings, minimum order pressure, or group chat chaos.</p>
        </div>

        <div class="ss-steps-grid">
          <div class="ss-step-card ss-reveal" data-delay="0">
            <div class="ss-step-num">01</div>
            <h3>{{ section.settings.step1_title | escape }}</h3>
            <p>{{ section.settings.step1_desc | escape }}</p>
          </div>

          <div class="ss-step-card ss-reveal" data-delay="90">
            <div class="ss-step-num">02</div>
            <h3>{{ section.settings.step2_title | escape }}</h3>
            <p>{{ section.settings.step2_desc | escape }}</p>
          </div>

          <div class="ss-step-card ss-reveal" data-delay="180">
            <div class="ss-step-num">03</div>
            <h3>{{ section.settings.step3_title | escape }}</h3>
            <p>{{ section.settings.step3_desc | escape }}</p>
          </div>
        </div>
      </div>
    </section>

    <section class="ss-section ss-examples-section ss-reveal">
      <div class="ss-wrap">
        <div class="ss-section-head">
          <div class="ss-mini-kicker">{{ section.settings.examples_kicker | default: 'BUILT FOR REAL GROUPS' }}</div>
          <h2 class="ss-h2">{{ section.settings.examples_headline | default: 'One system. Almost any group.' }}</h2>
          <p class="ss-body">{{ section.settings.examples_body | default: 'Teams, units, trips, businesses, fundraisers, families — if people need to order gear without one person managing chaos, it fits.' }}</p>
        </div>

        <div class="ss-example-grid">
          {%- assign example_art = 'team,unit,trip,business' | split: ',' -%}
          {%- assign example_lines = section.settings.example_cards | escape | newline_to_br | split: '<br />' -%}
          {%- assign example_i = 0 -%}
          {%- for line in example_lines -%}
            {%- assign line_clean = line | strip -%}
            {%- if line_clean == blank -%}{%- continue -%}{%- endif -%}
            {%- assign fields = line_clean | split: '|' -%}
            {%- assign art_idx = example_i | modulo: 4 -%}
            <div class="ss-example-card ss-reveal" data-delay="{{ art_idx | times: 70 }}">
              <div class="ss-example-art ss-example-art--{{ example_art[art_idx] }}">
                <span>{{ fields[0] | strip }}</span>
              </div>
              <h3>{{ fields[1] | strip }}</h3>
              <p>{{ fields[2] | strip }}</p>
            </div>
            {%- assign example_i = example_i | plus: 1 -%}
          {%- endfor -%}
        </div>
      </div>
    </section>

    <section class="ss-section ss-dashboard-section ss-reveal">
      <div class="ss-wrap ss-dashboard-grid">
        <div>
          <div class="ss-mini-kicker">{{ section.settings.dash_kicker | default: 'YOUR HOME BASE' }}</div>
          <h2 class="ss-h2">{{ section.settings.dash_headline | default: 'Every store lives in one clean dashboard.' }}</h2>
          <p class="ss-body">{{ section.settings.dash_body | default: 'Admins can manage products, edit placement, choose colors, hide items, delete products, build new merch, and share the storefront link. Members just shop.' }}</p>

          <div class="ss-feature-list">
            {%- assign dash_lines = section.settings.dash_features | escape | newline_to_br | split: '<br />' -%}
            {%- for line in dash_lines -%}
              {%- assign line_clean = line | strip -%}
              {%- if line_clean == blank -%}{%- continue -%}{%- endif -%}
              {%- assign fields = line_clean | split: '|' -%}
              <div>
                <strong>{{ fields[0] | strip }}</strong>
                <span>{{ fields[1] | strip }}</span>
              </div>
            {%- endfor -%}
          </div>
        </div>

        <div class="ss-admin-panel" aria-label="Dashboard tools preview">
          <div class="ss-admin-top">
            <div>
              <p>DASHBOARD</p>
              <h3>My Stores</h3>
            </div>
            <button type="button">Copy Link</button>
          </div>

          <div class="ss-store-row">
            <div class="ss-store-dot"></div>
            <div>
              <strong>Raptors Football</strong>
              <span>Live · 12 products</span>
            </div>
            <em>Manage</em>
          </div>

          <div class="ss-store-row">
            <div class="ss-store-dot ss-store-dot--gold"></div>
            <div>
              <strong>Family Reunion</strong>
              <span>Building · products generating</span>
            </div>
            <em>View</em>
          </div>

          <div class="ss-admin-actions">
            <span>Edit placement</span>
            <span>Build new product</span>
            <span>Hide product</span>
            <span>Delete product</span>
          </div>
        </div>
      </div>
    </section>

    <section class="ss-section ss-roles-section ss-reveal">
      <div class="ss-wrap">
        <div class="ss-section-head ss-center">
          <div class="ss-mini-kicker">{{ section.settings.roles_kicker | default: 'SIMPLE ACCESS' }}</div>
          <h2 class="ss-h2">{{ section.settings.roles_headline | default: 'Admins manage. Members order.' }}</h2>
          <p class="ss-body">{{ section.settings.roles_body | default: 'The store feels simple because each person only sees what they need.' }}</p>
        </div>

        <div class="ss-role-grid">
          {%- assign role_lines = section.settings.role_cards | escape | newline_to_br | split: '<br />' -%}
          {%- for line in role_lines -%}
            {%- assign line_clean = line | strip -%}
            {%- if line_clean == blank -%}{%- continue -%}{%- endif -%}
            {%- assign fields = line_clean | split: '|' -%}
            <div class="ss-role-card">
              <span>{{ fields[0] | strip }}</span>
              <h3>{{ fields[1] | strip }}</h3>
              <p>{{ fields[2] | strip }}</p>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </section>

    <section class="ss-section ss-trust-section ss-reveal">
      <div class="ss-wrap">
        <div class="ss-trust-shell">
          <div>
            <div class="ss-mini-kicker">{{ section.settings.trust_kicker | default: 'WHY IT WORKS' }}</div>
            <h2 class="ss-h2">{{ section.settings.trust_headline | default: 'Built for people who do not have time to manage merch.' }}</h2>
            <p class="ss-body">{{ section.settings.trust_body | default: 'Stella & Sage removes the annoying parts of group apparel: collecting sizes, handling payments, placing bulk orders, and being the person everyone texts when they need another shirt.' }}</p>
          </div>

          <div class="ss-trust-points">
            {%- assign trust_lines = section.settings.trust_points | escape | newline_to_br | split: '<br />' -%}
            {%- for line in trust_lines -%}
              {%- assign line_clean = line | strip -%}
              {%- if line_clean == blank -%}{%- continue -%}{%- endif -%}
              {%- assign fields = line_clean | split: '|' -%}
              <div>
                <strong>{{ fields[0] | strip }}</strong>
                <span>{{ fields[1] | strip }}</span>
              </div>
            {%- endfor -%}
          </div>
        </div>
      </div>
    </section>

    <section class="ss-section ss-faq-section ss-reveal">
      <div class="ss-wrap ss-wrap--medium">
        <div class="ss-section-head ss-center">
          <div class="ss-mini-kicker">{{ section.settings.faq_kicker | default: 'FAQ' }}</div>
          <h2 class="ss-h2">{{ section.settings.faq_headline | default: 'The questions people ask first.' }}</h2>
        </div>

        <div class="ss-faq-list">
          {%- assign faq_lines = section.settings.faq_items | escape | newline_to_br | split: '<br />' -%}
          {%- for line in faq_lines -%}
            {%- assign line_clean = line | strip -%}
            {%- if line_clean == blank -%}{%- continue -%}{%- endif -%}
            {%- assign fields = line_clean | split: '|' -%}
            <details>
              <summary>{{ fields[0] | strip }}<span class="ss-faq-icon" aria-hidden="true"></span></summary>
              <div class="ss-faq-body"><p>{{ fields[1] | strip }}</p></div>
            </details>
          {%- endfor -%}
        </div>
      </div>
    </section>

    <section class="ss-final-cta ss-reveal">
      <div class="ss-wrap ss-wrap--narrow ss-center">
        <div class="ss-mini-kicker">{{ section.settings.final_kicker | default: 'READY WHEN YOU ARE' }}</div>
        <h2 class="ss-final-title">{{ section.settings.final_headline | escape }}</h2>
        <p class="ss-final-sub">{{ section.settings.final_sub | escape }}</p>
        <a class="ss-btn ss-btn--dark" href="{{ request_url }}">{{ section.settings.final_cta_label | escape }} →</a>
      </div>
    </section>

  {%- endif -%}

  <div class="ss-marquee-wrap">
    <div class="ss-marquee-track">
      {%- assign marquee_items = section.settings.marquee_items | escape | newline_to_br | split: '<br />' -%}
      {%- for repeat in (1..2) -%}
        {%- for item in marquee_items -%}
          {%- assign item_clean = item | strip -%}
          {%- if item_clean != blank -%}
            <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>{{ item_clean }}</span>
          {%- endif -%}
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.dashboard_image != blank -%}
    <div class="ss-dashboard-img-hidden" aria-hidden="true">
      <img src="{{ section.settings.dashboard_image | image_url: width: 1400 }}" alt="" loading="lazy" width="{{ section.settings.dashboard_image.width }}" height="{{ section.settings.dashboard_image.height }}">
    </div>
  {%- endif -%}

</section>

<style>
  /* =========================
     STELLA & SAGE PREMIUM HOME
  ========================== */

  #ss-home-{{ section.id }} {
    --ss-accent: {{ ss_accent }};
    --ss-accent-deep: {{ ss_accent | color_darken: 12 }};
    --ss-accent-bright: {{ ss_accent | color_lighten: 22 }};
    --ss-accent-pale: {{ ss_accent | color_lighten: 32 }};
  }

  .ss-home,
  .ss-home * {
    box-sizing: border-box;
  }

  {%- if section.settings.use_serif %}
  /* Editorial serif display layer (toggle in section settings) */
  .ss-home .ss-hero-title,
  .ss-home .ss-h2,
  .ss-home .ss-final-title,
  .ss-home .ss-member-title {
    font-family: var(--ss-font-display, Georgia, serif);
    font-weight: 580;
    letter-spacing: -.025em;
    font-variation-settings: "opsz" 110;
  }

  .ss-home .ss-hero-title {
    line-height: .98;
    letter-spacing: -.03em;
  }

  .ss-home .ss-h2 {
    line-height: 1.04;
  }

  .ss-home .ss-member-title,
  .ss-home .ss-final-title {
    line-height: 1;
  }
  {%- endif %}

  /* Gold accent word inside the hero headline (*wrapped* in settings) */
  .ss-accent-word {
    font-style: italic;
    background: linear-gradient(105deg, var(--ss-accent-deep), var(--ss-accent) 55%, var(--ss-accent-bright));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    padding-right: .04em;
  }

  .ss-home {
    position: relative;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Helvetica, Arial, sans-serif;
    color: #11100e;
    background:
      radial-gradient(circle at 18% 5%, color-mix(in srgb, var(--ss-accent) 10%, transparent), transparent 30%),
      radial-gradient(circle at 80% 8%, rgba(255, 255, 255, 0.85), transparent 22%),
      linear-gradient(180deg, #fbf8f1 0%, #fffdf9 22%, #ffffff 50%, #fbfaf7 100%);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  .ss-wrap {
    width: min(1180px, calc(100% - 44px));
    margin: 0 auto;
  }

  .ss-wrap--narrow {
    max-width: 760px;
  }

  .ss-wrap--medium {
    max-width: 920px;
  }

  .ss-center {
    text-align: center;
  }

  .ss-bg-orb {
    position: absolute;
    border-radius: 999px;
    pointer-events: none;
    filter: blur(12px);
    opacity: .34;
  }

  .ss-bg-orb--one {
    width: 420px;
    height: 420px;
    top: -160px;
    left: -120px;
    background: color-mix(in srgb, var(--ss-accent) 10%, transparent);
  }

  .ss-bg-orb--two {
    width: 520px;
    height: 520px;
    top: 240px;
    right: -220px;
    background: rgba(14, 14, 14, 0.08);
  }

  @media (prefers-reduced-motion: no-preference) {
    .ss-reveal {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 560ms ease, transform 560ms ease;
    }

    .ss-reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ss-eyebrow,
  .ss-mini-kicker {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
    color: rgba(17, 16, 14, .58);
    font-size: 12px;
    font-weight: 850;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .ss-eyebrow-dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    background: var(--ss-accent-deep);
    box-shadow: 0 0 0 7px color-mix(in srgb, var(--ss-accent) 8%, transparent);
  }

  .ss-h2 {
    margin: 0;
    color: #11100e;
    font-size: clamp(34px, 5vw, 68px);
    line-height: .98;
    letter-spacing: -.055em;
    font-weight: 950;
  }

  .ss-body {
    margin: 18px 0 0;
    color: rgba(17, 16, 14, .64);
    font-size: clamp(16px, 2vw, 21px);
    line-height: 1.58;
    font-weight: 450;
  }

  .ss-section {
    position: relative;
    padding: 104px 0;
  }

  .ss-section-head {
    max-width: 760px;
    margin-bottom: 44px;
  }

  .ss-section-head.ss-center {
    margin-left: auto;
    margin-right: auto;
  }

  .ss-btn,
  .ss-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    cursor: pointer;
    white-space: nowrap;
    transition:
      transform 180ms ease,
      box-shadow 180ms ease,
      background 180ms ease,
      border-color 180ms ease,
      opacity 180ms ease;
  }

  .ss-btn {
    min-height: 54px;
    padding: 0 25px;
    border-radius: 999px;
    font-size: 15px;
    font-weight: 850;
    letter-spacing: -.01em;
  }

  .ss-btn--dark {
    color: #fff;
    background: #11100e;
    border: 1px solid color-mix(in srgb, var(--ss-accent) 28%, transparent);
    box-shadow: 0 18px 44px rgba(17, 16, 14, .18);
  }

  .ss-btn--dark:hover {
    transform: translateY(-2px);
    box-shadow: 0 24px 62px rgba(17, 16, 14, .24);
  }

  .ss-btn--light {
    color: #11100e;
    background: rgba(255, 255, 255, .72);
    border: 1px solid rgba(17, 16, 14, .12);
    box-shadow: 0 12px 34px rgba(17, 16, 14, .08);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .ss-btn--light:hover {
    transform: translateY(-2px);
    border-color: rgba(17, 16, 14, .22);
  }

  /* Gold shimmer sweep across primary buttons on hover */
  .ss-btn--dark,
  .ss-pill--primary {
    position: relative;
    overflow: hidden;
  }

  .ss-btn--dark::after,
  .ss-pill--primary::after {
    content: "";
    position: absolute;
    top: 0;
    left: -110%;
    width: 55%;
    height: 100%;
    background: linear-gradient(100deg, transparent, color-mix(in srgb, var(--ss-accent-bright) 35%, transparent), transparent);
    pointer-events: none;
  }

  @media (prefers-reduced-motion: no-preference) {
    .ss-btn--dark:hover::after,
    .ss-pill--primary:hover::after {
      left: 170%;
      transition: left .55s ease;
    }
  }

  /* HERO */

  .ss-hero {
    position: relative;
    padding: 118px 0 86px;
  }

  .ss-hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.02fr) minmax(360px, .98fr);
    gap: 56px;
    align-items: center;
  }

  .ss-hero-title {
    max-width: 760px;
    margin: 0;
    color: #11100e;
    font-size: clamp(54px, 8.4vw, 112px);
    line-height: .9;
    letter-spacing: -.075em;
    font-weight: 950;
  }

  .ss-hero-sub {
    max-width: 620px;
    margin: 25px 0 0;
    color: rgba(17, 16, 14, .66);
    font-size: clamp(18px, 2.2vw, 23px);
    line-height: 1.55;
    font-weight: 450;
  }

  .ss-hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 13px;
    align-items: center;
    margin-top: 34px;
  }

  .ss-hero-proofline {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 18px;
    color: rgba(17, 16, 14, .50);
    font-size: 13px;
    font-weight: 700;
  }

  .ss-hero-proofline::before {
    content: "";
    width: 24px;
    height: 1px;
    background: color-mix(in srgb, var(--ss-accent) 45%, transparent);
  }

  .ss-hero-visual {
    position: relative;
    min-height: 570px;
    perspective: 1400px;
  }

  .ss-device-card {
    position: relative;
    width: 100%;
    transform-style: preserve-3d;
    will-change: transform;
    transition: transform .18s ease-out;
    border-radius: 34px;
    padding: 13px;
    background:
      linear-gradient(145deg, rgba(255,255,255,.85), rgba(255,255,255,.42)),
      linear-gradient(145deg, color-mix(in srgb, var(--ss-accent) 12%, transparent), rgba(17,16,14,.045));
    border: 1px solid rgba(255,255,255,.8);
    box-shadow:
      0 45px 120px rgba(17, 16, 14, .20),
      inset 0 1px 0 rgba(255,255,255,.86);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
  }

  .ss-device-topbar {
    height: 44px;
    padding: 0 16px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .ss-device-topbar span {
    width: 10px;
    height: 10px;
    border-radius: 999px;
    background: rgba(17, 16, 14, .18);
  }

  .ss-dashboard-preview {
    border-radius: 25px;
    padding: 24px;
    background:
      radial-gradient(circle at 15% 0%, color-mix(in srgb, var(--ss-accent) 10%, transparent), transparent 32%),
      linear-gradient(180deg, #141311, #070706);
    color: #fff;
    min-height: 470px;
    overflow: hidden;
  }

  .ss-preview-head {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    align-items: flex-start;
  }

  .ss-preview-head p,
  .ss-admin-top p {
    margin: 0 0 6px;
    color: rgba(255,255,255,.42);
    font-size: 11px;
    letter-spacing: .14em;
    font-weight: 850;
  }

  .ss-preview-head h3,
  .ss-admin-top h3 {
    margin: 0;
    color: #fff;
    font-size: 30px;
    letter-spacing: -.04em;
    line-height: 1;
  }

  .ss-live-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 13px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--ss-accent) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--ss-accent) 22%, transparent);
    color: var(--ss-accent-bright);
    font-size: 12px;
    font-weight: 850;
  }

  .ss-live-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--ss-accent-bright);
  }

  @media (prefers-reduced-motion: no-preference) {
    .ss-live-dot {
      animation: ssLivePulse 2.2s ease-in-out infinite;
    }
  }

  @keyframes ssLivePulse {
    0%, 100% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--ss-accent-bright) 55%, transparent); }
    50% { box-shadow: 0 0 0 6px transparent; }
  }

  .ss-product-strip {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 11px;
    margin-top: 28px;
  }

  .ss-product-card {
    min-height: 156px;
    padding: 12px;
    border-radius: 20px;
    background: rgba(255,255,255,.08);
    border: 1px solid rgba(255,255,255,.09);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-between;
  }

  .ss-product-card p {
    margin: 8px 0 0;
    color: rgba(255,255,255,.68);
    font-size: 12px;
    font-weight: 750;
  }

  .ss-shirt {
    position: relative;
    width: 74px;
    height: 90px;
    margin-top: 4px;
    border-radius: 20px 20px 15px 15px;
    clip-path: polygon(20% 0, 35% 8%, 65% 8%, 80% 0, 100% 22%, 84% 38%, 84% 100%, 16% 100%, 16% 38%, 0 22%);
    box-shadow: inset 0 14px 22px rgba(255,255,255,.06);
  }

  .ss-shirt--black { background: #111; border: 1px solid rgba(255,255,255,.14); }
  .ss-shirt--sand { background: #d9c9a5; }

  .ss-shirt-logo,
  .ss-hat-logo {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    color: #11100e;
    background: var(--ss-accent-pale);
    font-size: 11px;
    font-weight: 950;
    letter-spacing: -.04em;
  }

  .ss-hat {
    position: relative;
    width: 88px;
    height: 62px;
    margin-top: 24px;
    background: #f2f0e9;
    border-radius: 999px 999px 18px 18px;
  }

  .ss-hat::after {
    content: "";
    position: absolute;
    left: 8px;
    right: 8px;
    bottom: -10px;
    height: 18px;
    border-radius: 999px;
    background: #11100e;
  }

  .ss-hat-logo {
    top: 8px;
    bottom: auto;
    width: 28px;
    height: 28px;
    font-size: 9px;
  }

  .ss-dashboard-tools {
    margin-top: 25px;
    display: grid;
    gap: 12px;
  }

  .ss-tool-row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 13px;
    border-radius: 18px;
    background: rgba(255,255,255,.075);
    border: 1px solid rgba(255,255,255,.08);
  }

  .ss-tool-icon {
    width: 34px;
    height: 34px;
    border-radius: 12px;
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--ss-accent) 68%, transparent), color-mix(in srgb, var(--ss-accent-bright) 42%, transparent));
    flex: 0 0 auto;
  }

  .ss-tool-row strong {
    display: block;
    color: rgba(255,255,255,.92);
    font-size: 14px;
    line-height: 1.1;
  }

  .ss-tool-row small {
    display: block;
    margin-top: 3px;
    color: rgba(255,255,255,.46);
    font-size: 12px;
    line-height: 1.25;
  }

  .ss-floating-card {
    position: absolute;
    padding: 15px 17px;
    border-radius: 20px;
    background: rgba(255,255,255,.78);
    border: 1px solid rgba(255,255,255,.88);
    box-shadow: 0 22px 70px rgba(17,16,14,.16);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .ss-floating-card strong {
    display: block;
    color: #11100e;
    font-size: 26px;
    letter-spacing: -.055em;
    line-height: 1;
  }

  .ss-floating-card span {
    display: block;
    margin-top: 4px;
    color: rgba(17,16,14,.52);
    font-size: 12px;
    font-weight: 850;
    text-transform: uppercase;
    letter-spacing: .1em;
  }

  .ss-floating-card--top {
    top: 44px;
    right: -12px;
  }

  .ss-floating-card--bottom {
    left: -18px;
    bottom: 62px;
  }

  @media (prefers-reduced-motion: no-preference) {
    .ss-floating-card--top {
      animation: ssFloat 6s ease-in-out infinite;
    }

    .ss-floating-card--bottom {
      animation: ssFloat 7s ease-in-out 1.2s infinite reverse;
    }
  }

  @keyframes ssFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-9px); }
  }

  /* PROOF BAR */

  .ss-proof-bar {
    padding: 0 0 42px;
  }

  .ss-proof-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    border-radius: 28px;
    overflow: hidden;
    background: rgba(255,255,255,.68);
    border: 1px solid rgba(17,16,14,.08);
    box-shadow: 0 24px 80px rgba(17,16,14,.08);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .ss-proof-item {
    padding: 30px 24px;
    border-right: 1px solid rgba(17,16,14,.075);
    text-align: center;
  }

  .ss-proof-item:last-child {
    border-right: 0;
  }

  .ss-proof-item strong {
    display: block;
    color: var(--ss-accent-deep);
    font-size: clamp(34px, 4.4vw, 58px);
    line-height: .92;
    letter-spacing: -.06em;
    font-weight: 950;
    font-variant-numeric: tabular-nums;
  }

  .ss-proof-item span {
    display: block;
    margin-top: 8px;
    color: rgba(17,16,14,.56);
    font-size: 13px;
    line-height: 1.35;
    font-weight: 750;
  }

  /* PAIN / SOLUTION */

  .ss-pain-section {
    background: #fff;
  }

  .ss-compare-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 18px;
  }

  .ss-compare-card {
    min-height: 430px;
    padding: clamp(24px, 4vw, 42px);
    border-radius: 34px;
    border: 1px solid rgba(17,16,14,.09);
    box-shadow: 0 24px 80px rgba(17,16,14,.06);
  }

  .ss-compare-card--old {
    background:
      linear-gradient(180deg, rgba(255,255,255,.88), rgba(250,248,243,.96));
  }

  .ss-compare-card--new {
    color: #fff;
    background:
      radial-gradient(circle at 15% 0%, color-mix(in srgb, var(--ss-accent) 15%, transparent), transparent 36%),
      linear-gradient(180deg, #171613, #080807);
  }

  .ss-card-label {
    margin-bottom: 22px;
    color: var(--ss-accent-deep);
    font-size: 12px;
    font-weight: 950;
    letter-spacing: .14em;
  }

  .ss-compare-card h3 {
    max-width: 500px;
    margin: 0 0 24px;
    font-size: clamp(26px, 3.5vw, 42px);
    line-height: 1;
    letter-spacing: -.05em;
    font-weight: 950;
  }

  .ss-compare-card--old h3 {
    color: #11100e;
  }

  .ss-compare-card ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 13px;
  }

  .ss-compare-card li {
    position: relative;
    padding-left: 30px;
    color: rgba(17,16,14,.62);
    font-size: 16px;
    line-height: 1.35;
    font-weight: 650;
  }

  .ss-compare-card--new li {
    color: rgba(255,255,255,.72);
  }

  .ss-compare-card li::before {
    content: "";
    position: absolute;
    top: .35em;
    left: 0;
    width: 17px;
    height: 17px;
    border-radius: 999px;
    background: rgba(17,16,14,.11);
  }

  .ss-compare-card--new li::before {
    background: var(--ss-accent-deep);
    box-shadow: 0 0 0 5px color-mix(in srgb, var(--ss-accent) 8%, transparent);
  }

  /* PROCESS */

  .ss-process-section {
    background: #fbfaf7;
    border-top: 1px solid rgba(17,16,14,.06);
    border-bottom: 1px solid rgba(17,16,14,.06);
  }

  .ss-steps-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .ss-step-card {
    min-height: 310px;
    padding: 28px;
    border-radius: 30px;
    background: rgba(255,255,255,.70);
    border: 1px solid rgba(17,16,14,.08);
    box-shadow: 0 20px 70px rgba(17,16,14,.055);
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
  }

  .ss-step-card:hover {
    transform: translateY(-5px);
    border-color: color-mix(in srgb, var(--ss-accent) 38%, transparent);
    box-shadow: 0 28px 84px rgba(17,16,14,.10);
  }

  .ss-step-num {
    width: 54px;
    height: 54px;
    display: grid;
    place-items: center;
    margin-bottom: 42px;
    border-radius: 18px;
    color: #11100e;
    background: color-mix(in srgb, var(--ss-accent) 12%, transparent);
    font-size: 14px;
    font-weight: 950;
    letter-spacing: -.02em;
  }

  .ss-step-card h3 {
    margin: 0;
    color: #11100e;
    font-size: 25px;
    line-height: 1.05;
    letter-spacing: -.04em;
    font-weight: 930;
  }

  .ss-step-card p {
    margin: 12px 0 0;
    color: rgba(17,16,14,.61);
    font-size: 15px;
    line-height: 1.52;
    font-weight: 520;
  }

  /* EXAMPLES */

  .ss-examples-section {
    background: #fff;
  }

  .ss-example-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .ss-example-card {
    padding: 13px;
    border-radius: 30px;
    background: #fff;
    border: 1px solid rgba(17,16,14,.08);
    box-shadow: 0 22px 70px rgba(17,16,14,.06);
    transition: transform .25s ease, border-color .25s ease, box-shadow .25s ease;
  }

  .ss-example-card:hover {
    transform: translateY(-5px);
    border-color: color-mix(in srgb, var(--ss-accent) 38%, transparent);
    box-shadow: 0 30px 86px rgba(17,16,14,.11);
  }

  .ss-example-art {
    height: 178px;
    border-radius: 22px;
    display: grid;
    place-items: center;
    overflow: hidden;
  }

  .ss-example-card:hover .ss-example-art span {
    transform: skewX(-7deg) scale(1.06);
  }

  .ss-example-art span {
    transition: transform .35s ease;
    color: #fff;
    font-size: 31px;
    font-weight: 950;
    letter-spacing: -.06em;
    transform: skewX(-7deg);
    text-shadow: 0 12px 34px rgba(0,0,0,.22);
  }

  .ss-example-art--team {
    background:
      radial-gradient(circle at 50% 40%, rgba(255,255,255,.18), transparent 34%),
      linear-gradient(145deg, #173a7a, #11100e);
  }

  .ss-example-art--unit {
    background:
      radial-gradient(circle at 50% 40%, color-mix(in srgb, var(--ss-accent) 14%, transparent), transparent 35%),
      linear-gradient(145deg, #293224, #090a08);
  }

  .ss-example-art--trip {
    background:
      radial-gradient(circle at 50% 40%, rgba(255,255,255,.20), transparent 34%),
      linear-gradient(145deg, #b76d45, #22110c);
  }

  .ss-example-art--business {
    background:
      radial-gradient(circle at 50% 40%, color-mix(in srgb, var(--ss-accent) 12%, transparent), transparent 35%),
      linear-gradient(145deg, #242424, #090909);
  }

  .ss-example-card h3 {
    margin: 20px 12px 0;
    color: #11100e;
    font-size: 19px;
    line-height: 1.1;
    letter-spacing: -.03em;
    font-weight: 920;
  }

  .ss-example-card p {
    margin: 9px 12px 16px;
    color: rgba(17,16,14,.58);
    font-size: 14px;
    line-height: 1.45;
    font-weight: 520;
  }

  /* DASHBOARD */

  .ss-dashboard-section {
    background:
      radial-gradient(circle at 80% 20%, color-mix(in srgb, var(--ss-accent) 9%, transparent), transparent 27%),
      linear-gradient(180deg, #11100e, #070706);
    color: #fff;
  }

  .ss-dashboard-section .ss-h2 {
    color: #fff;
  }

  .ss-dashboard-section .ss-body {
    color: rgba(255,255,255,.62);
  }

  .ss-dashboard-grid {
    display: grid;
    grid-template-columns: minmax(0, .9fr) minmax(360px, 1fr);
    gap: 52px;
    align-items: center;
  }

  .ss-feature-list {
    display: grid;
