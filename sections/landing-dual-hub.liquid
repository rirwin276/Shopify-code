{% comment %}
  LANDING — Apple-style dual-hub (V10)
  - Logged-out: Hero → Speed proof → How it works → Examples carousel → Final CTA
  - Logged-in: Welcome → Second/personal store CTA → Examples carousel
  - Each section is its own toggleable schema block.
  - No dashboard mockup image.
  - "~15 minutes" build time — never "48 hours".
  - Scroll animations via IntersectionObserver, respects prefers-reduced-motion.
{% endcomment %}

{%- assign explainer_url = section.settings.explainer_url | default: '/pages/private-storefronts' -%}
{%- assign portal_url = section.settings.portal_url | default: '/pages/portal' -%}
{%- assign mo_type = section.settings.metaobject_type | default: 'storefront' | strip -%}

{%- comment -%}Logged-in: parse storefront tags & metaobjects (same logic as portal-router){%- endcomment -%}
{%- assign has_storefront = false -%}
{%- assign store_count = 0 -%}
{%- assign storefront_tags = '' -%}
{%- assign admin_handles = '' -%}

{%- if customer -%}
  {%- for tag in customer.tags -%}
    {%- assign tag_down = tag | downcase | strip -%}
    {%- if tag_down contains 'b2b-admin-' -%}
      {%- assign ah = tag_down | remove: 'b2b-admin-' | strip -%}
      {%- if ah != blank -%}
        {%- assign admin_handles = admin_handles | append: '||' | append: ah | append: '||' -%}
      {%- endif -%}
    {%- elsif tag_down contains 'b2b-' -%}
      {%- assign has_storefront = true -%}
      {%- assign storefront_tags = storefront_tags | append: tag_down | append: '||' -%}
      {%- assign store_count = store_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- assign store_meta = blank -%}
{%- if shop.metaobjects[mo_type] and shop.metaobjects[mo_type].values != blank -%}
  {%- assign store_meta = shop.metaobjects[mo_type].values -%}
{%- endif -%}

{%- comment -%}Customer display name{%- endcomment -%}
{%- assign welcome_name = customer.first_name | strip -%}
{%- if welcome_name == blank -%}
  {%- assign welcome_name = customer.email | split: '@' | first -%}
{%- endif -%}

<section class="ldh" data-ldh id="ldh-{{ section.id }}">

  {%- if customer -%}

    {%- comment -%}======= LOGGED-IN VIEW ======={%- endcomment -%}

    {%- for block in section.blocks -%}

      {%- if block.type == 'welcome' -%}
        <div class="ldh-section ldh-welcome ldh-reveal" {{ block.shopify_attributes }}>
          <div class="ldh-wrap">
            <h1 class="ldh-welcome-h1">{{ block.settings.greeting_prefix | escape }}{{ welcome_name | escape }}.</h1>
            <p class="ldh-welcome-sub">{{ block.settings.greeting_sub | escape }}</p>

            <div class="ldh-action-row">
              {%- if has_storefront -%}
                {%- assign tags_arr = storefront_tags | split: '||' -%}
                {%- if store_count == 1 -%}
                  {%- comment -%}Single store — one big primary button{%- endcomment -%}
                  {%- for t in tags_arr -%}
                    {%- if t != blank -%}
                      {%- assign s_handle = t | remove: 'b2b-' | strip -%}
                      {%- assign s_url = '/pages/' | append: s_handle -%}
                      {%- assign s_name = s_handle | replace: '-', ' ' | capitalize -%}
                      {%- if store_meta != blank -%}
                        {%- for mo in store_meta -%}
                          {%- assign mo_page = mo.page.value | default: mo.page -%}
                          {%- assign mo_slug = mo.slug.value | default: mo.slug -%}
                          {%- assign mo_h = '' -%}
                          {%- if mo_page != blank and mo_page.handle != blank -%}
                            {%- assign mo_h = mo_page.handle | downcase | strip -%}
                          {%- elsif mo_slug != blank -%}
                            {%- assign mo_h = mo_slug | downcase | strip -%}
                          {%- endif -%}
                          {%- if mo_h == s_handle -%}
                            {%- assign mo_name = mo.display_name.value | default: mo.display_name -%}
                            {%- if mo_name != blank -%}{%- assign s_name = mo_name -%}{%- endif -%}
                            {%- if mo_page != blank and mo_page.url != blank -%}{%- assign s_url = mo_page.url -%}{%- endif -%}
                            {%- break -%}
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endif -%}
                      <a class="ldh-pill ldh-pill--primary" href="{{ s_url }}">Open {{ s_name | escape }} →</a>
                    {%- endif -%}
                  {%- endfor -%}
                {%- else -%}
                  {%- comment -%}Multiple stores — tile row{%- endcomment -%}
                  {%- for t in tags_arr -%}
                    {%- if t != blank -%}
                      {%- assign s_handle = t | remove: 'b2b-' | strip -%}
                      {%- assign s_url = '/pages/' | append: s_handle -%}
                      {%- assign s_name = s_handle | replace: '-', ' ' | capitalize -%}
                      {%- if store_meta != blank -%}
                        {%- for mo in store_meta -%}
                          {%- assign mo_page = mo.page.value | default: mo.page -%}
                          {%- assign mo_slug = mo.slug.value | default: mo.slug -%}
                          {%- assign mo_h = '' -%}
                          {%- if mo_page != blank and mo_page.handle != blank -%}
                            {%- assign mo_h = mo_page.handle | downcase | strip -%}
                          {%- elsif mo_slug != blank -%}
                            {%- assign mo_h = mo_slug | downcase | strip -%}
                          {%- endif -%}
                          {%- if mo_h == s_handle -%}
                            {%- assign mo_name = mo.display_name.value | default: mo.display_name -%}
                            {%- if mo_name != blank -%}{%- assign s_name = mo_name -%}{%- endif -%}
                            {%- if mo_page != blank and mo_page.url != blank -%}{%- assign s_url = mo_page.url -%}{%- endif -%}
                            {%- break -%}
                          {%- endif -%}
                        {%- endfor -%}
                      {%- endif -%}
                      <a class="ldh-pill ldh-pill--store" href="{{ s_url }}">{{ s_name | escape }} →</a>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              {%- endif -%}
              <a class="ldh-pill ldh-pill--secondary" href="{{ portal_url }}?stay=1">{{ block.settings.dashboard_label | escape }}</a>
              <a class="ldh-pill ldh-pill--secondary" href="{{ routes.account_url }}">{{ block.settings.orders_label | escape }}</a>
            </div>
          </div>
        </div>

      {%- elsif block.type == 'second_store' -%}
        <div class="ldh-section ldh-centered ldh-reveal" {{ block.shopify_attributes }}>
          <div class="ldh-wrap ldh-wrap--narrow">
            <h2 class="ldh-h2">{{ block.settings.headline | escape }}</h2>
            <p class="ldh-body">{{ block.settings.body | escape }}</p>
            <a class="ldh-btn ldh-btn--outline" href="{{ explainer_url }}">{{ block.settings.cta_label | escape }} →</a>
          </div>
        </div>

      {%- elsif block.type == 'examples' -%}
        <div class="ldh-section ldh-carousel-section ldh-reveal" {{ block.shopify_attributes }}>
          <div class="ldh-wrap">
            <h2 class="ldh-h2 ldh-centered-text">{{ block.settings.headline | escape }}</h2>
            <p class="ldh-body ldh-centered-text ldh-carousel-sub">{{ block.settings.subhead | escape }}</p>
          </div>
          <div class="ldh-carousel" data-ldh-carousel>
            <div class="ldh-carousel-shell">
              <button class="ldh-arrow ldh-arrow--left" type="button" aria-label="Previous" data-ldh-prev>&#8249;</button>
              <div class="ldh-track" data-ldh-track>
                {%- assign ex_count = 0 -%}
                {%- for b2 in section.blocks -%}
                  {%- if b2.type == 'example' -%}
                    {%- assign ex_count = ex_count | plus: 1 -%}
                    <div class="ldh-slide" data-ldh-slide {{ b2.shopify_attributes }}>
                      <div class="ldh-slide-inner">
                        {%- if b2.settings.image != blank -%}
                          {{ b2.settings.image | image_url: width: 1600 | image_tag: class: 'ldh-slide-img', loading: 'lazy', alt: b2.settings.alt | default: 'Team product example' }}
                        {%- else -%}
                          <div class="ldh-slide-placeholder">Add an image in the Theme Editor</div>
                        {%- endif -%}
                        {%- if b2.settings.caption != blank -%}
                          <div class="ldh-slide-cap">{{ b2.settings.caption | escape }}</div>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
                {%- if ex_count == 0 -%}
                  <div class="ldh-slide" data-ldh-slide>
                    <div class="ldh-slide-inner">
                      <div class="ldh-slide-placeholder">Add "Example slide" blocks in the Theme Editor to populate this carousel</div>
                    </div>
                  </div>
                {%- endif -%}
              </div>
              <button class="ldh-arrow ldh-arrow--right" type="button" aria-label="Next" data-ldh-next>&#8250;</button>
            </div>
            <div class="ldh-dots" data-ldh-dots></div>
          </div>
        </div>

      {%- endif -%}

    {%- endfor -%}

  {%- else -%}

    {%- comment -%}======= LOGGED-OUT VIEW ======={%- endcomment -%}

    {%- for block in section.blocks -%}

      {%- if block.type == 'hero' -%}
        <div class="ldh-section ldh-hero ldh-reveal" {{ block.shopify_attributes }}>
          <div class="ldh-wrap ldh-hero-wrap">
            <h1 class="ldh-hero-h1">{{ block.settings.headline | newline_to_br }}</h1>
            <p class="ldh-hero-sub">{{ block.settings.subhead | escape }}</p>
            <div class="ldh-hero-cta-wrap">
              <a class="ldh-btn ldh-btn--primary" href="{{ explainer_url }}">{{ block.settings.cta_label | escape }} →</a>
              <p class="ldh-hero-caption">{{ block.settings.caption | escape }}</p>
            </div>
          </div>
        </div>

      {%- elsif block.type == 'speed' -%}
        <div class="ldh-section ldh-speed ldh-reveal" {{ block.shopify_attributes }}>
          <div class="ldh-wrap ldh-wrap--narrow ldh-centered-text">
            <h2 class="ldh-h2">{{ block.settings.headline | escape }}</h2>
            <p class="ldh-body">{{ block.settings.subhead | escape }}</p>
            <div class="ldh-stats-row">
              <div class="ldh-stat ldh-reveal" data-delay="0">
                <div class="ldh-stat-num">{{ block.settings.stat1_num | escape }}</div>
                <div class="ldh-stat-label">{{ block.settings.stat1_label | escape }}</div>
              </div>
              <div class="ldh-stat ldh-reveal" data-delay="80">
                <div class="ldh-stat-num">{{ block.settings.stat2_num | escape }}</div>
                <div class="ldh-stat-label">{{ block.settings.stat2_label | escape }}</div>
              </div>
              <div class="ldh-stat ldh-reveal" data-delay="160">
                <div class="ldh-stat-num">{{ block.settings.stat3_num | escape }}</div>
                <div class="ldh-stat-label">{{ block.settings.stat3_label | escape }}</div>
              </div>
            </div>
          </div>
        </div>

      {%- elsif block.type == 'steps' -%}
        <div class="ldh-section ldh-steps-section ldh-reveal" {{ block.shopify_attributes }}>
          <div class="ldh-wrap ldh-wrap--medium">
            <h2 class="ldh-h2">{{ block.settings.headline | escape }}</h2>
            <div class="ldh-steps">
              <div class="ldh-step ldh-reveal" data-delay="0">
                <div class="ldh-step-num">01</div>
                <div class="ldh-step-body">
                  <strong class="ldh-step-title">{{ block.settings.step1_title | escape }}</strong>
                  <p class="ldh-step-desc">{{ block.settings.step1_desc | escape }}</p>
                </div>
              </div>
              <div class="ldh-step ldh-reveal" data-delay="80">
                <div class="ldh-step-num">02</div>
                <div class="ldh-step-body">
                  <strong class="ldh-step-title">{{ block.settings.step2_title | escape }}</strong>
                  <p class="ldh-step-desc">{{ block.settings.step2_desc | escape }}</p>
                </div>
              </div>
              <div class="ldh-step ldh-reveal" data-delay="160">
                <div class="ldh-step-num">03</div>
                <div class="ldh-step-body">
                  <strong class="ldh-step-title">{{ block.settings.step3_title | escape }}</strong>
                  <p class="ldh-step-desc">{{ block.settings.step3_desc | escape }}</p>
                </div>
              </div>
            </div>
          </div>
        </div>

      {%- elsif block.type == 'examples' -%}
        <div class="ldh-section ldh-carousel-section ldh-reveal" {{ block.shopify_attributes }}>
          <div class="ldh-wrap ldh-centered-text">
            <h2 class="ldh-h2">{{ block.settings.headline | escape }}</h2>
            <p class="ldh-body ldh-carousel-sub">{{ block.settings.subhead | escape }}</p>
          </div>
          <div class="ldh-carousel" data-ldh-carousel>
            <div class="ldh-carousel-shell">
              <button class="ldh-arrow ldh-arrow--left" type="button" aria-label="Previous" data-ldh-prev>&#8249;</button>
              <div class="ldh-track" data-ldh-track>
                {%- assign ex_count = 0 -%}
                {%- for b2 in section.blocks -%}
                  {%- if b2.type == 'example' -%}
                    {%- assign ex_count = ex_count | plus: 1 -%}
                    <div class="ldh-slide" data-ldh-slide {{ b2.shopify_attributes }}>
                      <div class="ldh-slide-inner">
                        {%- if b2.settings.image != blank -%}
                          {{ b2.settings.image | image_url: width: 1600 | image_tag: class: 'ldh-slide-img', loading: 'lazy', alt: b2.settings.alt | default: 'Team product example' }}
                        {%- else -%}
                          <div class="ldh-slide-placeholder">Add an image in the Theme Editor</div>
                        {%- endif -%}
                        {%- if b2.settings.caption != blank -%}
                          <div class="ldh-slide-cap">{{ b2.settings.caption | escape }}</div>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
                {%- if ex_count == 0 -%}
                  <div class="ldh-slide" data-ldh-slide>
                    <div class="ldh-slide-inner">
                      <div class="ldh-slide-placeholder">Add "Example slide" blocks in the Theme Editor to populate this carousel</div>
                    </div>
                  </div>
                {%- endif -%}
              </div>
              <button class="ldh-arrow ldh-arrow--right" type="button" aria-label="Next" data-ldh-next>&#8250;</button>
            </div>
            <div class="ldh-dots" data-ldh-dots></div>
          </div>
        </div>

      {%- elsif block.type == 'final_cta' -%}
        <div class="ldh-section ldh-final ldh-reveal" {{ block.shopify_attributes }}>
          <div class="ldh-wrap ldh-wrap--narrow ldh-centered-text">
            <h2 class="ldh-h2 ldh-h2--large">{{ block.settings.headline | escape }}</h2>
            <p class="ldh-body">{{ block.settings.subhead | escape }}</p>
            <a class="ldh-btn ldh-btn--primary" href="{{ explainer_url }}">{{ block.settings.cta_label | escape }} →</a>
          </div>
        </div>

      {%- endif -%}

    {%- endfor -%}

  {%- endif -%}

</section>

<style>
  /* ===== RESET & BASE ===== */
  .ldh {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    color: #0b0b0b;
    background: #fff;
    -webkit-font-smoothing: antialiased;
  }

  .ldh-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .ldh-wrap--narrow { max-width: 680px; }
  .ldh-wrap--medium { max-width: 860px; }
  .ldh-centered-text { text-align: center; }

  /* ===== SCROLL REVEAL ===== */
  @media (prefers-reduced-motion: no-preference) {
    .ldh-reveal {
      opacity: 0;
      transform: translateY(14px);
      transition: opacity 0.4s ease-out, transform 0.4s ease-out;
    }
    .ldh-reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ===== SECTIONS ===== */
  .ldh-section {
    padding: 100px 0;
  }
  @media (max-width: 600px) {
    .ldh-section { padding: 60px 0; }
  }

  /* ===== TYPOGRAPHY ===== */
  .ldh-h2 {
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.08;
    margin: 0 0 16px;
    color: #0b0b0b;
  }
  .ldh-h2--large {
    font-size: clamp(32px, 5vw, 64px);
  }
  .ldh-body {
    font-size: clamp(16px, 2vw, 20px);
    color: rgba(0,0,0,.6);
    line-height: 1.6;
    margin: 0 0 40px;
    font-weight: 400;
  }

  /* ===== BUTTONS ===== */
  .ldh-btn {
    display: inline-block;
    padding: 16px 36px;
    border-radius: 100px;
    font-weight: 700;
    font-size: 16px;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    cursor: pointer;
  }
  .ldh-btn--primary {
    background: #0b0b0b;
    color: #fff;
    border: 1px solid rgba(183,163,106,.5);
  }
  .ldh-btn--primary:hover { opacity: .88; transform: translateY(-1px); }
  .ldh-btn--outline {
    background: transparent;
    color: #0b0b0b;
    border: 1.5px solid rgba(0,0,0,.25);
  }
  .ldh-btn--outline:hover { border-color: #0b0b0b; }

  /* ===== HERO (LOGGED-OUT) ===== */
  .ldh-hero {
    padding-top: 140px;
    padding-bottom: 140px;
    text-align: center;
  }
  @media (max-width: 600px) {
    .ldh-hero { padding-top: 80px; padding-bottom: 80px; }
  }
  .ldh-hero-wrap { max-width: 860px; margin: 0 auto; padding: 0 24px; }
  .ldh-hero-h1 {
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.04;
    margin: 0 0 24px;
    color: #0b0b0b;
  }
  .ldh-hero-sub {
    font-size: clamp(17px, 2.2vw, 22px);
    color: rgba(0,0,0,.58);
    line-height: 1.6;
    margin: 0 auto 40px;
    max-width: 560px;
    font-weight: 400;
  }
  .ldh-hero-cta-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .ldh-hero-caption {
    font-size: 13px;
    color: rgba(0,0,0,.42);
    margin: 0;
    letter-spacing: 0.01em;
  }

  /* ===== SPEED PROOF (LOGGED-OUT) ===== */
  .ldh-speed {
    background: #faf9f6;
    border-top: 1px solid rgba(0,0,0,.06);
    border-bottom: 1px solid rgba(0,0,0,.06);
  }
  .ldh-stats-row {
    display: flex;
    gap: 0;
    justify-content: center;
    margin-top: 48px;
    border: 1px solid rgba(0,0,0,.09);
    border-radius: 16px;
    overflow: hidden;
  }
  .ldh-stat {
    flex: 1;
    padding: 40px 24px;
    border-right: 1px solid rgba(0,0,0,.09);
    text-align: center;
  }
  .ldh-stat:last-child { border-right: none; }
  .ldh-stat-num {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: rgba(183,163,106,1);
    line-height: 1;
    margin-bottom: 8px;
  }
  .ldh-stat-label {
    font-size: 13px;
    color: rgba(0,0,0,.55);
    font-weight: 500;
    line-height: 1.4;
  }
  @media (max-width: 600px) {
    .ldh-stats-row {
      flex-direction: column;
      border-radius: 12px;
    }
    .ldh-stat {
      border-right: none;
      border-bottom: 1px solid rgba(0,0,0,.09);
      padding: 28px 16px;
    }
    .ldh-stat:last-child { border-bottom: none; }
  }

  /* ===== STEPS (LOGGED-OUT) ===== */
  .ldh-steps-section { background: #fff; }
  .ldh-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 56px;
  }
  .ldh-step {
    display: flex;
    align-items: flex-start;
    gap: 40px;
    padding: 40px 0;
    border-bottom: 1px solid rgba(0,0,0,.07);
  }
  .ldh-step:last-child { border-bottom: none; }
  .ldh-step-num {
    font-size: clamp(56px, 8vw, 96px);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    color: rgba(183,163,106,.4);
    flex-shrink: 0;
    width: 120px;
    text-align: right;
  }
  .ldh-step-body { padding-top: 8px; flex: 1; }
  .ldh-step-title {
    display: block;
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 700;
    color: #0b0b0b;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }
  .ldh-step-desc {
    font-size: clamp(15px, 1.8vw, 18px);
    color: rgba(0,0,0,.6);
    line-height: 1.6;
    margin: 0;
  }
  @media (max-width: 600px) {
    .ldh-step {
      flex-direction: column;
      gap: 12px;
      padding: 32px 0;
    }
    .ldh-step-num {
      font-size: 48px;
      width: auto;
      text-align: left;
    }
  }

  /* ===== CAROUSEL ===== */
  .ldh-carousel-section { overflow: hidden; }
  .ldh-carousel-sub { margin-bottom: 40px; }
  .ldh-carousel { margin-top: 40px; position: relative; }
  .ldh-carousel-shell {
    position: relative;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .ldh-track {
    flex: 1;
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    gap: 24px;
    padding: 0 4px 4px;
  }
  .ldh-track::-webkit-scrollbar { display: none; }
  .ldh-slide {
    flex: 0 0 min(80vw, 720px);
    scroll-snap-align: start;
    border-radius: 16px;
    overflow: hidden;
    background: #f5f5f5;
  }
  .ldh-slide-inner {
    width: 100%;
    aspect-ratio: 16/9;
    position: relative;
    overflow: hidden;
  }
  .ldh-slide-img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .ldh-slide-placeholder {
    width: 100%; height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(0,0,0,.35);
    font-size: 14px;
    padding: 24px;
    text-align: center;
    box-sizing: border-box;
  }
  .ldh-slide-cap {
    padding: 12px 16px;
    font-size: 13px;
    color: rgba(0,0,0,.55);
    text-align: center;
  }
  .ldh-arrow {
    flex-shrink: 0;
    width: 44px; height: 44px;
    border-radius: 50%;
    border: 1.5px solid rgba(0,0,0,.15);
    background: #fff;
    font-size: 24px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #0b0b0b;
    transition: border-color 0.2s;
    line-height: 1;
    padding: 0;
  }
  .ldh-arrow:hover { border-color: #0b0b0b; }
  .ldh-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }
  .ldh-dotbtn {
    width: 7px; height: 7px;
    border-radius: 50%;
    border: none;
    background: rgba(0,0,0,.18);
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }
  .ldh-dotbtn.is-active {
    background: rgba(183,163,106,1);
    transform: scale(1.35);
  }
  @media (max-width: 600px) {
    .ldh-arrow { display: none; }
    .ldh-slide { flex: 0 0 88vw; }
  }

  /* ===== FINAL CTA (LOGGED-OUT) ===== */
  .ldh-final {
    background: #faf9f6;
    border-top: 1px solid rgba(0,0,0,.06);
  }
  .ldh-final .ldh-h2 { margin-bottom: 20px; }

  /* ===== LOGGED-IN: WELCOME ===== */
  .ldh-welcome {
    padding-top: 80px;
    padding-bottom: 60px;
    border-bottom: 1px solid rgba(0,0,0,.07);
  }
  .ldh-welcome-h1 {
    font-size: clamp(32px, 5vw, 60px);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 14px;
  }
  .ldh-welcome-sub {
    font-size: clamp(15px, 2vw, 18px);
    color: rgba(0,0,0,.6);
    margin: 0 0 32px;
    line-height: 1.5;
  }
  .ldh-action-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }
  .ldh-pill {
    display: inline-block;
    padding: 12px 24px;
    border-radius: 100px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }
  .ldh-pill--primary {
    background: #0b0b0b;
    color: #fff;
    border: 1px solid rgba(183,163,106,.5);
  }
  .ldh-pill--primary:hover { opacity: .88; transform: translateY(-1px); }
  .ldh-pill--store {
    background: rgba(183,163,106,.12);
    color: #5a4f2e;
    border: 1px solid rgba(183,163,106,.4);
  }
  .ldh-pill--store:hover { background: rgba(183,163,106,.22); }
  .ldh-pill--secondary {
    background: #fff;
    color: #0b0b0b;
    border: 1.5px solid rgba(0,0,0,.18);
  }
  .ldh-pill--secondary:hover { border-color: #0b0b0b; }

  /* ===== LOGGED-IN: SECOND STORE ===== */
  .ldh-centered { text-align: center; }

  /* ===== MARQUEE (kept from previous version) ===== */
  .ss-marquee-wrap {
    overflow: hidden;
    border-top: 1px solid rgba(0,0,0,.06);
    border-bottom: 1px solid rgba(0,0,0,.06);
    padding: 14px 0;
    background: #faf9f6;
  }
  .ss-marquee-track {
    display: flex;
    gap: 0;
    animation: ssMarquee 28s linear infinite;
    white-space: nowrap;
    will-change: transform;
  }
  .ss-marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    color: rgba(0,0,0,.5);
    padding: 0 32px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .ss-marquee-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: rgba(183,163,106,.7);
    flex-shrink: 0;
  }
  @keyframes ssMarquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ss-marquee-track { animation: none; }
  }
</style>

<script>
(function(){
  /* ===== SCROLL REVEAL ===== */
  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    var revealEls = document.querySelectorAll('#ldh-{{ section.id }} .ldh-reveal');
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var delay = entry.target.getAttribute('data-delay') || 0;
            setTimeout(function() {
              entry.target.classList.add('is-visible');
            }, parseInt(delay, 10));
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      revealEls.forEach(function(el) { io.observe(el); });
    } else {
      revealEls.forEach(function(el) { el.classList.add('is-visible'); });
    }
  }

  /* ===== CAROUSEL(S) ===== */
  var carousels = document.querySelectorAll('#ldh-{{ section.id }} [data-ldh-carousel]');
  carousels.forEach(function(carousel) {
    var track = carousel.querySelector('[data-ldh-track]');
    if (!track) return;
    var slides = Array.prototype.slice.call(track.querySelectorAll('[data-ldh-slide]'));
    if (slides.length < 2) return;

    var btnPrev = carousel.querySelector('[data-ldh-prev]');
    var btnNext = carousel.querySelector('[data-ldh-next]');
    var dotsWrap = carousel.querySelector('[data-ldh-dots]');
    var index = 0;
    var timer = null;
    var autoplayMs = {{ section.settings.autoplay_ms | default: 4500 }};

    function setActive(i) {
      index = (i + slides.length) % slides.length;
      track.scrollTo({ left: slides[index].offsetLeft, behavior: 'smooth' });
      updateDots();
    }
    function buildDots() {
      if (!dotsWrap) return;
      dotsWrap.innerHTML = '';
      slides.forEach(function(_, i) {
        var b = document.createElement('button');
        b.type = 'button';
        b.className = 'ldh-dotbtn';
        b.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        b.addEventListener('click', function() { stop(); setActive(i); start(); });
        dotsWrap.appendChild(b);
      });
      updateDots();
    }
    function updateDots() {
      if (!dotsWrap) return;
      var dots = dotsWrap.querySelectorAll('.ldh-dotbtn');
      dots.forEach(function(d, i) {
        d.classList.toggle('is-active', i === index);
      });
    }
    function next() { setActive(index + 1); }
    function prev() { setActive(index - 1); }
    function start() {
      stop();
      timer = setInterval(next, Math.max(2500, autoplayMs));
    }
    function stop() {
      if (timer) clearInterval(timer);
      timer = null;
    }

    if (btnNext) btnNext.addEventListener('click', function() { stop(); next(); start(); });
    if (btnPrev) btnPrev.addEventListener('click', function() { stop(); prev(); start(); });

    var scrollTimeout = null;
    track.addEventListener('scroll', function() {
      if (scrollTimeout) clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(function() {
        var best = 0, bestDist = Infinity;
        slides.forEach(function(s, i) {
          var dist = Math.abs(track.scrollLeft - s.offsetLeft);
          if (dist < bestDist) { bestDist = dist; best = i; }
        });
        index = best;
        updateDots();
      }, 100);
    }, { passive: true });

    buildDots();
    setActive(0);
    start();
    carousel.addEventListener('mouseenter', stop);
    carousel.addEventListener('mouseleave', start);
  });
})();
</script>

