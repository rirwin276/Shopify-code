{% comment %}
  LANDING — Apple-style (V11)
  - Settings-based (no blocks required) — works with existing templates/index.json
  - Logged-out: Hero → Speed proof → How it works → Final CTA → Marquee
  - Logged-in: Welcome by name → Store links → Second store CTA → Marquee
  - All original V9 schema settings preserved (kicker, primary_title, dashboard_image, etc.)
  - Dashboard image kept in schema but hidden via CSS — re-enable anytime.
  - "~15 minutes" build time — never "48 hours".
  - Scroll animations via IntersectionObserver, respects prefers-reduced-motion.
{% endcomment %}

{%- assign dashboard_url = section.settings.dashboard_url | default: '/pages/portal' -%}
{%- assign request_url = section.settings.request_url | default: '/pages/private-storefronts' -%}
{%- assign mo_type = section.settings.metaobject_type | default: 'storefront' | strip -%}

{%- comment -%}Logged-in: parse storefront tags & metaobjects (same logic as portal-router){%- endcomment -%}
{%- assign has_storefront = false -%}
{%- assign store_count = 0 -%}
{%- assign storefront_tags = '' -%}
{%- assign admin_handles = '' -%}

{%- if customer -%}
  {%- for tag in customer.tags -%}
    {%- assign tag_down = tag | downcase | strip -%}
    {%- if tag_down contains 'b2b-admin-' -%}
      {%- assign ah = tag_down | remove: 'b2b-admin-' | strip -%}
      {%- if ah != blank -%}
        {%- assign admin_handles = admin_handles | append: '||' | append: ah | append: '||' -%}
      {%- endif -%}
    {%- elsif tag_down contains 'b2b-' -%}
      {%- assign has_storefront = true -%}
      {%- assign storefront_tags = storefront_tags | append: tag_down | append: '||' -%}
      {%- assign store_count = store_count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- assign store_meta = blank -%}
{%- if shop.metaobjects[mo_type] and shop.metaobjects[mo_type].values != blank -%}
  {%- assign store_meta = shop.metaobjects[mo_type].values -%}
{%- endif -%}

{%- comment -%}Customer display name{%- endcomment -%}
{%- assign welcome_name = customer.first_name | strip -%}
{%- if welcome_name == blank -%}
  {%- assign welcome_name = customer.email | split: '@' | first -%}
{%- endif -%}

<section class="ldh" data-ldh id="ldh-{{ section.id }}">

  {%- if customer -%}

    {%- comment -%}======= LOGGED-IN VIEW ======={%- endcomment -%}

    <div class="ldh-section ldh-welcome ldh-reveal">
      <div class="ldh-wrap">
        <h1 class="ldh-welcome-h1">{{ section.settings.welcome_prefix | escape }}{{ welcome_name | escape }}.</h1>
        <p class="ldh-welcome-sub">{{ section.settings.greeting_sub | escape }}</p>

        <div class="ldh-action-row">
          {%- if has_storefront -%}
            {%- assign tags_arr = storefront_tags | split: '||' -%}
            {%- if store_count == 1 -%}
              {%- comment -%}Single store — one big primary button{%- endcomment -%}
              {%- for t in tags_arr -%}
                {%- if t != blank -%}
                  {%- assign s_handle = t | remove: 'b2b-' | strip -%}
                  {%- assign s_url = '/pages/' | append: s_handle -%}
                  {%- assign s_name = s_handle | replace: '-', ' ' | capitalize -%}
                  {%- if store_meta != blank -%}
                    {%- for mo in store_meta -%}
                      {%- assign mo_page = mo.page.value | default: mo.page -%}
                      {%- assign mo_slug = mo.slug.value | default: mo.slug -%}
                      {%- assign mo_h = '' -%}
                      {%- if mo_page != blank and mo_page.handle != blank -%}
                        {%- assign mo_h = mo_page.handle | downcase | strip -%}
                      {%- elsif mo_slug != blank -%}
                        {%- assign mo_h = mo_slug | downcase | strip -%}
                      {%- endif -%}
                      {%- if mo_h == s_handle -%}
                        {%- assign mo_name = mo.display_name.value | default: mo.display_name -%}
                        {%- if mo_name != blank -%}{%- assign s_name = mo_name -%}{%- endif -%}
                        {%- if mo_page != blank and mo_page.url != blank -%}{%- assign s_url = mo_page.url -%}{%- endif -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                  <a class="ldh-pill ldh-pill--primary" href="{{ s_url }}">Open {{ s_name | escape }} →</a>
                {%- endif -%}
              {%- endfor -%}
            {%- else -%}
              {%- comment -%}Multiple stores — tile row{%- endcomment -%}
              {%- for t in tags_arr -%}
                {%- if t != blank -%}
                  {%- assign s_handle = t | remove: 'b2b-' | strip -%}
                  {%- assign s_url = '/pages/' | append: s_handle -%}
                  {%- assign s_name = s_handle | replace: '-', ' ' | capitalize -%}
                  {%- if store_meta != blank -%}
                    {%- for mo in store_meta -%}
                      {%- assign mo_page = mo.page.value | default: mo.page -%}
                      {%- assign mo_slug = mo.slug.value | default: mo.slug -%}
                      {%- assign mo_h = '' -%}
                      {%- if mo_page != blank and mo_page.handle != blank -%}
                        {%- assign mo_h = mo_page.handle | downcase | strip -%}
                      {%- elsif mo_slug != blank -%}
                        {%- assign mo_h = mo_slug | downcase | strip -%}
                      {%- endif -%}
                      {%- if mo_h == s_handle -%}
                        {%- assign mo_name = mo.display_name.value | default: mo.display_name -%}
                        {%- if mo_name != blank -%}{%- assign s_name = mo_name -%}{%- endif -%}
                        {%- if mo_page != blank and mo_page.url != blank -%}{%- assign s_url = mo_page.url -%}{%- endif -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                  {%- endif -%}
                  <a class="ldh-pill ldh-pill--store" href="{{ s_url }}">{{ s_name | escape }} →</a>
                {%- endif -%}
              {%- endfor -%}
            {%- endif -%}
          {%- endif -%}
          <a class="ldh-pill ldh-pill--secondary" href="{{ dashboard_url }}?stay=1">{{ section.settings.dashboard_label | escape }}</a>
          <a class="ldh-pill ldh-pill--secondary" href="{{ routes.account_url }}">{{ section.settings.orders_label | escape }}</a>
        </div>
      </div>
    </div>

    <div class="ldh-section ldh-centered ldh-reveal">
      <div class="ldh-wrap ldh-wrap--narrow">
        <h2 class="ldh-h2">{{ section.settings.second_store_headline | escape }}</h2>
        <p class="ldh-body">{{ section.settings.second_store_body | escape }}</p>
        <a class="ldh-btn ldh-btn--outline" href="{{ request_url }}">{{ section.settings.second_store_cta | escape }} →</a>
      </div>
    </div>

  {%- else -%}

    {%- comment -%}======= LOGGED-OUT VIEW ======={%- endcomment -%}

    {%- comment -%}Hero{%- endcomment -%}
    <div class="ldh-section ldh-hero ldh-reveal">
      <div class="ldh-wrap ldh-hero-wrap">
        <h1 class="ldh-hero-h1">{{ section.settings.hero_headline | newline_to_br }}</h1>
        <p class="ldh-hero-sub">{{ section.settings.hero_sub | escape }}</p>
        <div class="ldh-hero-cta-wrap">
          <a class="ldh-btn ldh-btn--primary" href="{{ request_url }}">{{ section.settings.hero_cta_label | escape }}</a>
          <a class="ldh-btn ldh-btn--outline ldh-btn--signin" href="{{ routes.storefront_login_url }}?return_to={{ dashboard_url | url_encode }}">{{ section.settings.hero_signin_label | escape }}</a>
          <p class="ldh-hero-caption">{{ section.settings.hero_caption | escape }}</p>
        </div>
      </div>
    </div>

    {%- comment -%}Speed proof{%- endcomment -%}
    <div class="ldh-section ldh-speed ldh-reveal">
      <div class="ldh-wrap ldh-wrap--narrow ldh-centered-text">
        <h2 class="ldh-h2">{{ section.settings.speed_headline | escape }}</h2>
        <p class="ldh-body">{{ section.settings.speed_sub | escape }}</p>
        <div class="ldh-stats-row">
          <div class="ldh-stat ldh-reveal" data-delay="0">
            <div class="ldh-stat-num">{{ section.settings.stat1_num | escape }}</div>
            <div class="ldh-stat-label">{{ section.settings.stat1_label | escape }}</div>
          </div>
          <div class="ldh-stat ldh-reveal" data-delay="80">
            <div class="ldh-stat-num">{{ section.settings.stat2_num | escape }}</div>
            <div class="ldh-stat-label">{{ section.settings.stat2_label | escape }}</div>
          </div>
          <div class="ldh-stat ldh-reveal" data-delay="160">
            <div class="ldh-stat-num">{{ section.settings.stat3_num | escape }}</div>
            <div class="ldh-stat-label">{{ section.settings.stat3_label | escape }}</div>
          </div>
        </div>
      </div>
    </div>

    {%- comment -%}How it works{%- endcomment -%}
    <div class="ldh-section ldh-steps-section ldh-reveal">
      <div class="ldh-wrap ldh-wrap--medium">
        <h2 class="ldh-h2">{{ section.settings.steps_headline | escape }}</h2>
        <div class="ldh-steps">
          <div class="ldh-step ldh-reveal" data-delay="0">
            <div class="ldh-step-num">
              <div class="ldh-step-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><polyline points="16 16 12 12 8 16"/><line x1="12" y1="12" x2="12" y2="21"/><path d="M20.39 18.39A5 5 0 0 0 18 9h-1.26A8 8 0 1 0 3 16.3"/></svg>
              </div>
              01
            </div>
            <div class="ldh-step-body">
              <strong class="ldh-step-title">{{ section.settings.step1_title | escape }}</strong>
              <p class="ldh-step-desc">{{ section.settings.step1_desc | escape }}</p>
            </div>
          </div>
          <div class="ldh-step ldh-reveal" data-delay="80">
            <div class="ldh-step-num">
              <div class="ldh-step-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
              </div>
              02
            </div>
            <div class="ldh-step-body">
              <strong class="ldh-step-title">{{ section.settings.step2_title | escape }}</strong>
              <p class="ldh-step-desc">{{ section.settings.step2_desc | escape }}</p>
            </div>
          </div>
          <div class="ldh-step ldh-reveal" data-delay="160">
            <div class="ldh-step-num">
              <div class="ldh-step-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              </div>
              03
            </div>
            <div class="ldh-step-body">
              <strong class="ldh-step-title">{{ section.settings.step3_title | escape }}</strong>
              <p class="ldh-step-desc">{{ section.settings.step3_desc | escape }}</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    {%- comment -%}Final CTA{%- endcomment -%}
    <div class="ldh-section ldh-final ldh-reveal">
      <div class="ldh-wrap ldh-wrap--narrow ldh-centered-text">
        <h2 class="ldh-h2 ldh-h2--large">{{ section.settings.final_headline | escape }}</h2>
        <p class="ldh-body">{{ section.settings.final_sub | escape }}</p>
        <a class="ldh-btn ldh-btn--primary" href="{{ request_url }}">{{ section.settings.final_cta_label | escape }} →</a>
      </div>
    </div>

  {%- endif -%}

  {%- comment -%}
    Marquee — always visible.
    Items are intentionally duplicated to create a seamless infinite scroll loop:
    the CSS animation shifts the track by -50%, revealing the duplicate set,
    then loops — producing continuous motion without a visible jump.
  {%- endcomment -%}
  <div class="ss-marquee-wrap">
    <div class="ss-marquee-track">
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Youth Baseball</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Travel Soccer</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Military Units</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Fire Departments</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Youth Football</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Law Enforcement</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Travel Softball</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Corporate Teams</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Youth Hockey</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Cheer Squads</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Wrestling Teams</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Bachelor Trips</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Family Reunions</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>First Responders</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Youth Baseball</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Travel Soccer</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Military Units</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Fire Departments</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Youth Football</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Law Enforcement</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Travel Softball</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Corporate Teams</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Youth Hockey</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Cheer Squads</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Wrestling Teams</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Bachelor Trips</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>Family Reunions</span>
      <span class="ss-marquee-item"><span class="ss-marquee-dot"></span>First Responders</span>
    </div>
  </div>

  {%- comment -%}
    Dashboard image kept in schema for theme editor compatibility.
    Hidden via CSS — user can re-enable in theme editor by removing display:none below.
  {%- endcomment -%}
  {%- if section.settings.dashboard_image != blank -%}
    <div class="ldh-dashboard-img-hidden" aria-hidden="true">
      <img src="{{ section.settings.dashboard_image | image_url: width: 1400 }}" alt="" loading="lazy" width="{{ section.settings.dashboard_image.width }}" height="{{ section.settings.dashboard_image.height }}">
    </div>
  {%- endif -%}

</section>

<style>
  /* ===== RESET & BASE ===== */
  .ldh {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    color: #0b0b0b;
    background: #fff;
    -webkit-font-smoothing: antialiased;
  }

  .ldh-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .ldh-wrap--narrow { max-width: 680px; }
  .ldh-wrap--medium { max-width: 860px; }
  .ldh-centered-text { text-align: center; }

  /* ===== SCROLL REVEAL ===== */
  @media (prefers-reduced-motion: no-preference) {
    .ldh-reveal {
      opacity: 0;
      transform: translateY(14px);
      transition: opacity 0.4s ease-out, transform 0.4s ease-out;
    }
    .ldh-reveal.is-visible {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ===== SECTIONS ===== */
  .ldh-section {
    padding: 100px 0;
  }
  @media (max-width: 600px) {
    .ldh-section { padding: 60px 0; }
  }

  /* ===== TYPOGRAPHY ===== */
  .ldh-h2 {
    font-size: clamp(28px, 4vw, 52px);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.08;
    margin: 0 0 16px;
    color: #0b0b0b;
  }
  .ldh-h2--large {
    font-size: clamp(32px, 5vw, 64px);
  }
  .ldh-body {
    font-size: clamp(16px, 2vw, 20px);
    color: rgba(0,0,0,.6);
    line-height: 1.6;
    margin: 0 0 40px;
    font-weight: 400;
  }

  /* ===== BUTTONS ===== */
  .ldh-btn {
    display: inline-block;
    padding: 16px 36px;
    border-radius: 100px;
    font-weight: 700;
    font-size: 16px;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    cursor: pointer;
  }
  .ldh-btn--primary {
    background: #0b0b0b;
    color: #fff;
    border: 1px solid rgba(183,163,106,.5);
  }
  .ldh-btn--primary:hover { opacity: .88; transform: translateY(-1px); }
  .ldh-btn--outline {
    background: transparent;
    color: #0b0b0b;
    border: 1.5px solid rgba(0,0,0,.25);
  }
  .ldh-btn--outline:hover { border-color: #0b0b0b; }

  /* ===== HERO (LOGGED-OUT) ===== */
  .ldh-hero {
    padding-top: 140px;
    padding-bottom: 140px;
    text-align: center;
  }
  @media (max-width: 600px) {
    .ldh-hero { padding-top: 80px; padding-bottom: 80px; }
  }
  .ldh-hero-wrap { max-width: 860px; margin: 0 auto; padding: 0 24px; }
  .ldh-hero-h1 {
    font-size: clamp(48px, 7vw, 96px);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.04;
    margin: 0 0 24px;
    color: #0b0b0b;
  }
  .ldh-hero-sub {
    font-size: clamp(17px, 2.2vw, 22px);
    color: rgba(0,0,0,.58);
    line-height: 1.6;
    margin: 0 auto 40px;
    max-width: 560px;
    font-weight: 400;
  }
  .ldh-hero-cta-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  .ldh-hero-caption {
    font-size: 13px;
    color: rgba(0,0,0,.42);
    margin: 0;
    letter-spacing: 0.01em;
  }

  /* ===== SPEED PROOF (LOGGED-OUT) ===== */
  .ldh-speed {
    background: #faf9f6;
    border-top: 1px solid rgba(0,0,0,.06);
    border-bottom: 1px solid rgba(0,0,0,.06);
  }
  .ldh-stats-row {
    display: flex;
    gap: 0;
    justify-content: center;
    margin-top: 48px;
    border: 1px solid rgba(0,0,0,.09);
    border-radius: 16px;
    overflow: hidden;
  }
  .ldh-stat {
    flex: 1;
    padding: 40px 24px;
    border-right: 1px solid rgba(0,0,0,.09);
    text-align: center;
  }
  .ldh-stat:last-child { border-right: none; }
  .ldh-stat-num {
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 900;
    letter-spacing: -0.03em;
    color: rgba(183,163,106,1);
    line-height: 1;
    margin-bottom: 8px;
  }
  .ldh-stat-label {
    font-size: 13px;
    color: rgba(0,0,0,.55);
    font-weight: 500;
    line-height: 1.4;
  }
  @media (max-width: 600px) {
    .ldh-stats-row {
      flex-direction: column;
      border-radius: 12px;
    }
    .ldh-stat {
      border-right: none;
      border-bottom: 1px solid rgba(0,0,0,.09);
      padding: 28px 16px;
    }
    .ldh-stat:last-child { border-bottom: none; }
  }

  /* ===== STEPS (LOGGED-OUT) ===== */
  .ldh-steps-section { background: #fff; }
  .ldh-steps {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 56px;
  }
  .ldh-step {
    display: flex;
    align-items: flex-start;
    gap: 40px;
    padding: 40px 0;
    border-bottom: 1px solid rgba(0,0,0,.07);
  }
  .ldh-step:last-child { border-bottom: none; }
  .ldh-step-num {
    font-size: clamp(56px, 8vw, 96px);
    font-weight: 900;
    letter-spacing: -0.04em;
    line-height: 1;
    color: rgba(183,163,106,.4);
    flex-shrink: 0;
    width: 120px;
    text-align: right;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 10px;
  }
  .ldh-step-icon {
    width: 40px;
    height: 40px;
    background: rgba(183,163,106,0.12);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .ldh-step-icon svg {
    width: 20px;
    height: 20px;
    stroke: rgba(183,163,106,1);
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .ldh-step-body { padding-top: 8px; flex: 1; }
  .ldh-step-title {
    display: block;
    font-size: clamp(18px, 2.5vw, 24px);
    font-weight: 700;
    color: #0b0b0b;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }
  .ldh-step-desc {
    font-size: clamp(15px, 1.8vw, 18px);
    color: rgba(0,0,0,.6);
    line-height: 1.6;
    margin: 0;
  }
  @media (max-width: 600px) {
    .ldh-step {
      flex-direction: column;
      gap: 12px;
      padding: 32px 0;
    }
    .ldh-step-num {
      font-size: 48px;
      width: auto;
      text-align: left;
      align-items: flex-start;
      flex-direction: row;
      align-items: center;
    }
  }

  /* ===== FINAL CTA (LOGGED-OUT) ===== */
  .ldh-final {
    background: #faf9f6;
    border-top: 1px solid rgba(0,0,0,.06);
  }
  .ldh-final .ldh-h2 { margin-bottom: 20px; }

  /* ===== LOGGED-IN: WELCOME ===== */
  .ldh-welcome {
    padding-top: 80px;
    padding-bottom: 60px;
    border-bottom: 1px solid rgba(0,0,0,.07);
  }
  .ldh-welcome-h1 {
    font-size: clamp(32px, 5vw, 60px);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 0 0 14px;
    position: relative;
  }

  /* Gold underline flourish — draws in under the name on scroll-reveal */
  .ldh-welcome-h1::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -9px;
    height: 3px;
    width: 0%;
    border-radius: 2px;
    background: rgba(183,163,106,1);
    transition: width 700ms ease-out 180ms;
  }
  .ldh-welcome.is-visible .ldh-welcome-h1::after {
    width: 56%;
  }
  @media (prefers-reduced-motion: reduce) {
    .ldh-welcome-h1::after {
      width: 56%;
      transition: none;
    }
  }
  .ldh-welcome-sub {
    font-size: clamp(15px, 2vw, 18px);
    color: rgba(0,0,0,.6);
    margin: 0 0 32px;
    line-height: 1.5;
  }
  .ldh-action-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
  }
  .ldh-pill {
    display: inline-block;
    padding: 12px 24px;
    border-radius: 100px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    transition: opacity 0.2s ease, transform 0.2s ease;
    white-space: nowrap;
  }
  .ldh-pill--primary {
    background: #0b0b0b;
    color: #fff;
    border: 1px solid rgba(183,163,106,.5);
  }
  .ldh-pill--primary:hover { opacity: .88; transform: translateY(-1px); }
  .ldh-pill--store {
    background: rgba(183,163,106,.12);
    color: #5a4f2e;
    border: 1px solid rgba(183,163,106,.4);
  }
  .ldh-pill--store:hover { background: rgba(183,163,106,.22); }
  .ldh-pill--secondary {
    background: #fff;
    color: #0b0b0b;
    border: 1.5px solid rgba(0,0,0,.18);
  }
  .ldh-pill--secondary:hover { border-color: #0b0b0b; }

  /* ===== LOGGED-IN: SECOND STORE ===== */
  .ldh-centered { text-align: center; }

  /* ===== MARQUEE ===== */
  .ss-marquee-wrap {
    overflow: hidden;
    border-top: 1px solid rgba(0,0,0,.06);
    border-bottom: 1px solid rgba(0,0,0,.06);
    padding: 14px 0;
    background: #faf9f6;
  }
  .ss-marquee-track {
    display: flex;
    gap: 0;
    animation: ssMarquee 28s linear infinite;
    white-space: nowrap;
    will-change: transform;
  }
  .ss-marquee-item {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    font-weight: 600;
    color: rgba(0,0,0,.5);
    padding: 0 32px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .ss-marquee-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: rgba(183,163,106,.7);
    flex-shrink: 0;
  }
  @keyframes ssMarquee {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ss-marquee-track { animation: none; }
  }

  /* ===== HIDDEN DASHBOARD IMAGE ===== */
  /* Dashboard image is kept in the schema for theme editor access.
     Remove this rule to re-enable it on the live page. */
  .ldh-dashboard-img-hidden { display: none; }
</style>

<script>
(function(){
  /* ===== SCROLL REVEAL ===== */
  var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    var revealEls = document.querySelectorAll('#ldh-{{ section.id }} .ldh-reveal');
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            var delay = entry.target.getAttribute('data-delay') || 0;
            setTimeout(function() {
              entry.target.classList.add('is-visible');
            }, parseInt(delay, 10));
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1 });
      revealEls.forEach(function(el) { io.observe(el); });
    } else {
      revealEls.forEach(function(el) { el.classList.add('is-visible'); });
    }
  }
})();
</script>

