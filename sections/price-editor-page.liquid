{%- style -%}
  :root {
    --ap-bg: #f0f4f8;
    --ap-card: #ffffff;
    --ap-text: #0f172a;
    --ap-gray: #64748b;
    --ap-border: #e2e8f0;
    --ap-accent: #0f172a;
    --ap-accent2: #6366f1;
    --ap-success: #10b981;
    --ap-danger: #ef4444;
    --ap-shadow: 0 4px 16px rgba(15,23,42,0.08), 0 1px 3px rgba(15,23,42,0.04);
    --ap-radius: 18px;
    --ap-font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Inter", sans-serif;
  }

  .pe-wrap {
    max-width: 980px;
    margin: 0 auto;
    padding: 40px 24px 80px;
    font-family: var(--ap-font);
    color: var(--ap-text);
  }
  .pe-card {
    background: var(--ap-card);
    border: 1px solid var(--ap-border);
    border-radius: var(--ap-radius);
    box-shadow: var(--ap-shadow);
    padding: 28px;
  }
  .pe-head {
    margin-bottom: 18px;
  }
  .pe-head h1 {
    margin: 0 0 8px;
    font-size: clamp(24px, 4vw, 34px);
    letter-spacing: -0.02em;
  }
  .pe-head p {
    margin: 0;
    color: var(--ap-gray);
    font-size: 14px;
  }
  .ap-price-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--ap-border);
  }
  .ap-price-row:last-child { border-bottom: none; }
  .ap-price-label {
    flex: 1;
    font-size: 14px;
    font-weight: 700;
    color: var(--ap-text);
  }
  .ap-price-label span {
    display: block;
    font-size: 11px;
    font-weight: 500;
    color: var(--ap-gray);
    margin-top: 2px;
  }
  /* grouped row: two inputs side-by-side */
  .ap-inputs-group {
    display: flex;
    gap: 12px;
    align-items: flex-end;
  }
  .ap-input-col {
    display: flex;
    flex-direction: column;
    gap: 4px;
    align-items: center;
  }
  .ap-col-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--ap-gray);
    white-space: nowrap;
  }
  .ap-input-wrap {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .ap-dollar {
    font-size: 15px;
    font-weight: 700;
    color: var(--ap-gray);
  }
  .ap-price-input {
    width: 84px;
    padding: 9px 10px;
    border: 1.5px solid var(--ap-border);
    border-radius: 10px;
    font-size: 16px;
    font-weight: 700;
    text-align: center;
    font-family: var(--ap-font);
    background: #fff;
    color: var(--ap-text);
    box-sizing: border-box;
  }
  .ap-price-input:focus {
    outline: none;
    border-color: var(--ap-accent2);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
  }
  .pe-spinner {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 18px;
    padding: 12px 14px;
    border-radius: 12px;
    border: 1px solid #dbeafe;
    background: #eff6ff;
    color: #1d4ed8;
    font-size: 13px;
    font-weight: 600;
  }
  .pe-spinner.ok {
    border-color: #bbf7d0;
    background: #f0fdf4;
    color: #047857;
  }
  .pe-spinner.err {
    border-color: #fecaca;
    background: #fef2f2;
    color: #b91c1c;
  }
  .pe-spinner.hidden {
    display: none;
  }
  .pe-spinner-dot {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: currentColor;
    box-shadow: 0 0 0 4px rgba(29,78,216,0.14);
    flex: 0 0 auto;
  }
  .pe-actions {
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .pe-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: 44px;
    padding: 10px 20px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 700;
    font-family: var(--ap-font);
    border: none;
    background: var(--ap-accent);
    color: #fff;
    cursor: pointer;
    transition: all 0.2s;
  }
  .pe-btn:hover { background: #1e293b; transform: translateY(-1px); }
  .pe-btn:disabled { opacity: 0.65; cursor: not-allowed; transform: none; }
  .pe-status {
    min-height: 20px;
    font-size: 13px;
    font-weight: 600;
  }
  .pe-status.ok { color: #047857; }
  .pe-status.err { color: #b91c1c; }
  .pe-job {
    display: none;
    margin-top: 8px;
    padding: 12px 14px;
    border-radius: 10px;
    border: 1px solid #dbeafe;
    background: #eff6ff;
    color: #1e3a8a;
    font-size: 13px;
    font-weight: 600;
  }

  /* ── MODAL ─────────────────────────────────────────────── */
  .pe-modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15,23,42,0.55);
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }
  .pe-modal-overlay.open { display: flex; }
  .pe-modal {
    background: var(--ap-card);
    border: 1px solid var(--ap-border);
    border-radius: var(--ap-radius);
    box-shadow: 0 24px 64px rgba(15,23,42,0.2);
    padding: 32px 28px 24px;
    max-width: 420px;
    width: 90%;
    text-align: center;
  }
  .pe-modal h2 {
    margin: 0 0 8px;
    font-size: 20px;
    font-weight: 800;
    color: var(--ap-text);
    letter-spacing: -0.01em;
  }
  .pe-modal p {
    margin: 0 0 22px;
    color: var(--ap-gray);
    font-size: 13px;
    line-height: 1.55;
  }
  .pe-modal-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .pe-modal-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    min-height: 48px;
    padding: 12px 20px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 700;
    font-family: var(--ap-font);
    border: none;
    cursor: pointer;
    transition: all 0.2s;
  }
  .pe-modal-btn--primary {
    background: var(--ap-accent);
    color: #fff;
  }
  .pe-modal-btn--primary:hover { background: #1e293b; transform: translateY(-1px); }
  .pe-modal-btn--secondary {
    background: #f1f5f9;
    color: var(--ap-text);
    border: 1.5px solid var(--ap-border);
  }
  .pe-modal-btn--secondary:hover { background: #e2e8f0; transform: translateY(-1px); }
  .pe-modal-btn--ghost {
    background: none;
    color: var(--ap-gray);
    font-weight: 600;
    font-size: 13px;
  }
  .pe-modal-btn--ghost:hover { color: var(--ap-text); }

  /* schedule time picker in modal */
  .pe-schedule-row {
    display: flex;
    align-items: center;
    gap: 10px;
    justify-content: center;
    margin: -4px 0 12px;
    padding: 12px 16px;
    background: #f8fafc;
    border: 1px solid var(--ap-border);
    border-radius: 12px;
  }
  .pe-schedule-row label {
    font-size: 13px;
    font-weight: 700;
    color: var(--ap-text);
    white-space: nowrap;
  }
  #peScheduleTime {
    padding: 8px 12px;
    border: 1.5px solid var(--ap-border);
    border-radius: 8px;
    font-size: 16px;
    font-weight: 700;
    font-family: var(--ap-font);
    color: var(--ap-text);
    background: #fff;
    cursor: pointer;
  }
  #peScheduleTime:focus {
    outline: none;
    border-color: var(--ap-accent2);
    box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
  }

  @media (max-width: 720px) {
    .pe-wrap { padding: 20px 14px 46px; }
    .pe-card { padding: 18px; }
    .ap-price-row { gap: 10px; flex-wrap: wrap; }
    .ap-inputs-group { gap: 8px; }
    .ap-price-input { width: 76px; }
    .pe-btn { width: 100%; }
  }
{%- endstyle -%}

