<script>
(function() {
  var RAILWAY = 'https://printfulautomation-production.up.railway.app';
  var SECRET = {{ editor_secret | json }};
  var originalPrices = {};

  function headers() {
    return {
      'Content-Type': 'application/json',
      'X-Editor-Secret': SECRET
    };
  }

  function setStatus(msg, type) {
    var el = document.getElementById('peStatus');
    el.textContent = msg || '';
    el.className = 'pe-status' + (type ? ' ' + type : '');
  }

  function setJobStatus(msg, visible) {
    var el = document.getElementById('peJobStatus');
    el.textContent = msg || '';
    el.style.display = visible ? 'block' : 'none';
  }

  function setLoadState(msg, type) {
    var el = document.getElementById('peSpinner');
    var text = document.getElementById('peSpinnerText');
    text.textContent = msg || '';
    el.className = 'pe-spinner' + (type ? ' ' + type : '');
    if (!msg) el.classList.add('hidden');
  }

  function applyPrices(prices) {
    document.querySelectorAll('.ap-price-input').forEach(function(input) {
      var key = input.getAttribute('data-module');
      var rawValue = prices && prices[key] != null ? Number(prices[key]) : NaN;
      input.value = Number.isFinite(rawValue) ? String(rawValue) : '';
    });
    // snapshot the loaded values so we can diff later
    originalPrices = {};
    document.querySelectorAll('.ap-price-input').forEach(function(inp) {
      var key = inp.getAttribute('data-module');
      var val = parseFloat(inp.value);
      if (key && Number.isFinite(val)) originalPrices[key] = val;
    });
  }

  function collectChangedPrices() {
    var changed = {};
    document.querySelectorAll('.ap-price-input').forEach(function(inp) {
      var key = inp.getAttribute('data-module');
      var val = parseFloat(inp.value);
      if (!key || !Number.isFinite(val) || val <= 0) return;
      if (originalPrices[key] !== val) {
        changed[key] = val;
      }
    });
    return changed;
  }

  function loadPrices() {
    fetch(RAILWAY + '/api/pricing', {
      method: 'GET',
      headers: headers(),
      cache: 'no-store'
    })
      .then(function(r) {
        if (!r.ok) throw new Error('Failed to load prices (' + r.status + ')');
        return r.json();
      })
      .then(function(data) {
        var prices = data && data.prices ? data.prices : data;
        applyPrices(prices || {});
        setLoadState('Latest prices loaded.', 'ok');
      })
      .catch(function(err) {
        setLoadState('Could not load current prices. You can still edit values and save new pricing.', 'err');
      });
  }

  function pollJob(jobId) {
    var attempts = 0;
    var maxAttempts = 120;

    function tick() {
      attempts += 1;
      fetch(RAILWAY + '/job/' + encodeURIComponent(jobId), {
        method: 'GET',
        headers: { 'X-Editor-Secret': SECRET },
        cache: 'no-store'
      })
      .then(function(r) {
        if (!r.ok) throw new Error('Failed to poll job (' + r.status + ')');
        return r.json();
      })
      .then(function(job) {
        var state = (job.status || job.state || 'running').toLowerCase();
        var progress = job.progress || job.percent || job.pct || '';
        var countText = '';
        if (job.processed != null && job.total != null) {
          countText = ' • ' + job.processed + '/' + job.total;
        }

        setJobStatus('⏳ Repricing job ' + state + (progress !== '' ? ' • ' + progress + '%' : '') + countText, true);

        if (state === 'completed' || state === 'complete' || state === 'success') {
          setJobStatus('✅ Repricing complete.', true);
          return;
        }
        if (state === 'failed' || state === 'error' || state === 'cancelled') {
          setJobStatus('❌ Repricing failed: ' + (job.error || state), true);
          return;
        }
        if (attempts < maxAttempts) {
          setTimeout(tick, 2500);
        } else {
          setJobStatus('⚠️ Repricing still running. Refresh later to check status.', true);
        }
      })
      .catch(function(err) {
        setJobStatus('⚠️ Job status unavailable: ' + err.message, true);
      });
    }

    tick();
  }

  function savePrices(applyExisting, scheduledTime) {
    var btn = document.getElementById('peSaveBtn');
    var changedPrices = collectChangedPrices();

    if (Object.keys(changedPrices).length === 0) {
      setStatus('⚠️ No price changes detected.', 'err');
      return;
    }

    var payload = {
      prices: changedPrices,
      apply_to_existing: applyExisting,
      apply_now: applyExisting && !scheduledTime
    };
    if (scheduledTime) {
      payload.scheduled_time = scheduledTime;
      payload.apply_to_existing = true;
    }

    btn.disabled = true;
    if (scheduledTime) {
      setStatus('⏳ Saving prices and scheduling repricing for ' + scheduledTime + '…');
    } else if (applyExisting) {
      setStatus('⏳ Saving prices and starting repricing…');
    } else {
      setStatus('⏳ Saving prices…');
    }
    setJobStatus('', false);

    fetch(RAILWAY + '/api/pricing', {
      method: 'POST',
      headers: headers(),
      body: JSON.stringify(payload)
    })
      .then(function(r) {
        return r.json().catch(function() { return {}; }).then(function(data) {
          if (!r.ok || data.status === 'error') {
            throw new Error(data.error || ('Failed to save prices (' + r.status + ')'));
          }
          return data;
        });
      })
      .then(function(data) {
        // update snapshot so next save only sends newly changed values
        Object.assign(originalPrices, changedPrices);
        if (scheduledTime) {
          setStatus('✅ Prices saved. Repricing scheduled for ' + scheduledTime + '.', 'ok');
        } else {
          setStatus('✅ Prices saved.', 'ok');
        }
        var jobId = data.job_id || data.jobId || (data.job && (data.job.id || data.job.job_id));
        if (applyExisting && !scheduledTime && jobId) {
          pollJob(jobId);
        } else if (applyExisting && !scheduledTime) {
          setJobStatus('✅ Repricing started in the background.', true);
        }
      })
      .catch(function(err) {
        setStatus('❌ ' + err.message, 'err');
      })
      .finally(function() {
        btn.disabled = false;
      });
  }

  function openModal() {
    // reset schedule section
    document.getElementById('peScheduleSection').style.display = 'none';
    document.getElementById('peModal').classList.add('open');
  }

  function closeModal() {
    document.getElementById('peModal').classList.remove('open');
  }

  document.getElementById('peSaveBtn').addEventListener('click', function() {
    var changed = collectChangedPrices();
    if (Object.keys(changed).length === 0) {
      setStatus('⚠️ No price changes detected. Edit at least one value before saving.', 'err');
      return;
    }
    openModal();
  });

  document.getElementById('peModalApplyNow').addEventListener('click', function() {
    closeModal();
    savePrices(true, null);
  });

  document.getElementById('peModalScheduleBtn').addEventListener('click', function() {
    var section = document.getElementById('peScheduleSection');
    section.style.display = section.style.display === 'none' ? 'block' : 'none';
  });

  document.getElementById('peModalScheduleConfirm').addEventListener('click', function() {
    var time = document.getElementById('peScheduleTime').value || '03:00';
    closeModal();
    savePrices(true, time);
  });

  document.getElementById('peModalFutureOnly').addEventListener('click', function() {
    closeModal();
    savePrices(false, null);
  });

  document.getElementById('peModalCancel').addEventListener('click', closeModal);

  document.getElementById('peModal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });

  loadPrices();
})();
</script>

{%- endif -%}

