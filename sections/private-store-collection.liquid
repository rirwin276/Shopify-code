{% if is_admin %}
<script>
document.addEventListener("DOMContentLoaded", function() {
  const overlay = document.getElementById("psShareOverlay");
  const openBtn = document.getElementById("psShareStoreBtn");
  const openBtnMobile = document.getElementById("psShareStoreBtnMobile");
  const closeBtn = document.getElementById("psShareClose");
  const copyBtn = document.getElementById("psCopyJoinLink");
  const input = document.getElementById("psJoinLink");
  const qrBox = document.getElementById("psQRCode");
  const tabs = document.querySelectorAll("[data-ps-share-tab]");
  const panels = document.querySelectorAll("[data-ps-share-panel]");
  let qrMade = false;

  function openShare() {
    if (!overlay) return;
    overlay.classList.add("open");
    overlay.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";

    if (!qrMade && qrBox && window.QRCode && input) {
      qrBox.innerHTML = "";
      new QRCode(qrBox, {
        text: input.value,
        width: 180,
        height: 180,
        colorDark: "#11100e",
        colorLight: "#ffffff",
        correctLevel: QRCode.CorrectLevel.H
      });
      qrMade = true;
    }
  }

  function closeShare() {
    if (!overlay) return;
    overlay.classList.remove("open");
    overlay.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
  }

  if (openBtn) openBtn.addEventListener("click", openShare);
  if (openBtnMobile) openBtnMobile.addEventListener("click", openShare);
  if (closeBtn) closeBtn.addEventListener("click", closeShare);

  if (overlay) {
    overlay.addEventListener("click", function(e) {
      if (e.target === overlay) closeShare();
    });
  }

  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape") closeShare();
  });

  tabs.forEach(function(tab) {
    tab.addEventListener("click", function() {
      const target = tab.getAttribute("data-ps-share-tab");

      tabs.forEach(function(t) {
        t.classList.toggle("active", t === tab);
      });

      panels.forEach(function(panel) {
        panel.classList.toggle("active", panel.getAttribute("data-ps-share-panel") === target);
      });
    });
  });

  if (copyBtn && input) {
    copyBtn.addEventListener("click", function() {
      const original = copyBtn.textContent;
      const text = input.value;

      function copied() {
        copyBtn.textContent = "Copied";
        setTimeout(function() {
          copyBtn.textContent = original;
        }, 1600);
      }

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(text).then(copied).catch(function() {
          input.select();
          document.execCommand("copy");
          copied();
        });
      } else {
        input.select();
        document.execCommand("copy");
        copied();
      }
    });
  }
});
</script>
{% endif %}

