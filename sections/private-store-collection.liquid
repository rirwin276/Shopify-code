{% comment %}
  PRIVATE STORE HERO — MOBILE "PRIDE" VERSION
  - Desktop: Standard layout.
  - Mobile: HUGE Logo (150px) + Name. Everything else hidden.
{% endcomment %}

{% assign handle = collection.handle | downcase | strip %}
{% assign member_tag = 'storefront-member--' | append: handle %}
{% assign admin_tag  = 'storefront-admin--'  | append: handle %}

{% assign is_admin = false %}
{% assign allowed = false %}

{% if customer %}
  {% for t in customer.tags %}
    {% assign td = t | downcase | strip %}
    {% if td == admin_tag %}
      {% assign is_admin = true %}
      {% assign allowed = true %}
      {% break %}
    {% endif %}
    {% if td == member_tag %}
      {% assign allowed = true %}
    {% endif %}
  {% endfor %}
{% endif %}

{% unless customer %}
  <section class="ps-hero">
    <div class="ps-wrap ps-center">
      <h1 class="ps-title">Sign in to access your private store</h1>
      <p class="ps-sub">You must be logged in to view this storefront.</p>
      <div class="ps-actions">
        <a class="ps-btn ps-btn-solid" href="{{ routes.account_login_url }}?return_url={{ request.path | url_encode }}">Sign in</a>
        <a class="ps-btn ps-btn-ghost" href="/pages/portal">Back to Dashboard</a>
      </div>
    </div>
  </section>
  {% break %}
{% endunless %}

{% unless allowed %}
  <section class="ps-hero">
    <div class="ps-wrap ps-center">
      <h1 class="ps-title">Access required</h1>
      <p class="ps-sub">You don’t currently have access to this private store.</p>
      <div class="ps-actions">
        <a class="ps-btn ps-btn-solid" href="/pages/portal">Request access</a>
        <a class="ps-btn ps-btn-ghost" href="/pages/portal">Back to Dashboard</a>
      </div>
    </div>
  </section>
  {% break %}
{% endunless %}

{% assign entry = shop.metaobjects.custom_shop[handle] %}
{% assign store_name = collection.title %}
{% assign store_logo = blank %}

{% if entry %}
  {% assign n = entry.name.value | default: entry.name %}
  {% if n != blank %}{% assign store_name = n %}{% endif %}
  {% assign l = entry.logo.value | default: entry.logo %}
  {% if l != blank %}{% assign store_logo = l %}{% endif %}
{% endif %}

{% assign logo_url = store_logo | image_url: width: 400 %}

<section class="ps-hero">
  <div class="ps-wrap ps-center">
    <div class="ps-logo">
      {% if store_logo != blank %}
        {{ store_logo | image_url: width: 420 | image_tag: class: 'ps-logo-img', loading: 'lazy', alt: store_name }}
      {% else %}
        <span class="ps-logo-fallback">{{ store_name | slice: 0, 1 | upcase }}</span>
      {% endif %}
    </div>

    <h1 class="ps-title">{{ store_name }}</h1>
    
    {%- comment -%} HIDDEN ON MOBILE {%- endcomment -%}
    <p class="ps-sub mobile-hide">Your private storefront for approved items, quick reorders, and custom requests.</p>

    <div class="ps-actions mobile-hide">
      <a class="ps-btn ps-btn-ghost" href="/pages/portal">← Dashboard</a>
      {% if is_admin %}
        <a class="ps-btn ps-btn-solid" href="/pages/admin-powers?shop={{ handle | url_encode }}">Admin Powers</a>
      {% endif %}
    </div>

    <div class="ps-divider mobile-hide" aria-hidden="true"></div>
  </div>
</section>

{%- comment -%} --- GRID LOGO OVERLAY LOGIC --- {%- endcomment -%}
<style>
  .card__inner { position: relative !important; overflow: visible !important; }
  .ss-grid-overlay {
    position: absolute; top: 20%; left: 20%; width: 60%; height: 60%;
    z-index: 5; pointer-events: none;
    display: flex; align-items: center; justify-content: center;
  }
  .ss-grid-overlay img { position: absolute; width: auto; max-width: 100%; height: auto; }
</style>

<script>
document.addEventListener("DOMContentLoaded", function() {
  {% for p in collection.products %}
    {% assign pos = p.metafields.custom.logo_position %}
    {% if pos != blank and pos != "approved" and pos != "DELETED" %}
      (function() {
        const card = document.querySelector('[data-product-id="{{ p.id }}"] .card__inner') || 
                     document.querySelector('.card[data-id="{{ p.id }}"] .card__inner');
        if (card && !card.querySelector('.ss-grid-overlay')) {
          const overlay = document.createElement('div');
          overlay.className = 'ss-grid-overlay';
          overlay.innerHTML = `<img src="{{ logo_url }}" style="{{ pos | replace: '|', ';' }}">`;
          card.appendChild(overlay);
        }
      })();
    {% endif %}
  {% endfor %}
});
</script>

<style>
  /* BASE STYLES (Desktop) */
  .ps-hero {
    padding: 38px 16px 18px;
    background-image:
      radial-gradient(ellipse 65% 55% at 50% 0%, rgba(183,163,106,.10) 0%, transparent 68%),
      radial-gradient(circle, rgba(0,0,0,.040) 1px, transparent 1px);
    background-size: auto, 24px 24px;
  }
  .ps-wrap { max-width: 980px; margin: 0 auto; }
  .ps-center { text-align: center; }
  
  .ps-logo {
    width: 140px; height: 140px; margin: 0 auto 14px;
    display:flex; align-items:center; justify-content:center;
    position: relative;
  }
  /* Warm radial glow behind the logo */
  .ps-logo::before{
    content: '';
    position: absolute;
    inset: -28px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(183,163,106,.22) 0%, transparent 68%);
    pointer-events: none;
    z-index: 0;
  }
  .ps-logo-img { max-width: 100%; max-height: 100%; object-fit: contain; display:block; position: relative; z-index: 1; }
  .ps-logo-fallback { font-weight: 900; font-size: 46px; opacity: .35; position: relative; z-index: 1; }
  
  .ps-title { margin: 0; font-size: clamp(38px, 5vw, 64px); letter-spacing: -0.02em; line-height: 1.02; }
  .ps-sub { margin: 10px auto 0; max-width: 720px; opacity: .75; font-size: 16px; }
  
  .ps-actions { margin-top: 18px; display:flex; gap: 12px; justify-content:center; flex-wrap: wrap; }
  .ps-btn { display:inline-flex; align-items:center; justify-content:center; padding: 12px 24px; border-radius: 999px; text-decoration:none; font-weight: 800; border: 1px solid rgba(0,0,0,.14); font-size: 14px; transition: opacity .15s ease, box-shadow .15s ease; }
  .ps-btn:hover{ opacity: .92; box-shadow: 0 4px 14px rgba(0,0,0,.10); }
  .ps-btn-solid { background: #111; color: #fff; border-color: rgba(183,163,106,.55); }
  .ps-btn-ghost { background: #f4f4f4; color: #111; border: none; }
  
  /* Gold hairline divider with centred ornament */
  .ps-divider {
    position: relative;
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(183,163,106,.60) 35%, rgba(183,163,106,.80) 50%, rgba(183,163,106,.60) 65%, transparent 100%);
    margin: 28px auto 0;
    max-width: 760px;
    border: none;
  }
  .ps-divider::after{
    content: '✦' / '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 10px;
    color: rgba(183,163,106,.90);
    line-height: 1;
  }

  /* Entrance animations — respect reduced-motion */
  @media (prefers-reduced-motion: no-preference){
    @keyframes ps-fadein-scale{
      from{ opacity: 0; transform: scale(.95); }
      to{ opacity: 1; transform: scale(1); }
    }
    @keyframes ps-fadeup{
      from{ opacity: 0; transform: translateY(10px); }
      to{ opacity: 1; transform: translateY(0); }
    }
    .ps-logo{ animation: ps-fadein-scale 400ms ease both; }
    .ps-title{ animation: ps-fadeup 400ms ease 90ms both; }
    .ps-sub{ animation: ps-fadeup 400ms ease 160ms both; }
    .ps-actions{ animation: ps-fadeup 400ms ease 220ms both; }
  }

  /* --- MOBILE OPTIMIZATION --- */
  @media (max-width: 768px) {
    /* Hide the clutter */
    .mobile-hide { display: none !important; }
    
    /* Padding: Enough top space so the logo doesn't hit the nav bar */
    .ps-hero { padding: 30px 16px 10px 16px; }
    
    /* BIG LOGO: Increased from 80px to 150px */
    .ps-logo { width: 150px; height: 150px; margin-bottom: 12px; }
    
    /* Title: Balanced size */
    .ps-title { font-size: 32px; margin-bottom: 10px; }
  }
</style>

{% schema %}
{ "name": "Private Store Hero", "settings": [], "presets": [{ "name": "Private Store Hero" }] }
{% endschema %}