{% comment %}
  PRIVATE STORE HEADER (FULL COPY/PASTE)

  - Pulls storefront metaobject (default type key: "storefront") to show logo/name/subtitle
  - Shows role badge (Admin / Member) based on tags:
      Member: b2b-<page.handle>
      Admin:  b2b-admin-<page.handle>

  Buttons:
  - Back to portal -> /pages/portal?stay=1
  - My Account / Orders -> routes.account_url
{% endcomment %}

{% assign handle = page.handle | downcase | strip %}
{% assign portal_url = '/pages/portal?stay=1' %}
{% assign account_url = routes.account_url %}

{% assign mo_type = section.settings.metaobject_type | default: 'storefront' | strip %}
{% assign store_meta = blank %}
{% if shop.metaobjects[mo_type] and shop.metaobjects[mo_type].values != blank %}
  {% assign store_meta = shop.metaobjects[mo_type].values %}
{% endif %}

{% assign tile_logo = blank %}
{% assign tile_name = page.title | default: handle | replace: '-', ' ' | capitalize %}
{% assign tile_sub = section.settings.default_subtitle | default: 'Approved products & easy reorders' %}

{% if store_meta != blank %}
  {% for mo in store_meta %}
    {% assign mo_page = mo.page.value | default: mo.page %}
    {% assign mo_slug = mo.slug.value | default: mo.slug %}
    {% assign mo_handle = '' %}

    {% if mo_page != blank and mo_page.handle != blank %}
      {% assign mo_handle = mo_page.handle | downcase | strip %}
    {% elsif mo_slug != blank %}
      {% assign mo_handle = mo_slug | downcase | strip %}
    {% endif %}

    {% if mo_handle == handle %}
      {% assign mo_logo = mo.logo.value | default: mo.logo %}
      {% if mo_logo != blank %}{% assign tile_logo = mo_logo %}{% endif %}

      {% assign mo_name = mo.display_name.value | default: mo.display_name %}
      {% if mo_name != blank %}{% assign tile_name = mo_name %}{% endif %}

      {% assign mo_sub = mo.subtitle.value | default: mo.subtitle %}
      {% if mo_sub != blank %}{% assign tile_sub = mo_sub %}{% endif %}
      {% break %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign is_member = false %}
{% assign is_admin = false %}
{% if customer %}
  {% assign member_tag = 'b2b-' | append: handle %}
  {% assign admin_tag = 'b2b-admin-' | append: handle %}
  {% for t in customer.tags %}
    {% assign td = t | downcase | strip %}
    {% if td == admin_tag %}{% assign is_admin = true %}{% endif %}
    {% if td == member_tag %}{% assign is_member = true %}{% endif %}
  {% endfor %}
{% endif %}

<section class="ss-storehead" data-ss-storehead>
  <div class="ss-storehead__wrap">
    <div class="ss-storehead__left">
      <div class="ss-storehead__logo" aria-hidden="true">
        {% if tile_logo != blank %}
          {{ tile_logo | image_url: width: 240 | image_tag: class: 'ss-storehead__logoimg', loading: 'lazy', alt: tile_name }}
        {% else %}
          <span class="ss-storehead__logofallback">S&amp;S</span>
        {% endif %}
      </div>

      <div class="ss-storehead__meta">
        <div class="ss-storehead__title">{{ tile_name }}</div>
        <div class="ss-storehead__sub">{{ tile_sub }}</div>

        {% if customer %}
          <div class="ss-storehead__badges">
            {% if is_admin %}
              <span class="ss-pill ss-pill--dark">Admin</span>
            {% elsif is_member %}
              <span class="ss-pill">Member</span>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ss-storehead__right">
      <a class="ss-btn ss-btn--ghost" href="{{ portal_url }}">
        {{ section.settings.back_button_label | default: 'Back to portal' }}
      </a>

      <a class="ss-btn ss-btn--solid" href="{{ account_url }}">
        {{ section.settings.dashboard_button_label | default: 'My Account / Orders' }}
      </a>
    </div>
  </div>
</section>

<style>
  .ss-storehead{ padding: 10px 0 6px; }
  .ss-storehead__wrap{
    max-width: 1100px;
    margin: 0 auto;
    padding: 14px 18px;
    border-radius: 20px;
    border: 1px solid rgba(183,163,106,.40);
    background: linear-gradient(180deg, #fffef9 0%, #f3f0e6 100%);
    box-shadow: 0 14px 32px rgba(0,0,0,.08), 0 0 0 1px rgba(183,163,106,.25), 0 0 20px rgba(183,163,106,.10);

    display:flex;
    align-items:center;
    justify-content:space-between;
    gap: 14px;
    flex-wrap: wrap;
  }

  .ss-storehead__left{
    display:flex;
    align-items:center;
    gap: 14px;
    min-width: 260px;
    flex: 1;
  }

  .ss-storehead__logo{
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(183,163,106,.26) 0%, rgba(183,163,106,.08) 100%);
    box-shadow: 0 0 0 4px rgba(183,163,106,.32), inset 0 1px 3px rgba(0,0,0,.06), 0 4px 12px rgba(183,163,106,.22);
    overflow:hidden;
    display:flex;
    align-items:center;
    justify-content:center;
    flex: 0 0 auto;
  }
  .ss-storehead__logoimg{
    width: 100%;
    height: 100%;
    object-fit: contain;
    background:#fff;
    display:block;
  }
  .ss-storehead__logofallback{
    font-weight: 900;
    color: rgba(183,163,106,.7);
    font-size: 14px;
  }

  .ss-storehead__title{
    font-weight: 900;
    font-size: 18px;
    line-height: 1.15;
    margin: 0;
  }
  .ss-storehead__sub{
    margin-top: 3px;
    color: rgba(0,0,0,.65);
    font-size: 13px;
    line-height: 1.35;
  }

  .ss-storehead__badges{ margin-top: 8px; display:flex; gap: 8px; flex-wrap: wrap; }
  .ss-pill{
    display:inline-flex;
    align-items:center;
    gap: 5px;
    padding: 6px 11px;
    border-radius: 999px;
    border: 1px solid rgba(183,163,106,.45);
    background: rgba(183,163,106,.12);
    font-weight: 900;
    font-size: 12px;
    color: rgba(0,0,0,.75);
  }
  .ss-pill::before{
    content: '✦' / '';
    font-size: 9px;
    color: rgba(183,163,106,.8);
    line-height: 1;
  }
  .ss-pill--dark{
    background:#0b0b0b;
    border-color: rgba(183,163,106,.80);
    color:#fff;
    box-shadow: 0 0 0 2px rgba(183,163,106,.45), 0 0 16px rgba(183,163,106,.28);
  }
  .ss-pill--dark::before{
    content: '★' / '';
    font-size: 9px;
    color: rgba(183,163,106,.9);
  }

  .ss-storehead__right{
    display:flex;
    align-items:center;
    justify-content:flex-end;
    gap: 10px;
    flex: 0 0 auto;
  }

  .ss-btn{
    display:inline-block;
    padding: 11px 16px;
    border-radius: 999px;
    font-weight: 900;
    text-decoration:none;
    border:1px solid rgba(0,0,0,.16);
    cursor:pointer;
    white-space: nowrap;
    transition: opacity .15s ease, box-shadow .15s ease;
  }
  .ss-btn--solid{
    background:#0b0b0b;
    color:#fff;
    border:1px solid rgba(183,163,106,.55);
  }
  .ss-btn--ghost{
    background:#fff;
    color:#0b0b0b;
  }
  .ss-btn:hover{ opacity:.92; box-shadow: 0 4px 14px rgba(0,0,0,.10); }

  @media (max-width: 620px){
    .ss-storehead__right{ width: 100%; justify-content:flex-start; flex-wrap: wrap; }
    .ss-btn{ width: 100%; text-align:center; }
  }
</style>

{% schema %}
{
  "name": "Private Store Header",
  "settings": [
    {
      "type": "text",
      "id": "metaobject_type",
      "label": "Metaobject type key (storefront records)",
      "default": "storefront"
    },
    {
      "type": "text",
      "id": "default_subtitle",
      "label": "Default subtitle (if metaobject subtitle is blank)",
      "default": "Approved products & easy reorders"
    },
    {
      "type": "text",
      "id": "back_button_label",
      "label": "Back button label",
      "default": "Back to portal"
    },
    {
      "type": "text",
      "id": "dashboard_button_label",
      "label": "Account button label",
      "default": "My Account / Orders"
    }
  ],
  "presets": [
    { "name": "Private Store Header" }
  ]
}
{% endschema %}
