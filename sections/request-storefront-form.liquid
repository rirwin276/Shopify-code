  .sf-form-wrap { background: #fff; border: 1px solid rgba(0,0,0,0.08); border-radius: 20px; padding: 24px; box-shadow: 0 10px 40px rgba(0,0,0,0.04); position: relative; }
  .sf-auth-card { text-align:center; padding: 18px 4px; }
  .sf-auth-icon { width: 58px; height: 58px; margin: 0 auto 14px; border-radius: 18px; display:flex; align-items:center; justify-content:center; background:#f4f4f5; font-size:28px; }
  .sf-auth-title { margin: 0 0 10px; font-size: 24px; font-weight: 950; letter-spacing: -0.03em; color:#111; }
  .sf-auth-text { max-width: 560px; margin: 0 auto 22px; color:#64748b; font-size: 15px; line-height: 1.55; }
  .sf-auth-actions { display:grid; gap: 10px; max-width: 430px; margin: 0 auto; }
  .sf-block { padding: 4px 0; }
  .sf-divider { height: 1px; background: linear-gradient(90deg, rgba(183,163,106,0.35), rgba(0,0,0,0.06) 40%); margin: 22px 0; }
  .sf-legend { font-size: 12px; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 800; color: #8a7a4f; margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }
  .sf-legend::before { content: ''; width: 18px; height: 2px; border-radius: 2px; background: #b7a36a; }

  /* ── Color swatch picker ─────────────────────────────────────────────── */
  .sf-swatches { display: grid; grid-template-columns: repeat(auto-fill, minmax(74px, 1fr)); gap: 10px 6px; }
  .sf-sw { display: flex; flex-direction: column; align-items: center; gap: 5px; cursor: pointer; padding: 7px 2px 6px; border-radius: 12px; border: 1.5px solid transparent; transition: background .15s ease, border-color .15s ease; }
  .sf-sw:hover { background: #f7f5f0; }
  .sf-sw input { position: absolute; opacity: 0; pointer-events: none; }
  .sf-sw-dot { width: 34px; height: 34px; border-radius: 50%; background: var(--sw); box-shadow: inset 0 -2px 5px rgba(0,0,0,0.14); transition: transform .12s ease, box-shadow .15s ease; }
  .sf-sw-dot--light { border: 1px solid #ddd; }
  .sf-sw-dot--earthy { background: conic-gradient(#ece5d5 0 25%, #c8b088 0 50%, #8b8d8e 0 75%, #5f5849 0); }
  .sf-sw-dot--any { background: #fff; border: 2px dashed #cbb; display: flex; align-items: center; justify-content: center; font-weight: 900; color: #b7a36a; font-size: 15px; }
  .sf-sw-name { font-size: 10.5px; font-weight: 800; color: #666; letter-spacing: 0.01em; white-space: nowrap; }
  .sf-sw input:checked ~ .sf-sw-dot { transform: scale(1.12); box-shadow: 0 0 0 3px #fff, 0 0 0 6px #b7a36a, inset 0 -2px 5px rgba(0,0,0,0.14); }
  .sf-sw input:checked ~ .sf-sw-name { color: #111; }
  .sf-sw:has(input:checked) { border-color: rgba(183,163,106,0.55); background: rgba(183,163,106,0.08); }
  .sf-sw input:focus-visible ~ .sf-sw-dot { outline: 2px solid #0f172a; outline-offset: 3px; }
  .sf-sw--wide .sf-sw-name { white-space: normal; text-align: center; line-height: 1.15; font-size: 10px; }
  /* Color picker owns the right column of Step 1 (spanning the rows) so the
     Store Type + conditional sport/branch + Storefront Name stack on the
     left and never reflow it. */
  .sf-field--color { grid-column: 2; grid-row: 1 / span 3; }
  @media (max-width: 720px) { .sf-field--color { grid-column: auto; grid-row: auto; } }
  .sf-swatches.sf-field-error { border: 1.5px solid #dc2626 !important; border-radius: 14px; padding: 8px; background: #fff6f6; box-shadow: 0 0 0 3px rgba(220,38,38,0.10) !important; }
  .sf-grid { display: grid; gap: 14px; grid-template-columns: 1fr 1fr; }
  @media(max-width: 680px) { .sf-grid { grid-template-columns: 1fr; } }
  .sf-field { margin-bottom: 0; }
  .sf-label { display: block; font-weight: 800; font-size: 13px; margin-bottom: 8px; color: #333; }
  .sf-input, .sf-select { width: 100%; padding: 12px 14px; border: 1px solid #ddd; border-radius: 12px; font-size: 16px; transition: all 0.2s; background: #fafafa; color: #333; }
  .sf-input:focus, .sf-select:focus { border-color: #111; background: #fff; outline: none; }
  .sf-help { font-size: 12px; color: #888; margin-top: 6px; }
  .sf-mono { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; color: #111; background: #eee; padding: 2px 6px; border-radius: 6px; }
  .sf-file-drop { border: 2px dashed #ddd; border-radius: 14px; padding: 22px; text-align: center; cursor: pointer; transition: all 0.2s; background: #fafafa; position: relative; font-weight: 900; }
  .sf-file-drop:hover { border-color: #999; background: #f0f0f0; }
  .sf-file-input { display: none; }
  .sf-preview-row { margin-top: 12px; display: flex; gap: 12px; align-items: flex-start; padding: 12px; border: 1px solid #eee; border-radius: 14px; background: #fafafa; }
  .sf-preview-img { width: 74px; height: 74px; border-radius: 14px; object-fit: contain; background: #fff; border: 1px solid #e6e6e6; }
  .sf-preview-meta { flex: 1; }
  .sf-badge-row { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
  .sf-badge { display: inline-flex; align-items: center; padding: 6px 10px; border-radius: 999px; font-weight: 900; font-size: 12px; letter-spacing: 0.02em; border: 1px solid rgba(0,0,0,0.08); background: #fff; }
  .sf-badge--neutral { color: #444; background: #fff; }
  .sf-badge--excellent { color: #0b2a6b; background: #e8f0ff; border-color: rgba(11,42,107,0.18); }
  .sf-badge--good { color: #0f4d2a; background: #e8f8ef; border-color: rgba(15,77,42,0.18); }
  .sf-badge--risky { color: #6a4a00; background: #fff6db; border-color: rgba(106,74,0,0.18); }
  .sf-badge--bad { color: #7a0b0b; background: #ffe8e8; border-color: rgba(122,11,11,0.18); }
  .sf-quality-sub { font-size: 12px; color: #666; margin-bottom: 10px; line-height: 1.35; }
  .sf-actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .sf-action-btn { appearance: none; border: 1px solid #ddd; background: #fff; color: #111; font-weight: 900; font-size: 12px; padding: 10px 12px; border-radius: 999px; cursor: pointer; transition: transform .08s ease, border-color .2s ease; }
  .sf-action-btn:hover { border-color: #bbb; transform: translateY(-1px); }
  .sf-action-btn--ghost { background: transparent; }
  .sf-mini-status { margin-top: 10px; font-size: 12px; color: #64748b; font-weight: 800; display: inline-flex; align-items: center; gap: 8px; }
  .sf-mini-status::before { content: ""; width: 14px; height: 14px; border: 2px solid rgba(15,23,42,0.18); border-top-color: #0f172a; border-radius: 999px; display: inline-block; animation: sfspin 1s linear infinite; }
  .sf-hidden { display: none !important; }
  .sf-submit-row { margin-top: 18px; }
  .sf-btn { width: 100%; background: #111; color: #fff; border: none; padding: 14px 16px; border-radius: 999px; font-size: 16px; font-weight: 900; cursor: pointer; transition: transform 0.1s; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; }
  .sf-btn:hover { transform: translateY(-1px); background: #000; color: #fff; }
  .sf-btn--solid { background:#0f172a; }
  .sf-btn--outline { background: transparent; border: 2px solid #111; color: #111; }
  .sf-fineprint { margin: 14px 0 0; font-size: 12px; color: #94a3b8; text-align: center; line-height: 1.35; }
  .sf-error { background: #fee; color: #c00; padding: 14px 14px; border-radius: 12px; margin-bottom: 16px; text-align: center; font-weight: 800; border: 1px solid rgba(220, 38, 38, 0.18); }
  .sf-field-error { border-color: #dc2626 !important; box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.10) !important; background: #fff !important; }
  .sf-file-drop.sf-field-error { border-color: #dc2626 !important; background: #fff6f6 !important; }
  .sf-toast { position: fixed; left: 50%; bottom: 18px; transform: translateX(-50%); z-index: 9999; width: min(720px, calc(100% - 24px)); pointer-events: none; }
  .sf-toast-inner { pointer-events: auto; background: #0f172a; color: #fff; border-radius: 14px; padding: 12px 14px; display: flex; align-items: center; justify-content: space-between; gap: 14px; box-shadow: 0 18px 50px rgba(15,23,42,0.25); opacity: 0; transform: translateY(8px); transition: opacity .16s ease, transform .16s ease; }
  .sf-toast--show .sf-toast-inner { opacity: 1; transform: translateY(0); }
  .sf-toast-msg { font-size: 13px; line-height: 1.35; }
  .sf-toast-x { appearance: none; border: none; background: rgba(255,255,255,0.12); color: #fff; width: 34px; height: 34px; border-radius: 10px; cursor: pointer; font-size: 16px; font-weight: 900; }
