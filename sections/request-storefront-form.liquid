{% comment %}
  STELLA & SAGE — STORE REQUEST FORM
  Account-first flow using the exact same return_url pattern as the working dashboard link.
{% endcomment %}

{% assign studio_uploader_base_url = section.settings.studio_uploader_base_url | default: "https://studio-uploader-production.up.railway.app" %}
{% assign admin_email = section.settings.admin_email | default: "ryan.irwin@stellaandsagecompany.com" %}
{% assign portal_url = section.settings.portal_url | default: "/pages/portal" %}

{% capture encoded_form_return %}{{ request.path | url_encode }}{% endcapture %}
{% assign login_url = routes.account_login_url | append: '?return_url=' | append: encoded_form_return %}

{{ 'ss-wow.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ss-wow.js' | asset_url }}" defer></script>

<div class="sf-container" data-storefront-request-form>
  <div class="sf-header ss-reveal">
    <h1 class="sf-h1">Request a Storefront</h1>
    <p class="sf-sub">A few quick details, then we build your private shop.</p>
  </div>

  {% unless customer %}
    <div class="sf-form-wrap ss-reveal">
      <div class="sf-auth-card">
        <div class="sf-auth-icon">🔐</div>
        <h2 class="sf-auth-title">Sign in to start your free store</h2>
        <p class="sf-auth-text">
          Create an account or sign in first. This keeps your new storefront connected to your dashboard so you can manage it later.
        </p>

        <div class="sf-auth-actions">
          <a class="sf-btn sf-btn--solid" href="{{ login_url }}">Sign in or create account</a>
          <a class="sf-btn sf-btn--outline" href="{{ portal_url }}">Go to dashboard</a>
        </div>

        <p class="sf-fineprint">After signing in, you’ll come right back here to fill out the store request form.</p>
      </div>
    </div>
  {% else %}
    <div class="sf-form-wrap ss-reveal">
      <div id="sf-toast" class="sf-toast sf-hidden" role="status" aria-live="polite">
        <div class="sf-toast-inner">
          <div class="sf-toast-msg" id="sf-toast-msg">Please complete the required fields and add your logo.</div>
          <button type="button" class="sf-toast-x" onclick="sfToastHide()" aria-label="Dismiss">✕</button>
        </div>
      </div>

      <div id="sf-error-inline" class="sf-error sf-hidden"></div>

      <form id="sf-request-form" class="sf-form" onsubmit="submitToStudioUploader(event)" novalidate>
        <input type="hidden" name="customer_id" id="SF_CUST_ID" value="{{ customer.id }}">
        <input type="hidden" name="customer_email" id="SF_CUST_EMAIL" value="{{ customer.email }}">
        <input type="hidden" name="main_session_id" id="SF_MAIN_SESSION" value="">
        <input type="hidden" name="type_of_store" id="SF_TYPE_OF_STORE" value="">

        <div class="sf-block ss-reveal" data-stagger="true">
          <div class="sf-legend">Basics</div>
          <div class="sf-grid">
            <div class="sf-field">
              <label class="sf-label" for="OrgType">Organization Type *</label>
              <select id="OrgType" name="org_type" class="sf-select" required onchange="toggleConditionals()">
                <option value="" disabled selected>Select an option...</option>
                <option value="Small Business">Small Business</option>
                <option value="Sports Team">Sports Team</option>
                <option value="Military Unit">Military Unit</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="sf-field sf-hidden" id="MilitaryBranch">
              <label class="sf-label" for="BranchInput">Which Branch? *</label>
              <select id="BranchInput" name="military_branch" class="sf-select">
                <option value="" disabled selected>Select Branch...</option>
                <option value="Army">Army</option>
                <option value="Navy">Navy</option>
                <option value="Air Force">Air Force</option>
                <option value="Marines">Marines</option>
                <option value="Coast Guard">Coast Guard</option>
                <option value="Space Force">Space Force</option>
              </select>
            </div>

            <div class="sf-field sf-hidden" id="SportType">
              <label class="sf-label" for="SportInput">Which Sport? *</label>
              <select id="SportInput" name="sport_type" class="sf-select">
                <option value="" disabled selected>Select a sport...</option>
                <option value="softball">Softball</option>
                <option value="baseball">Baseball</option>
                <option value="hockey">Hockey</option>
                <option value="soccer">Soccer</option>
                <option value="volleyball">Volleyball</option>
                <option value="basketball">Basketball</option>
                <option value="football">Football</option>
                <option value="lacrosse">Lacrosse</option>
                <option value="wrestling">Wrestling</option>
                <option value="swimming">Swimming</option>
                <option value="track">Track &amp; Field</option>
                <option value="cross-country">Cross Country</option>
                <option value="golf">Golf</option>
                <option value="tennis">Tennis</option>
                <option value="cheer">Cheer / Cheerleading</option>
              </select>
            </div>

            <div class="sf-field sf-field--color">
              <label class="sf-label">Primary Shirt Color *</label>
              <div class="sf-swatches" role="radiogroup" aria-label="Primary shirt color">
                {%- comment -%}
                  These general colors are matched to each garment's REAL
                  catalog color by hex on the backend (color_logic.py), so
                  "Blue" reliably lands on True Royal / Team Royal etc.
                  The picked color becomes the storefront display color;
                  additional variants are filled with neutrals.
                {%- endcomment -%}
                <label class="sf-sw"><input type="radio" name="primary_color" value="Black" required><span class="sf-sw-dot" style="--sw:#151515"></span><span class="sf-sw-name">Black</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Charcoal"><span class="sf-sw-dot" style="--sw:#3e3d3d"></span><span class="sf-sw-name">Charcoal</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Gray"><span class="sf-sw-dot" style="--sw:#8b8d8e"></span><span class="sf-sw-name">Gray</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="White"><span class="sf-sw-dot sf-sw-dot--light" style="--sw:#f7f7f4"></span><span class="sf-sw-name">White</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Cream / Natural"><span class="sf-sw-dot sf-sw-dot--light" style="--sw:#ece5d5"></span><span class="sf-sw-name">Cream</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Tan / Khaki"><span class="sf-sw-dot" style="--sw:#c8b088"></span><span class="sf-sw-name">Tan</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Brown"><span class="sf-sw-dot" style="--sw:#6b4a33"></span><span class="sf-sw-name">Brown</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Olive / Military Green"><span class="sf-sw-dot" style="--sw:#5f5849"></span><span class="sf-sw-name">Olive</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Green"><span class="sf-sw-dot" style="--sw:#2f7d3b"></span><span class="sf-sw-name">Green</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Teal"><span class="sf-sw-dot" style="--sw:#128a8a"></span><span class="sf-sw-name">Teal</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Light Blue"><span class="sf-sw-dot" style="--sw:#a5c8e4"></span><span class="sf-sw-name">Lt. Blue</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Blue"><span class="sf-sw-dot" style="--sw:#1d4e9e"></span><span class="sf-sw-name">Blue</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Navy"><span class="sf-sw-dot" style="--sw:#1f2a44"></span><span class="sf-sw-name">Navy</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Purple"><span class="sf-sw-dot" style="--sw:#5d3a8e"></span><span class="sf-sw-name">Purple</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Pink"><span class="sf-sw-dot" style="--sw:#e56ca5"></span><span class="sf-sw-name">Pink</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Maroon"><span class="sf-sw-dot" style="--sw:#6e2639"></span><span class="sf-sw-name">Maroon</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Red"><span class="sf-sw-dot" style="--sw:#c8102e"></span><span class="sf-sw-name">Red</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Orange"><span class="sf-sw-dot" style="--sw:#e8722a"></span><span class="sf-sw-name">Orange</span></label>
                <label class="sf-sw"><input type="radio" name="primary_color" value="Yellow"><span class="sf-sw-dot" style="--sw:#f2c744"></span><span class="sf-sw-name">Yellow</span></label>
                <label class="sf-sw sf-sw--wide"><input type="radio" name="primary_color" value="Earthy / Neutral tones"><span class="sf-sw-dot sf-sw-dot--earthy"></span><span class="sf-sw-name">Earthy tones</span></label>
                <label class="sf-sw sf-sw--wide"><input type="radio" name="primary_color" value="No preference"><span class="sf-sw-dot sf-sw-dot--any">?</span><span class="sf-sw-name">No preference</span></label>
              </div>
              <p class="sf-help">Your pick becomes the store's display color — we fill the other variants with clean neutrals. You can fine-tune every product's colors later in the editor.</p>
            </div>

            <div class="sf-field">
              <label class="sf-label" for="StoreName">Storefront Name *</label>
              <input type="text" id="StoreName" name="storefront_name" class="sf-input" placeholder="e.g. Santee Soccer Club" required oninput="generateHandle()" autocomplete="organization">
              <p class="sf-help">Proposed Handle: <span id="HandlePreview" class="sf-mono">...</span></p>
              <input type="hidden" id="HiddenHandle" name="storefront_handle">
            </div>
          </div>
        </div>

        <div class="sf-divider"></div>

        <div class="sf-block ss-reveal" data-stagger="true">
          <div class="sf-legend">Logo</div>
          <div class="sf-field">
            <label class="sf-label">Main Logo / Store Image *</label>
            <div class="sf-file-drop" id="MainLogoDrop" onclick="return openUploaderModal();">
              <span id="MainLogoText">🪄 Add &amp; edit logo</span>
              <input type="file" id="MainLogo" name="storefront_logo_file" class="sf-file-input" accept="image/png, image/jpeg, image/webp" required>
            </div>

            <div class="sf-preview-row sf-hidden" id="MainLogoPreviewRow">
              <img id="MainLogoPreview" class="sf-preview-img" alt="Main logo preview" width="74" height="74" loading="lazy">
              <div class="sf-preview-meta">
                <div class="sf-badge-row"><span class="sf-badge sf-badge--neutral" id="MainLogoBadge">Checking…</span></div>
                <div class="sf-quality-sub" id="MainLogoQualitySub"></div>
                <div class="sf-actions sf-hidden" id="MainLogoActions">
                  <button type="button" class="sf-action-btn" onclick="return openUploaderModal();">Edit</button>
                  <button type="button" class="sf-action-btn sf-action-btn--ghost" onclick="return clearEdited();">Remove</button>
                </div>
              </div>
            </div>

            <div class="sf-mini-status sf-hidden" id="MainLogoPending">Saving your image… please wait.</div>
          </div>

          <div id="sf-limit-msg" class="sf-error sf-hidden">You have reached the limit of 3 requests per day. Please try again tomorrow.</div>

          <div class="sf-submit-row">
            <button type="submit" id="sf-submit-btn" class="sf-btn sf-btn--solid">Submit Request</button>
          </div>

          <p class="sf-fineprint">By submitting, you authorize Stella &amp; Sage to create and configure a private storefront for your group.</p>
        </div>
      </form>

      <div id="sf-provision" class="sf-hidden sf-provision">
        <div class="sf-provision-card">
          <div class="sf-spinner sf-spinner--big"></div>
          <div class="sf-provision-title">Creating your storefront…</div>
          <div class="sf-provision-sub">This usually takes about a minute. Your full product build will continue on your dashboard.</div>
          <div class="sf-progress"><div id="sf-progress-bar" class="sf-progress-bar"></div></div>
          <div id="sf-provision-status" class="sf-status">Securing request…</div>
          <div class="sf-provision-actions"><button type="button" class="sf-btn sf-btn--outline" onclick="sfCancelProvisioning()">Back</button></div>
        </div>
      </div>

      <div id="sf-uploader-modal" class="sf-modal sf-hidden" aria-hidden="true">
        <div class="sf-modal-backdrop" onclick="closeUploaderModal()"></div>
        <div class="sf-modal-card" role="dialog" aria-modal="true" aria-label="Studio Uploader">
          <div class="sf-modal-top">
            <div class="sf-modal-title">Studio Uploader <span id="sf-modal-slot" class="sf-modal-chip">main</span></div>
            <button type="button" class="sf-modal-x" onclick="closeUploaderModal()" aria-label="Close">✕</button>
          </div>
          <iframe id="sf-uploader-iframe" class="sf-modal-iframe" src="about:blank" title="Studio Uploader Editor" allow="clipboard-read; clipboard-write"></iframe>
          <div class="sf-modal-help">Upload your image, do quick edits, then hit <b>Done</b>. This window will close automatically.</div>
        </div>
      </div>
    </div>
  {% endunless %}
</div>

{% if customer %}
<script>
  const SF_UPLOADER_BASE = "{{ studio_uploader_base_url | escape }}".replace(/\/+$/,'');
  const SF_ADMIN_EMAIL = "{{ admin_email | escape }}".toLowerCase();
  const SF_USER_EMAIL = ("{{ customer.email | escape }}").toLowerCase();
  const SF_IS_ADMIN = (SF_USER_EMAIL === SF_ADMIN_EMAIL);
  const SF_PORTAL_URL = "{{ portal_url | escape }}" || "/pages/portal";

  let sfToastTimer = null;
  let sfProvisionTimer = null;
  let sfProvisionStart = 0;
  const sfQualityState = { main: { tier: null, okToSubmit: false, hasFile: false, pending: false } };

  document.addEventListener("DOMContentLoaded", function() {
    checkRateLimit();
    wireLiveErrorClearing();
    generateHandle();
    toggleConditionals();
    updateSubmitEnabled();
  });

  function sfToastShow(msg) {
    const t = document.getElementById('sf-toast');
    const m = document.getElementById('sf-toast-msg');
    if (m && msg) m.innerHTML = msg;
    if (!t) return;
    t.classList.remove('sf-hidden');
    t.classList.add('sf-toast--show');
    if (sfToastTimer) clearTimeout(sfToastTimer);
    sfToastTimer = setTimeout(sfToastHide, 5200);
  }

  function sfToastHide() {
    const t = document.getElementById('sf-toast');
    if (!t) return;
    t.classList.remove('sf-toast--show');
    setTimeout(() => t.classList.add('sf-hidden'), 180);
  }

  function checkRateLimit() {
    if (SF_IS_ADMIN) return;
    const STORAGE_KEY = 'sf_submissions_' + new Date().toISOString().slice(0, 10);
    const count = parseInt(localStorage.getItem(STORAGE_KEY) || 0);
    if (count >= 3) {
      const btn = document.getElementById('sf-submit-btn');
      if (btn) { btn.disabled = true; btn.style.opacity = "0.5"; btn.innerText = "Daily Limit Reached"; }
      hideEl('sf-limit-msg', false);
    }
  }

  function incrementRateLimit() {
    const STORAGE_KEY = 'sf_submissions_' + new Date().toISOString().slice(0, 10);
    const count = parseInt(localStorage.getItem(STORAGE_KEY) || 0);
    localStorage.setItem(STORAGE_KEY, count + 1);
  }

  function toggleConditionals() {
    const type = document.getElementById('OrgType')?.value || "";
    const mil = document.getElementById('MilitaryBranch');
    const sport = document.getElementById('SportType');
    const branchInput = document.getElementById('BranchInput');
    const sportInput = document.getElementById('SportInput');
    if (mil) mil.classList.add('sf-hidden');
    if (sport) sport.classList.add('sf-hidden');
    if (branchInput) branchInput.required = false;
    if (sportInput) sportInput.required = false;
    if (type === 'Military Unit') { if (mil) mil.classList.remove('sf-hidden'); if (branchInput) branchInput.required = true; }
    if (type === 'Sports Team') { if (sport) sport.classList.remove('sf-hidden'); if (sportInput) sportInput.required = true; }
    updateSubmitEnabled();
  }

  function generateHandle() {
    const name = (document.getElementById('StoreName')?.value || "").trim();
    const base = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    const custId = (document.getElementById('SF_CUST_ID')?.value || "").toString();
    const last4 = custId ? custId.slice(-4) : "new";
    const handle = base ? (base + "-" + last4) : "";
    setText('HandlePreview', handle || '...');
    const hidden = document.getElementById('HiddenHandle');
    if (hidden) hidden.value = handle;
    updateSubmitEnabled();
  }

  function wireLiveErrorClearing() {
    const form = document.getElementById('sf-request-form');
    if (!form) return;
    const clearIfValid = (el) => {
      if (!el || !el.classList) return;
      // Picking a color swatch clears the group's error highlight.
      if (el.type === 'radio' && el.checked) {
        const group = el.closest('.sf-swatches');
        if (group) group.classList.remove('sf-field-error');
        return;
      }
      if (el.classList.contains('sf-field-error') && (el.value || '').toString().trim()) el.classList.remove('sf-field-error');
    };
    form.addEventListener('input', (e) => clearIfValid(e.target), { passive: true });
    form.addEventListener('change', (e) => clearIfValid(e.target), { passive: true });
  }

  function openUploaderModal() {
    const modal = document.getElementById("sf-uploader-modal");
    const iframe = document.getElementById("sf-uploader-iframe");
    const chip = document.getElementById("sf-modal-slot");
    if (!modal || !iframe) return false;
    if (!SF_UPLOADER_BASE) { alert("Studio Uploader URL not configured in section settings."); return false; }
    if (chip) chip.textContent = "main";
    if (modal.parentNode !== document.body) document.body.appendChild(modal);
    iframe.src = SF_UPLOADER_BASE + "/ui?embed=1&return=postmessage&slot=main";
    modal.classList.remove("sf-hidden");
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    return false;
  }

  function closeUploaderModal() {
    const modal = document.getElementById("sf-uploader-modal");
    const iframe = document.getElementById("sf-uploader-iframe");
    if (iframe) iframe.src = "about:blank";
    if (modal) { modal.classList.add("sf-hidden"); modal.setAttribute("aria-hidden", "true"); }
    document.body.style.overflow = "";
  }

  window.addEventListener("message", async (event) => {
    const msg = event?.data;
    if (!msg || typeof msg !== "object" || msg.type !== "studio-uploader:done") return;
    try { if (event.origin !== new URL(SF_UPLOADER_BASE).origin) return; } catch (e) { return; }

    const finalizeUrl = msg.finalize_url || "";
    const directFinalImageUrl = msg.final_image_url || "";
    const sessionId = msg.session_id || "";
    const filename = msg.filename || "main_logo.png";
    const mime = msg.mime || "image/png";
    if (!finalizeUrl || !sessionId) { sfToastShow("Could not save that image. Please try again."); return; }

    setPending(true);
    try {
      const finalizeRes = await fetch(finalizeUrl, { method: "POST", headers: { "Accept": "application/json" }, cache: "no-store" });
      if (!finalizeRes.ok) throw new Error("Finalize failed " + finalizeRes.status);
      const finalizeJson = await finalizeRes.json();
      if (!finalizeJson || finalizeJson.status !== "ok") throw new Error("Finalize returned invalid response");
      let imageUrl = finalizeJson.final_image_url || directFinalImageUrl || "";
      if (!imageUrl) throw new Error("Finalize response missing final_image_url");
      imageUrl = new URL(imageUrl, SF_UPLOADER_BASE).toString();
      const file = await fileFromSavedImage(imageUrl, filename, mime);
      injectMainLogoFile(file, sessionId);
      await applyEditedPreview(file);
      closeUploaderModal();
      sfToastShow("Logo saved. Your form is ready when you are.");
    } catch (err) {
      console.error(err);
      sfToastShow("Could not save that image. Please try again.");
    } finally {
      setPending(false);
      updateSubmitEnabled();
    }
  });

  async function fileFromSavedImage(imageUrl, filename, mime) {
    const imageRes = await fetch(imageUrl + (imageUrl.includes("?") ? "&" : "?") + "t=" + Date.now(), { method: "GET", cache: "no-store" });
    if (!imageRes.ok) throw new Error("Image fetch failed " + imageRes.status);
    const blob = await imageRes.blob();
    if (!blob || blob.size === 0) throw new Error("Image fetch returned empty blob");
    return new File([blob], filename || "main_logo.png", { type: mime || blob.type || "image/png" });
  }

  function injectMainLogoFile(file, sessionId) {
    const input = document.getElementById("MainLogo");
    if (input) { const dt = new DataTransfer(); dt.items.add(file); input.files = dt.files; }
    const hs = document.getElementById("SF_MAIN_SESSION");
    if (hs) hs.value = sessionId || hs.value || "";
  }

  function setPending(on) {
    sfQualityState.main.pending = !!on;
    hideEl("MainLogoPending", !on);
    if (on) { setBadge("MainLogoBadge", "neutral", "Saving…"); setText("MainLogoQualitySub", "Please wait until the image is ready."); }
  }

  async function applyEditedPreview(file) {
    setText("MainLogoText", "✅ Ready");
    document.getElementById("MainLogoDrop")?.classList.remove("sf-field-error");
    const imgEl = document.getElementById("MainLogoPreview");
    if (imgEl && imgEl.dataset.objectUrl) { try { URL.revokeObjectURL(imgEl.dataset.objectUrl); } catch (e) {} }
    const url = URL.createObjectURL(file);
    if (imgEl) { imgEl.dataset.objectUrl = url; imgEl.src = url; }
    hideEl("MainLogoPreviewRow", false);
    hideEl("MainLogoActions", false);
    setBadge("MainLogoBadge", "neutral", "Checking…");
    setText("MainLogoQualitySub", "");
    const image = new Image();
    image.onload = () => {
      const longest = Math.max(image.naturalWidth || 0, image.naturalHeight || 0);
      let tier = "good";
      if (longest >= 3000) tier = "excellent";
      else if (longest >= 2400) tier = "good";
      else if (longest >= 1200) tier = "risky";
      else tier = "bad";
      const copy = {
        excellent: ["Excellent", "Awesome — should print great."],
        good: ["Good", "Should print fine."],
        risky: ["Good Enough", "Probably okay for simple logos, but not ideal."],
        bad: ["Bad", "Too low-quality to print cleanly. Please edit again or choose a better file."]
      };
      setBadge("MainLogoBadge", tier, copy[tier][0]);
      setText("MainLogoQualitySub", copy[tier][1]);
      sfQualityState.main.hasFile = true;
      sfQualityState.main.tier = tier;
      sfQualityState.main.okToSubmit = (tier !== "bad");
      updateSubmitEnabled();
    };
    image.onerror = () => { setBadge("MainLogoBadge", "bad", "Bad"); setText("MainLogoQualitySub", "Preview failed to load. Please try again."); sfQualityState.main = { tier: "bad", okToSubmit: false, hasFile: false, pending: false }; updateSubmitEnabled(); };
    image.src = url;
  }

  function clearEdited() {
    const input = document.getElementById("MainLogo");
    const previewImg = document.getElementById("MainLogoPreview");
    if (input) input.value = "";
    if (previewImg && previewImg.dataset.objectUrl) { try { URL.revokeObjectURL(previewImg.dataset.objectUrl); } catch (e) {} delete previewImg.dataset.objectUrl; previewImg.removeAttribute("src"); }
    sfQualityState.main = { tier: null, okToSubmit: false, hasFile: false, pending: false };
    hideEl("MainLogoPreviewRow", true);
    hideEl("MainLogoActions", true);
    hideEl("MainLogoPending", true);
    setBadge("MainLogoBadge", "neutral", "Checking…");
    setText("MainLogoQualitySub", "");
    setText("MainLogoText", "🪄 Add & edit logo");
    const hs = document.getElementById("SF_MAIN_SESSION");
    if (hs) hs.value = "";
    updateSubmitEnabled();
    return false;
  }

  function validateBeforeSubmit() {
    clearAllFieldErrors();
    hideInlineError();
    const form = document.getElementById('sf-request-form');
    if (!form) return true;
    let ok = true;
    form.querySelectorAll('[required]').forEach((el) => {
      if (el.disabled || el.closest('.sf-hidden')) return;
      const tag = el.tagName.toLowerCase();
      if (el.type === 'radio') {
        // Radio groups (the color swatches): one of the group must be checked.
        if (!form.querySelector('input[name="' + el.name + '"]:checked')) {
          markFieldError(el.closest('.sf-swatches') || el);
          ok = false;
        }
        return;
      }
      const val = (el.value || '').toString().trim();
      if ((tag === 'select' && !el.value) || ((tag === 'input' || tag === 'textarea') && !val && el.type !== 'file')) { markFieldError(el); ok = false; }
    });
    generateHandle();
    if (!(document.getElementById("HiddenHandle")?.value || "").trim()) { markFieldError(document.getElementById("StoreName")); ok = false; }
    const mainDrop = document.getElementById("MainLogoDrop");
    if (!sfQualityState.main.hasFile) { markFieldError(mainDrop); ok = false; }
    else if (sfQualityState.main.pending) { markFieldError(mainDrop); ok = false; showInlineError("Please wait — your logo is still saving."); }
    else if (sfQualityState.main.tier === "bad") { markFieldError(mainDrop); ok = false; }
    if (!ok) { sfToastShow("Please complete the required fields and add your logo."); scrollToFirstError(); }
    return ok;
  }

  function updateSubmitEnabled() {
    const btn = document.getElementById('sf-submit-btn');
    if (!btn) return;
    const isMainReady = sfQualityState.main.hasFile && !sfQualityState.main.pending && sfQualityState.main.okToSubmit;
    const hasHandle = !!(document.getElementById("HiddenHandle")?.value || "").trim();
    const STORAGE_KEY = 'sf_submissions_' + new Date().toISOString().slice(0, 10);
    const limited = (!SF_IS_ADMIN && parseInt(localStorage.getItem(STORAGE_KEY) || 0) >= 3);
    const enabled = !limited && isMainReady && hasHandle;
    btn.disabled = !enabled;
    btn.style.opacity = enabled ? "1" : "0.6";
  }

  function buildDashboardRedirectUrl() {
    const handle = (document.getElementById("HiddenHandle")?.value || "").trim();
    return SF_PORTAL_URL + (handle ? ("?new_store=1&store_handle=" + encodeURIComponent(handle)) : "?new_store=1");
  }

  function startProvisioning90s() {
    const form = document.getElementById('sf-request-form');
    const provision = document.getElementById('sf-provision');
    const statusEl = document.getElementById('sf-provision-status');
    const bar = document.getElementById('sf-progress-bar');
    const header = document.querySelector('.sf-header');
    if (header) header.classList.add('sf-hidden');
    if (form) form.classList.add('sf-hidden');
    if (provision) provision.classList.remove('sf-hidden');
    if (bar) bar.style.width = '0%';
    const steps = [
      { time: 1500, text: "Securing request…" },
      { time: 11000, text: "Validating details…" },
      { time: 24000, text: "Preparing your workspace…" },
      { time: 40000, text: "Configuring access & admin controls…" },
      { time: 58000, text: "Uploading assets…" },
      { time: 72000, text: "Queuing product generation…" },
      { time: 90000, text: "<b>Success!</b> Redirecting to your dashboard…" }
    ];
    steps.forEach((s) => setTimeout(() => { if (statusEl) statusEl.innerHTML = s.text; }, s.time));
    sfProvisionStart = Date.now();
    const total = 90000;
    if (sfProvisionTimer) clearInterval(sfProvisionTimer);
    sfProvisionTimer = setInterval(() => {
      const pct = Math.min(100, ((Date.now() - sfProvisionStart) / total) * 100);
      if (bar) bar.style.width = pct.toFixed(2) + '%';
      if (pct >= 100) { clearInterval(sfProvisionTimer); window.location.href = buildDashboardRedirectUrl(); }
    }, 180);
  }

  function stopProvisioning() {
    if (sfProvisionTimer) clearInterval(sfProvisionTimer);
    sfProvisionTimer = null;
    hideEl('sf-provision', true);
    document.querySelector('.sf-header')?.classList.remove('sf-hidden');
    document.getElementById('sf-request-form')?.classList.remove('sf-hidden');
  }

  function sfCancelProvisioning() {
    stopProvisioning();
    const btn = document.getElementById('sf-submit-btn');
    if (btn) { btn.disabled = false; btn.style.opacity = "1"; }
  }

  async function submitToStudioUploader(e) {
    e.preventDefault();
    const STORAGE_KEY = 'sf_submissions_' + new Date().toISOString().slice(0, 10);
    if (!SF_IS_ADMIN && parseInt(localStorage.getItem(STORAGE_KEY) || 0) >= 3) { sfToastShow("Daily limit reached."); return; }
    generateHandle();
    if (!validateBeforeSubmit()) { updateSubmitEnabled(); return; }
    if (!SF_UPLOADER_BASE) { alert("Studio Uploader URL not configured in section settings."); return; }

    const btn = document.getElementById('sf-submit-btn');
    if (btn) { btn.disabled = true; btn.style.opacity = "0.85"; }
    startProvisioning90s();

    const endpoint = SF_UPLOADER_BASE + "/api/storefront-request";
    const form = document.getElementById('sf-request-form');
    const formData = new FormData(form);

    const orgType = (document.getElementById('OrgType')?.value || "").trim();
    const sportVal = (document.getElementById('SportInput')?.value || "").trim();
    const branchVal = (document.getElementById('BranchInput')?.value || "").trim();
    let typeOfStore = "";
    if (orgType === "Sports Team" && sportVal) typeOfStore = sportVal;
    else if (orgType === "Military Unit" && branchVal) typeOfStore = branchVal;
    else if (orgType) typeOfStore = orgType;
    document.getElementById('SF_TYPE_OF_STORE').value = typeOfStore;
    if (typeOfStore) formData.set("type_of_store", typeOfStore);

    const pcVal = (document.querySelector('input[name="primary_color"]:checked')?.value || "").toString().trim();
    formData.set("primary_color", pcVal || "No preference");
    const mainInput = document.getElementById("MainLogo");
    if (!mainInput || !mainInput.files || mainInput.files.length === 0 || (mainInput.files[0] && mainInput.files[0].size === 0)) formData.delete("storefront_logo_file");
    const ms = (document.getElementById("SF_MAIN_SESSION")?.value || "").trim();
    if (!ms) formData.delete("main_session_id");
    formData.delete("secondary_session_id");
    formData.delete("storefront_logo_secondary");

    try {
      const res = await fetch(endpoint, { method: "POST", body: formData });
      if (!res.ok) { const t = await res.text().catch(() => ""); throw new Error("Uploader returned " + res.status + (t ? (": " + t.slice(0, 240)) : "")); }
      if (!SF_IS_ADMIN) incrementRateLimit();
    } catch (err) {
      console.error(err);
      stopProvisioning();
      if (btn) { btn.disabled = false; btn.style.opacity = "1"; }
      showInlineError("We couldn't submit your request. Please double-check your details and try again.<br><span style='font-weight:700;'>Reason:</span> " + escapeHtml(err.message || "Unknown error"));
      sfToastShow("Submit failed — please review and try again.");
      scrollToInlineError();
      updateSubmitEnabled();
    }
  }

  function clearAllFieldErrors() { document.querySelectorAll('.sf-field-error').forEach(el => el.classList.remove('sf-field-error')); }
  function markFieldError(el) { if (el) el.classList.add('sf-field-error'); }
  function scrollToFirstError() { const first = document.querySelector('.sf-field-error'); if (first) first.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
  function showInlineError(html) { const el = document.getElementById('sf-error-inline'); if (el) { el.innerHTML = html || "Something went wrong. Please try again."; el.classList.remove('sf-hidden'); } }
  function hideInlineError() { const el = document.getElementById('sf-error-inline'); if (el) { el.classList.add('sf-hidden'); el.innerHTML = ""; } }
  function scrollToInlineError() { const el = document.getElementById('sf-error-inline'); if (el && !el.classList.contains('sf-hidden')) el.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
  function escapeHtml(str) { return (str || "").replace(/[&<>"']/g, (m) => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[m])); }
  function hideEl(id, hide) { const el = document.getElementById(id); if (el) el.classList.toggle('sf-hidden', !!hide); }
  function setText(id, text) { const el = document.getElementById(id); if (el) el.innerText = text || ""; }
  function setBadge(id, tier, text) { const el = document.getElementById(id); if (el) { el.className = "sf-badge sf-badge--" + tier; el.innerText = text; } }
</script>
{% endif %}

<style>
  .sf-container { max-width: 720px; margin: 56px auto; padding: 0 18px; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
