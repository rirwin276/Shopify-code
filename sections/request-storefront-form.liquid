  .sf-provision-title { font-size: 18px; font-weight: 900; color: #0f172a; margin: 6px 0 6px; letter-spacing: -0.01em; }
  .sf-provision-sub { font-size: 13px; color: #64748b; margin-bottom: 18px; }
  .sf-progress { width: 100%; height: 8px; border-radius: 999px; background: #eef2f7; overflow: hidden; margin: 18px 0 14px; }
  .sf-progress-bar { width: 0%; height: 100%; background: #0f172a; border-radius: 999px; transition: width .18s linear; }
  .sf-status { margin-top: 6px; font-size: 13px; color: #64748b; min-height: 24px; transition: opacity .28s ease; opacity: 1; }
  .sf-status b { color: #10b981; }
  .sf-spinner { width: 18px; height: 18px; border: 3px solid rgba(15,23,42,0.18); border-top-color: #0f172a; border-radius: 50%; animation: sfspin 1s linear infinite; display: inline-block; vertical-align: middle; }
  .sf-spinner--big { width: 44px; height: 44px; border-width: 4px; margin: 0 auto 14px; display: block; }
  @keyframes sfspin { to { transform: rotate(360deg); } }
  .sf-provision-actions { margin-top: 16px; display: flex; justify-content: center; }
  .sf-modal { position: fixed; inset: 0; z-index: 10000; display: flex; align-items: center; justify-content: center; }
  .sf-modal-backdrop { position: absolute; inset: 0; background: rgba(15,23,42,0.45); backdrop-filter: blur(6px); }
  .sf-modal-card { position: relative; width: min(1100px, calc(100% - 24px)); height: min(680px, calc(100vh - 24px)); margin: 12px auto; background: #0b1220; border: 1px solid rgba(255,255,255,0.12); border-radius: 18px; overflow: hidden; box-shadow: 0 25px 90px rgba(0,0,0,0.40); display: flex; flex-direction: column; }
  .sf-modal-top { display: flex; align-items: center; justify-content: space-between; padding: 12px 14px; background: rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.10); color: #fff; }
