{% comment %}
  STELLA & SAGE — STORE REQUEST FORM (RAILWAY ONLY) — SINGLE PAGE (NO WIZARD)

  - NO Make.com
  - Uses Studio Uploader popup editor (iframe modal) for the Main Logo
  - Editor returns session_id + finalize_url via postMessage
  - Shopify fetches finalize JSON -> fetches final_image_url blob -> injects into <input type="file">
  - Submit is BLOCKED until Main image is actually saved/injected (photo ready)
  - On submit: immediately shows the 90s provisioning screen
  - If Railway fails: returns to form and shows the error
  - After provisioning screen completes: redirects to dashboard with new_store=1 + store_handle param

  REQUIRED on FastAPI (app.py):
  - CORS enabled for your Shopify domain(s)
  - GET /ui supports embed mode + return=postmessage + slot=main
  - POST /api/storefront-request accepts fields + files + main_session_id

  NOTE:
  - Secondary logo upload has been removed. Pro Builders now handle additional/custom images.
{% endcomment %}

{% schema %}
{
  "name": "Store Request Form",
  "settings": [
    {
      "type": "text",
      "id": "studio_uploader_base_url",
      "label": "Studio Uploader Base URL (Railway)",
      "default": "https://studio-uploader-production.up.railway.app"
    },
    {
      "type": "text",
      "id": "admin_email",
      "label": "Admin Email (Unlimited Requests)",
      "default": "ryan.irwin@stellaandsagecompany.com"
    }
  ],
  "presets": [
    { "name": "Store Request Form (Railway) — Single Page" }
  ]
}
{% endschema %}

{% assign studio_uploader_base_url = section.settings.studio_uploader_base_url | default: "https://studio-uploader-production.up.railway.app" %}
{% assign admin_email = section.settings.admin_email | default: "ryan.irwin@stellaandsagecompany.com" %}

{{ 'ss-wow.css' | asset_url | stylesheet_tag }}
<script src="{{ 'ss-wow.js' | asset_url }}" defer></script>

<div class="sf-container">
  <div class="sf-header ss-reveal">
    <h1 class="sf-h1">Request a Storefront</h1>
    <p class="sf-sub">A few quick details, then we build your private shop.</p>
  </div>

  <div class="sf-form-wrap ss-reveal">



      <div id="sf-toast" class="sf-toast sf-hidden" role="status" aria-live="polite">
        <div class="sf-toast-inner">
          <div class="sf-toast-msg" id="sf-toast-msg">
            Please complete the required fields and replace any logo marked <b>Bad</b>.
          </div>
          <button type="button" class="sf-toast-x" onclick="sfToastHide()" aria-label="Dismiss">✕</button>
        </div>
      </div>

      <div id="sf-error-inline" class="sf-error sf-hidden"></div>

      <form id="sf-request-form" class="sf-form" onsubmit="submitToStudioUploader(event)" novalidate>
        <input type="hidden" name="customer_id" id="SF_CUST_ID" value="{{ customer.id }}">
        <input type="hidden" name="customer_email" id="SF_CUST_EMAIL" value="{{ customer.email }}">

        <input type="hidden" name="main_session_id" id="SF_MAIN_SESSION" value="">
        <input type="hidden" name="type_of_store" id="SF_TYPE_OF_STORE" value="">

        <div class="sf-block ss-reveal" data-stagger="true">
          <div class="sf-legend">Basics</div>

          <div class="sf-grid">
            <div class="sf-field">
              <label class="sf-label" for="OrgType">Organization Type *</label>
              <select id="OrgType" name="org_type" class="sf-select" required onchange="toggleConditionals()">
                <option value="" disabled selected>Select an option...</option>
                <option value="Small Business">Small Business</option>
                <option value="Sports Team">Sports Team</option>
                <option value="Military Unit">Military Unit</option>
                <option value="Other">Other</option>
              </select>
            </div>

            <div class="sf-field sf-hidden" id="MilitaryBranch">
              <label class="sf-label" for="BranchInput">Which Branch? *</label>
              <select id="BranchInput" name="military_branch" class="sf-select">
                <option value="" disabled selected>Select Branch...</option>
                <option value="Army">Army</option>
                <option value="Navy">Navy</option>
                <option value="Air Force">Air Force</option>
                <option value="Marines">Marines</option>
                <option value="Coast Guard">Coast Guard</option>
                <option value="Space Force">Space Force</option>
              </select>
            </div>

            <div class="sf-field sf-hidden" id="SportType">
              <label class="sf-label" name="SportInput">Which Sport? *</label>
              <select id="SportInput" name="sport_type" class="sf-select">
                <option value="" disabled selected>Select a sport...</option>
                <option value="softball">Softball</option>
                <option value="baseball">Baseball</option>
                <option value="hockey">Hockey</option>
                <option value="soccer">Soccer</option>
                <option value="volleyball">Volleyball</option>
                <option value="basketball">Basketball</option>
                <option value="football">Football</option>
                <option value="lacrosse">Lacrosse</option>
                <option value="wrestling">Wrestling</option>
                <option value="swimming">Swimming</option>
                <option value="track">Track &amp; Field</option>
                <option value="cross-country">Cross Country</option>
                <option value="golf">Golf</option>
                <option value="tennis">Tennis</option>
                <option value="cheer">Cheer / Cheerleading</option>
              </select>
            </div>

            <div class="sf-field">
              <label class="sf-label" for="PrimaryColor">Primary Shirt Color Preference *</label>
              <select id="PrimaryColor" name="primary_color" class="sf-select" required>
                <option value="" disabled selected>Select a color...</option>
                <option value="No preference">No preference</option>

                <option value="" disabled>──────────</option>
                <option value="Neutral / Earthy">Neutral / Earthy</option>
                <option value="Black">Black</option>
                <option value="White">White</option>
                <option value="Gray">Gray</option>
                <option value="Charcoal">Charcoal</option>
                <option value="Navy">Navy</option>
                <option value="Brown">Brown</option>
                <option value="Tan / Khaki">Tan / Khaki</option>
                <option value="Cream / Natural">Cream / Natural</option>
                <option value="Olive / Military Green">Olive / Military Green</option>

                <option value="" disabled>──────────</option>
                <option value="Red">Red</option>
                <option value="Blue">Blue</option>
                <option value="Green">Green</option>
                <option value="Orange">Orange</option>
                <option value="Yellow">Yellow</option>
                <option value="Purple">Purple</option>
                <option value="Pink">Pink</option>

                <option value="" disabled>──────────</option>
                <option value="Light Blue">Light Blue</option>
                <option value="Royal Blue">Royal Blue</option>
                <option value="Teal">Teal</option>
                <option value="Maroon">Maroon</option>
                <option value="Burgundy">Burgundy</option>
              </select>
              <p class="sf-help">This helps us pick your default thumbnail color. You'll still be able to offer multiple colors later.</p>
            </div>
          </div>
        </div>

        <div class="sf-divider"></div>

        <div class="sf-block ss-reveal" data-stagger="true">
          <div class="sf-legend">Store</div>

          <div class="sf-field">
            <label class="sf-label" for="StoreName">Storefront Name *</label>
            <input
              type="text"
              id="StoreName"
              name="storefront_name"
              class="sf-input"
              placeholder="e.g. Hamaker Custom Woodworking"
              required
              oninput="generateHandle()"
              autocomplete="organization"
            >
            <p class="sf-help">Proposed Handle: <span id="HandlePreview" class="sf-mono">...</span></p>
            <input type="hidden" id="HiddenHandle" name="storefront_handle">
          </div>
        </div>

        <div class="sf-divider"></div>

        <div class="sf-block ss-reveal" data-stagger="true">
          <div class="sf-legend">Logo</div>

          <div class="sf-field">
            <label class="sf-label">Main Logo / Store Image *</label>

            <div class="sf-file-drop" id="MainLogoDrop" onclick="openUploaderModal()">
              <span id="MainLogoText">🪄 Add &amp; edit logo</span>
              <input
                type="file"
                id="MainLogo"
                name="storefront_logo_file"
                class="sf-file-input"
                accept="image/png, image/jpeg, image/webp"
                required
              >
            </div>

            <div class="sf-preview-row sf-hidden" id="MainLogoPreviewRow">
              <img id="MainLogoPreview" class="sf-preview-img" alt="Main logo preview" width="74" height="74" loading="lazy">
              <div class="sf-preview-meta">
                <div class="sf-badge-row">
                  <span class="sf-badge sf-badge--neutral" id="MainLogoBadge">Checking…</span>
                </div>
                <div class="sf-quality-sub" id="MainLogoQualitySub"></div>

                <div class="sf-actions sf-hidden" id="MainLogoActions">
                  <button type="button" class="sf-action-btn" onclick="return openUploaderModal()">Edit</button>
                  <button type="button" class="sf-action-btn sf-action-btn--ghost" onclick="return clearEdited()">Remove</button>
                </div>
              </div>
            </div>

            <div class="sf-mini-status sf-hidden" id="MainLogoPending">
              Saving your image… please wait.
            </div>

            <div class="sf-resource-hint" style="margin-top: 20px; padding: 14px 16px; background: #f7f7f7; border-radius: 12px; border: 1px solid #e8e8e8; display: flex; align-items: center; gap: 10px;">
              <span style="font-size: 22px;">🎨</span>
              <span style="font-size: 14px; color: rgba(0,0,0,0.7); font-weight: 500;">
                Don't have a logo yet?
                <a href="/pages/resources" target="_blank" aria-label="Check out our Resources page (opens in new tab)" style="color: #111; font-weight: 800; text-decoration: underline;">
                  Check out our Resources page
                </a>
                — free ChatGPT prompts to build one in minutes.
              </span>
            </div>
          </div>

          <div id="sf-limit-msg" class="sf-error sf-hidden" style="margin-top:16px;">
            You have reached the limit of 3 requests per day. Please try again tomorrow.
          </div>

          <div class="sf-submit-row">
            <button type="submit" id="sf-submit-btn" class="sf-btn sf-btn--solid">Submit Request</button>
          </div>

          <p class="sf-fineprint">
            By submitting, you authorize Stella &amp; Sage to create and configure a private storefront for your group.
          </p>
        </div>
      </form>

      <div id="sf-provision" class="sf-hidden sf-provision">
        <div class="sf-provision-card">
          <div class="sf-spinner sf-spinner--big"></div>
          <div class="sf-provision-title">Creating your storefront…</div>
          <div class="sf-provision-sub">This usually takes about a minute. Your full product build will continue on your dashboard.</div>

          <div class="sf-progress">
            <div id="sf-progress-bar" class="sf-progress-bar"></div>
          </div>

          <div id="sf-provision-status" class="sf-status"></div>

          <div class="sf-provision-actions">
            <button type="button" class="sf-btn sf-btn--outline" onclick="sfCancelProvisioning()">Back</button>
          </div>
        </div>
      </div>

      <div id="sf-uploader-modal" class="sf-modal sf-hidden" aria-hidden="true">
        <div class="sf-modal-backdrop" onclick="closeUploaderModal()"></div>
        <div class="sf-modal-card" role="dialog" aria-modal="true" aria-label="Studio Uploader">
          <div class="sf-modal-top">
            <div class="sf-modal-title">
              Studio Uploader
              <span id="sf-modal-slot" class="sf-modal-chip">main</span>
            </div>
            <button type="button" class="sf-modal-x" onclick="closeUploaderModal()" aria-label="Close">✕</button>
          </div>

          <iframe
            id="sf-uploader-iframe"
            class="sf-modal-iframe"
            src="about:blank"
            title="Studio Uploader Editor"
            allow="clipboard-read; clipboard-write"
          ></iframe>

          <div class="sf-modal-help">
            Upload your image, do quick edits, then hit <b>Done</b>. This window will close automatically.
          </div>
        </div>
      </div>



  </div>
</div>

<script>
  const SF_UPLOADER_BASE = "{{ studio_uploader_base_url | escape }}".replace(/\/+$/,'');
  const SF_ADMIN_EMAIL = "{{ admin_email | escape }}".toLowerCase();
  const SF_USER_EMAIL = ("{{ customer.email | escape }}").toLowerCase();
  const SF_IS_ADMIN = (SF_USER_EMAIL === SF_ADMIN_EMAIL);
  const SF_IS_LOGGED_IN = {% if customer %}true{% else %}false{% endif %};
  const SF_LOGIN_URL = "{{ routes.account_login_url }}?return_url={{ shop.url | append: '/pages/storefront' | url_encode }}";
  const SF_SESSION_KEY = 'sf_pending_form_v1';

  const sfQualityState = {
    main: { tier: null, okToSubmit: false, hasFile: false, pending: false }
  };

  let sfToastTimer = null;
  let sfProvisionTimer = null;
  let sfProvisionStart = 0;
  let sfProvisionWasShown = false;

  function sfToastShow(msg) {
    const t = document.getElementById('sf-toast');
    const m = document.getElementById('sf-toast-msg');
    if (m && msg) m.innerHTML = msg;
    if (!t) return;
    t.classList.remove('sf-hidden');
    t.classList.add('sf-toast--show');
    if (sfToastTimer) clearTimeout(sfToastTimer);
    sfToastTimer = setTimeout(sfToastHide, 4500);
  }

  function sfToastHide() {
    const t = document.getElementById('sf-toast');
    if (!t) return;
    t.classList.remove('sf-toast--show');
    setTimeout(() => t.classList.add('sf-hidden'), 180);
  }

  window.addEventListener('scroll', () => sfToastHide(), { passive: true });
  document.addEventListener('input', () => sfToastHide());

  document.addEventListener("DOMContentLoaded", function() {
    checkRateLimit();
    wireLiveErrorClearing();
    generateHandle();
    toggleConditionals();
    updateSubmitEnabled();
    sfRestoreFromSession();
  });

  function checkRateLimit() {
    if (SF_IS_ADMIN) return;

    const MAX_PER_DAY = 3;
    const STORAGE_KEY = 'sf_submissions_' + new Date().toISOString().slice(0, 10);

    let count = localStorage.getItem(STORAGE_KEY) || 0;
    if (parseInt(count) >= MAX_PER_DAY) {
      const btn = document.getElementById('sf-submit-btn');
      if (btn) {
        btn.disabled = true;
        btn.style.opacity = "0.5";
        btn.innerText = "Daily Limit Reached";
      }
      const msg = document.getElementById('sf-limit-msg');
      if (msg) msg.classList.remove('sf-hidden');
    }
  }

  function incrementRateLimit() {
    const STORAGE_KEY = 'sf_submissions_' + new Date().toISOString().slice(0, 10);
    let count = localStorage.getItem(STORAGE_KEY) || 0;
    localStorage.setItem(STORAGE_KEY, parseInt(count) + 1);
  }

  function toggleConditionals() {
    const type = document.getElementById('OrgType')?.value || "";
    const mil = document.getElementById('MilitaryBranch');
    const sport = document.getElementById('SportType');
    const branchInput = document.getElementById('BranchInput');
    const sportInput = document.getElementById('SportInput');

    if (mil) mil.classList.add('sf-hidden');
    if (sport) sport.classList.add('sf-hidden');
    if (branchInput) branchInput.required = false;
    if (sportInput) sportInput.required = false;

    if (type === 'Military Unit') {
      if (mil) mil.classList.remove('sf-hidden');
      if (branchInput) branchInput.required = true;
    } else if (type === 'Sports Team') {
      if (sport) sport.classList.remove('sf-hidden');
      if (sportInput) sportInput.required = true;
    }
  }

  function generateHandle() {
    const name = (document.getElementById('StoreName')?.value || "").trim();
    const base = name.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '');
    const custId = (document.getElementById('SF_CUST_ID')?.value || "");
    const last4 = custId ? custId.toString().slice(-4) : "0000";
    const handle = base ? (base + "-" + last4) : "";

    const hp = document.getElementById('HandlePreview');
    const hh = document.getElementById('HiddenHandle');
    if (hp) hp.innerText = handle || "...";
    if (hh) hh.value = handle;

    updateSubmitEnabled();
  }

  function wireLiveErrorClearing() {
    const form = document.getElementById('sf-request-form');
    if (!form) return;

    const clearIfValid = (el) => {
      if (!el || !el.classList) return;
      if (el.classList.contains('sf-field-error')) {
        const val = (el.value || '').toString().trim();
        if (!el.required || val.length > 0) el.classList.remove('sf-field-error');
      }
    };

    form.addEventListener('input', (e) => clearIfValid(e.target), { passive: true });
    form.addEventListener('change', (e) => clearIfValid(e.target), { passive: true });
  }

  function openUploaderModal() {
    const modal = document.getElementById("sf-uploader-modal");
    const iframe = document.getElementById("sf-uploader-iframe");
    const chip = document.getElementById("sf-modal-slot");

    if (!modal || !iframe) return;

    if (!SF_UPLOADER_BASE) {
      alert("Studio Uploader URL not configured in section settings.");
      return;
    }

    if (chip) chip.textContent = "main";

    if (modal.parentNode !== document.body) {
      document.body.appendChild(modal);
    }

    const src = SF_UPLOADER_BASE + "/ui?embed=1&return=postmessage&slot=main";
    iframe.src = src;

    modal.classList.remove("sf-hidden");
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
    return false;
  }

  function closeUploaderModal() {
    const modal = document.getElementById("sf-uploader-modal");
    const iframe = document.getElementById("sf-uploader-iframe");
    if (iframe) iframe.src = "about:blank";
    if (modal) {
      modal.classList.add("sf-hidden");
      modal.setAttribute("aria-hidden", "true");
    }
    document.body.style.overflow = "";
  }

  window.addEventListener("message", async (event) => {
    const msg = event?.data;
    if (!msg || typeof msg !== "object") return;
    if (msg.type !== "studio-uploader:done") return;

    try {
      const allowedOrigin = new URL(SF_UPLOADER_BASE).origin;
      if (event.origin !== allowedOrigin) return;
    } catch (e) {
      return;
    }

    const finalizeUrl = msg.finalize_url || "";
    const directFinalImageUrl = msg.final_image_url || "";
    const sessionId = msg.session_id || "";
    const filename = msg.filename || "main_logo.png";
    const mime = msg.mime || "image/png";

    if (!finalizeUrl || !sessionId) {
      console.error("Uploader message missing finalize_url or session_id", msg);
      sfToastShow("Could not save that image. Please try again.");
      return;
    }

    setPending(true);

    try {
      const finalizeRes = await fetch(finalizeUrl, {
        method: "POST",
        headers: { "Accept": "application/json" },
        cache: "no-store"
      });

      if (!finalizeRes.ok) {
        throw new Error("Finalize failed " + finalizeRes.status);
      }

      const finalizeJson = await finalizeRes.json();
      if (!finalizeJson || finalizeJson.status !== "ok") {
        throw new Error("Finalize returned invalid response");
      }

      let imageUrl = finalizeJson.final_image_url || directFinalImageUrl || "";
      if (!imageUrl) {
        throw new Error("Finalize response missing final_image_url");
      }

      imageUrl = new URL(imageUrl, SF_UPLOADER_BASE).toString();

      const imageRes = await fetch(
        imageUrl + (imageUrl.includes("?") ? "&" : "?") + "t=" + Date.now(),
        {
          method: "GET",
          cache: "no-store"
        }
      );

      if (!imageRes.ok) {
        throw new Error("Image fetch failed " + imageRes.status);
      }

      const blob = await imageRes.blob();
      if (!blob || blob.size === 0) {
        throw new Error("Image fetch returned empty blob");
      }

      const file = new File([blob], filename, { type: mime });

      const input = document.getElementById("MainLogo");
      if (input) {
        const dt = new DataTransfer();
        dt.items.add(file);
        input.files = dt.files;
      }

      const hs = document.getElementById("SF_MAIN_SESSION");
      if (hs) hs.value = sessionId;

      await applyEditedPreview(file);
      closeUploaderModal();
    } catch (err) {
      console.error(err);
      sfToastShow("Could not save that image. Please try again.");
    } finally {
      setPending(false);
      updateSubmitEnabled();
    }
  });

  function setPending(on) {
    const pendingId = "MainLogoPending";
    const badgeId = "MainLogoBadge";
    const subId = "MainLogoQualitySub";

    sfQualityState.main.pending = !!on;

    const p = document.getElementById(pendingId);
    if (p) p.classList.toggle("sf-hidden", !on);

    if (on) {
      setBadge(badgeId, "neutral", "Saving…");
      setText(subId, "Please wait until the image is ready.");
    }
  }

  async function applyEditedPreview(file) {
    const textId = "MainLogoText";
    const rowId = "MainLogoPreviewRow";
    const imgId = "MainLogoPreview";
    const badgeId = "MainLogoBadge";
    const subId = "MainLogoQualitySub";
    const actionsId = "MainLogoActions";
    const dropId = "MainLogoDrop";

    const labelEl = document.getElementById(textId);
    if (labelEl) labelEl.innerText = "✅ Ready";

    const dropEl = document.getElementById(dropId);
    if (dropEl) dropEl.classList.remove("sf-field-error");

    const imgEl = document.getElementById(imgId);
    if (imgEl && imgEl.dataset.objectUrl) {
      try { URL.revokeObjectURL(imgEl.dataset.objectUrl); } catch (e) {}
    }

    const url = URL.createObjectURL(file);
    if (imgEl) {
      imgEl.dataset.objectUrl = url;
      imgEl.src = url;
    }

    hideEl(rowId, false);
    hideEl(actionsId, false);

    setBadge(badgeId, "neutral", "Checking…");
    setText(subId, "");

    const image = new Image();
    image.onload = async () => {
      const w = image.naturalWidth || 0;
      const h = image.naturalHeight || 0;
      const longest = Math.max(w, h);

      let tier = "good";
      if (longest >= 3000) tier = "excellent";
      else if (longest >= 2400) tier = "good";
      else if (longest >= 1800) tier = "risky";
      else tier = "bad";

      let headline = "";
      let sub = "";
      if (tier === "excellent") {
        headline = "Excellent";
        sub = "Awesome — should print great.";
      } else if (tier === "good") {
        headline = "Good";
        sub = "Should print fine.";
      } else if (tier === "risky") {
        headline = "Good Enough";
        sub = "Probably okay for simple logos, but not ideal.";
      } else {
        headline = "Bad";
        sub = "Too low-quality to print cleanly. Please edit again or choose a better file.";
      }

      setBadge(badgeId, tier, headline);
      setText(subId, sub);

      sfQualityState.main.hasFile = true;
      sfQualityState.main.tier = tier;
      sfQualityState.main.okToSubmit = (tier !== "bad");

      updateSubmitEnabled();
    };

    image.onerror = () => {
      setBadge(badgeId, "bad", "Bad");
      setText(subId, "Preview failed to load. Please try again.");

      sfQualityState.main.hasFile = false;
      sfQualityState.main.tier = "bad";
      sfQualityState.main.okToSubmit = false;

      updateSubmitEnabled();
    };

    image.src = url;
  }

  function clearEdited() {
    const input = document.getElementById("MainLogo");
    const previewImg = document.getElementById("MainLogoPreview");

    if (input) input.value = "";

    if (previewImg && previewImg.dataset.objectUrl) {
      try { URL.revokeObjectURL(previewImg.dataset.objectUrl); } catch (e) {}
      delete previewImg.dataset.objectUrl;
      previewImg.removeAttribute("src");
    }

    sfQualityState.main = { tier: null, okToSubmit: false, hasFile: false, pending: false };
    hideEl("MainLogoPreviewRow", true);
    hideEl("MainLogoActions", true);
    hideEl("MainLogoPending", true);
    setBadge("MainLogoBadge", "neutral", "Checking…");
    setText("MainLogoQualitySub", "");

    const t = document.getElementById("MainLogoText");
    if (t) t.innerText = "🪄 Add & edit logo";

    const hs = document.getElementById("SF_MAIN_SESSION");
    if (hs) hs.value = "";

    updateSubmitEnabled();
    return false;
  }

  function clearAllFieldErrors() {
    document.querySelectorAll('.sf-field-error').forEach(el => el.classList.remove('sf-field-error'));
  }

  function markFieldError(el) {
    if (!el) return;
    el.classList.add('sf-field-error');
  }

  function scrollToFirstError() {
    const first = document.querySelector('.sf-field-error');
    if (first) first.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function validateBeforeSubmit() {
    clearAllFieldErrors();
    hideInlineError();

    const form = document.getElementById('sf-request-form');
    if (!form) return true;

    let ok = true;

    const required = form.querySelectorAll('[required]');
    required.forEach((el) => {
      if (el.disabled) return;
      if (el.closest('.sf-hidden')) return;

      const tag = el.tagName.toLowerCase();
      const val = (el.value || '').toString().trim();

      if (tag === 'select') {
        if (!el.value) {
          markFieldError(el);
          ok = false;
        }
      } else if (tag === 'input' || tag === 'textarea') {
        if (!val) {
          markFieldError(el);
          ok = false;
        }
      }
    });

    generateHandle();

    const handle = (document.getElementById("HiddenHandle")?.value || "").trim();
    if (!handle) {
      markFieldError(document.getElementById("StoreName"));
      ok = false;
    }

    const mainDrop = document.getElementById("MainLogoDrop");
    if (!sfQualityState.main.hasFile) {
      markFieldError(mainDrop);
      ok = false;
    } else if (sfQualityState.main.pending) {
      markFieldError(mainDrop);
      ok = false;
      showInlineError("Please wait — your logo is still saving.");
    } else if (sfQualityState.main.tier === "bad") {
      markFieldError(mainDrop);
      ok = false;
    }

    if (!ok) {
      sfToastShow();
      scrollToFirstError();
    }

    return ok;
  }

  function updateSubmitEnabled() {
    const btn = document.getElementById('sf-submit-btn');
    if (!btn) return;

    const isMainReady = sfQualityState.main.hasFile && !sfQualityState.main.pending && sfQualityState.main.okToSubmit;

    const handle = (document.getElementById("HiddenHandle")?.value || "").trim();
    const hasHandle = !!handle;

    const STORAGE_KEY = 'sf_submissions_' + new Date().toISOString().slice(0, 10);
    const limited = (!SF_IS_ADMIN && parseInt(localStorage.getItem(STORAGE_KEY) || 0) >= 3);

    const enabled = !limited && isMainReady && hasHandle;
    btn.disabled = !enabled;
    btn.style.opacity = enabled ? "1" : "0.6";
  }

  function buildDashboardRedirectUrl() {
    const handle = (document.getElementById("HiddenHandle")?.value || "").trim();

    if (handle) {
      return "/pages/portal?new_store=1&store_handle=" + encodeURIComponent(handle);
    }

    return "/pages/portal?new_store=1";
  }

  function startProvisioning90s() {
    sfProvisionWasShown = true;

    const form = document.getElementById('sf-request-form');
    const provision = document.getElementById('sf-provision');
    const statusEl = document.getElementById('sf-provision-status');
    const bar = document.getElementById('sf-progress-bar');
    const header = document.querySelector('.sf-header');

    if (header) header.classList.add('sf-hidden');
    if (form) form.classList.add('sf-hidden');
    if (provision) provision.classList.remove('sf-hidden');

    if (bar) bar.style.width = '0%';
    if (statusEl) {
      statusEl.style.opacity = '0';
      statusEl.innerHTML = 'Securing request…';
      setTimeout(() => statusEl.style.opacity = '1', 120);
    }

    const steps = [
      { time: 1500,  text: "Securing request…" },
      { time: 11000, text: "Validating details…" },
      { time: 24000, text: "Preparing your workspace…" },
      { time: 40000, text: "Configuring access & admin controls…" },
      { time: 58000, text: "Uploading assets…" },
      { time: 72000, text: "Queuing product generation…" },
      { time: 90000, text: "<b>Success!</b> Redirecting to your dashboard…" }
    ];

    steps.forEach((s) => {
      setTimeout(() => {
        if (!statusEl) return;
        statusEl.style.opacity = '0';
        setTimeout(() => {
          statusEl.innerHTML = s.text;
          statusEl.style.opacity = '1';
        }, 260);
      }, s.time);
    });

    sfProvisionStart = Date.now();
    const total = 90000;

    if (sfProvisionTimer) clearInterval(sfProvisionTimer);
    sfProvisionTimer = setInterval(() => {
      const pct = Math.min(100, ((Date.now() - sfProvisionStart) / total) * 100);
      if (bar) bar.style.width = pct.toFixed(2) + '%';

      if (pct >= 100) {
        clearInterval(sfProvisionTimer);
        window.location.href = buildDashboardRedirectUrl();
      }
    }, 180);
  }

  function stopProvisioning() {
    if (sfProvisionTimer) clearInterval(sfProvisionTimer);
    sfProvisionTimer = null;

    const provision = document.getElementById('sf-provision');
    if (provision) provision.classList.add('sf-hidden');

    const header = document.querySelector('.sf-header');
    if (header) header.classList.remove('sf-hidden');

    const form = document.getElementById('sf-request-form');
    if (form) form.classList.remove('sf-hidden');
  }

  function sfCancelProvisioning() {
    stopProvisioning();
    const btn = document.getElementById('sf-submit-btn');
    if (btn) {
      btn.disabled = false;
      btn.style.opacity = "1";
    }
  }

  async function submitToStudioUploader(e) {
    e.preventDefault();

    const STORAGE_KEY = 'sf_submissions_' + new Date().toISOString().slice(0, 10);
    if (!SF_IS_ADMIN && parseInt(localStorage.getItem(STORAGE_KEY) || 0) >= 3) {
      sfToastShow("Daily limit reached.");
      return;
    }

    generateHandle();

    if (!validateBeforeSubmit()) {
      updateSubmitEnabled();
      return;
    }

    if (!SF_IS_LOGGED_IN) {
      sfSaveToSession();
      window.location.href = SF_LOGIN_URL;
      return;
    }

    if (!SF_UPLOADER_BASE) {
      alert("Studio Uploader URL not configured in section settings.");
      return;
    }

    const btn = document.getElementById('sf-submit-btn');
    if (btn) {
      btn.disabled = true;
      btn.style.opacity = "0.85";
    }

    startProvisioning90s();

    const endpoint = SF_UPLOADER_BASE + "/api/storefront-request";
    const form = document.getElementById('sf-request-form');
    const formData = new FormData(form);

    (function() {
      const orgType = (document.getElementById('OrgType')?.value || "").trim();
      const sportVal = (document.getElementById('SportInput')?.value || "").trim();
      const branchVal = (document.getElementById('BranchInput')?.value || "").trim();

      let typeOfStore = "";
      if (orgType === "Sports Team" && sportVal) {
        typeOfStore = sportVal;
      } else if (orgType === "Military Unit" && branchVal) {
        typeOfStore = branchVal;
      } else if (orgType) {
        typeOfStore = orgType;
      }

      const tosEl = document.getElementById('SF_TYPE_OF_STORE');
      if (tosEl) tosEl.value = typeOfStore;
      if (typeOfStore) formData.set("type_of_store", typeOfStore);
    })();

    const pcEl = document.getElementById("PrimaryColor");
    const pcVal = (pcEl && pcEl.value) ? pcEl.value.toString().trim() : "";
    if (pcVal) {
      formData.set("primary_color", pcVal);
    } else {
      formData.set("primary_color", "No preference");
      console.warn("PrimaryColor was empty at submit; defaulting to No preference");
    }

    const mainInput = document.getElementById("MainLogo");

    if (!mainInput || !mainInput.files || mainInput.files.length === 0 || (mainInput.files[0] && mainInput.files[0].size === 0)) {
      formData.delete("storefront_logo_file");
    }

    const ms = (document.getElementById("SF_MAIN_SESSION")?.value || "").trim();
    if (!ms) formData.delete("main_session_id");

    formData.delete("secondary_session_id");
    formData.delete("storefront_logo_secondary");

    try {
      const res = await fetch(endpoint, {
        method: "POST",
        body: formData
      });

      if (!res.ok) {
        const t = await res.text().catch(() => "");
        throw new Error("Uploader returned " + res.status + (t ? (": " + t.slice(0, 240)) : ""));
      }

      if (!SF_IS_ADMIN) incrementRateLimit();
    } catch (err) {
      console.error(err);

      stopProvisioning();

      if (btn) {
        btn.disabled = false;
        btn.style.opacity = "1";
      }

      showInlineError(
        "We couldn't submit your request. " +
        "Please double-check your details and try again. " +
        "<br><span style='font-weight:700;'>Reason:</span> " +
        escapeHtml(err.message || "Unknown error")
      );

      sfToastShow("Submit failed — please review and try again.");
      scrollToInlineError();
      updateSubmitEnabled();
    }
  }

  function showInlineError(html) {
    const el = document.getElementById('sf-error-inline');
    if (!el) return;
    el.innerHTML = html || "Something went wrong. Please try again.";
    el.classList.remove('sf-hidden');
  }

  function hideInlineError() {
    const el = document.getElementById('sf-error-inline');
    if (!el) return;
    el.classList.add('sf-hidden');
    el.innerHTML = "";
  }

  function scrollToInlineError() {
    const el = document.getElementById('sf-error-inline');
    if (el && !el.classList.contains('sf-hidden')) {
      el.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  }

  function escapeHtml(str) {
    return (str || "").replace(/[&<>"']/g, (m) => ({
      "&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"
    }[m]));
  }

  function sfSaveToSession() {
    try {
      const data = {
        org_type: document.getElementById('OrgType')?.value || '',
        military_branch: document.getElementById('BranchInput')?.value || '',
        sport_type: document.getElementById('SportInput')?.value || '',
        primary_color: document.getElementById('PrimaryColor')?.value || '',
        storefront_name: document.getElementById('StoreName')?.value || '',
        main_session_id: document.getElementById('SF_MAIN_SESSION')?.value || '',
        _saved_at: Date.now()
      };
      localStorage.setItem(SF_SESSION_KEY, JSON.stringify(data));
    } catch(e) {}
  }

  function sfRestoreFromSession() {
    try {
      const raw = localStorage.getItem(SF_SESSION_KEY);
      if (!raw) return;
      localStorage.removeItem(SF_SESSION_KEY);
      const data = JSON.parse(raw);

      if (data.org_type) {
        const el = document.getElementById('OrgType');
        if (el) { el.value = data.org_type; toggleConditionals(); }
      }
      if (data.military_branch) {
        const el = document.getElementById('BranchInput');
        if (el) el.value = data.military_branch;
      }
      if (data.sport_type) {
        const el = document.getElementById('SportInput');
        if (el) el.value = data.sport_type;
      }
      if (data.primary_color) {
        const el = document.getElementById('PrimaryColor');
        if (el) el.value = data.primary_color;
      }
      if (data.storefront_name) {
        const el = document.getElementById('StoreName');
        if (el) { el.value = data.storefront_name; generateHandle(); }
      }
      if (data.storefront_name || data.org_type) {
        sfToastShow("Your answers have been restored. Just re-upload your logo and you're ready to go.");
      }
    } catch(e) {}
  }

  function hideEl(id, hide) {
    const el = document.getElementById(id);
    if (!el) return;
    if (hide) el.classList.add('sf-hidden');
    else el.classList.remove('sf-hidden');
  }

  function setText(id, text) {
    const el = document.getElementById(id);
    if (el) el.innerText = text || "";
  }

  function setBadge(id, tier, text) {
    const el = document.getElementById(id);
    if (!el) return;
    el.className = "sf-badge sf-badge--" + tier;
    el.innerText = text;
  }
</script>

