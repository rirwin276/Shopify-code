{% comment %}
  Stella & Sage — Resources / Logo Launch Helper
  - Replaces old tab-heavy prompt layout.
  - Smoother guided flow: Pick prompt → Generate logo → Upload to storefront request.
  - Every prompt includes transparent background, no padding, tight crop, high-resolution requirements.
{% endcomment %}

<section class="ss-resources" id="ss-resources-{{ section.id }}">
  <div class="ss-res-wrap">

    <header class="ss-res-hero">
      <div class="ss-res-kicker">Logo Launch Helper</div>
      <h1 class="ss-res-h1">{{ section.settings.title }}</h1>
      <p class="ss-res-sub">{{ section.settings.subtitle }}</p>

      <div class="ss-res-hero-actions">
        <a class="ss-res-btn ss-res-btn--dark" href="/pages/request-storefront-form">Request a storefront →</a>
        <a class="ss-res-btn ss-res-btn--light" href="#prompt-library">Browse prompts</a>
      </div>
    </header>

    <section class="ss-res-flow" aria-label="How to use this page">
      <div class="ss-flow-card">
        <span>01</span>
        <h3>Pick a prompt</h3>
        <p>Choose the logo style that fits your team, trip, event, business, or group.</p>
      </div>

      <div class="ss-flow-card">
        <span>02</span>
        <h3>Generate your logo</h3>
        <p>Paste the prompt into ChatGPT and replace the highlighted placeholders.</p>
      </div>

      <div class="ss-flow-card">
        <span>03</span>
        <h3>Upload it</h3>
        <p>Use the finished logo when you request your Stella &amp; Sage storefront.</p>
      </div>
    </section>

    <section class="ss-res-warning">
      <div class="ss-warning-icon">!</div>
      <div>
        <strong>Important before you upload</strong>
        <p>Your logo should have a transparent background, no extra padding, no mockup, and no empty space around it. The artwork should be tightly cropped, centered, crisp, and high resolution.</p>
      </div>
    </section>

    <section class="ss-res-categories" aria-label="Prompt categories">
      <button class="ss-cat-card ss-cat-card--active" type="button" data-res-category="sports">
        <span>🏅</span>
        <strong>Sports Teams</strong>
        <p>Wordmarks, mascots, badges, and hat-ready logos.</p>
      </button>

      <button class="ss-cat-card" type="button" data-res-category="vacation">
        <span>🏖️</span>
        <strong>Family Trips</strong>
        <p>Vacation crews, reunions, lake trips, and beach weeks.</p>
      </button>

      <button class="ss-cat-card" type="button" data-res-category="parties">
        <span>💍</span>
        <strong>Weddings &amp; Parties</strong>
        <p>Bachelor trips, bachelorette parties, and wedding marks.</p>
      </button>

      <button class="ss-cat-card" type="button" data-res-category="groups">
        <span>🎲</span>
        <strong>Groups &amp; Fundraisers</strong>
        <p>Clubs, businesses, charity events, and work teams.</p>
      </button>
    </section>

