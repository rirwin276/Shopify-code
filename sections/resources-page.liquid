<script>
  function resShowTab(tabId, btn) {
    document.querySelectorAll('.res-panel').forEach(function(p) {
      p.classList.add('res-panel--hidden');
    });
    document.querySelectorAll('.res-tab').forEach(function(t) {
      t.classList.remove('res-tab--active');
      t.setAttribute('aria-selected', 'false');
    });
    document.getElementById('res-panel-' + tabId).classList.remove('res-panel--hidden');
    btn.classList.add('res-tab--active');
    btn.setAttribute('aria-selected', 'true');
  }

  function resCopy(btn, promptId) {
    const el = document.getElementById(promptId);
    const text = el.innerText;
    const orig = btn.textContent;
    navigator.clipboard.writeText(text).then(function() {
      btn.textContent = '✅ Copied!';
      setTimeout(function() { btn.textContent = orig; }, 2000);
    }).catch(function() {
      btn.textContent = '⚠️ Copy failed';
      setTimeout(function() { btn.textContent = orig; }, 2000);
    });
  }
</script>

