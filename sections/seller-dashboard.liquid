    transition: opacity 1.1s ease, transform 1.1s ease;
    font-size: 11px;
    color: rgba(91,107,130,0.92);
    font-weight: 650;
    line-height: 1.25;
  }
  .ss-fmsg.is-active{
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 950px) { .ss-hero { grid-template-columns: 1fr; } }

  @media (max-width: 850px) {
    .ss-block-stores { order: 1; }
    .ss-block-hero { order: 2; }

    .ss-desktop-cta { display: none; }
    .ss-desktop-insights { display: none; }

    .ss-mobile-cta {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin: 6px 0 12px;
      padding: 0 4px;
    }
    .ss-mobile-insights { display: block; }

    .ss-store-card { flex-direction: column; align-items: flex-start; gap: 16px; padding: 16px 16px; }
    .ss-col-identity, .ss-col-engine, .ss-col-controls { width: 100%; justify-content: flex-start; }
    .ss-col-engine { padding: 0; justify-content: flex-start; }
    .ss-header { flex-direction: column; align-items: flex-start; gap: 14px; }
    .ss-stats { grid-template-columns: 1fr; }
    .ss-col-controls { gap: 10px; flex-wrap: wrap; }

    .ss-buildwrap{ align-items: flex-start; max-width: 100%; }
    .ss-founderline{ text-align: left; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ss-store-card { animation: none !important; transition: none !important; }
    .ss-dot-building-anim { animation: none !important; }
    .ss-progress-bar-anim { animation: none !important; }
  }

  .ss-leave-btn {
    background: transparent;
    color: #b00020;
    border: 1px solid rgba(176,0,32,.28);
    font-size: 11px;
    font-weight: 800;
    padding: 8px 14px;
    border-radius: 999px;
    cursor: pointer;
    white-space: nowrap;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    transition: 0.18s ease;
  }
  .ss-leave-btn:hover { background: rgba(176,0,32,.06); }
</style>

