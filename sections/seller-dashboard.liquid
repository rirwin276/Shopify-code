@media (max-width: 850px) {
    .ss-block-stores { order: 1; }
    .ss-block-hero { order: 2; }

    .ss-desktop-cta { display: none; }
    .ss-desktop-insights { display: none; }

    .ss-mobile-cta {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin: 6px 0 14px;
      padding: 0 2px;
    }
    .ss-mobile-insights { display: block; }

    /* Card: stacked layout, generous breathing room */
    .ss-store-card {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      padding: 0;
      border-radius: 22px;
      overflow: hidden;
    }

    /* Identity row: logo + name side by side, full width */
    .ss-col-identity {
      width: 100%;
      gap: 14px;
      padding: 16px 16px 12px;
      border-bottom: 1px solid rgba(15,23,42,0.05);
    }

    /* Logo: bigger and more prominent on mobile */
    .ss-logo-frame {
      width: 52px;
      height: 52px;
      border-radius: 14px;
      flex-shrink: 0;
    }

    .ss-card-title { font-size: 16px; font-weight: 820; letter-spacing: -0.02em; }
    .ss-card-subtitle { font-size: 11px; }

    /* Engine: status badge row */
    .ss-col-engine {
      width: 100%;
      padding: 10px 16px;
      justify-content: flex-start;
      border-bottom: 1px solid rgba(15,23,42,0.05);
    }

    /* Controls: buttons full width, pill style, stacked cleanly */
    .ss-col-controls {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 8px;
      padding: 12px 14px 14px;
    }

    /* Open Storefront button: full width, bold, Apple-style */
    .ss-open-btn {
      width: 100%;
      justify-content: center;
      padding: 13px 16px;
      font-size: 14px;
      font-weight: 750;
      border-radius: 14px;
      letter-spacing: -0.01em;
    }

    /* Admin button: outlined, full width */
    .ss-admin-btn {
      width: 100%;
      text-align: center;
      padding: 11px 16px;
      font-size: 13px;
      border-radius: 14px;
    }

    /* Leave Store: subtle, full width */
    .ss-leave-btn {
      width: 100%;
      text-align: center;
      padding: 10px 16px;
      font-size: 12px;
      border-radius: 14px;
    }

    /* Wake button: full width */
    .ss-wake-btn {
      width: 100%;
      justify-content: center;
      padding: 13px 16px;
      font-size: 14px;
      border-radius: 14px;
    }

    .ss-buildwrap { align-items: flex-start; max-width: 100%; }
    .ss-founderline { text-align: left; }
  }