{% comment %}
  SHOP DASHBOARD — STUDIO EDITION (WITH SELLER MODE)

  v0.40 changes (this update):
  ✅ Remove hardcoded 5-minute localStorage countdown timer
  ✅ Poll backend /api/store/{handle}/ready-status every 10s (admin/god only)
  ✅ Unlock card only when backend confirms is_fully_ready = true
  ✅ Updated loading messages to veteran-owned store copy
  ✅ Sleeping/waking states show appropriate loading messages
  ✅ Non-admin members see static Liquid-rendered messages (no polling)
  ✅ New-store onboarding modal triggered by ?new_store=1&store_handle=...
  ✅ Adds polished dashboard/admin/storefront screenshot previews
  ✅ Mobile-first onboarding layout while preserving the desktop split-card look
  ✅ Mobile sticky footer with subtle fade cue instead of scroll-for-more pill

  Notes:
  - This does NOT write to the is_fully_ready metaobject (Printful Automation does that).
  - New device/browser no longer triggers loading screen if store is already live.
{% endcomment %}

{% assign explainer_url = '/pages/private-storefronts' %}
{% assign portal_url = '/pages/portal' %}
{% assign account_url = routes.account_url %}
{% assign storefront_request_url = '/pages/request-storefront-form' %}

{% assign has_storefront = false %}
{% assign requested_badge = false %}
{% assign member_handles_blob = '||' %}
{% assign admin_handles_blob  = '||' %}
{% assign store_count = 0 %}
{% assign admin_count = 0 %}
{% assign form_access_url = section.settings.form_access_url | default: '' %}
{% assign form_product_url = section.settings.form_product_url | default: '' %}
{% assign allow_any_member_to_add_people = section.settings.allow_any_member_to_add_people | default: false %}
{% assign request_btn_label = 'Create a New Storefront' %}

{% assign display_name = '' %}
{% if customer %}
  {% capture nm %}{{ customer.first_name }} {{ customer.last_name }}{% endcapture %}
  {% assign display_name = nm | strip %}
{% endif %}

{% if customer %}
  {% for tag in customer.tags %}
    {% assign tag_stripped = tag | strip %}
    {% assign tag_down = tag_stripped | downcase %}

    {% if tag_down == 'storefront-requested' %}
      {% assign requested_badge = true %}
    {% endif %}

    {% if tag_down contains 'storefront-admin--' %}
      {% assign ah = tag_stripped | remove: 'storefront-admin--' | remove: 'STOREFRONT-ADMIN--' | strip %}
      {% if ah != blank %}
        {% capture admin_needle %}||{{ ah }}||{% endcapture %}
        {% unless admin_handles_blob contains admin_needle %}
          {% assign admin_handles_blob = admin_handles_blob | append: ah | append: '||' %}
          {% assign admin_count = admin_count | plus: 1 %}
        {% endunless %}
        {% capture member_needle_from_admin %}||{{ ah }}||{% endcapture %}
        {% unless member_handles_blob contains member_needle_from_admin %}
          {% assign member_handles_blob = member_handles_blob | append: ah | append: '||' %}
          {% assign store_count = store_count | plus: 1 %}
          {% assign has_storefront = true %}
        {% endunless %}
      {% endif %}
    {% endif %}

    {% if tag_down contains 'storefront-member--' %}
      {% assign mh = tag_stripped | remove: 'storefront-member--' | remove: 'STOREFRONT-MEMBER--' | strip %}
      {% if mh != blank %}
        {% capture member_needle %}||{{ mh }}||{% endcapture %}
        {% unless member_handles_blob contains member_needle %}
          {% assign member_handles_blob = member_handles_blob | append: mh | append: '||' %}
          {% assign store_count = store_count | plus: 1 %}
          {% assign has_storefront = true %}
        {% endunless %}
      {% endif %}
    {% endif %}
  {% endfor %}
{% endif %}

{% comment %} --- CHECK FOR SUPER ADMIN STATUS --- {% endcomment %}
{% assign is_god = false %}
{% if customer %}
  {% if customer.email == 'ryan.irwin@stellaandsagecompany.com' or customer.tags contains 'super-admin' %}
    {% assign is_god = true %}
  {% endif %}
{% endif %}

{% comment %} SMART SORTING LOGIC {% endcomment %}
{% assign bucket_admin = '' %}
{% assign bucket_live = '' %}
{% assign bucket_building = '' %}

{% assign raw_handles = member_handles_blob | split: '||' %}

{% for h in raw_handles %}
  {% assign handle = h | strip %}
  {% if handle == blank %}{% continue %}{% endif %}
  {% capture needle %}||{{ handle }}||{% endcapture %}

  {% if admin_handles_blob contains needle %}
    {% assign bucket_admin = bucket_admin | append: needle %}
  {% else %}
    {% assign entry = shop.metaobjects.custom_shop[handle] %}
    {% assign is_ready = entry.is_fully_ready.value | default: entry.is_fully_ready %}
    {% if is_ready == true or is_ready == 'true' %}
      {% assign bucket_live = bucket_live | append: needle %}
    {% else %}
      {% assign bucket_building = bucket_building | append: needle %}
    {% endif %}
  {% endif %}
{% endfor %}

{% assign sorted_blob = bucket_admin | append: bucket_live | append: bucket_building %}
{% assign handles_array = sorted_blob | split: '||' %}

{% comment %} --- CALCULATE TOTAL PRODUCTS --- {% endcomment %}
{% assign total_products_all = 0 %}
{% if customer and has_storefront %}
  {% for raw_handle in handles_array %}
    {% assign handle = raw_handle | strip %}
    {% if handle != blank %}
      {% assign entry = shop.metaobjects.custom_shop[handle] %}
      {% assign collection_handle = handle %}
      {% if entry %}
        {% assign ch = entry.collection_handle.value | default: entry.collection_handle %}
        {% if ch != blank %}{% assign collection_handle = ch | strip %}{% endif %}
      {% endif %}
      {% assign c = collections[collection_handle] %}
      {% if c %}
        {% assign pc = c.products_count | default: 0 %}
        {% assign total_products_all = total_products_all | plus: pc %}
      {% endif %}
    {% endif %}
  {% endfor %}
{% endif %}

{% if is_god %}
<script>
  window.SS_GOD_STORES = [
    {% for raw_handle in handles_array %}
      {% assign handle = raw_handle | strip %}
      {% if handle != blank %}
        {% assign entry = shop.metaobjects.custom_shop[handle] %}
        {% assign n = entry.name.value | default: entry.name | default: handle %}
        { handle: {{ handle | json }}, name: {{ n | json }} },
      {% endif %}
    {% endfor %}
  ];
  window.SS_ALL_PLATFORM_STORES = [
    {% for store in shop.metaobjects.custom_shop.values %}
      {% unless store.tags contains 'status:closed' %}
        {
          handle: {{ store.system.handle | json }},
          name: {{ store.name | json }},
          collection_handle: {{ store.collection_handle | json }}
        },
      {% endunless %}
    {% endfor %}
  ];
</script>
{% endif %}

<section class="ss-portal" data-ss-portal>
  <div class="ss-bg">
    <div class="ss-wrap">

      <header class="ss-header">
        <div class="ss-header-text">
          <h1 class="ss-h1">
            {% if customer %}
              {% if customer.first_name != blank %}
                {{ customer.first_name | escape }}’s Dashboard
              {% elsif display_name != blank %}
                {{ display_name | escape }}’s Dashboard
              {% else %}
                My Dashboard
              {% endif %}
            {% else %}
              Studio Dashboard
            {% endif %}
          </h1>
          <p class="ss-sub">Manage your private collections and track real-time design production.</p>
        </div>

        {% if customer %}
          <div class="ss-user-pill">
            <div class="ss-avatar">{{ customer.first_name | slice: 0, 1 | default: 'U' | upcase }}</div>
            <div class="ss-user-meta">
              <span class="ss-user-name">{{ display_name | default: customer.email }}</span>
              <span class="ss-user-status">● Active Member</span>
            </div>

          </div>
        {% endif %}
      </header>

      {% if customer.tags contains 'seller' %}
        <div class="ss-seller-alert">
          <div class="ss-seller-content">
            <div class="ss-seller-icon">⚡</div>
            <div class="ss-seller-text">
              <strong>Seller Mode Active</strong>
              <p>You have orders waiting in the hub.</p>
            </div>
          </div>
          <a href="/pages/maker-hub" class="ss-btn-seller">
            Go to Production Hub &rarr;
          </a>
        </div>
      {% endif %}

      {% unless customer %}
        <div class="ss-loggedout-shell">
          <div class="ss-card ss-empty-state ss-empty-state--premium">
            <div class="ss-empty-icon">⌁</div>
            <div class="ss-locked-kicker">PRIVATE DASHBOARD</div>
            <h2>Your stores live here.</h2>
            <p>Sign in to manage private storefronts, shop stores you’ve joined, edit product placement, build new merch, and keep every group store in one clean place.</p>
            <div class="ss-action-row">
              <a class="ss-btn-primary" href="{{ routes.storefront_login_url }}?return_to={{ portal_url | url_encode }}">Sign in</a>
              <a class="ss-btn-secondary" href="{{ storefront_request_url }}">Create a Storefront</a>
            </div>
          </div>

          <div class="ss-locked-preview" aria-hidden="true">
            <div class="ss-preview-window">
              <div class="ss-preview-top">
                <span></span><span></span><span></span>
              </div>
              <div class="ss-preview-main">
                <div class="ss-preview-heading">
                  <div>
                    <small>DASHBOARD PREVIEW</small>
                    <strong>My Stores</strong>
                  </div>
                  <em>Live</em>
                </div>

                <div class="ss-preview-store-row">
                  <div class="ss-preview-logo">SS</div>
                  <div><strong>Raptors Football</strong><span>Private Store · 12 products</span></div>
                  <button>Shop Store</button>
                </div>

                <div class="ss-preview-store-row ss-preview-store-row--soft">
                  <div class="ss-preview-logo ss-preview-logo--gold">IR</div>
                  <div><strong>Family Reunion</strong><span>Building · products generating</span></div>
                  <button>Building</button>
                </div>

                <div class="ss-preview-tools">
                  <span>Edit placement</span>
                  <span>Build products</span>
                  <span>Copy link</span>
                  <span>Manage colors</span>
                </div>
              </div>
            </div>
          </div>

          <div class="ss-loggedout-benefits">
            <div><strong>Admins manage</strong><span>Hide, delete, edit, rebuild, and share storefront links.</span></div>
            <div><strong>Members shop</strong><span>Normal buyers only see the simple store experience.</span></div>
            <div><strong>Stores stay organized</strong><span>Every team, trip, unit, family, or event lives in one dashboard.</span></div>
          </div>
        </div>
      {% else %}

        <div class="ss-main">

          <div class="ss-block ss-block-stores">
            {% if has_storefront or is_god %}
              <div class="ss-grid-label">Active Productions</div>

              <div class="ss-store-grid">

                {% if is_god %}
                  <div class="ss-store-card ss-clickrow ss-god-card" role="link" tabindex="0" data-href="/pages/super-admin" style="border-color: #3b82f6; box-shadow: 0 0 0 1px rgba(59,130,246,0.1), 0 10px 24px rgba(59,130,246,0.1);">
                    <div class="ss-col-identity">
                      <div class="ss-logo-frame" style="background:#eff6ff; border-color:#dbeafe;">
                        <span style="font-size:24px;">⚡</span>
                      </div>
                      <div class="ss-identity-text">
                        <h3 class="ss-card-title" style="color:#1e40af;">Command Center</h3>
                        <span class="ss-card-subtitle" style="background:#dbeafe; color:#1e40af; border-color:#bfdbfe;">Super Admin</span>
                      </div>
                    </div>
                    <div class="ss-col-engine">
                      <div class="ss-status-finished" style="background:#eff6ff; border-color:#bfdbfe;">
                        <span class="ss-dot-live" style="background:#3b82f6; box-shadow:0 0 0 3px rgba(59,130,246,0.2);"></span>
                        <span class="ss-status-text" style="color:#1e40af;">GOD MODE ACTIVE</span>
                      </div>
                    </div>
                    <div class="ss-col-controls">
                      <a href="/pages/super-admin" class="ss-open-btn" style="background:#2563eb;">
                        <span>Enter God Mode</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.75"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                      </a>
                    </div>
                  </div>
                {% endif %}
                {% if is_god %}
                  <!-- PRICE EDITOR CARD -->
                  <div class="ss-store-card ss-clickrow ss-pricing-card" role="link" tabindex="0" data-href="/pages/price-editor" style="border-color: #7c3aed; box-shadow: 0 0 0 1px rgba(124,58,237,0.15), 0 10px 24px rgba(124,58,237,0.08);">
                    <div class="ss-col-identity">
                      <div class="ss-logo-frame" style="background:#f5f3ff; border-color:#ddd6fe;">
                        <span style="font-size:24px;">💰</span>
                      </div>
                      <div class="ss-identity-text">
                        <h3 class="ss-card-title" style="color:#5b21b6;">Price Editor</h3>
                        <span class="ss-card-subtitle" style="background:#ede9fe; color:#5b21b6; border-color:#c4b5fd;">Super Admin</span>
                      </div>
                    </div>
                    <div class="ss-col-engine">
                      <div class="ss-status-finished" style="background:#f5f3ff; border-color:#c4b5fd;">
                        <span class="ss-dot-live" style="background:#7c3aed; box-shadow:0 0 0 3px rgba(124,58,237,0.2);"></span>
                        <span class="ss-status-text" style="color:#5b21b6;">GLOBAL PRICING</span>
                      </div>
                    </div>
                    <div class="ss-col-controls">
                      <a href="/pages/price-editor" class="ss-open-btn" style="background:#7c3aed;">
                        <span>Edit Prices</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.75"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                      </a>
                    </div>
                  </div>
                {% endif %}

                {% for raw_handle in handles_array %}
                  {% assign handle = raw_handle | strip %}
                  {% if handle != blank %}

                    {% assign entry = shop.metaobjects.custom_shop[handle] %}
                    {% assign tile_logo_clean = blank %}
                    {% assign tile_logo_file = blank %}
                    {% assign tile_onboarding_image = blank %}
                    {% assign tile_name = handle | replace: '-', ' ' | capitalize %}
                    {% assign is_fully_ready = false %}
                    {% assign collection_handle = handle %}

                    {% if entry %}
                      {% assign n = entry.name.value | default: entry.name %}
                      {% if n != blank %}{% assign tile_name = n %}{% endif %}

                      {% assign ready = entry.is_fully_ready.value | default: entry.is_fully_ready %}
                      {% if ready == true or ready == 'true' %}{% assign is_fully_ready = true %}{% endif %}

                      {% assign lcu = entry.logo_clean_url.value | default: entry.logo_clean_url %}
                      {% if lcu == blank %}{% assign lcu = entry.logo_clean.value | default: entry.logo_clean %}{% endif %}
                      {% if lcu == blank %}{% assign lcu = entry.logo_clean_url_.value | default: entry.logo_clean_url_ %}{% endif %}
                      {% if lcu != blank %}{% assign tile_logo_clean = lcu | strip %}{% endif %}

                      {% assign lf = entry.logo.value | default: entry.logo %}
                      {% if lf != blank %}{% assign tile_logo_file = lf %}{% endif %}
                      {% if tile_logo_clean != blank %}
                        {% assign tile_onboarding_image = tile_logo_clean %}
                      {% elsif tile_logo_file != blank %}
                        {% assign tile_onboarding_image = tile_logo_file | image_url: width: 1200 %}
                      {% endif %}

                      {% assign ch = entry.collection_handle.value | default: entry.collection_handle %}
                      {% if ch != blank %}{% assign collection_handle = ch | strip %}{% endif %}
                    {% endif %}

                    {% assign tile_url = routes.collections_url | append: '/' | append: collection_handle %}
                    {% capture admin_url %}/pages/admin-powers?shop={{ handle | url_encode }}{% endcapture %}

                    {% assign collection = collections[collection_handle] %}
                    {% assign product_count = collection.products_count | default: 0 %}

                    {% capture admin_needle2 %}||{{ handle }}||{% endcapture %}
                    {% assign tile_is_admin = false %}
                    {% if admin_handles_blob contains admin_needle2 %}{% assign tile_is_admin = true %}{% endif %}

                    {%- comment %} Read sleep/waking status from metaobject {%- endcomment -%}
                    {%- assign tile_status = '' -%}
                    {%- if entry -%}
                      {%- assign tile_status = entry.status.value | default: entry.status | default: '' | strip | downcase -%}
                    {%- endif -%}
                    {%- assign tile_is_sleeping = false -%}
                    {%- assign tile_is_waking = false -%}
                    {%- if tile_status == 'sleeping' -%}{%- assign tile_is_sleeping = true -%}{%- endif -%}
                    {%- if tile_status == 'waking' -%}{%- assign tile_is_waking = true -%}{%- endif -%}

                    <div
                      class="ss-store-card {% if is_fully_ready and tile_is_sleeping == false and tile_is_waking == false %}ss-clickrow{% endif %}"
                      role="link"
                      tabindex="0"
                      data-href="{{ tile_url }}"
                      data-ss-handle="{{ handle | escape }}"
                      data-ss-backend="{{ section.settings.backend_url | escape }}"
                      data-ss-products="{{ product_count }}"
                      data-ss-ready="{% if is_fully_ready and tile_is_sleeping == false and tile_is_waking == false %}1{% else %}0{% endif %}"
                      data-ss-building="{% if tile_is_waking %}1{% elsif tile_is_sleeping == false and is_fully_ready == false %}1{% else %}0{% endif %}"
                      data-ss-onboarding-admin="{% if tile_is_admin or is_god %}1{% else %}0{% endif %}"
                      data-ss-onboarding-image="{{ tile_onboarding_image | escape }}"
                      data-admin-href="{{ admin_url }}"
                      data-ss-bootstrapper="{% if tile_is_admin or is_god %}1{% else %}0{% endif %}"
                      data-ss-sleep-status="{% if tile_is_sleeping %}sleeping{% elsif tile_is_waking %}waking{% else %}active{% endif %}"
                      style="animation-delay: {{ forloop.index0 | times: 80 }}ms;{% if tile_is_sleeping %} opacity:0.65; border-color:rgba(99,102,241,0.4);{% elsif tile_is_waking %} border-color:rgba(59,130,246,0.5);{% endif %}"
                    >

                      <div class="ss-col-identity">
                        <div class="ss-logo-frame">
                          {% if tile_logo_clean != blank %}
                            <img
                              src="{{ tile_logo_clean | escape }}"
                              loading="lazy"
                              decoding="async"
                              fetchpriority="low"
                              alt="{{ tile_name | escape }}"
                              width="72"
                              height="72">
                          {% elsif tile_logo_file != blank %}
                            {{ tile_logo_file
                              | image_url: width: 300
                              | image_tag: loading: 'lazy', decoding: 'async', alt: tile_name, width: 72, height: 72 }}
                          {% else %}
                            <span class="ss-logo-fallback">{{ tile_name | slice: 0, 2 | upcase }}</span>
                          {% endif %}
                        </div>

                        <div class="ss-identity-text">
                          <h3 class="ss-card-title">{{ tile_name }}</h3>
                          <span class="ss-card-subtitle">Private Collection</span>
                        </div>
                      </div>

                      <div class="ss-col-engine">
                        {% if is_fully_ready and tile_is_sleeping == false and tile_is_waking == false %}
                          <div class="ss-status-finished">
                            <span class="ss-dot-live"></span>
                            <span class="ss-status-text">LIVE STOREFRONT</span>
                          </div>
                        {% elsif tile_is_sleeping %}
                          <div class="ss-status-finished ss-status-hibernating">
                            <span class="ss-dot-live ss-dot-hibernating"></span>
                            <span class="ss-status-text">HIBERNATING STORE</span>
                          </div>
                        {% elsif tile_is_waking or is_fully_ready == false %}
                          <div class="ss-buildwrap">
                            <div class="ss-buildtop">
                              <div class="ss-status-building ss-buildbadge">
                                <span class="ss-dot-building ss-dot-building-anim"></span>
                                <span class="ss-status-text-building">BUILDING YOUR STORE</span>
                              </div>
                            </div>
                            <div class="ss-progress" aria-hidden="true">
                              <div class="ss-progress-track">
                                <div class="ss-progress-bar ss-progress-bar-anim"></div>
                              </div>
                            </div>
                            <div class="ss-founderline" aria-live="polite">
                              <span class="ss-fmsg ss-fmsg-a is-active">Thank you for supporting a veteran-owned store. You can leave this page — production will continue.</span>
                              <span class="ss-fmsg ss-fmsg-b">Your products are being built right now. This page will update automatically when your store is ready.</span>
                            </div>
                          </div>
                        {% endif %}
                      </div>

                      <div class="ss-col-controls">

                        {% if tile_is_sleeping %}
                          {% if tile_is_admin or is_god %}
                            <button
                              class="ss-open-btn ss-wake-btn"
                              data-wake-store-sd
                              data-handle="{{ handle | escape }}"
                              style="background:#2563eb;">
                              ☀️ Wake Up Store
                            </button>
                          {% else %}
                            <button
                              class="ss-leave-btn"
                              data-leave-store
                              data-handle="{{ handle | escape }}"
                              data-name="{{ tile_name | escape }}">
                              Leave Store
                            </button>
                            <p style="font-size:11px; opacity:.65; margin:4px 0 0; text-align:center;">If you need your store woken up, talk to the store admin.</p>
                          {% endif %}
                        {% elsif tile_is_waking %}
                          <button class="ss-open-btn ss-disabled" disabled style="opacity:0.5; cursor:not-allowed; box-shadow:none;">⏳ Rebuilding…</button>
                        {% else %}

                          {% if tile_is_admin %}
                            {% if is_fully_ready %}
                              <a href="{{ admin_url }}" class="ss-admin-btn ss-admin-dyn" title="Admin" data-admin-href="{{ admin_url }}">Admin</a>
                            {% else %}
                              <span class="ss-admin-btn ss-disabled ss-admin-dyn" title="Admin disabled while system prepares" data-admin-href="{{ admin_url }}">Admin</span>
                            {% endif %}
                          {% endif %}

                          {% if is_fully_ready %}
                            <a href="{{ tile_url }}" class="ss-open-btn">
                              <span>Shop Store</span>
                              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.75"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                            </a>
                          {% else %}
                            <button class="ss-open-btn ss-disabled ss-open-dyn" disabled data-open-href="{{ tile_url }}">
                              System Preparing...
                            </button>
                          {% endif %}

                          {% unless tile_is_admin %}
                            {% if is_fully_ready %}
                              <button
                                class="ss-leave-btn"
                                data-leave-store
                                data-handle="{{ handle | escape }}"
                                data-name="{{ tile_name | escape }}">
                                Leave Store
                              </button>
                            {% endif %}
                          {% endunless %}
                        {% endif %}

                      </div>

                    </div>

                  {% endif %}
                {% endfor %}
              </div>

              <div class="ss-mobile-insights">
                <div class="ss-insights-card">
                  <div class="ss-insights-title">Insights</div>
                  <div class="ss-stats">
                    <div class="ss-stat">
                      <div class="ss-stat-label">Studios</div>
                      <div class="ss-stat-value">{{ store_count }}</div>
                    </div>
                    <div class="ss-stat">
                      <div class="ss-stat-label">Products Live</div>
                      <div class="ss-stat-value">{{ total_products_all }}</div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="ss-mobile-cta">
                <a class="ss-btn-primary ss-btn-cta" href="{{ storefront_request_url }}">
                  Create a New Storefront
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
                <a class="ss-btn-secondary" href="{{ explainer_url }}">How it works</a>
              </div>

            {% else %}
              <div class="ss-card ss-empty-state">
                <div class="ss-empty-icon">✨</div>
                <h2>No Active Productions</h2>
                <p>You don't have any private stores assigned yet.</p>

                {% if requested_badge %}
                  <div class="ss-badge-pending">Request Under Review</div>
                {% else %}
                  <a class="ss-btn-primary" href="{{ storefront_request_url }}">{{ request_btn_label }}</a>
                  <div style="height:10px"></div>
                  <a class="ss-btn-secondary" href="{{ explainer_url }}">How it works</a>
                {% endif %}
              </div>
            {% endif %}
          </div>

          <div class="ss-block ss-block-hero">
            <div class="ss-hero">
              <div class="ss-hero-left">
                <div class="ss-hero-kicker">Your private storefront platform</div>

                <div class="ss-hero-title">
                  One dashboard for every team, brand, and community you run.
                </div>

                <div class="ss-hero-sub">
                  Your storefront and products are generated automatically using your uploaded brand assets and placement rules.
                  Once live, take a quick look at mockups to confirm everything looks perfect before ordering.
                </div>

                <div class="ss-hero-actions ss-desktop-cta">
                  <a class="ss-btn-primary ss-btn-cta" href="{{ storefront_request_url }}">
                    Create a New Storefront
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                  <a class="ss-btn-secondary" href="{{ explainer_url }}">How it works</a>
                </div>
              </div>

              <div class="ss-hero-right ss-desktop-insights">
                <div class="ss-stats">
                  <div class="ss-stat">
                    <div class="ss-stat-label">Studios</div>
                    <div class="ss-stat-value">{{ store_count }}</div>
                  </div>
                  <div class="ss-stat">
                    <div class="ss-stat-label">Products Live</div>
                    <div class="ss-stat-value">{{ total_products_all }}</div>
                  </div>
                </div>

                <div class="ss-banner">
                  <div class="ss-banner-dot"></div>
                  <div class="ss-banner-text">
                    <strong>Status:</strong>
                    Automated provisioning is active. Your storefront updates as products publish.
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>

      {% endunless %}
    </div>
  </div>
  

  <div class="ss-onboardingOverlay" id="ssNewStoreOnboarding" aria-hidden="true">
    <div class="ss-onboardingBackdrop" data-ss-onboarding-close></div>
    <div class="ss-onboardingCard" role="dialog" aria-modal="true" aria-labelledby="ssOnboardingTitle">
      <button type="button" class="ss-onboardingX" data-ss-onboarding-close aria-label="Close tutorial">✕</button>

      <div class="ss-onboardingMedia" id="ssOnboardingMedia">
        <div class="ss-onboardingGlow"></div>

        <div class="ss-onboardingLogoShell" id="ssOnboardingLogoShell">
          <span id="ssOnboardingLogoFallback">S&amp;S</span>
          <img id="ssOnboardingLogoImg" alt="Store logo preview" loading="eager" decoding="async" fetchpriority="high">
        </div>

        <div class="ss-onboardingShotShell" id="ssOnboardingShotShell" aria-hidden="true">
          <div class="ss-onboardingShotTop">
            <span id="ssOnboardingShotLabel">Dashboard preview</span>
            <span>Preview</span>
          </div>
          <img id="ssOnboardingShotImg" alt="Onboarding screen preview" loading="eager">
        </div>

        <div class="ss-onboardingBuildPill">
          <span class="ss-onboardingPulse"></span>
          <span id="ssOnboardingPillText">Store build started</span>
        </div>
      </div>

      <div class="ss-onboardingContent">
        <div class="ss-onboardingSlides">
          <article class="ss-onboardingSlide is-active" data-ss-onboarding-slide="0">
            <div class="ss-onboardingKicker">Welcome to Stella &amp; Sage</div>
            <h2 class="ss-onboardingTitle" id="ssOnboardingTitle">Your store is live. Your products are building now.</h2>
            <p class="ss-onboardingText">
              Thanks for supporting a veteran-owned and operated business. Your store has been created successfully, and your products are now being built in the background.
            </p>
            <p class="ss-onboardingText">
              This can take about <strong>15–20 minutes</strong>. You can leave this page and come back later — production will continue either way.
            </p>
            <div class="ss-onboardingCallout">
              Congratulations — you just fired yourself as the middleman.
            </div>
          </article>

          <article class="ss-onboardingSlide" data-ss-onboarding-slide="1">
            <div class="ss-onboardingKicker">Dashboard</div>
            <h2 class="ss-onboardingTitle">Everything lives in one simple dashboard.</h2>
            <p class="ss-onboardingText">
              Every store you create or join will live here. You can come back anytime to shop, manage, or build more products from one place.
            </p>
            <p class="ss-onboardingText">
              Admin tools are only shown to store admins. Customers who join your store can shop or leave the store, but they will not have access to product editing or admin controls.
            </p>
            <div class="ss-onboardingMiniGrid">
              <div><strong>Admins</strong><span>Manage products and store tools</span></div>
              <div><strong>Members</strong><span>Shop the store without extra controls</span></div>
            </div>
          </article>

          <article class="ss-onboardingSlide" data-ss-onboarding-slide="2">
            <div class="ss-onboardingKicker">Admin tools</div>
            <h2 class="ss-onboardingTitle">Simple tools. Powerful control.</h2>
            <p class="ss-onboardingText">
              Your admin page lets you view products, hide products, delete products, adjust logo placement, and choose product colors without using complicated design software.
            </p>
            <p class="ss-onboardingText">
              Pro Builders let you add more customizable merch with different images, front and back designs, and your store image library. Adding a new shirt later only takes a few minutes.
            </p>
            <div class="ss-onboardingMiniGrid ss-onboardingMiniGrid3">
              <div><strong>Edit</strong><span>Placement and colors</span></div>
              <div><strong>Build</strong><span>New products fast</span></div>
              <div><strong>Store</strong><span>Up to 10 images</span></div>
            </div>
          </article>

          <article class="ss-onboardingSlide" data-ss-onboarding-slide="3">
            <div class="ss-onboardingKicker">Storefront</div>
            <h2 class="ss-onboardingTitle">Your beautiful store is almost ready to share.</h2>
            <p class="ss-onboardingText">
              Once the build finishes, your store will unlock and everyone can shop the finished merch directly from your private storefront.
            </p>
            <p class="ss-onboardingText">
              No collecting sizes. No chasing payments. No spreadsheets. Just share the link with your team, group, family, business, or event.
            </p>
            <div class="ss-onboardingCallout ss-onboardingCalloutReady">
              Your store will open automatically when production is complete.
            </div>
          </article>
        </div>

        <div class="ss-onboardingScrollHint" aria-hidden="true">
          <span>Scroll for more</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M6 9l6 6 6-6"></path>
          </svg>
        </div>

        <div class="ss-onboardingFooter">
          <div class="ss-onboardingDots" aria-hidden="true">
            <span class="is-active"></span><span></span><span></span><span></span>
          </div>
          <div class="ss-onboardingBtns">
            <button type="button" class="ss-onboardingBack" data-ss-onboarding-back>Back</button>
            <button type="button" class="ss-onboardingNext" data-ss-onboarding-next>Next</button>
          </div>
        </div>
      </div>
    </div>
  </div>
<div class="ss-leaveOverlay" id="ssLeaveModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.45); z-index:9999; align-items:center; justify-content:center; padding:18px;">
    <div style="width:min(480px,100%); background:#fff; border-radius:16px; border:1px solid rgba(0,0,0,.14); box-shadow:0 22px 70px rgba(0,0,0,.22); padding:20px;">
      <p style="font-weight:900; font-size:16px; margin:0 0 8px;" id="ssLeaveTitle">Leave storefront?</p>
      <p style="margin:0 0 14px; opacity:.8; font-size:14px; line-height:1.45;" id="ssLeaveText"></p>
      <div style="display:flex; gap:10px; flex-wrap:wrap;">
        <button id="ssLeaveConfirm" class="ss-open-btn" style="background:#b00020; box-shadow:none;">Yes, leave</button>
        <button id="ssLeaveCancel" class="ss-btn-secondary">Cancel</button>
      </div>
      <div id="ssLeaveStatus" style="margin-top:10px; font-size:12px; opacity:.75;"></div>
    </div>
  </div>
</section>

<script>
  (function(){


    // ---------------------------
    // New Store Onboarding Tutorial
    // Triggered by /pages/portal?new_store=1&store_handle=<handle>
    // ---------------------------
    function initNewStoreOnboarding(){
      var params = new URLSearchParams(window.location.search || '');
      var storeHandle = (params.get('store_handle') || '').trim();
      var shouldShow = params.get('new_store') === '1' || !!storeHandle;
      if(!shouldShow) return;

      var forceOnboarding = params.get('force_onboarding') === '1' || params.get('test_onboarding') === '1';

      var modal = document.getElementById('ssNewStoreOnboarding');
      if(!modal) return;

      var card = null;
      if(storeHandle && window.CSS && CSS.escape){
        card = document.querySelector('.ss-store-card[data-ss-handle="' + CSS.escape(storeHandle) + '"]');
      }
      if(!card && storeHandle){
        card = Array.prototype.slice.call(document.querySelectorAll('.ss-store-card[data-ss-handle]')).find(function(el){
          return (el.getAttribute('data-ss-handle') || '') === storeHandle;
        });
      }
      if(!card){
        card = document.querySelector('.ss-store-card[data-ss-building="1"][data-ss-onboarding-admin="1"]') || document.querySelector('.ss-store-card[data-ss-handle][data-ss-onboarding-admin="1"]');
      }
      if(!card) return;
      if(!storeHandle) storeHandle = (card.getAttribute('data-ss-handle') || '').trim();

      var storageKey = storeHandle ? ('ss-new-store-onboarding-seen-' + storeHandle) : 'ss-new-store-onboarding-seen-generic';
      if(!forceOnboarding && localStorage.getItem(storageKey) === '1'){
        try { window.history.replaceState({}, document.title, window.location.pathname); } catch(e) {}
        return;
      }

      var isStoreAdmin = card.getAttribute('data-ss-onboarding-admin') === '1';
      if(!isStoreAdmin && !forceOnboarding){
        try { window.history.replaceState({}, document.title, window.location.pathname); } catch(e) {}
        return;
      }

      var storeName = 'your store';
      var logoSrc = card.getAttribute('data-ss-onboarding-image') || '';
      var title = card.querySelector('.ss-card-title');
      if(title && title.textContent.trim()) storeName = title.textContent.trim();
      if(!logoSrc){
        var img = card.querySelector('.ss-logo-frame img');
        if(img && img.getAttribute('src')) logoSrc = img.getAttribute('src');
      }

      var media = document.getElementById('ssOnboardingMedia');
      var fallback = document.getElementById('ssOnboardingLogoFallback');
      var logoImg = document.getElementById('ssOnboardingLogoImg');
      var logoShell = document.getElementById('ssOnboardingLogoShell');
      var shotShell = document.getElementById('ssOnboardingShotShell');
      var shotImg = document.getElementById('ssOnboardingShotImg');
      var shotLabel = document.getElementById('ssOnboardingShotLabel');
      var pillText = document.getElementById('ssOnboardingPillText');

      var onboardingMediaSlides = [
        { kind: 'logo', pill: 'Store build started' },
        {
          kind: 'shot',
          pill: 'Your dashboard',
          label: 'Dashboard preview',
          src: 'https://cdn.shopify.com/s/files/1/0798/2055/4490/files/dashboard_onboarding_modual.png?v=1778737340'
        },
        {
          kind: 'shot',
          pill: 'Admin powers',
          label: 'Admin tools preview',
          src: 'https://cdn.shopify.com/s/files/1/0798/2055/4490/files/admin_dashbaord_onboard_modual.png?v=1778737340'
        },
        {
          kind: 'shot',
          pill: 'Your storefront',
          label: 'Storefront preview',
          src: 'https://cdn.shopify.com/s/files/1/0798/2055/4490/files/storefront_onboard_modual.png?v=1778737340'
        }
      ];

      function withFreshToken(src){
        if(!src) return '';
        if(src.indexOf('ssv=') > -1) return src;
        if(src.indexOf('cdn.shopify.com') === -1 && src.indexOf('logo_clean') === -1) return src;
        return src + (src.indexOf('?') === -1 ? '?' : '&') + 'ssv=' + Date.now();
      }

      if(fallback){
        var initials = storeName.split(/\s+/).filter(Boolean).slice(0,2).map(function(w){ return w.charAt(0); }).join('').toUpperCase();
        fallback.textContent = initials || 'S&S';
      }
      if(logoImg && logoShell){
        if(logoSrc){
          logoImg.src = withFreshToken(logoSrc);
          logoShell.classList.add('has-img');
        } else {
          logoImg.removeAttribute('src');
          logoShell.classList.remove('has-img');
        }
      }

      function renderMedia(){
        var item = onboardingMediaSlides[slideIndex] || onboardingMediaSlides[0];
        if(pillText) pillText.textContent = item.pill || 'Store build started';

        if(item.kind === 'shot'){
          if(media) media.classList.add('has-shot');
          if(logoShell) logoShell.style.display = 'none';
          if(shotShell) {
            shotShell.classList.add('is-visible');
            shotShell.setAttribute('aria-hidden', 'false');
          }
          if(shotImg && item.src && shotImg.getAttribute('src') !== item.src) shotImg.src = item.src;
          if(shotLabel) shotLabel.textContent = item.label || 'Preview';
        } else {
          if(media) media.classList.remove('has-shot');
          if(logoShell) logoShell.style.display = '';
          if(shotShell) {
            shotShell.classList.remove('is-visible');
            shotShell.setAttribute('aria-hidden', 'true');
          }
        }
      }

      var slideIndex = 0;
      var slides = Array.prototype.slice.call(modal.querySelectorAll('[data-ss-onboarding-slide]'));
      var dots = Array.prototype.slice.call(modal.querySelectorAll('.ss-onboardingDots span'));
      var backBtn = modal.querySelector('[data-ss-onboarding-back]');
      var nextBtn = modal.querySelector('[data-ss-onboarding-next]');

      function render(){
        slides.forEach(function(slide, i){ slide.classList.toggle('is-active', i === slideIndex); });
        dots.forEach(function(dot, i){ dot.classList.toggle('is-active', i === slideIndex); });
        if(backBtn) backBtn.style.visibility = slideIndex === 0 ? 'hidden' : 'visible';
        if(nextBtn) nextBtn.textContent = slideIndex >= slides.length - 1 ? 'Got it' : 'Next';
        renderMedia();
      }

      function close(){
        localStorage.setItem(storageKey, '1');
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        try { window.history.replaceState({}, document.title, window.location.pathname); } catch(e) {}
      }

      function next(){
        if(slideIndex >= slides.length - 1){ close(); return; }
        slideIndex += 1;
        render();
      }

      function back(){
        slideIndex = Math.max(0, slideIndex - 1);
        render();
      }

      modal.querySelectorAll('[data-ss-onboarding-close]').forEach(function(btn){ btn.addEventListener('click', close); });
      if(nextBtn) nextBtn.addEventListener('click', next);
      if(backBtn) backBtn.addEventListener('click', back);
      document.addEventListener('keydown', function(e){
        if(!modal.classList.contains('is-open')) return;
        if(e.key === 'Escape') close();
        if(e.key === 'ArrowRight') next();
        if(e.key === 'ArrowLeft') back();
      });

      render();
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    initNewStoreOnboarding();
    // ---------------------------
    // Click rows
    // ---------------------------
    var rows = document.querySelectorAll('.ss-store-card[data-href]');
    rows.forEach(function(row){
      var href = row.getAttribute('data-href');
      if(!href) return;

      row.addEventListener('click', function(e){
        if (e.target.closest('a, button')) return;
        if (!row.classList.contains('ss-clickrow')) return;
        window.location.href = href;
      });

      row.addEventListener('keydown', function(e){
        if (e.key === 'Enter' || e.key === ' ') {
          if (!row.classList.contains('ss-clickrow')) return;
          e.preventDefault();
          window.location.href = href;
        }
      });
    });

    // ---------------------------
    // Remove trailing " ####" (UI only)
    // ---------------------------
    function stripSuffix4Digits(txt){
      if(!txt) return txt;
      return txt.replace(/\s\d{4}\s*$/,'').replace(/-\d{4}\s*$/,'');
    }
    document.querySelectorAll('.ss-card-title').forEach(function(el){
      var cleaned = stripSuffix4Digits((el.textContent || '').trim());
      if(cleaned) el.textContent = cleaned;
    });

    // ============================================================
    // Backend URL (used for polling and leave-store)
    // ============================================================
    var BACKEND_URL = {{ section.settings.backend_url | default: '' | json }};

    // --- Enable admin link after store unlocks ---
    function enableAdminUI(card){
      var admin = card.querySelector('.ss-admin-dyn');
      if(!admin) return;
      if(!(admin.tagName && admin.tagName.toLowerCase() === 'span')) return;
      var href = admin.getAttribute('data-admin-href') || '';
      if(!href) return;
      var a = document.createElement('a');
      a.href = href;
      a.className = 'ss-admin-btn ss-admin-dyn';
      a.setAttribute('data-admin-href', href);
      a.title = 'Admin';
      a.textContent = 'Admin';
      admin.parentNode.replaceChild(a, admin);
    }

    // --- Transition a card to the live/unlocked state ---
    function setLiveUI(card){
      // Never upgrade sleeping or waking cards — their controls are managed by Liquid
      var sleepStatus = card.getAttribute('data-ss-sleep-status');
      if(sleepStatus === 'sleeping' || sleepStatus === 'waking') return;
      card.classList.add('ss-clickrow');
      card.setAttribute('data-ss-unlocked','1');
      card.style.opacity = '';
      card.style.borderColor = '';
      card.style.boxShadow = '';

      // Engine: replace buildwrap with LIVE pill
      var engine = card.querySelector('.ss-col-engine');
      if(engine){
        var buildwrap = engine.querySelector('.ss-buildwrap');
        if(buildwrap) buildwrap.parentNode.removeChild(buildwrap);
        if(!engine.querySelector('.ss-status-finished')){
          var finished = document.createElement('div');
          finished.className = 'ss-status-finished';
          finished.innerHTML = '<span class="ss-dot-live"></span><span class="ss-status-text">LIVE STOREFRONT</span>';
          engine.appendChild(finished);
        }
      }

      // Controls: wire up Shop Store link and Admin link
      var controls = card.querySelector('.ss-col-controls');
      if(controls){
        var isBootstrapper = card.getAttribute('data-ss-bootstrapper') === '1';
        var storeHref = card.getAttribute('data-href') || '#';
        var adminHref = card.getAttribute('data-admin-href') || '';

        // Remove "only admin can wake" helper text if present
        var wakeNote = controls.querySelector('p');
        if(wakeNote) wakeNote.parentNode.removeChild(wakeNote);

        // Build shop-store anchor
        function makeOpenLink(){
          var a = document.createElement('a');
          a.href = storeHref;
          a.className = 'ss-open-btn';
          a.innerHTML = '<span>Shop Store</span><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.75"><path d="M5 12h14M12 5l7 7-7 7"/></svg>';
          return a;
        }

        // Replace .ss-open-dyn placeholder (building state)
        var dynBtn = controls.querySelector('.ss-open-dyn');
        if(dynBtn){
          dynBtn.parentNode.replaceChild(makeOpenLink(), dynBtn);
        }

        // Replace wake button (sleeping state — admin)
        var wakeBtn = controls.querySelector('[data-wake-store-sd]');
        if(wakeBtn){
          if(isBootstrapper && adminHref){
            var adminA = document.createElement('a');
            adminA.href = adminHref;
            adminA.className = 'ss-admin-btn ss-admin-dyn';
            adminA.setAttribute('data-admin-href', adminHref);
            adminA.title = 'Admin';
            adminA.textContent = 'Admin';
            controls.insertBefore(adminA, wakeBtn);
          }
          wakeBtn.parentNode.replaceChild(makeOpenLink(), wakeBtn);
        }

        // Replace any remaining disabled open button (waking / sleeping non-admin)
        var disBtn = controls.querySelector('.ss-open-btn.ss-disabled');
        if(disBtn){
          if(isBootstrapper && adminHref && !controls.querySelector('.ss-admin-dyn')){
            var adminA2 = document.createElement('a');
            adminA2.href = adminHref;
            adminA2.className = 'ss-admin-btn ss-admin-dyn';
            adminA2.setAttribute('data-admin-href', adminHref);
            adminA2.title = 'Admin';
            adminA2.textContent = 'Admin';
            disBtn.parentNode.insertBefore(adminA2, disBtn);
          }
          disBtn.parentNode.replaceChild(makeOpenLink(), disBtn);
        }
      }

      // Enable admin span → link (building state)
      enableAdminUI(card);
    }

    // --- Cycle between message A and B every 20 s ---
    function startMsgCycle(card){
      var msgA = card.querySelector('.ss-fmsg-a');
      var msgB = card.querySelector('.ss-fmsg-b');
      if(!msgA || !msgB) return;
      setInterval(function(){
        if(msgA.classList.contains('is-active')){
          msgA.classList.remove('is-active');
          msgB.classList.add('is-active');
        } else {
          msgB.classList.remove('is-active');
          msgA.classList.add('is-active');
        }
      }, 20000);
    }

    // --- Poll backend every 10 s until ready = true ---
    function startPollingReady(card){
      var handle = card.getAttribute('data-ss-handle') || '';
      var backendUrl = (card.getAttribute('data-ss-backend') || BACKEND_URL || '').replace(/\/$/, '');
      if(!handle || !backendUrl) return;
      var intervalId = setInterval(function(){
        if(!document.body.contains(card)){ clearInterval(intervalId); return; }
        fetch(backendUrl + '/store/' + encodeURIComponent(handle) + '/ready-status', { cache: 'no-store' })
          .then(function(r){ return r.json(); })
          .then(function(data){
            if(data.ready === true || data.ready === 'true' || data.is_fully_ready === true || data.is_fully_ready === 'true'){
              clearInterval(intervalId);
              var bar = card.querySelector('.ss-progress-bar');
              if(bar) bar.style.width = '100%';
              setTimeout(function(){ window.location.reload(); }, 800);
            }
          })
          .catch(function(err){ console.error('[ss-poll] ready-status error for ' + handle + ':', err); /* keep polling */ });
      }, 10000);
    }

    // --- Initialise each store card ---
    document.querySelectorAll('.ss-store-card[data-ss-building="1"]').forEach(function(card){
      startMsgCycle(card);
      startPollingReady(card);
    });

    // Ready cards: Liquid already rendered LIVE — call setLiveUI to ensure JS state is consistent
    document.querySelectorAll('.ss-store-card[data-ss-ready="1"]').forEach(function(card){
      setLiveUI(card);
    });

    // --- Leave Store ---
    var leaveModal   = document.getElementById('ssLeaveModal');
    var leaveText    = document.getElementById('ssLeaveText');
    var leaveStatus  = document.getElementById('ssLeaveStatus');
    var leaveConfirm = document.getElementById('ssLeaveConfirm');
    var leaveCancel  = document.getElementById('ssLeaveCancel');
    var leaveHandle  = '';

    document.addEventListener('click', function(e){
      var btn = e.target.closest('[data-leave-store]');
      if(!btn) return;
      leaveHandle = btn.getAttribute('data-handle') || '';
      var name = btn.getAttribute('data-name') || leaveHandle;
      leaveText.textContent = 'You will be removed from "' + name + '". You can only re-join if an admin invites you back.';
      leaveStatus.textContent = '';
      leaveConfirm.disabled = false;
      leaveModal.style.display = 'flex';
    });

    leaveCancel && leaveCancel.addEventListener('click', function(){ leaveModal.style.display = 'none'; });
    leaveModal  && leaveModal.addEventListener('click', function(e){ if(e.target===leaveModal) leaveModal.style.display='none'; });

    leaveConfirm && leaveConfirm.addEventListener('click', async function(){
      if(!leaveHandle) return;
      if(!BACKEND_URL){
        leaveStatus.textContent = 'Backend URL not configured in section settings.';
        return;
      }
      leaveConfirm.disabled = true;
      leaveStatus.textContent = 'Removing\u2026';
      try {
        var res = await fetch(BACKEND_URL + '/api/storefront/' + encodeURIComponent(leaveHandle) + '/leave', {
          method: 'POST',
          headers: {'Content-Type':'application/json'},
          body: JSON.stringify({ customer_id: String({{ customer.id | json }}) }),
          credentials: 'omit'
        });
        if(!res.ok){ leaveStatus.textContent = 'Error: ' + res.status; leaveConfirm.disabled=false; return; }
        leaveStatus.textContent = 'Done! Refreshing\u2026';
        setTimeout(function(){ window.location.reload(); }, 800);
      } catch(err) {
        leaveStatus.textContent = 'Network error: ' + (err.message||'unknown');
        leaveConfirm.disabled = false;
      }
    });

    // --- Wake Store (seller dashboard) ---
    // Routed through the Shopify App Proxy relay: auth is the proxy signature +
    // the logged-in customer's storefront-admin--{handle} tag (verified
    // server-side). No admin secret is exposed to the browser.
    var SD_RELAY_URL = '/apps/ss/relay';
    document.addEventListener('click', function(e){
      var btn = e.target.closest('[data-wake-store-sd]');
      if(!btn) return;
      var handle = btn.getAttribute('data-handle') || '';
      if(!handle) return;
      if(!confirm('Wake up store "' + handle + '"? This will re-run Printful to rebuild all products.')) return;
      btn.disabled = true;
      btn.textContent = 'Waking up\u2026';
      fetch(SD_RELAY_URL + '/store/' + encodeURIComponent(handle) + '/wakeup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' }
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if(data.job_id || data.status === 'ok'){
          btn.textContent = '\u2705 Waking! Reloading\u2026';
          setTimeout(function(){ window.location.reload(); }, 2000);
        } else {
          btn.textContent = '\u274C Failed';
          btn.disabled = false;
        }
      })
      .catch(function(){ btn.textContent = '\u274C Error'; btn.disabled = false; });
    });

    // --- God Mode: new store notifications ---
    if (document.querySelector('.ss-god-card')) {
      var seen = (localStorage.getItem('ss-god-seen-stores') || '').split(',').filter(Boolean);
      var allStores = window.SS_ALL_PLATFORM_STORES || [];
      var newStores = allStores.filter(function(s){ return seen.indexOf(s.handle) === -1; });

      function ssGodEscape(str) {
        return String(str)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function ssGodMarkAllSeen() {
        var allHandles = (window.SS_ALL_PLATFORM_STORES || []).map(function(s){ return s.handle; });
        localStorage.setItem('ss-god-seen-stores', allHandles.join(','));
        var panel = document.querySelector('.ss-new-stores-panel');
        if (panel) panel.remove();
        var badge = document.querySelector('.ss-god-new-badge');
        if (badge) badge.remove();
      }

      if (newStores.length > 0) {
        // Add badge to god card
        var godCard = document.querySelector('.ss-god-card');
        var badge = document.createElement('span');
        badge.className = 'ss-god-new-badge';
        badge.textContent = newStores.length + ' new stores built';
        godCard.style.position = 'relative';
        godCard.appendChild(badge);

        // Add new stores panel after the god card
        var panel = document.createElement('div');
        panel.className = 'ss-new-stores-panel';
        panel.innerHTML = '<div class="ss-nsp-title">🆕 ' + newStores.length + ' new stores built</div>' +
          newStores.map(function(s){
            var collectionHandle = s.collection_handle || s.handle;
            return '<div class="ss-nsp-row">' +
              '<div class="ss-nsp-info"><span class="ss-nsp-name">' + ssGodEscape(s.name) + '</span><span class="ss-nsp-handle">@' + ssGodEscape(s.handle) + '</span></div>' +
              '<a href="/collections/' + encodeURIComponent(collectionHandle) + '" class="ss-nsp-visit" target="_blank">Visit Store →</a>' +
              '</div>';
          }).join('') +
          '<button class="ss-nsp-dismiss">Mark all seen ✓</button>';
        godCard.parentNode.insertBefore(panel, godCard.nextSibling);

        var dismissBtn = panel.querySelector('.ss-nsp-dismiss');
        if (dismissBtn) {
          dismissBtn.addEventListener('click', ssGodMarkAllSeen);
        }
      }

      // Mark all seen when clicking the god mode link
      var godLink = document.querySelector('.ss-god-card a[href="/pages/super-admin"]');
      if (godLink) {
        godLink.addEventListener('click', ssGodMarkAllSeen);
      }
    }

  })();
</script>

