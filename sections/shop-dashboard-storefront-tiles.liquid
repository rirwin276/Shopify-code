@media (max-width: 640px){
  .sdtiles__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
  .sdtiles__media { aspect-ratio: 4/5; min-height: 180px; }
  .sdtiles__body { padding: 10px; }
  .sdtiles__name { font-size: 13px; font-weight: 900; letter-spacing: -.01em; }
  .sdtiles__meta { gap: 5px; margin-top: 7px; }
  .sdtiles__badge { font-size: 11px; padding: 4px 8px; }
  .sdtiles__cta { gap: 7px; margin-top: 9px; }
  .sdtiles__btn { padding: 9px 10px; font-size: 12px; border-radius: 999px; letter-spacing: -.01em; }
  .sdtiles__sleep-banner { font-size: 11px; padding: 6px 9px; }
}