{% comment %}
  Shop Dashboard - Storefront Tiles (FULL REWRITE)
  - Works without array "push" (theme-check safe)
  - Reads customer tags:
      storefront-admin--<handle>
      storefront-member--<handle>
  - Looks up metaobject by handle:
      shop.metaobjects.custom_shop[handle]
  - ALWAYS renders something (so it can’t “show nothing” silently)
  - Optional Debug mode to print what the storefront actually sees

  NEW:
  - Admin Powers button (admins only): /pages/admin-powers?shop=<handle>
  - Optional Remove store button (UI + webhook)
{% endcomment %}

<section class="sdtiles section-{{ section.id }}">
  <style>
    .section-{{ section.id }} { padding: {{ section.settings.padding_y }}px 0; }
    .sdtiles__wrap { max-width: {{ section.settings.max_width }}px; margin: 0 auto; padding: 0 16px; }

    .sdtiles__banner {
      border: 2px dashed rgba(0,0,0,.25);
      border-radius: 14px;
      padding: 10px 12px;
      margin-bottom: 14px;
      background: rgba(0,0,0,.02);
      font-weight: 800;
      font-size: 13px;
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
    }
    .sdtiles__banner small { font-weight: 600; opacity: .7; }

    .sdtiles__head { margin-bottom: 12px; }
    .sdtiles__title { margin: 0; font-size: clamp(20px, 2.3vw, 28px); line-height: 1.15; }
    .sdtiles__sub { margin: 6px 0 0; opacity: .75; font-size: 14px; line-height: 1.4; }

    .sdtiles__grid { display: grid; grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr)); gap: 14px; }
    @media (max-width: 990px){ .sdtiles__grid { grid-template-columns: repeat({{ section.settings.columns_tablet }}, minmax(0, 1fr)); } }
    @media (max-width: 640px){ .sdtiles__grid { grid-template-columns: 1fr; } }

    .sdtiles__card { border: 1px solid rgba(0,0,0,.12); border-radius: 16px; overflow: hidden; background: {{ section.settings.card_bg }}; box-shadow: 0 6px 18px rgba(0,0,0,.06); }
    .sdtiles__media { position: relative; aspect-ratio: {{ section.settings.logo_aspect_ratio }}; background: rgba(0,0,0,.04); display:flex; align-items:center; justify-content:center; }
    .sdtiles__media img { width: 100%; height: 100%; object-fit: {{ section.settings.logo_fit }}; display:block; }
    .sdtiles__placeholder { font-weight: 800; letter-spacing: .06em; opacity: .55; font-size: 12px; }

    .sdtiles__body { padding: 14px; }
    .sdtiles__name { margin: 0; font-size: 16px; line-height: 1.25; font-weight: 800; }
    .sdtiles__meta { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
    .sdtiles__badge { display:inline-flex; align-items:center; gap: 6px; padding: 6px 10px; border-radius: 999px; font-size: 12px; line-height:1; border: 1px solid rgba(0,0,0,.12); background: rgba(255,255,255,.65); }
    .sdtiles__dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(0,0,0,.35); }

    .sdtiles__cta { margin-top: 12px; display:flex; flex-direction: column; gap: 10px; }

    .sdtiles__btn {
      width: 100%;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding: 10px 12px;
      border-radius: 12px;
      text-decoration:none;
      font-weight: 800;
      font-size: 13px;
      border: 1px solid rgba(0,0,0,.14);
      background: {{ section.settings.button_bg }};
      color: {{ section.settings.button_text }};
      cursor: pointer;
    }
    .sdtiles__btn:hover { filter: brightness(.98); }

    .sdtiles__btn--secondary{
      background: {{ section.settings.secondary_button_bg }};
      color: {{ section.settings.secondary_button_text }};
    }

    .sdtiles__btn--danger{
      background: #fff;
      color: #b00020;
      border-color: rgba(176,0,32,.28);
    }

    .sdtiles__panel { border: 1px dashed rgba(0,0,0,.22); border-radius: 16px; padding: 16px; background: rgba(0,0,0,.02); }
    .sdtiles__panel h3 { margin: 0 0 6px; font-size: 16px; }
    .sdtiles__panel p { margin: 0 0 12px; opacity: .8; line-height: 1.35; }
    .sdtiles__row { display:flex; gap: 10px; flex-wrap: wrap; }
    .sdtiles__linkbtn { display:inline-flex; align-items:center; justify-content:center; padding: 10px 12px; border-radius: 12px; text-decoration:none; font-weight: 800; font-size: 13px; border: 1px solid rgba(0,0,0,.14); background: {{ section.settings.secondary_button_bg }}; color: {{ section.settings.secondary_button_text }}; }

    .sdtiles__debug { margin-top: 14px; padding: 12px; border-radius: 12px; border: 1px solid rgba(0,0,0,.14); background: rgba(0,0,0,.02); font-size: 12px; line-height: 1.35; white-space: pre-wrap; }
    .sdtiles__debug strong { font-weight: 900; }

    /* Remove store modal */
    .sdtiles__modalOverlay{
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.45);
      z-index: 9999;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 18px;
    }
    .sdtiles__modal{
      width: min(520px, 100%);
      background: #fff;
      border-radius: 16px;
      border: 1px solid rgba(0,0,0,.14);
      box-shadow: 0 22px 70px rgba(0,0,0,.22);
      padding: 16px;
    }
    .sdtiles__modalTitle{ font-weight: 900; font-size: 16px; margin: 0 0 8px; }
    .sdtiles__modalText{ margin: 0; opacity: .8; line-height: 1.45; }
    .sdtiles__modalActions{ margin-top: 12px; display:flex; gap: 10px; flex-wrap: wrap; }
    .sdtiles__modalActions .sdtiles__btn{ width: auto; }
    .sdtiles__statusLine{ margin-top: 10px; font-size: 12px; opacity: .75; }

    .sdtiles__card--sleeping { opacity: 0.7; border-color: rgba(99,102,241,0.45) !important; filter: grayscale(0.15); }
    .sdtiles__sleep-banner { background: linear-gradient(90deg, rgba(99,102,241,0.12), rgba(139,92,246,0.12)); border: 1px solid rgba(99,102,241,0.35); border-radius: 8px; padding: 8px 12px; font-size: 12px; color: #6366f1; font-weight: 700; margin-bottom: 10px; letter-spacing: 0.01em; }

    .sdtiles__card--waking { border-color: rgba(217,119,6,0.45) !important; }
  </style>

  <div class="sdtiles__wrap">
    {% if section.settings.show_loaded_banner %}
      <div class="sdtiles__banner">
        <div>SECTION LOADED ✅ <small>(Storefront tiles)</small></div>
        <small>{{ request.path }}</small>
      </div>
    {% endif %}

    <div class="sdtiles__head">
      <h2 class="sdtiles__title">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p class="sdtiles__sub">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    {%- if customer == nil -%}
      <div class="sdtiles__panel">
        <h3>{{ section.settings.login_title }}</h3>
        <p>{{ section.settings.login_text }}</p>
        <div class="sdtiles__row">
          <a class="sdtiles__linkbtn" href="{{ routes.account_login_url }}?return_url={{ request.path | url_encode }}">{{ section.settings.login_button_label }}</a>
          {% if section.settings.request_storefront_url != blank %}
            <a class="sdtiles__linkbtn" href="{{ section.settings.request_storefront_url }}">{{ section.settings.request_storefront_label }}</a>
          {% endif %}
        </div>
      </div>

      {% if section.settings.debug_mode %}
        <div class="sdtiles__debug"><strong>DEBUG</strong>
customer: nil (not logged in)
page: {{ request.path }}
        </div>
      {% endif %}

    {%- else -%}

      {%- assign handles_str = '|' -%}
      {%- assign admin_str = '|' -%}

      {%- for t in customer.tags -%}
        {%- if t contains section.settings.admin_tag_prefix -%}
          {%- assign h = t | remove: section.settings.admin_tag_prefix | strip -%}
          {%- if h != blank -%}
            {%- assign token = '|' | append: h | append: '|' -%}
            {%- unless handles_str contains token -%}
              {%- assign handles_str = handles_str | append: h | append: '|' -%}
            {%- endunless -%}
            {%- unless admin_str contains token -%}
              {%- assign admin_str = admin_str | append: h | append: '|' -%}
            {%- endunless -%}
          {%- endif -%}

        {%- elsif t contains section.settings.member_tag_prefix -%}
          {%- assign h = t | remove: section.settings.member_tag_prefix | strip -%}
          {%- if h != blank -%}
            {%- assign token = '|' | append: h | append: '|' -%}
            {%- unless handles_str contains token -%}
              {%- assign handles_str = handles_str | append: h | append: '|' -%}
            {%- endunless -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}

      {%- assign handles_list = handles_str | split: '|' -%}

      {%- assign real_count = 0 -%}
      {%- for h in handles_list -%}
        {%- if h != blank -%}
          {%- assign real_count = real_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if real_count == 0 -%}
        <div class="sdtiles__panel">
          <h3>{{ section.settings.empty_title }}</h3>
          <p>{{ section.settings.empty_text }}</p>
          <div class="sdtiles__row">
            {% if section.settings.request_storefront_url != blank %}
              <a class="sdtiles__linkbtn" href="{{ section.settings.request_storefront_url }}">{{ section.settings.request_storefront_label }}</a>
            {% endif %}
          </div>
        </div>
      {%- else -%}
        <div class="sdtiles__grid">
          {%- for h in handles_list -%}
            {%- if h == blank -%}{% continue %}{%- endif -%}

            {%- assign token = '|' | append: h | append: '|' -%}
            {%- assign role = 'Member' -%}
            {%- assign is_admin_tile = false -%}
            {%- if admin_str contains token -%}
              {%- assign role = 'Admin' -%}
              {%- assign is_admin_tile = true -%}
            {%- endif -%}

            {%- assign entry = shop.metaobjects.custom_shop[h] -%}

            {%- assign display_name = h -%}
            {%- assign status_value = 'under_construction' -%}
            {%- assign logo_value = blank -%}

            {%- if entry != blank -%}
              {%- if entry.name != blank -%}
                {%- assign display_name = entry.name.value | default: entry.name -%}
              {%- endif -%}
              {%- if entry.status != blank -%}
                {%- assign status_value = entry.status.value | default: entry.status -%}
              {%- endif -%}
              {%- if entry.logo != blank -%}
                {%- assign logo_value = entry.logo.value | default: entry.logo -%}
              {%- endif -%}
            {%- endif -%}

            {%- assign status_label = status_value | replace: '_', ' ' | capitalize -%}
            {%- if status_value == 'sleeping' -%}
              {%- assign status_label = 'Hibernation Mode' -%}
            {%- endif -%}

            {%- assign is_sleeping = false -%}
            {%- assign is_waking = false -%}
            {%- if status_value == 'sleeping' -%}{%- assign is_sleeping = true -%}{%- endif -%}
            {%- if status_value == 'waking' -%}{%- assign is_waking = true -%}{%- endif -%}

            {%- assign h_enc = h | url_encode -%}
            {%- assign storefront_url = section.settings.storefront_base_url | append: '?shop=' | append: h_enc -%}
            {%- assign admin_powers_url = section.settings.admin_powers_url | default: '/pages/admin-powers' -%}
            {%- assign admin_powers_link = admin_powers_url | append: '?shop=' | append: h_enc -%}

            <div class="sdtiles__card{% if is_sleeping %} sdtiles__card--sleeping{% elsif is_waking %} sdtiles__card--waking{% endif %}">
              <div class="sdtiles__media">
                {% if logo_value != blank %}
                  {{ logo_value | image_url: width: 1200 | image_tag: loading: 'lazy', alt: display_name }}
                {% else %}
                  <div class="sdtiles__placeholder">{{ section.settings.logo_placeholder_text }}</div>
                {% endif %}
              </div>

              <div class="sdtiles__body">
                <h3 class="sdtiles__name">{{ display_name }}</h3>

                {% if is_sleeping %}
                  <div class="sdtiles__sleep-banner">🌙 Hibernation Mode — Store is resting</div>
                {% elsif is_waking %}
                  <div class="sdtiles__sleep-banner" style="color:#d97706; border-color:rgba(217,119,6,0.3); background:rgba(217,119,6,0.08);">⚡ Waking Up — Products are being rebuilt…</div>
                {% endif %}

                <div class="sdtiles__meta">
                  {% if section.settings.show_status_badge %}
                    <span class="sdtiles__badge"><span class="sdtiles__dot"></span>{{ status_label }}</span>
                  {% endif %}
                  {% if section.settings.show_role_badge %}
                    <span class="sdtiles__badge"><span class="sdtiles__dot"></span>{{ role }}</span>
                  {% endif %}
                </div>

                <div class="sdtiles__cta">
                  {% if is_sleeping %}
                    <button type="button" class="sdtiles__btn" disabled style="opacity:0.5; cursor:not-allowed;">🌙 In Hibernation</button>
                    {% if is_admin_tile %}
                      <button
                        type="button"
                        class="sdtiles__btn sdtiles__btn--secondary"
                        data-wake-store
                        data-handle="{{ h | escape }}"
                        data-backend-url="{{ section.settings.backend_url | escape }}">
                        ☀️ Wake Up Store
                      </button>
                    {% else %}
                      <p style="font-size:12px; opacity:.75; margin:0;">This store is in hibernation mode. Ask the store admin to wake it up.</p>
                    {% endif %}
                  {% elsif is_waking %}
                    <button type="button" class="sdtiles__btn" disabled style="opacity:0.6; cursor:not-allowed;">⚡ Waking up…</button>
                  {% else %}
                    <a class="sdtiles__btn" href="{{ storefront_url }}">
                      {{ section.settings.open_button_label }}
                    </a>

                    {% if is_admin_tile %}
                      <a class="sdtiles__btn sdtiles__btn--secondary" href="{{ admin_powers_link }}">
                        {{ section.settings.admin_powers_label }}
                      </a>
                    {% endif %}

                    {% if section.settings.enable_remove_store %}
                      {% unless is_admin_tile %}
                      <button
                        type="button"
                        class="sdtiles__btn sdtiles__btn--danger"
                        data-remove-store
                        data-handle="{{ h | escape }}"
                        data-name="{{ display_name | escape }}">
                        {{ section.settings.remove_store_label }}
                      </button>
                      {% endunless %}
                    {% endif %}
                  {% endif %}
                </div>

                {% if section.settings.show_handle_line %}
                  <div style="margin-top:10px; font-size:12px; opacity:.75;">Handle: <strong>{{ h }}</strong></div>
                {% endif %}

                {% if section.settings.show_missing_metaobject_note and entry == blank %}
                  <div style="margin-top:10px; font-size:12px; opacity:.75;">{{ section.settings.missing_metaobject_text }}</div>
                {% endif %}
              </div>
            </div>

          {%- endfor -%}
        </div>
      {%- endif -%}

      {% if section.settings.debug_mode %}
        <div class="sdtiles__debug"><strong>DEBUG</strong>
customer email: {{ customer.email }}
page: {{ request.path }}

expected prefixes:
- admin:  {{ section.settings.admin_tag_prefix }}
- member: {{ section.settings.member_tag_prefix }}

all tags:
{% for t in customer.tags %}- {{ t }}
{% endfor %}

handles_str: {{ handles_str }}
admin_str: {{ admin_str }}
real_count: {{ real_count }}

note: metaobject lookup is shop.metaobjects.custom_shop[handle]
        </div>
      {% endif %}

    {%- endif -%}
  </div>

  <div class="sdtiles__modalOverlay" id="sdtilesModal">
    <div class="sdtiles__modal" role="dialog" aria-modal="true" aria-labelledby="sdtilesModalTitle">
      <p class="sdtiles__modalTitle" id="sdtilesModalTitle">{{ section.settings.remove_modal_title }}</p>
      <p class="sdtiles__modalText" id="sdtilesModalText"></p>
      <div class="sdtiles__modalActions">
        <button type="button" class="sdtiles__btn sdtiles__btn--danger" id="sdtilesConfirm">{{ section.settings.remove_confirm_label }}</button>
        <button type="button" class="sdtiles__btn sdtiles__btn--secondary" id="sdtilesCancel">{{ section.settings.remove_cancel_label }}</button>
      </div>
      <div class="sdtiles__statusLine" id="sdtilesStatus"></div>
    </div>
  </div>

  <script>
  (function(){
    const enableRemove = {{ section.settings.enable_remove_store | json }};
    if(!enableRemove) return;

    const backendUrl = {{ section.settings.backend_url | default: '' | json }};
    const webhookUrl = {{ section.settings.remove_store_webhook_url | json }};
    const modal = document.getElementById('sdtilesModal');
    const modalText = document.getElementById('sdtilesModalText');
    const statusLine = document.getElementById('sdtilesStatus');
    const btnConfirm = document.getElementById('sdtilesConfirm');
    const btnCancel = document.getElementById('sdtilesCancel');

    let currentHandle = "";
    let currentName = "";

    function openModal(handle, name){
      currentHandle = handle || "";
      currentName = name || handle || "";
      statusLine.textContent = "";
      modalText.textContent = `Are you sure you want to remove "${currentName}" from your dashboard? You will no longer have access to this storefront unless an admin re-invites you.`;
      modal.style.display = 'flex';
    }
    function closeModal(){
      modal.style.display = 'none';
      currentHandle = "";
      currentName = "";
    }

    document.addEventListener('click', (e) => {
      const btn = e.target.closest('[data-remove-store]');
      if(!btn) return;
      const handle = btn.getAttribute('data-handle') || "";
      const name = btn.getAttribute('data-name') || handle;
      openModal(handle, name);
    });

    btnCancel && btnCancel.addEventListener('click', closeModal);
    modal && modal.addEventListener('click', (e) => {
      if(e.target === modal) closeModal();
    });

    btnConfirm && btnConfirm.addEventListener('click', async () => {
      if(!currentHandle) return;

      btnConfirm.disabled = true;
      statusLine.textContent = "Removing access\u2026";

      // Prefer the backend_url API endpoint if configured
      if(backendUrl){
        try{
          const res = await fetch(backendUrl + '/api/storefront/' + encodeURIComponent(currentHandle) + '/leave', {
            method: "POST",
            headers: {"Content-Type":"application/json"},
            body: JSON.stringify({ customer_id: String({{ customer.id | json }}) }),
            credentials: "omit"
          });

          if(!res.ok){
            statusLine.textContent = "Error: " + res.status;
            btnConfirm.disabled = false;
            return;
          }

          statusLine.textContent = "Done! Refreshing\u2026";
          setTimeout(() => window.location.reload(), 800);
        }catch(err){
          statusLine.textContent = "Network error: " + (err && err.message ? err.message : "unknown");
          btnConfirm.disabled = false;
        }
        return;
      }

      // Fallback to legacy webhook URL if no backend_url
      if(!webhookUrl){
        statusLine.textContent = "No removal method configured (set backend URL or legacy webhook URL in section settings).";
        btnConfirm.disabled = false;
        return;
      }

      try{
        const res = await fetch(webhookUrl, {
          method: "POST",
          headers: {"Content-Type":"application/json"},
          body: JSON.stringify({
            shop_handle: currentHandle,
            action: "leave_storefront"
          })
        });

        if(!res.ok){
          const txt = await res.text();
          statusLine.textContent = "Webhook error: " + res.status + " " + txt;
          btnConfirm.disabled = false;
          return;
        }

        statusLine.textContent = "Success! Refreshing\u2026";
        window.location.reload();
      }catch(err){
        statusLine.textContent = "Network error: " + (err && err.message ? err.message : "unknown");
        btnConfirm.disabled = false;
      }
    });
  })();

  // --- Wake Store ---
  document.addEventListener('click', (e) => {
    const btn = e.target.closest('[data-wake-store]');
    if (!btn) return;
    const handle = btn.getAttribute('data-handle');
    const backendUrl = btn.getAttribute('data-backend-url') || '';
    if (!backendUrl) { alert('Backend URL not configured in section settings.'); return; }
    if (!confirm(`Wake up store "${handle}"? This will re-run Printful to rebuild all products.`)) return;
    btn.disabled = true;
    btn.textContent = 'Waking up\u2026';
    fetch(backendUrl + '/admin/store/' + encodeURIComponent(handle) + '/wakeup', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Admin-Secret': 'stellasage-god-mode-2026-xK9mP' }
    })
    .then(r => r.json())
    .then(data => {
      if (data.job_id || data.status === 'ok' || data.status === 'queued' || data.status === 'waking' || data.status === 'started') {
        btn.textContent = '✅ Waking up… Reloading in 3s';
        setTimeout(() => window.location.reload(), 3000);
      } else {
        btn.textContent = '❌ Failed: ' + (data.error || data.message || 'Unknown error');
        btn.disabled = false;
      }
    })
    .catch(err => { btn.textContent = '❌ Error: ' + (err && err.message ? err.message : 'Network error'); btn.disabled = false; });
  });
  </script>
</section>

{% schema %}
{
  "name": "Shop Dashboard tiles",
  "settings": [
    { "type": "checkbox", "id": "show_loaded_banner", "label": "Show loaded banner (for troubleshooting)", "default": true },
    { "type": "checkbox", "id": "debug_mode", "label": "Debug mode (prints tags/handles)", "default": false },

    { "type": "text", "id": "heading", "label": "Heading", "default": "Your Storefronts" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Select a storefront to manage or shop." },

    { "type": "range", "id": "max_width", "min": 960, "max": 1400, "step": 20, "label": "Max width (px)", "default": 1200 },
    { "type": "range", "id": "padding_y", "min": 0, "max": 80, "step": 4, "label": "Vertical padding", "default": 24 },

    { "type": "range", "id": "columns_desktop", "min": 2, "max": 4, "step": 1, "label": "Columns (desktop)", "default": 3 },
    { "type": "range", "id": "columns_tablet", "min": 1, "max": 3, "step": 1, "label": "Columns (tablet)", "default": 2 },

    { "type": "text", "id": "storefront_base_url", "label": "Storefront page URL (base)", "default": "/pages/custom-shop" },

    { "type": "header", "content": "Admin Powers" },
    { "type": "text", "id": "admin_powers_url", "label": "Admin Powers page path", "default": "/pages/admin-powers" },
    { "type": "text", "id": "admin_powers_label", "label": "Admin Powers button label", "default": "Admin Powers" },

    { "type": "text", "id": "admin_tag_prefix", "label": "Admin tag prefix", "default": "storefront-admin--" },
    { "type": "text", "id": "member_tag_prefix", "label": "Member tag prefix", "default": "storefront-member--" },

    { "type": "checkbox", "id": "show_status_badge", "label": "Show status badge", "default": true },
    { "type": "checkbox", "id": "show_role_badge", "label": "Show role badge", "default": true },
    { "type": "checkbox", "id": "show_handle_line", "label": "Show handle line", "default": false },

    { "type": "text", "id": "logo_placeholder_text", "label": "Logo placeholder text", "default": "LOGO" },
    {
      "type": "select",
      "id": "logo_fit",
      "label": "Logo fit",
      "default": "cover",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" }
      ]
    },
    {
      "type": "select",
      "id": "logo_aspect_ratio",
      "label": "Logo area aspect ratio",
      "default": "16/9",
      "options": [
        { "value": "16/9", "label": "16:9" },
        { "value": "3/2", "label": "3:2" },
        { "value": "4/3", "label": "4:3" },
        { "value": "1/1", "label": "1:1" }
      ]
    },

    { "type": "color", "id": "card_bg", "label": "Card background", "default": "#ffffff" },
