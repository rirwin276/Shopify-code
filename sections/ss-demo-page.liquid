<script>
  (function () {
    var params = new URLSearchParams(window.location.search || '');
    if (params.get('view') === 'dashboard' || params.get('dashboard') === 'true') {
      document.documentElement.className += ' ss-demo-dashboard-view';
    }
  })();
</script>

<section class="ss-demo-page ss-demo-landing-view">
  <div class="ss-demo-hero ss-demo-hero--compact">
    <span class="ss-demo-hero__pill">Public Demo</span>
    <h1>Preview the full store experience.</h1>
    <p>Click into a live sample storefront and a dashboard-style admin preview. The demo behaves like a real store, but purchasing, sharing, and admin changes are locked.</p>
  </div>

  <div class="ss-demo-console">
    <div class="ss-demo-console__top">
      <div>
        <small>DEMO ACCOUNT</small>
        <h2>Ryan’s Demo Dashboard</h2>
        <p>Sample stores attached to the demo library can be shown here for anyone to explore.</p>
      </div>
      <a class="ss-demo-btn ss-demo-btn--gold" href="/pages/request-storefront-form">Create My Store</a>
    </div>

    <div class="ss-demo-store-card">
      <div class="ss-demo-store-card__main">
        <div class="ss-demo-logo ss-demo-logo--large">R</div>
        <div>
          <span class="ss-demo-status">Live demo · Checkout locked</span>
          <h3>Raptors Demo Store</h3>
          <p>Browse the customer storefront, open products, and preview the admin/dashboard tools with real actions disabled.</p>
        </div>
      </div>
      <div class="ss-demo-store-card__actions">
        <a class="ss-demo-btn ss-demo-btn--dark" href="/collections/raptors-3978?demo=true">View Storefront</a>
        <a class="ss-demo-btn ss-demo-btn--light" href="/pages/demo?view=dashboard&store=raptors-3978&demo=true">View Dashboard</a>
      </div>
    </div>

    <div class="ss-demo-console-grid">
      <article><strong>Storefront</strong><span>Customers see a simple private collection and product pages.</span></article>
      <article><strong>Dashboard</strong><span>Admins see store status, products, sharing, and management tools.</span></article>
      <article><strong>Demo lock</strong><span>Buy, share, edit, delete, leave-store, and admin actions show a demo-only message.</span></article>
    </div>
  </div>
</section>

<section class="ss-demo-page ss-demo-dashboard-shell">
  <div class="ss-demo-dash-header">
    <div>
      <span class="ss-demo-hero__pill">Demo Dashboard</span>
      <h1>Ryan’s Demo Dashboard</h1>
      <p>This is a public preview of how a private merch store feels after someone joins or manages one.</p>
    </div>
    <a class="ss-demo-btn ss-demo-btn--gold" href="/pages/request-storefront-form">Create My Store</a>
  </div>

  <div class="ss-demo-dash-layout">
    <aside class="ss-demo-side-card">
      <div class="ss-demo-avatar">R</div>
      <h3>Demo Member</h3>
      <p>Preview account</p>
      <div class="ss-demo-side-stat"><strong>1</strong><span>Demo store</span></div>
      <div class="ss-demo-side-stat"><strong>Locked</strong><span>Purchasing/admin actions</span></div>
    </aside>

    <main class="ss-demo-main-card">
      <div class="ss-demo-main-card__top">
        <div>
          <small>PRIVATE STORE</small>
          <h2>Raptors Demo Store</h2>
          <p>Open the storefront, inspect products, and preview tools. Everything risky is disabled.</p>
        </div>
        <span class="ss-demo-live-pill">Systems Operational</span>
      </div>

      <div class="ss-demo-product-preview">
        <div class="ss-demo-product-tile"><span>Hoodie</span><strong>Premium Pullover Hoodie</strong></div>
        <div class="ss-demo-product-tile"><span>Tee</span><strong>Staple Tee</strong></div>
        <div class="ss-demo-product-tile"><span>Youth</span><strong>Youth Staple Tee</strong></div>
      </div>

      <div class="ss-demo-admin-actions">
        <a class="ss-demo-btn ss-demo-btn--dark" href="/collections/raptors-3978?demo=true">Open Storefront</a>
        <a class="ss-demo-btn ss-demo-btn--light ss-demo-disabled" href="#">Share Store</a>
        <a class="ss-demo-btn ss-demo-btn--light ss-demo-disabled" href="#">Edit Products</a>
        <a class="ss-demo-btn ss-demo-btn--light ss-demo-disabled" href="#">Add Members</a>
        <a class="ss-demo-btn ss-demo-btn--light ss-demo-disabled" href="#">Admin Tools</a>
        <a class="ss-demo-btn ss-demo-btn--light ss-demo-disabled" href="#">Leave Store</a>
      </div>
    </main>
  </div>
</section>

{% schema %}
{
  "name": "SS Demo Page",
  "settings": [],
  "presets": [
    { "name": "SS Demo Page" }
  ]
}
{% endschema %}
