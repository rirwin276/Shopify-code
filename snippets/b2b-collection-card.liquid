{% comment %}
B2B Collection Card
Input:
- col (collection object)
{% endcomment %}

{% assign c = col %}
{% if c == blank %}
  {% break %}
{% endif %}

<a href="{{ c.url }}"
   style="display:block;background:#fff;border:1px solid rgba(0,0,0,.10);border-radius:16px;overflow:hidden;text-decoration:none;color:#111;box-shadow:0 10px 22px rgba(0,0,0,.06);">

  <div style="aspect-ratio:16/9;background:rgba(0,0,0,.04);display:flex;align-items:center;justify-content:center;overflow:hidden;">
    {% if c.featured_image %}
      {{ c.featured_image
        | image_url: width: 1200
        | image_tag: loading: 'lazy', style: 'width:100%;height:100%;object-fit:cover;' }}
    {% else %}
      <div style="color:rgba(0,0,0,.6);font-weight:700;">
        {{ c.title }}
      </div>
    {% endif %}
  </div>

  <div style="padding:14px 14px 16px;">
    <div style="font-weight:900;font-size:16px;line-height:1.2;margin-bottom:4px;">
      {{ c.title }}
    </div>

    {% if c.description != blank %}
      <div style="color:rgba(0,0,0,.65);font-size:13px;line-height:1.35;">
        {{ c.description | strip_html | truncate: 90 }}
      </div>
    {% else %}
      <div style="color:rgba(0,0,0,.65);font-size:13px;line-height:1.35;">
        Shop this collection
      </div>
    {% endif %}
  </div>
</a>
