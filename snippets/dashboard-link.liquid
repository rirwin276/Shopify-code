{% comment %}
  Dashboard Link (Login-aware)
  - Logged in → /pages/portal
  - Logged out → login → return to /pages/portal
{% endcomment %}

{% assign dashboard_url = '/pages/portal' %}

{% if customer %}
  <a href="{{ dashboard_url }}" class="nav-dashboard">
    Dashboard
  </a>
{% else %}
  {% capture encoded %}{{ dashboard_url | url_encode }}{% endcapture %}
  <a href="{{ routes.storefront_login_url }}?return_to={{ encoded }}" class="nav-dashboard" onclick="try{localStorage.setItem('sf_pending_signin_v1',JSON.stringify({return_path:'{{ dashboard_url | escape }}',_saved_at:Date.now()}))}catch(e){}">
    Dashboard
  </a>
{% endif %}
