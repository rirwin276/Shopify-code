{%- comment -%}
  STELLA & SAGE — PREMIUM CATALOG SYNC
  ✅ Logic: Unchanged (Safe AI Wiring Intact)
  ✅ Visuals: Upgraded to "SaaS Studio" aesthetic
  ✅ Mobile: Optimized for touch feedback & responsive sizing
{%- endcomment -%}

{%- liquid
  assign p = product_card_product | default: product
  assign lock_code = p.metafields.custom.logo_position | default: ''

  # --- LOGO SOURCE (DYNAMIC + PIXELCUT CLEAN URL) ---
  assign store_handle = ''
  if collection and collection.handle != blank
    assign store_handle = collection.handle
  endif
  if store_handle == blank
    assign store_handle = request.params.shop | default: '' | strip
  endif

  assign logo_url = ''
  if store_handle != blank
    assign _shop_meta = shop.metaobjects.custom_shop[store_handle]
    if _shop_meta
      assign _clean = _shop_meta.logo_clean_url.value | default: _shop_meta.logo_clean_url
      if _clean != blank
        assign logo_url = _clean
      else
        assign _logo = _shop_meta.logo.value | default: _shop_meta.logo
        if _logo != blank
          assign logo_url = _logo | image_url: width: 400
        endif
      endif
    endif
  endif

  # --- MASTER BOX SETTINGS ---
  assign pixel_ratio = p.featured_media.aspect_ratio | default: 1.0
  assign media_width = p.featured_media.width | default: 600
  assign media_height = p.featured_media.height | default: 600

  # --- ZONE READER ---
  assign zone_style = "top: 20%; left: 20%; width: 60%; height: 60%;"
  for tag in p.tags
    assign tag_down = tag | downcase
    if tag_down contains 'zone:'
      assign zone_parts = tag_down | remove: 'zone:' | split: '-'
      if zone_parts.size == 4
        capture zone_style
          echo "top:" | append: zone_parts[0] | append: "%; "
          echo "left:" | append: zone_parts[1] | append: "%; "
          echo "width:" | append: zone_parts[2] | append: "%; "
          echo "height:" | append: zone_parts[3] | append: "%;"
        endcapture
        break
      endif
    endif
  endfor
-%}

<div class="product-card ss-card-shell" data-product-id="{{ p.id }}">
  <a href="{{ p.url }}" class="ss-link-wrapper">
    
    {%- comment -%} IMAGE AREA {%- endcomment -%}
    <div class="ss-image-stage">
      <div class="ss-master-box" style="aspect-ratio: {{ pixel_ratio }};">
        {%- if p.featured_media -%}
          <img src="{{ p.featured_media | image_url: width: 600 }}"
               class="ss-shirt-img"
               loading="lazy"
               width="{{ media_width }}"
               height="{{ media_height }}"
               alt="{{ p.featured_media.alt | escape }}">

          {%- comment -%} OVERLAY LOGIC {%- endcomment -%}
          {%- if lock_code != blank and lock_code != 'approved' and lock_code != 'DELETED' -%}
            <div class="ss-zone-box" style="{{ zone_style }}">
              <div class="ss-logo-wrapper" style="{{ lock_code | replace: '|', ';' }}">
                {%- if logo_url != blank -%}
                  <img src="{{ logo_url }}" class="ss-logo-img" width="200" height="200" alt="Logo">
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

        {%- else -%}
          {{ 'product-1' | placeholder_svg_tag: 'ss-shirt-img' }}
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} INFO AREA {%- endcomment -%}
    <div class="ss-info-deck">
      <h3 class="ss-title">{{ p.title }}</h3>
      <div class="ss-meta-row">
        <span class="ss-price">{{ p.price | money_without_trailing_zeros }}</span>
      </div>
    </div>
  </a>
</div>

<style>
  /* --- THE CONTAINER (The "Physical" Card) --- */
  .ss-card-shell {
    display: flex !important;
    flex-direction: column !important;
    background: #ffffff;
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s cubic-bezier(0.25, 0.8, 0.25, 1), box-shadow 0.2s ease, border-color 0.2s ease;
    border: 1px solid rgba(0,0,0,0.06);
    height: 100%;
    position: relative;
    /* Hardware acceleration for smooth mobile animation */
    transform: translateZ(0); 
    -webkit-transform: translateZ(0);
  }

  /* --- DESKTOP INTERACTION (Mouse Only) --- */
  @media (hover: hover) {
    .ss-card-shell:hover {
      transform: translateY(-6px);
      box-shadow: 0 12px 24px rgba(0,0,0,0.08);
      border-color: rgba(0,0,0,0.0);
      z-index: 5;
    }
    
    /* Subtle zoom on image only */
    .ss-card-shell:hover .ss-shirt-img {
      transform: scale(1.03); 
    }
  }

  /* --- MOBILE INTERACTION (Touch Feedback) --- */
  .ss-card-shell:active {
    /* Slight "press down" effect when tapped on phone */
    transform: scale(0.98);
    border-color: rgba(0,0,0,0.15);
  }

  /* --- THE IMAGE STAGE --- */
  .ss-image-stage {
    width: 100%;
    position: relative;
    background-color: #f8f9fa;
    padding: 20px; /* Desktop Padding */
    box-sizing: border-box;
  }
  
  .ss-link-wrapper {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ss-master-box {
    position: relative;
    width: 100%;
    height: auto;
    display: block;
    mix-blend-mode: multiply;
  }

  /* --- IMAGES & LAYERS --- */
  .ss-shirt-img {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: contain;
    display: block;
    z-index: 1;
    transition: transform 0.5s ease;
  }

  .ss-zone-box { position: absolute; pointer-events: none; z-index: 10; overflow: hidden; }
  .ss-logo-wrapper { position: absolute; z-index: 11; }
  .ss-logo-img { width: 100%; height: auto; display: block; }

  /* --- TYPOGRAPHY --- */
  .ss-info-deck {
    padding: 16px 20px 20px 20px;
    text-align: left;
    background: #fff;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .ss-title {
    font-weight: 600;
    font-size: 15px;
    margin: 0 0 8px 0;
    color: #1a1a1a;
    line-height: 1.4;
    letter-spacing: -0.01em;
  }

  .ss-price {
    font-size: 14px;
    color: #555555;
    font-weight: 500;
  }

  /* --- MOBILE SPECIFIC OVERRIDES (Screens smaller than 768px) --- */
  @media screen and (max-width: 767px) {
    .ss-image-stage {
      padding: 10px; /* Tighten padding so image is bigger on phone */
    }
    .ss-info-deck {
      padding: 12px 14px; /* Less whitespace for text area */
    }
    .ss-title {
      font-size: 14px; /* Slightly smaller text prevents wrapping */
    }
    .ss-card-shell {
      border-radius: 8px; /* Slightly tighter corners on small screens */
    }
  }
</style>