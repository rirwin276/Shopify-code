{% comment %}
  STELLA & SAGE - DATA LAYER
  Passes the "Grandma-Proofed" Pixelcut URL to JavaScript.
  Also gently upgrades dashboard store-logo thumbnail URLs for sharper retina/mobile display.
{% endcomment %}

<script>
  window.SS = window.SS || {};
  window.SS.config = window.SS.config || {};

  {%- if collection and collection.handle -%}
    {%- assign store_handle = collection.handle -%}
    
    {%- comment -%} 
      Load the metaobject. 
      Note: We use the system key 'custom_shop' and look up by handle. 
    {%- endcomment -%}
    {%- assign store_meta = shop.metaobjects.custom_shop[store_handle] -%}
    
    {%- if store_meta -%}
      window.SS.config.storeHandle = "{{ store_handle }}";
      
      {%- comment -%} 
        PRIORITY 1: The "Logo Clean Url" (Pixelcut transparent PNG).
        We assume the key is 'logo_clean_url' based on your label.
      {%- endcomment -%}
      {%- if store_meta.logo_clean_url != blank -%}
        window.SS.config.logoUrl = "{{ store_meta.logo_clean_url }}";
        
      {%- comment -%} PRIORITY 2: Fallback to raw upload if Pixelcut failed {%- endcomment -%}
      {%- elsif store_meta.logo != blank -%}
        window.SS.config.logoUrl = "{{ store_meta.logo | image_url: width: 900 }}";
        
      {%- endif -%}
      
    {%- endif -%}
  {%- endif -%}

  (function () {
    var path = window.location.pathname || '';
    if (path.indexOf('/pages/portal') !== 0) return;

    function upgradeShopifyImageUrl(src) {
      if (!src || src.indexOf('cdn.shopify.com') === -1) return src;
      try {
        var url = new URL(src, window.location.origin);
        url.searchParams.set('width', '900');
        return url.toString();
      } catch (e) {
        if (src.indexOf('width=') !== -1) return src.replace(/width=\d+/g, 'width=900');
        return src + (src.indexOf('?') === -1 ? '?' : '&') + 'width=900';
      }
    }

    function sharpenDashboardLogos() {
      var imgs = document.querySelectorAll('.ss-logo-frame img');
      imgs.forEach(function (img, index) {
        if (!img || img.dataset.ssQualityUpgraded === '1') return;
        var current = img.currentSrc || img.getAttribute('src') || '';
        var upgraded = upgradeShopifyImageUrl(current);
        if (upgraded && upgraded !== current) {
          img.setAttribute('src', upgraded);
        }
        img.setAttribute('decoding', 'async');
        img.setAttribute('loading', index < 4 ? 'eager' : 'lazy');
        if (index < 4) img.setAttribute('fetchpriority', 'high');
        img.style.imageRendering = 'auto';
        img.style.transform = 'translateZ(0)';
        img.style.webkitBackfaceVisibility = 'hidden';
        img.dataset.ssQualityUpgraded = '1';
      });
    }

    function addProductCounts() {
      document.querySelectorAll('.ss-store-card[data-ss-products]').forEach(function (card) {
        if (card.dataset.ssProductCountInjected === '1') return;
        var count = parseInt(card.getAttribute('data-ss-products') || '0', 10);
        var identity = card.querySelector('.ss-identity-text');
        var title = card.querySelector('.ss-card-title');
        if (!identity || !title || !count || count < 1) return;
        var line = document.createElement('span');
        line.className = 'ss-card-product-count';
        line.textContent = count + ' live product' + (count === 1 ? '' : 's');
        title.insertAdjacentElement('afterend', line);
        card.dataset.ssProductCountInjected = '1';
      });
    }

    function polishDashboardCards() {
      sharpenDashboardLogos();
      addProductCounts();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', polishDashboardCards, { once: true });
    } else {
      polishDashboardCards();
    }

    var observer = new MutationObserver(polishDashboardCards);
    if (document.body) observer.observe(document.body, { childList: true, subtree: true });
  })();
</script>

<style>
  @media (max-width: 850px) {
    .ss-portal .ss-bg {
      padding-top: 30px !important;
      padding-bottom: 34px !important;
    }

    .ss-portal .ss-wrap {
      padding-left: 14px !important;
      padding-right: 14px !important;
    }

    .ss-portal .ss-store-grid {
      gap: 10px !important;
    }

    .ss-portal .ss-store-card {
      border-radius: 20px !important;
      overflow: hidden !important;
    }

    .ss-portal .ss-col-identity {
      padding: 12px 14px 8px !important;
      gap: 12px !important;
    }

    .ss-portal .ss-logo-frame {
      width: 86px !important;
      height: 86px !important;
      border-radius: 18px !important;
      box-shadow: 0 10px 24px rgba(15,23,42,.06) !important;
    }

    .ss-portal .ss-logo-frame img {
      padding: 3px !important;
      image-rendering: auto !important;
    }

    .ss-portal .ss-card-title {
      font-size: 17px !important;
      line-height: 1.08 !important;
      margin-bottom: 5px !important;
      letter-spacing: -.035em !important;
    }

    .ss-portal .ss-card-subtitle {
      display: inline-flex !important;
      width: fit-content !important;
      font-size: 10px !important;
      padding: 3px 8px !important;
      border-radius: 999px !important;
      letter-spacing: .12em !important;
      text-transform: uppercase !important;
    }

    .ss-portal .ss-card-product-count {
      display: block !important;
      margin: -1px 0 6px !important;
      font-size: 11px !important;
      font-weight: 800 !important;
      color: rgba(15,23,42,.48) !important;
      letter-spacing: .02em !important;
    }

    .ss-portal .ss-col-engine {
      padding: 7px 14px 8px !important;
    }

    .ss-portal .ss-status-finished,
    .ss-portal .ss-status-building {
      padding: 7px 12px !important;
      border-radius: 999px !important;
    }

    .ss-portal .ss-status-text,
    .ss-portal .ss-status-text-building {
      font-size: 10px !important;
      letter-spacing: .10em !important;
    }

    .ss-portal .ss-col-controls {
      padding: 9px 12px 12px !important;
      gap: 8px !important;
    }

    .ss-portal .ss-admin-btn {
      min-height: 42px !important;
      padding: 9px 14px !important;
      font-size: 12px !important;
      border-radius: 999px !important;
      letter-spacing: .14em !important;
      background: rgba(255,255,255,.74) !important;
      color: rgba(87,73,36,.96) !important;
      border-color: rgba(87,73,36,.16) !important;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.75) !important;
    }

    .ss-portal .ss-open-btn {
      min-height: 52px !important;
      padding: 12px 16px !important;
      font-size: 16px !important;
      border-radius: 999px !important;
      box-shadow: 0 16px 34px rgba(15,23,42,.16) !important;
    }

    .ss-portal .ss-leave-btn {
      min-height: 38px !important;
      padding: 8px 14px !important;
      font-size: 11px !important;
      border-radius: 999px !important;
    }
  }

  @media (max-width: 400px) {
    .ss-portal .ss-logo-frame {
      width: 76px !important;
      height: 76px !important;
    }

    .ss-portal .ss-card-title {
      font-size: 16px !important;
    }
  }

  @media (min-width: 851px) {
    .ss-portal .ss-card-product-count {
      display: block;
      margin: 3px 0 5px;
      font-size: 11px;
      font-weight: 780;
      color: rgba(91,107,130,.72);
    }

    .ss-portal .ss-admin-btn {
      padding: 8px 12px !important;
      font-size: 11px !important;
      letter-spacing: .09em !important;
    }
  }
</style>