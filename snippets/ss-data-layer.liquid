{% comment %}
  STELLA & SAGE - DATA LAYER
  Passes the "Grandma-Proofed" Pixelcut URL to JavaScript.
  Also upgrades dashboard store-logo thumbnails using the original Shopify MediaImage when available.
{% endcomment %}

<script>
  window.SS = window.SS || {};
  window.SS.config = window.SS.config || {};
  window.SS.dashboardLogoMap = window.SS.dashboardLogoMap || {};

  {%- if collection and collection.handle -%}
    {%- assign store_handle = collection.handle -%}
    {%- assign store_meta = shop.metaobjects.custom_shop[store_handle] -%}
    {%- if store_meta -%}
      window.SS.config.storeHandle = "{{ store_handle }}";
      {%- if store_meta.logo_clean_url != blank -%}
        window.SS.config.logoUrl = "{{ store_meta.logo_clean_url }}";
      {%- elsif store_meta.logo != blank -%}
        window.SS.config.logoUrl = "{{ store_meta.logo | image_url: width: 1600 }}";
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}

  {%- if customer -%}
    {%- assign ss_dash_handles_blob = '||' -%}
    {%- for tag in customer.tags -%}
      {%- assign tag_stripped = tag | strip -%}
      {%- assign tag_down = tag_stripped | downcase -%}
      {%- assign ss_dash_handle = '' -%}
      {%- if tag_down contains 'storefront-admin--' -%}
        {%- assign ss_dash_handle = tag_stripped | remove: 'storefront-admin--' | remove: 'STOREFRONT-ADMIN--' | strip -%}
      {%- elsif tag_down contains 'storefront-member--' -%}
        {%- assign ss_dash_handle = tag_stripped | remove: 'storefront-member--' | remove: 'STOREFRONT-MEMBER--' | strip -%}
      {%- endif -%}
      {%- if ss_dash_handle != blank -%}
        {%- capture ss_dash_needle -%}||{{ ss_dash_handle }}||{%- endcapture -%}
        {%- unless ss_dash_handles_blob contains ss_dash_needle -%}
          {%- assign ss_dash_handles_blob = ss_dash_handles_blob | append: ss_dash_handle | append: '||' -%}
          {%- assign ss_dash_entry = shop.metaobjects.custom_shop[ss_dash_handle] -%}
          {%- if ss_dash_entry -%}
            {%- assign ss_dash_logo_file = ss_dash_entry.logo.value | default: ss_dash_entry.logo -%}
            {%- assign ss_dash_logo_clean = ss_dash_entry.logo_clean_url.value | default: ss_dash_entry.logo_clean_url -%}
            {%- if ss_dash_logo_clean == blank -%}{%- assign ss_dash_logo_clean = ss_dash_entry.logo_clean.value | default: ss_dash_entry.logo_clean -%}{%- endif -%}
            {%- if ss_dash_logo_file != blank -%}
              {%- assign ss_logo_900 = ss_dash_logo_file | image_url: width: 900 -%}
              {%- assign ss_logo_1600 = ss_dash_logo_file | image_url: width: 1600 -%}
              {%- assign ss_logo_2400 = ss_dash_logo_file | image_url: width: 2400 -%}
              {%- capture ss_logo_srcset -%}{{ ss_logo_900 }} 900w, {{ ss_logo_1600 }} 1600w, {{ ss_logo_2400 }} 2400w{%- endcapture -%}
              window.SS.dashboardLogoMap[{{ ss_dash_handle | json }}] = {
                src: {{ ss_logo_1600 | json }},
                srcset: {{ ss_logo_srcset | strip | json }}
              };
            {%- elsif ss_dash_logo_clean != blank -%}
              window.SS.dashboardLogoMap[{{ ss_dash_handle | json }}] = { src: {{ ss_dash_logo_clean | json }}, srcset: '' };
            {%- endif -%}
          {%- endif -%}
        {%- endunless -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}

  (function () {
    var path = window.location.pathname || '';
    if (path.indexOf('/pages/portal') !== 0) return;

    function upgradeShopifyImageUrl(src) {
      if (!src || src.indexOf('cdn.shopify.com') === -1) return src;
      try {
        var url = new URL(src, window.location.origin);
        url.searchParams.set('width', '1600');
        return url.toString();
      } catch (e) {
        if (src.indexOf('width=') !== -1) return src.replace(/width=\d+/g, 'width=1600');
        return src + (src.indexOf('?') === -1 ? '?' : '&') + 'width=1600';
      }
    }

    function sharpenDashboardLogos() {
      var cards = document.querySelectorAll('.ss-store-card[data-ss-handle]');
      cards.forEach(function (card, index) {
        var img = card.querySelector('.ss-logo-frame img');
        if (!img) return;

        var handle = card.getAttribute('data-ss-handle') || '';
        var mapped = window.SS && window.SS.dashboardLogoMap ? window.SS.dashboardLogoMap[handle] : null;
        var mappedSrc = mapped && typeof mapped === 'object' ? mapped.src : mapped;
        var mappedSrcset = mapped && typeof mapped === 'object' ? mapped.srcset : '';
        var current = img.getAttribute('src') || '';
        var upgraded = mappedSrc || upgradeShopifyImageUrl(current);

        if (upgraded && img.dataset.ssDashboardMapped !== upgraded) {
          var pre = new Image();
          pre.onload = function () {
            img.removeAttribute('srcset');
            if (mappedSrcset) img.setAttribute('srcset', mappedSrcset);
            img.setAttribute('sizes', '(max-width: 850px) 116px, 88px');
            img.setAttribute('src', upgraded);
            img.dataset.ssDashboardMapped = upgraded;
          };
          pre.src = upgraded;
        }

        img.setAttribute('decoding', 'async');
        img.setAttribute('loading', index < 5 ? 'eager' : 'lazy');
        if (index < 5) img.setAttribute('fetchpriority', 'high');
        img.style.imageRendering = 'auto';
        img.style.transform = 'translateZ(0)';
        img.style.webkitBackfaceVisibility = 'hidden';
        img.dataset.ssQualityUpgraded = '1';
      });
    }

    function addProductCounts() {
      document.querySelectorAll('.ss-store-card[data-ss-products]').forEach(function (card) {
        if (card.dataset.ssProductCountInjected === '1') return;
        var count = parseInt(card.getAttribute('data-ss-products') || '0', 10);
        var title = card.querySelector('.ss-card-title');
        if (!title || !count || count < 1) return;
        var line = document.createElement('span');
        line.className = 'ss-card-product-count';
        line.textContent = count + ' live product' + (count === 1 ? '' : 's');
        title.insertAdjacentElement('afterend', line);
        card.dataset.ssProductCountInjected = '1';
      });
    }

    function polishDashboardCards() {
      sharpenDashboardLogos();
      addProductCounts();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', polishDashboardCards, { once: true });
    } else {
      polishDashboardCards();
    }

    var observer = new MutationObserver(polishDashboardCards);
    if (document.body) observer.observe(document.body, { childList: true, subtree: true });
  })();
</script>

<style>
  @media (max-width: 850px) {
    .ss-portal .ss-bg { padding-top: 28px !important; padding-bottom: 34px !important; }
    .ss-portal .ss-wrap { padding-left: 14px !important; padding-right: 14px !important; }
    .ss-portal .ss-store-grid { gap: 12px !important; }
    .ss-portal .ss-store-card {
      border-radius: 24px !important;
      overflow: hidden !important;
      border-color: rgba(15,23,42,.055) !important;
      box-shadow: 0 18px 44px rgba(15,23,42,.055), inset 0 1px 0 rgba(255,255,255,.85) !important;
    }
    .ss-portal .ss-col-identity {
      padding: 16px 16px 9px !important;
      gap: 14px !important;
      align-items: center !important;
    }
    .ss-portal .ss-logo-frame {
      width: 116px !important;
      height: 116px !important;
      min-width: 116px !important;
      border-radius: 22px !important;
      background: rgba(255,255,255,.82) !important;
      border: 1px solid rgba(15,23,42,.07) !important;
      box-shadow: 0 12px 28px rgba(15,23,42,.075) !important;
    }
    .ss-portal .ss-logo-frame img {
      padding: 0 !important;
      image-rendering: auto !important;
      object-fit: contain !important;
      transform: translateZ(0) !important;
      filter: contrast(1.055) saturate(1.055) !important;
    }
    .ss-portal .ss-identity-text {
      min-width: 0 !important;
      padding-top: 2px !important;
    }
    .ss-portal .ss-card-title {
      font-size: 18px !important;
      line-height: 1.06 !important;
      margin-bottom: 5px !important;
      letter-spacing: -.04em !important;
    }
    .ss-portal .ss-card-subtitle {
      display: inline-flex !important;
      width: fit-content !important;
      font-size: 10px !important;
      padding: 4px 9px !important;
      border-radius: 999px !important;
      letter-spacing: .12em !important;
      text-transform: uppercase !important;
    }
    .ss-portal .ss-card-product-count {
      display: block !important;
      margin: 0 0 7px !important;
      font-size: 12px !important;
      font-weight: 850 !important;
      color: rgba(15,23,42,.46) !important;
      letter-spacing: .01em !important;
    }
    .ss-portal .ss-col-engine { padding: 7px 16px 8px !important; }
    .ss-portal .ss-status-finished, .ss-portal .ss-status-building { padding: 7px 12px !important; border-radius: 999px !important; }
    .ss-portal .ss-status-text, .ss-portal .ss-status-text-building { font-size: 10px !important; letter-spacing: .10em !important; }
    .ss-portal .ss-col-controls { padding: 10px 14px 14px !important; gap: 8px !important; }
    .ss-portal .ss-admin-btn {
      min-height: 42px !important;
      padding: 9px 14px !important;
      font-size: 12px !important;
      border-radius: 999px !important;
      letter-spacing: .14em !important;
      background: rgba(255,255,255,.76) !important;
      color: rgba(87,73,36,.96) !important;
      border-color: rgba(87,73,36,.16) !important;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.78) !important;
    }
    .ss-portal .ss-open-btn {
      min-height: 54px !important;
      padding: 12px 16px !important;
      font-size: 16px !important;
      border-radius: 999px !important;
      box-shadow: 0 17px 36px rgba(15,23,42,.17) !important;
    }
    .ss-portal .ss-leave-btn { min-height: 38px !important; padding: 8px 14px !important; font-size: 11px !important; border-radius: 999px !important; }
  }

  @media (max-width: 400px) {
    .ss-portal .ss-logo-frame {
      width: 104px !important;
      height: 104px !important;
      min-width: 104px !important;
    }
    .ss-portal .ss-card-title { font-size: 17px !important; }
  }

  @media (min-width: 851px) {
    .ss-portal .ss-logo-frame {
      width: 88px !important;
      height: 88px !important;
      min-width: 88px !important;
      border-radius: 18px !important;
    }
    .ss-portal .ss-card-product-count { display: block; margin: 3px 0 5px; font-size: 11px; font-weight: 780; color: rgba(91,107,130,.72); }
    .ss-portal .ss-admin-btn { padding: 8px 12px !important; font-size: 11px !important; letter-spacing: .09em !important; }
    .ss-portal .ss-logo-frame img { padding: 0 !important; filter: contrast(1.045) saturate(1.045) !important; }
  }
</style>