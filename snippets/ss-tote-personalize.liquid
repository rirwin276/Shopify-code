{%- comment -%}
  ss-tote-personalize.liquid
  --------------------------
  Customer-facing "Name & Number on the back" widget.

  Renders ONLY when the admin enabled personalization at build time — the
  build writes a fully-resolved custom.personalization json metafield on the
  product: {enabled, font, font_label, font_family, font_weight, color,
  color_label, color_hex, max_name_len, max_number_len}. The font and text
  color are the ADMIN's choice; the customer only types a name and number,
  both required before add-to-cart (native form validation — these inputs
  live inside the product form in blocks/buy-buttons.liquid and submit as
  Shopify line-item properties; no product/variant is created per order).

  The live canvas preview is an approximation for the shopper. The
  authoritative print file is rendered server-side at order-fulfillment time
  from the same typed values + the admin's saved font/color, so what prints
  always matches what was ordered.
{%- endcomment -%}
{%- assign ss_pers = product.metafields.custom.personalization.value -%}
{%- if ss_pers and ss_pers.enabled -%}
  <div
    class="ss-pers"
    data-ss-pers
    data-initial-color="{{ product.selected_or_first_available_variant.option1 | escape }}"
    data-font-family="{{ ss_pers.font_family | escape }}"
    data-font-weight="{{ ss_pers.font_weight | default: 700 }}"
    data-color-hex="{{ ss_pers.color_hex | default: '#141414' | escape }}"
    data-max-name="{{ ss_pers.max_name_len | default: 14 }}"
    data-max-number="{{ ss_pers.max_number_len | default: 2 }}"
  >
    <div class="ss-pers-head">
      <span class="ss-pers-kicker">Personalize the Back</span>
      <p class="ss-pers-sub">Add your name and number — printed in {{ ss_pers.font_label | default: 'our jersey style' }}, {{ ss_pers.color_label | downcase | default: 'as shown' }}.</p>
    </div>

    <div class="ss-pers-grid">
      <div class="ss-pers-preview">
        <canvas class="ss-pers-canvas" data-ss-pers-canvas width="640" height="640" aria-label="Personalization preview"></canvas>
      </div>

      <div class="ss-pers-fields">
        <label class="ss-pers-label" for="PersName-{{ product.id }}">Name</label>
        <input
          class="ss-pers-input"
          type="text"
          id="PersName-{{ product.id }}"
          name="properties[Name]"
          data-ss-pers-name
          maxlength="{{ ss_pers.max_name_len | default: 14 }}"
          required
          pattern="[A-Za-z '\-]{1,{{ ss_pers.max_name_len | default: 14 }}}"
          placeholder="e.g. Emma"
          autocomplete="off"
        >

        <label class="ss-pers-label" for="PersNumber-{{ product.id }}">Number</label>
        <input
          class="ss-pers-input ss-pers-input--number"
          type="text"
          id="PersNumber-{{ product.id }}"
          name="properties[Number]"
          data-ss-pers-number
          inputmode="numeric"
          pattern="[0-9]{1,{{ ss_pers.max_number_len | default: 2 }}}"
          maxlength="{{ ss_pers.max_number_len | default: 2 }}"
          required
          placeholder="e.g. 7"
          autocomplete="off"
        >

        <p class="ss-pers-note">Both fields are required — this item is printed just for you.</p>
      </div>
    </div>
  </div>

  <script
    src="{{ 'ss-tote-personalize.js' | asset_url }}"
    defer
    data-mockups-url="https://printfulautomation-production.up.railway.app/editor/pro-shirt/ec8000/mockups-public"
  ></script>

  {% stylesheet %}
    .ss-pers {
      margin: 18px 0;
      padding: 18px;
      border: 1px solid rgba(17,16,14,0.10);
      border-radius: 18px;
      background: rgba(183,163,106,0.05);
    }
    .ss-pers-kicker {
      font-size: 11px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase;
      color: rgba(183,163,106,1);
    }
    .ss-pers-sub { margin: 4px 0 16px; font-size: 13px; color: rgba(17,16,14,0.6); }
    .ss-pers-grid { display: grid; grid-template-columns: 200px 1fr; gap: 20px; align-items: start; }
    @media (max-width: 600px) { .ss-pers-grid { grid-template-columns: 1fr; } }
    .ss-pers-preview {
      position: relative; width: 100%; aspect-ratio: 1; border-radius: 14px; overflow: hidden;
      background: #f5f1e8;
    }
    .ss-pers-canvas { width: 100%; height: 100%; display: block; }
    .ss-pers-fields { display: flex; flex-direction: column; gap: 6px; }
    .ss-pers-label { font-size: 12px; font-weight: 700; margin-top: 8px; }
    .ss-pers-label:first-child { margin-top: 0; }
    .ss-pers-input {
      padding: 10px 12px; border: 1px solid rgba(17,16,14,0.16); border-radius: 10px;
      font-size: 14px; width: 100%; box-sizing: border-box;
    }
    .ss-pers-input:invalid { border-color: rgba(220,38,38,0.45); }
    .ss-pers-input--number { max-width: 100px; }
    .ss-pers-note { margin: 10px 0 0; font-size: 11.5px; color: rgba(17,16,14,0.5); }
  {% endstylesheet %}
{%- endif -%}
