{
  "sections": {
    "custom_liquid_PYf38a": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "{% comment %}\n  ADMIN POWERS — V9 (GOD MODE FIX)\n  - Added hardcoded access for Ryan Irwin.\n  - Keeps member count hidden.\n  - Keeps QR code and public toggle logic.\n{% endcomment %}\n\n{%- assign dashboard_url = '/pages/portal' -%}\n{%- assign join_path = '/pages/join-store' -%}\n\n{%- comment %} 1. GET SHOP HANDLE {% endcomment -%}\n{%- assign shop_handle = request.params.shop | default: '' | strip -%}\n{%- if shop_handle == blank -%}\n  {%- assign _cfh = content_for_header -%}\n  {%- assign _url_part = _cfh | split: '\"pageurl\":\"' | last | split: '\"' | first -%}\n  {%- assign _url_part = _url_part | replace: '\\u0026', '&' -%}\n  {%- if _url_part contains '?' -%}\n    {%- assign _qs = _url_part | split: '?' | last -%}\n    {%- assign _pairs = _qs | split: '&' -%}\n    {%- for p in _pairs -%}\n      {%- assign kv = p | split: '=' -%}\n      {%- if kv[0] == 'shop' -%}{%- assign shop_handle = kv[1] | default: '' | strip -%}{%- endif -%}\n    {%- endfor -%}\n  {%- endif -%}\n{%- endif -%}\n{%- assign shop_handle = shop_handle | replace: '%2D', '-' | replace: '%5F', '_' | strip | downcase -%}\n\n{%- comment %} 2. PERMISSIONS CHECK (GOD MODE UPDATE) {% endcomment -%}\n{%- assign required_admin_tag = 'storefront-admin--' | append: shop_handle -%}\n{%- assign is_admin_for_shop = false -%}\n{%- assign is_super_admin = false -%}\n\n{%- if customer and shop_handle != blank -%}\n  \n  {%- comment %} A. Check specific email (God Mode) {% endcomment -%}\n  {%- if customer.email == 'ryan.irwin@stellaandsagecompany.com' -%}\n    {%- assign is_super_admin = true -%}\n    {%- assign is_admin_for_shop = true -%}\n  {%- endif -%}\n\n  {%- comment %} B. Check tags {% endcomment -%}\n  {%- for t in customer.tags -%}\n    {%- assign tag_down = t | downcase | strip -%}\n    {%- if tag_down == 'super-admin' -%}\n      {%- assign is_super_admin = true -%}\n      {%- assign is_admin_for_shop = true -%}\n    {%- endif -%}\n    {%- if tag_down == required_admin_tag -%}{%- assign is_admin_for_shop = true -%}{%- endif -%}\n  {%- endfor -%}\n{%- endif -%}\n\n{%- if customer == nil -%}\n  <div class=\"sf-container-auth\">\n    <div class=\"sf-card-auth\">\n      <div class=\"sf-icon-lock\">🔒</div>\n      <h2>Please sign in</h2>\n      <p>You must be signed in to access Admin Powers.</p>\n      <a href=\"{{ routes.account_login_url }}?return_url={{ request.path | append: '?shop=' | append: shop_handle | url_encode }}\" class=\"sf-btn sf-btn--primary\">Sign In</a>\n    </div>\n  </div>\n{%- elsif is_admin_for_shop == false -%}\n  <div class=\"sf-container-auth\">\n    <div class=\"sf-card-auth\">\n      <div class=\"sf-icon-lock\" style=\"background:#fee;color:#c00;\">🚫</div>\n      <h2>Access Denied</h2>\n      <p>You do not have permission to manage <strong>{{ shop_handle }}</strong>.</p>\n      <a href=\"{{ dashboard_url }}\" class=\"sf-btn sf-btn--outline\">Back to Dashboard</a>\n    </div>\n  </div>\n{%- else -%}\n\n  {%- assign shop_meta = shop.metaobjects.custom_shop[shop_handle] -%}\n  {%- assign join_mode = 'secure' -%}\n  {%- assign collection_handle = shop_handle -%}\n  {%- assign store_name = shop_handle -%}\n\n  {%- if shop_meta -%}\n    {%- assign raw_jm = shop_meta.join_mode.value | default: shop_meta.join_mode -%}\n    {%- assign jm = raw_jm | strip | downcase -%}\n    {%- if jm contains 'public' -%}{%- assign join_mode = 'public' -%}{%- endif -%}\n    \n    {%- assign join_code = shop_meta.join_code.value | default: shop_meta.join_code | default: '' | strip -%}\n    {%- assign ch = shop_meta.collection_handle.value | default: shop_meta.collection_handle | default: '' | strip -%}\n    {%- if ch != blank -%}{%- assign collection_handle = ch -%}{%- endif -%}\n    {%- assign sn = shop_meta.name.value | default: shop_meta.name -%}\n    {%- if sn != blank -%}{%- assign store_name = sn -%}{%- endif -%}\n  {%- endif -%}\n\n  {%- assign join_link = shop.url | append: join_path | append: '?shop=' | append: collection_handle -%}\n  {%- if join_code != blank -%}\n    {%- assign join_link = join_link | append: '&code=' | append: join_code -%}\n  {%- endif -%}\n\n  <script src=\"https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js\"></script>\n\n  <div class=\"sf-admin-layout\">\n    <script>\n      window.SSAP = window.SSAP || {};\n      SSAP.collectionHandle = {{ collection_handle | json }};\n      SSAP.shopHandle = {{ shop_handle | json }};\n      SSAP.mechanicUrl = \"https://webhooks.mechanic.dev/582ce69e-ceda-4086-9416-d0cd52260ce9\"; // Your Admin Powers Hook\n    </script>\n\n    <header class=\"sf-admin-header\">\n      <div>\n        <div class=\"sf-badge-admin\">\n          {% if is_super_admin %}God Mode Active{% else %}Admin Access{% endif %}\n        </div>\n        <h1 class=\"sf-admin-title\">{{ store_name }}</h1>\n        <p class=\"sf-admin-sub\">Storefront Management Console</p>\n      </div>\n      <div class=\"sf-admin-actions\">\n        <a href=\"/collections/{{ collection_handle }}\" class=\"sf-btn sf-btn--glass\">View Store</a>\n        <a href=\"{{ dashboard_url }}\" class=\"sf-btn sf-btn--glass\">Dashboard</a>\n      </div>\n    </header>\n\n    <div class=\"sf-admin-grid\">\n      \n      <div class=\"sf-col\">\n        <section class=\"sf-card\">\n          <div class=\"sf-card-head\">\n            <h3>Invite & Access</h3>\n            <p>Control how people enter this storefront.</p>\n          </div>\n          <div class=\"sf-radio-group\">\n            <label class=\"sf-radio {% if join_mode == 'secure' %}selected{% endif %}\">\n              <input type=\"radio\" name=\"joinmode\" value=\"secure\" {% if join_mode == 'secure' %}checked{% endif %}>\n              <div class=\"sf-radio-info\">\n                <span class=\"sf-radio-title\">Secure (Invite Only)</span>\n                <span class=\"sf-radio-desc\">Only people you add below can access.</span>\n              </div>\n            </label>\n            <label class=\"sf-radio {% if join_mode == 'public' %}selected{% endif %}\">\n              <input type=\"radio\" name=\"joinmode\" value=\"public\" {% if join_mode == 'public' %}checked{% endif %}>\n              <div class=\"sf-radio-info\">\n                <span class=\"sf-radio-title\">Public (Shareable)</span>\n                <span class=\"sf-radio-desc\">Anyone with the link or QR code can join.</span>\n              </div>\n            </label>\n          </div>\n          <button id=\"btnSaveMode\" class=\"sf-btn sf-btn--primary sf-w-full\">Save Settings</button>\n          <div id=\"statusMode\" class=\"sf-status\"></div>\n\n          <div id=\"blockPublic\" class=\"sf-public-block\" {% if join_mode != 'public' %}style=\"display:none\"{% endif %}>\n            <div class=\"sf-divider\"></div>\n            \n            <div class=\"sf-tabs\">\n              <button class=\"sf-tab-link active\" onclick=\"openTab(event, 'tabLink')\">Link</button>\n              <button class=\"sf-tab-link\" onclick=\"openTab(event, 'tabQR')\">QR Code</button>\n            </div>\n\n            <div id=\"tabLink\" class=\"sf-tab-content\" style=\"display:block;\">\n              <div class=\"sf-copy-row\">\n                <input id=\"inputJoinLink\" class=\"sf-input sf-input-mono\" value=\"{{ join_link | escape }}\" readonly>\n                <button id=\"btnCopy\" class=\"sf-btn sf-btn--outline\">Copy</button>\n              </div>\n              <p class=\"sf-helper\">Copy and paste this link to your team chat or email.</p>\n            </div>\n\n            <div id=\"tabQR\" class=\"sf-tab-content\" style=\"display:none;\">\n              <div class=\"sf-qr-wrapper\">\n                <div id=\"qrcode\"></div>\n                <p class=\"sf-helper\">Print this out for flyers or let people scan it instantly.</p>\n              </div>\n            </div>\n\n          </div>\n        </section>\n      </div>\n\n      <section class=\"sf-card\">\n        <div class=\"sf-card-head\">\n          <h3>Manage Roster</h3>\n          <p>Add or remove people from this storefront.</p>\n        </div>\n        <div class=\"sf-form-group\">\n          <label class=\"sf-label\">Member Emails</label>\n          <textarea id=\"inputEmails\" class=\"sf-textarea\" placeholder=\"futuremember1@email.com, futuremember2@email.com...\"></textarea>\n          <p class=\"sf-helper\">Enter multiple emails separated by commas.</p>\n        </div>\n        <div class=\"sf-form-group\">\n          <label class=\"sf-label\">Access Level</label>\n          <select id=\"inputRole\" class=\"sf-select\">\n            <option value=\"member\" selected>Member (Can Shop)</option>\n            <option value=\"admin\">Admin (Can Edit Settings)</option>\n          </select>\n        </div>\n        <div class=\"sf-btn-row\">\n          <button id=\"btnAdd\" class=\"sf-btn sf-btn--primary\">Add Members</button>\n          <button id=\"btnRemove\" class=\"sf-btn sf-btn--danger\">Remove</button>\n        </div>\n        <div id=\"statusMembers\" class=\"sf-status\"></div>\n      </section>\n\n    </div>\n  </div>\n\n  <style>\n    /* PREMIUM THEME */\n    :root {\n      --sf-bg: #f8fafc;\n      --sf-card: #ffffff;\n      --sf-text: #0f172a;\n      --sf-gray: #64748b;\n      --sf-border: #e2e8f0;\n      --sf-accent: #0f172a;\n      --sf-success: #10b981;\n      --sf-danger: #ef4444;\n      --sf-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);\n    }\n\n    .sf-container-auth { max-width: 400px; margin: 80px auto; text-align: center; font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif; }\n    .sf-card-auth { background: var(--sf-card); padding: 40px; border-radius: 20px; border: 1px solid var(--sf-border); box-shadow: var(--sf-shadow); }\n    .sf-icon-lock { font-size: 32px; background: #f1f5f9; width: 60px; height: 60px; line-height: 60px; border-radius: 50%; margin: 0 auto 20px; }\n    \n    .sf-admin-layout { max-width: 1000px; margin: 0 auto; padding: 40px 20px; font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif; color: var(--sf-text); }\n    \n    .sf-admin-header { \n      display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 30px; \n      padding: 24px; border-radius: 16px; \n      background: rgba(255,255,255,0.7); backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.5);\n      box-shadow: var(--sf-shadow);\n      flex-wrap: wrap; gap: 20px; \n    }\n    .sf-badge-admin { display: inline-block; background: var(--sf-accent); color: #fff; font-size: 11px; font-weight: 700; text-transform: uppercase; padding: 4px 10px; border-radius: 99px; margin-bottom: 10px; letter-spacing: 0.05em; }\n    .sf-admin-title { font-size: 28px; font-weight: 800; margin: 0; letter-spacing: -0.02em; }\n    .sf-admin-sub { color: var(--sf-gray); margin: 5px 0 0; }\n    .sf-admin-actions { display: flex; gap: 10px; }\n    \n    .sf-admin-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }\n    .sf-col { display: flex; flex-direction: column; gap: 24px; }\n    @media(max-width: 800px) { .sf-admin-grid { grid-template-columns: 1fr; } }\n    \n    .sf-card { background: var(--sf-card); border: 1px solid var(--sf-border); border-radius: 16px; padding: 24px; box-shadow: var(--sf-shadow); }\n    \n    .sf-card-head { margin-bottom: 20px; }\n    .sf-card-head h3 { margin: 0 0 4px; font-size: 18px; font-weight: 700; }\n    .sf-card-head p { margin: 0; font-size: 13px; color: var(--sf-gray); }\n    \n    .sf-radio-group { display: flex; flex-direction: column; gap: 12px; margin-bottom: 20px; }\n    .sf-radio { display: flex; align-items: flex-start; gap: 12px; padding: 16px; border: 1px solid var(--sf-border); border-radius: 12px; cursor: pointer; transition: all 0.2s; background: #fff; }\n    .sf-radio:hover { border-color: #94a3b8; }\n    .sf-radio.selected { border-color: var(--sf-accent); background: #f1f5f9; }\n    .sf-radio input { margin-top: 4px; }\n    .sf-radio-title { display: block; font-weight: 700; font-size: 14px; margin-bottom: 2px; }\n    .sf-radio-desc { display: block; font-size: 12px; color: var(--sf-gray); }\n    \n    .sf-form-group { margin-bottom: 20px; }\n    .sf-label { display: block; font-size: 12px; font-weight: 700; margin-bottom: 8px; color: var(--sf-gray); text-transform: uppercase; }\n    .sf-input, .sf-textarea, .sf-select { width: 100%; padding: 12px; border: 1px solid var(--sf-border); border-radius: 8px; font-size: 14px; font-family: inherit; transition: 0.2s; background: #fff; }\n    .sf-input:focus, .sf-textarea:focus, .sf-select:focus { outline: none; border-color: var(--sf-accent); box-shadow: 0 0 0 3px rgba(15, 23, 42, 0.1); }\n    .sf-textarea { min-height: 120px; resize: vertical; }\n    .sf-input-mono { font-family: monospace; background: #f1f5f9; color: #475569; }\n    .sf-helper { font-size: 12px; color: var(--sf-gray); margin-top: 6px; }\n    \n    .sf-btn { display: inline-flex; align-items: center; justify-content: center; padding: 10px 20px; border-radius: 8px; font-weight: 600; font-size: 14px; cursor: pointer; transition: all 0.2s; border: none; text-decoration: none; }\n    .sf-btn--primary { background: var(--sf-accent); color: #fff; }\n    .sf-btn--primary:hover { background: #334155; }\n    .sf-btn--glass { background: rgba(255,255,255,0.5); border: 1px solid rgba(0,0,0,0.1); color: var(--sf-text); }\n    .sf-btn--glass:hover { background: #fff; }\n    .sf-btn--outline { background: transparent; border: 1px solid var(--sf-border); color: var(--sf-text); }\n    .sf-btn--outline:hover { background: #f8fafc; border-color: #94a3b8; }\n    .sf-btn--danger { background: #fee2e2; color: #991b1b; }\n    .sf-btn--danger:hover { background: #fecaca; }\n    .sf-w-full { width: 100%; }\n    \n    .sf-btn-row { display: flex; gap: 10px; margin-top: 10px; }\n    .sf-divider { height: 1px; background: var(--sf-border); margin: 20px 0; }\n    .sf-copy-row { display: flex; gap: 10px; }\n    .sf-copy-row input { flex: 1; }\n    .sf-status { margin-top: 15px; font-size: 13px; font-weight: 600; min-height: 20px; }\n    .sf-public-block { margin-top: 20px; animation: fadeIn 0.2s ease-out; }\n    \n    /* QR TABS */\n    .sf-tabs { display: flex; gap: 10px; margin-bottom: 15px; border-bottom: 1px solid var(--sf-border); padding-bottom: 10px; }\n    .sf-tab-link { background: none; border: none; font-size: 13px; font-weight: 600; color: var(--sf-gray); cursor: pointer; padding: 5px 10px; border-radius: 6px; }\n    .sf-tab-link.active { background: #e2e8f0; color: var(--sf-text); }\n    .sf-qr-wrapper { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 10px; background: #fff; border-radius: 12px; border: 1px solid var(--sf-border); }\n    #qrcode img { margin: 0 auto; display: block; }\n    \n    @keyframes fadeIn { from { opacity: 0; transform: translateY(-5px); } to { opacity: 1; transform: translateY(0); } }\n  </style>\n\n  <script>\n    // TAB LOGIC\n    function openTab(evt, tabName) {\n      var i, x, tablinks;\n      x = document.getElementsByClassName(\"sf-tab-content\");\n      for (i = 0; i < x.length; i++) { x[i].style.display = \"none\"; }\n      tablinks = document.getElementsByClassName(\"sf-tab-link\");\n      for (i = 0; i < tablinks.length; i++) { tablinks[i].className = tablinks[i].className.replace(\" active\", \"\"); }\n      document.getElementById(tabName).style.display = \"block\";\n      evt.currentTarget.className += \" active\";\n    }\n\n    (function(){\n      const btnSaveMode = document.getElementById('btnSaveMode');\n      const statusMode = document.getElementById('statusMode');\n      const blockPublic = document.getElementById('blockPublic');\n      const btnCopy = document.getElementById('btnCopy');\n      const inputJoinLink = document.getElementById('inputJoinLink');\n      const inputEmails = document.getElementById('inputEmails');\n      const inputRole = document.getElementById('inputRole');\n      const btnAdd = document.getElementById('btnAdd');\n      const btnRemove = document.getElementById('btnRemove');\n      const statusMembers = document.getElementById('statusMembers');\n\n      // GENERATE QR CODE\n      new QRCode(document.getElementById(\"qrcode\"), {\n        text: \"{{ join_link }}\",\n        width: 150,\n        height: 150,\n        colorDark : \"#0f172a\",\n        colorLight : \"#ffffff\",\n        correctLevel : QRCode.CorrectLevel.H\n      });\n\n      async function post(action, payload){\n        const body = Object.assign({\n          action: action,\n          shop_handle: String(SSAP.collectionHandle || \"\"),\n          requested_by_customer_id: {{ customer.id | json }},\n          requested_by_email: {{ customer.email | json }}\n        }, payload || {});\n\n        return fetch(SSAP.mechanicUrl, {\n          method: 'POST',\n          headers: { 'Content-Type': 'application/json' },\n          body: JSON.stringify(body)\n        });\n      }\n\n      document.addEventListener('change', (e) => {\n        if(e.target && e.target.name === 'joinmode'){\n          document.querySelectorAll('.sf-radio').forEach(el => el.classList.remove('selected'));\n          e.target.closest('.sf-radio').classList.add('selected');\n          blockPublic.style.display = (e.target.value === 'public') ? 'block' : 'none';\n        }\n      });\n\n      btnSaveMode.addEventListener('click', async () => {\n        const mode = document.querySelector('input[name=\"joinmode\"]:checked').value;\n        btnSaveMode.disabled = true;\n        btnSaveMode.textContent = 'Saving...';\n        statusMode.textContent = '';\n        try {\n          const res = await post(\"set_join_mode\", { join_mode: mode });\n          if(!res.ok) throw new Error();\n          statusMode.textContent = 'Settings Saved ✅';\n          statusMode.style.color = '#10b981';\n        } catch(err) {\n          statusMode.textContent = 'Error saving settings.';\n          statusMode.style.color = '#ef4444';\n        } finally {\n          btnSaveMode.disabled = false;\n          btnSaveMode.textContent = 'Save Settings';\n        }\n      });\n\n      btnCopy && btnCopy.addEventListener('click', () => {\n        navigator.clipboard.writeText(inputJoinLink.value);\n        btnCopy.textContent = 'Copied!';\n        setTimeout(() => btnCopy.textContent = 'Copy', 1500);\n      });\n\n      async function handleMemberAction(action) {\n        const rawText = inputEmails.value;\n        const emails = rawText.split(',').map(e => e.trim().toLowerCase()).filter(e => e.length > 0);\n        const role = inputRole.value;\n\n        if(emails.length === 0) {\n          statusMembers.textContent = 'Please enter at least one email.';\n          statusMembers.style.color = '#ef4444';\n          return;\n        }\n\n        if(action === 'remove' && !confirm(`Remove ${emails.length} member(s)?`)) return;\n\n        statusMembers.textContent = `Processing...`;\n        statusMembers.style.color = '#64748b';\n        btnAdd.disabled = true;\n        btnRemove.disabled = true;\n\n        try {\n          const res = await post(action === 'add' ? \"add_members_bulk\" : \"remove_members_bulk\", { \n            emails: emails, \n            role: role \n          });\n          \n          if(res.ok) {\n            statusMembers.textContent = `Success! Roster updated.`;\n            statusMembers.style.color = '#10b981';\n            inputEmails.value = ''; \n          } else {\n            throw new Error('Server error');\n          }\n        } catch(e) {\n          statusMembers.textContent = `Error: Could not process request.`;\n          statusMembers.style.color = '#ef4444';\n        } finally {\n          btnAdd.disabled = false;\n          btnRemove.disabled = false;\n        }\n      }\n\n      btnAdd.addEventListener('click', () => handleMemberAction('add'));\n      btnRemove.addEventListener('click', () => handleMemberAction('remove'));\n    })();\n  </script>\n{%- endif -%}",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 16,
        "padding-block-end": 0
      }
    }
  },
  "order": [
    "custom_liquid_PYf38a"
  ]
}
