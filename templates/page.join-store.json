      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "{% comment %}\n  JOIN STORE LANDING PAGE (SAFE MODE + DELAY SEQUENCE)\n  - \"Backup URL Parser\" included.\n  - \"Design Mode\" check added.\n  - ADDED: 20-second \"Gated Access\" loading sequence to allow API propagation.\n  - UPDATED: Uses 'storefront_login_url' + 'return_to' for seamless New Customer Account loops.\n  - UPDATED: Final redirect goes to Dashboard (/pages/portal).\n{% endcomment %}\n\n{%- comment -%} --- 1. ROBUST URL PARSING --- {%- endcomment -%}\n{%- assign shop_handle = request.params.shop | default: '' | strip -%}\n{%- assign code = request.params.code | default: '' | strip -%}\n\n{%- if shop_handle == blank -%}\n  {%- assign _cfh = content_for_header -%}\n  {%- assign _url_part = _cfh | split: '\"pageurl\":\"' | last | split: '\"' | first -%}\n  {%- assign _url_part = _url_part | replace: '\\u0026', '&' -%}\n  {%- if _url_part contains '?' -%}\n    {%- assign _qs = _url_part | split: '?' | last -%}\n    {%- assign _pairs = _qs | split: '&' -%}\n    {%- for p in _pairs -%}\n      {%- assign kv = p | split: '=' -%}\n      {%- if kv[0] == 'shop' -%}{%- assign shop_handle = kv[1] | default: '' | strip -%}{%- endif -%}\n      {%- if kv[0] == 'code' -%}{%- assign code = kv[1] | default: '' | strip -%}{%- endif -%}\n    {%- endfor -%}\n  {%- endif -%}\n{%- endif -%}\n\n{%- assign shop_handle = shop_handle | replace: '%2D', '-' | replace: '%5F', '_' | strip | downcase -%}\n\n{%- comment -%} --- 2. GET STORE DATA --- {%- endcomment -%}\n{%- assign store_entry = shop.metaobjects.custom_shop[shop_handle] -%}\n{%- assign store_name = store_entry.name | default: shop_handle -%}\n{%- assign store_logo = store_entry.logo.value | default: store_entry.logo -%}\n{%- assign collection_url = '/collections/' | append: shop_handle -%}\n\n<div class=\"sf-join-container\">\n\n  {%- if customer == nil -%}\n    {%- comment -%} GUEST VIEW: FORCE LOGIN & RETURN TO EXACT LINK {%- endcomment -%}\n    \n    {%- unless request.design_mode -%}\n      <script>\n        (function() {\n          // 1. Capture the exact Join Link (with ?shop=...&code=...)\n          // We MUST come back here so the \"Join\" button works.\n          var returnUrl = window.location.pathname + window.location.search;\n\n          // 2. Get Shopify's \"New Account\" Login URL safely\n          var baseLoginUrl = {{ routes.storefront_login_url | json }};\n\n          // 3. Build the Redirect\n          // \"return_to\" overrides the default order page redirect.\n          var separator = baseLoginUrl.indexOf('?') === -1 ? '?' : '&';\n          var redirectUrl = baseLoginUrl + separator + 'return_to=' + encodeURIComponent(returnUrl);\n\n          // 4. Force the Login\n          window.location.href = redirectUrl;\n        })();\n      </script>\n    {%- endunless -%}\n\n    <div class=\"sf-loading-state\">\n      {%- if request.design_mode -%}\n        <div class=\"sf-card sf-card--info\">\n          <h3>Admin Preview Mode</h3>\n          <p>Redirect disabled because you are in the Theme Editor.</p>\n          <p><strong>Store Handle:</strong> {{ shop_handle | default: '(None detected)' }}</p>\n        </div>\n      {%- else -%}\n        <div class=\"sf-spinner\"></div>\n        <p>Redirecting to login...</p>\n      {%- endif -%}\n    </div>\n\n  {%- elsif store_entry == nil and shop_handle != blank -%}\n    <div class=\"sf-card sf-card--error\">\n      <h2>Store Not Found</h2>\n      <p>The link you used seems to be invalid or the store \"<strong>{{ shop_handle }}</strong>\" does not exist.</p>\n      <a href=\"/pages/portal\" class=\"sf-btn sf-btn--outline\">Back to Dashboard</a>\n    </div>\n\n  {%- elsif shop_handle == blank -%}\n    <div class=\"sf-card sf-card--error\">\n      <h2>Invalid Link</h2>\n      <p>This link is missing the shop ID. Please check the URL.</p>\n      <a href=\"/pages/portal\" class=\"sf-btn sf-btn--outline\">Back to Dashboard</a>\n    </div>\n\n  {%- else -%}\n    {%- comment -%} SUCCESS VIEW: SHOW PREVIEW CARD {%- endcomment -%}\n    <div class=\"sf-card\">\n      <div class=\"sf-logo-area\">\n        {%- if store_logo != blank -%}\n          {{ store_logo | image_url: width: 300 | image_tag: class: 'sf-store-logo', loading: 'eager' }}\n        {%- else -%}\n          <div class=\"sf-logo-fallback\">{{ store_name | slice: 0, 2 | upcase }}</div>\n        {%- endif -%}\n      </div>\n\n      <div class=\"sf-content\">\n        <span class=\"sf-badge\">You have been invited to join</span>\n        <h1 class=\"sf-title\">{{ store_name }}</h1>\n        <p class=\"sf-sub\">Click below to add this private collection to your dashboard.</p>\n        \n        <button id=\"btnJoin\" class=\"sf-btn sf-btn--primary\" onclick=\"joinStore()\">\n          Join Storefront\n        </button>\n        \n        <div id=\"joinStatus\" class=\"sf-status\"></div>\n      </div>\n    </div>\n\n    <script>\n      function joinStore() {\n        var btn = document.getElementById('btnJoin');\n        var statusEl = document.getElementById('joinStatus');\n        \n        // 1. Lock the Button immediately\n        btn.disabled = true;\n        btn.innerHTML = '<span class=\"sf-spinner-small\"></span> Processing...';\n        statusEl.innerHTML = \"Initializing secure connection...\";\n        statusEl.classList.add('active');\n        \n        var mechanicUrl = \"https://webhooks.mechanic.dev/582ce69e-ceda-4086-9416-d0cd52260ce9\";\n\n        var payload = {\n          action: \"self_join\",\n          shop_handle: \"{{ shop_handle }}\",\n          code: \"{{ code }}\",\n          customer_id: {{ customer.id | json }},\n          customer_email: {{ customer.email | json }}\n        };\n\n        // 2. Fire the Webhook (Don't wait for it to finish to start the show)\n        fetch(mechanicUrl, {\n          method: 'POST',\n          headers: {'Content-Type':'application/json'},\n          body: JSON.stringify(payload)\n        })\n        .then(function(res){\n          if(!res.ok) throw new Error('Webhook failed');\n          // We don't redirect here anymore. We wait for the timer below.\n        })\n        .catch(function(err){\n          console.error(err);\n          // If the network request actually fails, we should tell them.\n          btn.disabled = false;\n          btn.innerHTML = 'Try Again';\n          statusEl.innerHTML = 'Connection Error. Please try again.';\n          statusEl.style.color = 'red';\n        });\n\n        // 3. THE \"FANCY SHIT\" SEQUENCE (20 Seconds Total)\n        // This runs regardless of how fast the webhook returns to ensure tags propagate.\n        \n        var steps = [\n          { time: 2000, text: \"Verifying invite code...\" },\n          { time: 6000, text: \"Authenticating user profile...\" },\n          { time: 11000, text: \"Granting gated access permissions...\" },\n          { time: 16000, text: \"Syncing dashboard assets...\" },\n          { time: 20000, text: \"<b>Success!</b> Redirecting...\" }\n        ];\n\n        steps.forEach(function(step) {\n          setTimeout(function() {\n            // Fade out, change text, fade in\n            statusEl.style.opacity = '0';\n            setTimeout(function(){\n              statusEl.innerHTML = step.text;\n              statusEl.style.opacity = '1';\n            }, 300);\n          }, step.time);\n        });\n\n        // 4. Final Redirect after 21 seconds\n        // UPDATED: Now sends them to the Dashboard (/pages/portal)\n        setTimeout(function(){ \n          window.location.href = \"/pages/portal\"; \n        }, 21000);\n      }\n    </script>\n  {%- endif -%}\n\n</div>\n\n<style>\n  /* CLEAN UI - MATCHING DASHBOARD THEME */\n  .sf-join-container { max-width: 500px; margin: 60px auto; padding: 0 20px; font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif; text-align: center; }\n  .sf-card { background: #fff; border: 1px solid rgba(0,0,0,0.08); border-radius: 24px; padding: 40px; box-shadow: 0 10px 40px rgba(0,0,0,0.06); overflow: hidden; }\n  .sf-card--error { border-color: #fee; background: #fffafa; }\n  .sf-card--info { border-color: #e0f2fe; background: #f0f9ff; color: #0369a1; padding: 20px; }\n  \n  .sf-logo-area { width: 100px; height: 100px; margin: 0 auto 24px; border-radius: 20px; background: #f8fafc; border: 1px solid rgba(0,0,0,0.06); display: flex; align-items: center; justify-content: center; overflow: hidden; }\n  .sf-store-logo { width: 100%; height: 100%; object-fit: contain; padding: 10px; }\n  .sf-logo-fallback { font-size: 28px; font-weight: 800; color: #94a3b8; }\n  \n  .sf-badge { display: inline-block; font-size: 11px; text-transform: uppercase; letter-spacing: 0.08em; font-weight: 700; color: #64748b; margin-bottom: 8px; background: #f1f5f9; padding: 4px 10px; border-radius: 99px; }\n  .sf-title { font-size: 26px; font-weight: 900; margin: 0 0 12px; color: #0f172a; letter-spacing: -0.02em; }\n  .sf-sub { font-size: 15px; color: #64748b; margin: 0 0 30px; line-height: 1.5; }\n  \n  .sf-btn { width: 100%; border: none; padding: 16px; border-radius: 99px; font-size: 16px; font-weight: 700; cursor: pointer; transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; gap: 8px; }\n  .sf-btn--primary { background: #0f172a; color: #fff; box-shadow: 0 4px 12px rgba(15, 23, 42, 0.2); }\n  .sf-btn--primary:hover { background: #000; transform: translateY(-1px); }\n  .sf-btn--primary:disabled { opacity: 0.7; cursor: not-allowed; transform: none; background: #334155; }\n  .sf-btn--outline { background: transparent; border: 1px solid #e2e8f0; color: #0f172a; width: auto; padding: 12px 24px; }\n  \n  /* STATUS ANIMATION STYLES */\n  .sf-status { \n    margin-top: 20px; \n    font-size: 13px; \n    font-weight: 500; \n    color: #64748b; \n    min-height: 24px; \n    transition: opacity 0.3s ease; \n    opacity: 0; \n  }\n  .sf-status.active { opacity: 1; }\n  .sf-status b { color: #10b981; }\n\n  .sf-spinner-small { width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.3); border-top-color: #fff; border-radius: 50%; animation: spin 0.8s linear infinite; }\n  @keyframes spin { to { transform: rotate(360deg); } }\n  .sf-spinner { width: 40px; height: 40px; border: 4px solid #e2e8f0; border-top-color: #0f172a; border-radius: 50%; animation: spin 1s linear infinite; margin: 0 auto 16px; }\n  .sf-loading-state { margin-top: 60px; color: #64748b; }\n</style>",
