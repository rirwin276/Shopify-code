{% layout none %}
{% comment %}ADMIN_SECRET is hardcoded below{% endcomment %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stella & Sage — God Mode</title>
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
<style>
  :root { 
    --bg: #0f172a; 
    --card-bg: #1e293b; 
    --header-bg: #1e293b;
    --text: #f8fafc; 
    --gray: #94a3b8;
    --border: #334155; 
    --accent: #3b82f6; 
    --danger: #ef4444; 
    --danger-hover: #dc2626;
    --success: #10b981;
    --warning: #f59e0b;
  }
  
  * { box-sizing: border-box; }
  
  body { 
    background: var(--bg); 
    color: var(--text); 
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; 
    padding: 0; margin: 0; 
    min-height: 100vh;
  }

  /* --- LAYOUT --- */
  .sa-wrapper { display: grid; grid-template-columns: 280px 1fr; min-height: 100vh; }

  /* --- SIDEBAR --- */
  .sa-sidebar {
    background: var(--card-bg); border-right: 1px solid var(--border);
    padding: 30px 20px; display: flex; flex-direction: column; gap: 30px;
    position: sticky; top: 0; height: 100vh; overflow-y: auto;
  }
  .sa-profile { text-align: center; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
  .sa-avatar {
    width: 80px; height: 80px; border-radius: 50%; object-fit: cover;
    border: 3px solid var(--accent); margin-bottom: 15px; background: #000;
  }
  .sa-sidebar h1 { font-size: 18px; margin: 0; font-weight: 800; letter-spacing: -0.5px; }
  .sa-sidebar p { color: var(--gray); font-size: 13px; margin: 5px 0 0; }
  .sa-badge-god { 
    background: linear-gradient(135deg, #3b82f6, #8b5cf6); 
    color: white; padding: 4px 10px; border-radius: 20px; 
    font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 1px;
    display: inline-block; margin-top: 10px;
  }

  /* --- TOOLS WIDGETS --- */
  .sa-widget { margin-bottom: 20px; }
  .sa-widget h3 { font-size: 11px; text-transform: uppercase; color: var(--gray); margin-bottom: 15px; letter-spacing: 1px; font-weight: 700; }
  .sa-input-group { margin-bottom: 15px; }
  .sa-label { display: block; font-size: 11px; color: var(--gray); margin-bottom: 5px; font-weight: 600; }
  .sa-input { 
    width: 100%; background: #0f172a; border: 1px solid var(--border); 
    color: white; padding: 10px; border-radius: 6px; font-size: 13px; 
    transition: 0.2s;
  }
  .sa-input:focus { border-color: var(--accent); outline: none; }

  /* --- BUTTONS --- */
  .btn { 
    border: none; cursor: pointer; padding: 10px 16px; border-radius: 6px; 
    font-size: 12px; font-weight: 600; text-decoration: none; 
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    transition: 0.2s;
  }
  .btn-primary { background: var(--accent); color: white; width: 100%; }
  .btn-primary:hover { background: #2563eb; }
  .btn-glass { background: rgba(255,255,255,0.05); color: var(--text); border: 1px solid var(--border); }
  .btn-glass:hover { background: rgba(255,255,255,0.1); border-color: var(--text); }
  .btn-danger { background: rgba(239, 68, 68, 0.1); color: #fca5a5; border: 1px solid rgba(239, 68, 68, 0.2); }
  .btn-danger:hover { background: var(--danger); color: white; border-color: var(--danger); }
  .btn-sm { padding: 6px 12px; font-size: 11px; }
  .btn-warning { background: rgba(245, 158, 11, 0.1); color: #fcd34d; border: 1px solid rgba(245, 158, 11, 0.2); }
  .btn-warning:hover { background: var(--warning); color: white; border-color: var(--warning); }

  /* --- STORE TAB BUTTONS --- */
  .tab-btn {
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--border);
    color: var(--gray);
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    transition: 0.2s;
  }
  .tab-btn.active, .tab-btn:hover {
    background: var(--accent);
    color: white;
    border-color: var(--accent);
  }

  /* --- MAIN CONTENT --- */
  .sa-main { padding: 40px 50px; overflow-y: auto; }
  .sa-section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30px; }
  .sa-search { 
    background: var(--card-bg); border: 1px solid var(--border); 
    color: white; padding: 12px 20px; border-radius: 100px; 
    width: 300px; font-size: 14px;
  }
  .sa-search:focus { border-color: var(--accent); outline: none; }

  /* --- STORE CARDS --- */
  .store-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px; }
  .store-card {
    background: var(--card-bg); border: 1px solid var(--border); 
    border-radius: 12px; padding: 20px; position: relative;
    transition: 0.2s; display: flex; flex-direction: column; justify-content: space-between;
  }
  .store-card:hover { transform: translateY(-3px); border-color: var(--accent); box-shadow: 0 10px 20px rgba(0,0,0,0.2); }
  .store-header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px; }
  .store-icon { 
    width: 40px; height: 40px; background: #334155; 
    border-radius: 8px; display: flex; align-items: center; justify-content: center; 
    font-size: 18px; color: var(--gray);
  }
  .store-status { font-size: 10px; font-weight: 700; text-transform: uppercase; padding: 4px 8px; border-radius: 4px; letter-spacing: 0.5px; }
  .status-active { background: rgba(16, 185, 129, 0.1); color: var(--success); }
  .status-closed { background: rgba(148, 163, 184, 0.1); color: var(--gray); }
  .status-private { background: rgba(245, 158, 11, 0.1); color: var(--warning); }
  .status-sleeping { background: rgba(99, 102, 241, 0.15); color: #a5b4fc; }

  @keyframes sa-wake-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(59,130,246,0.35); }
    50%       { box-shadow: 0 0 0 6px rgba(59,130,246,0); }
  }

  .store-name { font-size: 16px; font-weight: 700; margin: 0 0 5px; color: white; }
  .store-handle { font-size: 12px; color: var(--gray); font-family: monospace; }
  .store-actions { margin-top: 20px; padding-top: 15px; border-top: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; }

  /* GRAVEYARD SECTION */
  .graveyard-section { margin-top: 80px; opacity: 0.7; }
  .graveyard-section:hover { opacity: 1; transition: 0.3s; }
  .graveyard-title { font-size: 14px; text-transform: uppercase; color: var(--gray); letter-spacing: 1px; border-bottom: 1px solid var(--border); padding-bottom: 10px; margin-bottom: 20px; }

  /* MODAL */
  .modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); backdrop-filter: blur(5px); z-index: 1000; }
  .modal { 
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); 
    width: 90%; max-width: 600px; background: var(--card-bg); 
    border: 1px solid var(--border); border-radius: 16px; padding: 0; 
    max-height: 85vh; display: flex; flex-direction: column; overflow: hidden;
  }
  
  .modal-header { padding: 20px; border-bottom: 1px solid var(--border); display: flex; justify-content: space-between; align-items: center; background: rgba(15, 23, 42, 0.5); }
  .modal-tabs { display: flex; border-bottom: 1px solid var(--border); background: #0f172a; }
  .modal-tab { flex: 1; padding: 15px; text-align: center; cursor: pointer; color: var(--gray); font-size: 13px; font-weight: 600; transition: 0.2s; }
  .modal-tab:hover { color: white; background: rgba(255,255,255,0.05); }
  .modal-tab.active { color: var(--accent); border-bottom: 2px solid var(--accent); }
  
  .modal-content { padding: 20px; overflow-y: auto; flex: 1; }
  .tab-pane { display: none; }
  .tab-pane.active { display: block; }

  .modal-row { display: flex; align-items: center; gap: 15px; padding: 12px; background: var(--bg); border-radius: 8px; border: 1px solid var(--border); margin-bottom: 10px; }
  .modal-img { width: 40px; height: 40px; background: #334155; border-radius: 6px; object-fit: cover; }
  
  /* SETTINGS TOGGLE */
  .setting-row { display: flex; justify-content: space-between; align-items: center; padding: 15px; background: #0f172a; border-radius: 8px; border: 1px solid var(--border); }
</style>
</head>
<body>

{% assign is_super = false %}
{% if customer %}
  {% if customer.email == 'ryan.irwin@stellaandsagecompany.com' %}{% assign is_super = true %}{% endif %}
  {% for t in customer.tags %}
    {% if t contains 'super-admin' %}{% assign is_super = true %}{% endif %}
  {% endfor %}
{% endif %}

{% if is_super %}
  
  <div class="sa-wrapper">
    
    <aside class="sa-sidebar">
      <div class="sa-profile">
        <img src="https://cdn.shopify.com/s/files/1/0798/2055/4490/files/freeddy_the_frog.jpg?v=1770183074" class="sa-avatar" width="80" height="80" alt="Super Admin Avatar" loading="lazy">
        <h1>Super Admin</h1>
        <div class="sa-badge-god">God Mode Active</div>
        <p>Logged in as {{ customer.first_name }}</p>
      </div>

      <div class="sa-widget">
        <h3><i class="fas fa-chart-bar"></i> System Stats</h3>
        {% assign total_stores = 0 %}
        {% assign active_count = 0 %}
        {% assign sleeping_count = 0 %}
        {% assign waking_count = 0 %}
        {% assign closed_count = 0 %}
        {% for store in shop.metaobjects.custom_shop.values %}
          {% assign total_stores = total_stores | plus: 1 %}
          {% if store.tags contains 'status:closed' %}
            {% assign closed_count = closed_count | plus: 1 %}
          {% else %}
            {%- assign _sv = '' -%}
            {%- for _f in store.fields -%}
              {%- if _f.key == 'status' -%}{%- assign _sv = _f.value -%}{%- endif -%}
            {%- endfor -%}
            {%- if _sv == blank -%}{%- assign _sv = store.status.value | default: store.status | default: '' -%}{%- endif -%}
            {% if _sv == 'sleeping' %}
              {% assign sleeping_count = sleeping_count | plus: 1 %}
            {% elsif _sv == 'waking' %}
              {% assign waking_count = waking_count | plus: 1 %}
            {% else %}
              {% assign active_count = active_count | plus: 1 %}
            {% endif %}
          {% endif %}
        {% endfor %}
        <div style="font-size:12px; color:var(--gray); line-height:2;">
          <div>Total: <strong style="color:white;">{{ total_stores }}</strong></div>
          <div>Active: <strong style="color:var(--success);">{{ active_count }}</strong></div>
          <div>Sleeping: <strong style="color:#a5b4fc;">{{ sleeping_count }}</strong></div>
          <div>Waking: <strong style="color:#93c5fd;">{{ waking_count }}</strong></div>
          <div>Closed: <strong style="color:var(--gray);">{{ closed_count }}</strong></div>
        </div>
      </div>

      <div class="sa-widget">
        <h3><i class="fas fa-tag"></i> Global Price Override</h3>
        <div class="sa-input-group">
          <label class="sa-label">Target Tag (Model)</label>
          <input type="text" id="targetTag" class="sa-input" placeholder="e.g. bella-3006-blk">
        </div>
        <div class="sa-input-group">
          <label class="sa-label">New Price ($)</label>
          <input type="number" id="newPrice" class="sa-input" placeholder="0.00">
        </div>
        <button id="btnUpdatePrice" class="btn btn-primary">Update Prices</button>
        <div id="priceStatus" style="font-size:11px; margin-top:10px; min-height:15px; text-align:center;"></div>
      </div>

      <div class="sa-widget">
        <h3><i class="fas fa-link"></i> Quick Links</h3>
        <a href="/admin/products" target="_blank" class="btn btn-glass" style="width:100%; margin-bottom:10px;">Shopify Admin</a>
        <a href="/pages/portal" class="btn btn-glass" style="width:100%; margin-bottom:10px;">Back to Portal</a>
        <button class="btn btn-warning" style="width:100%;" onclick="sleepAllInactive()">
          <i class="fas fa-moon"></i> Sleep All Inactive
        </button>
        <div id="sleepAllStatus" style="font-size:11px; margin-top:8px; min-height:14px; text-align:center;"></div>
      </div>

      <div class="sa-widget">
        <h3><i class="fas fa-print"></i> Run Printful by Handle</h3>
        <div class="sa-input-group">
          <label class="sa-label">Store Handle</label>
          <input type="text" id="printfulHandle" class="sa-input" placeholder="e.g. my-store-handle">
        </div>
        <button class="btn btn-primary" onclick="runPrintful()">Run Printful</button>
        <div id="printfulStatus" style="font-size:11px; margin-top:8px; min-height:14px; text-align:center;"></div>
      </div>
    </aside>

    <main class="sa-main">
      <div class="sa-section-header">
        <div>
          <h2 style="margin:0;">Store Operations</h2>
          <p style="color:var(--gray); margin:5px 0 0; font-size:14px;">Manage active storefronts, members, and inventory.</p>
        </div>
        <input type="text" id="storeSearch" class="sa-search" placeholder="Search stores..." onkeyup="filterStores()">
      </div>

      <h3 style="color:var(--text); margin-bottom:20px;">Active Storefronts</h3>
      <div id="storeTabs" style="display:flex; gap:10px; margin-bottom:20px; flex-wrap:wrap;">
        <button class="tab-btn active" onclick="setTab('all', event)">All Stores</button>
        <button class="tab-btn" onclick="setTab('most_sales', event)">Most Sales</button>
        <button class="tab-btn" onclick="setTab('least_sales', event)">Least Sales</button>
        <button class="tab-btn" onclick="setTab('sleeping', event)">Sleeping</button>
        <button class="tab-btn" onclick="setTab('waking', event)">Waking</button>
        <button class="tab-btn" onclick="setTab('awake_no_sales', event)">Awake / No Sales</button>
      </div>
      <div class="store-grid" id="activeStoreGrid">
        {% for store in shop.metaobjects.custom_shop.values %}
          {% unless store.tags contains 'status:closed' %}
            {%- assign store_status_val = '' -%}
            {%- for f in store.fields -%}
              {%- if f.key == 'status' -%}{%- assign store_status_val = f.value -%}{%- endif -%}
            {%- endfor -%}
            {%- if store_status_val == blank -%}
              {%- assign store_status_val = store.status.value | default: store.status | default: '' -%}
            {%- endif -%}
            {%- assign is_store_sleeping = false -%}
            {%- assign is_store_waking = false -%}
            {%- if store_status_val == 'sleeping' -%}{%- assign is_store_sleeping = true -%}{%- endif -%}
            {%- if store_status_val == 'waking' -%}{%- assign is_store_waking = true -%}{%- endif -%}

            <div class="store-card" data-name="{{ store.name | downcase }}" data-handle="{{ store.system.handle }}" data-sleep-status="{% if is_store_sleeping %}sleeping{% elsif is_store_waking %}waking{% else %}active{% endif %}" data-sales="0" {% if is_store_sleeping %}style="opacity:0.5; border-color:rgba(99,102,241,0.4);"{% elsif is_store_waking %}style="border-color:rgba(59,130,246,0.5); animation:sa-wake-pulse 2s ease-in-out infinite;"{% endif %}>
              <div>
                <div class="store-header">
                  <div class="store-icon"><i class="fas fa-store"></i></div>
                  {% if is_store_sleeping %}
                    <span class="store-status status-sleeping">💤 Sleeping</span>
                  {% elsif is_store_waking %}
                    <span class="store-status" style="background:rgba(59,130,246,0.15); color:#93c5fd;">⏳ Waking</span>
                  {% elsif store.tags contains 'status:private' %}
                    <span class="store-status status-private">Private</span>
                  {% else %}
                    <span class="store-status status-active">Public</span>
                  {% endif %}
                </div>
                <h3 class="store-name">{{ store.name }}</h3>
                <div class="store-handle">{{ store.system.handle }}</div>
              </div>

              <div class="store-actions">
                {% if is_store_sleeping %}
                  <button class="btn btn-primary btn-sm" onclick="wakeStore('{{ store.system.handle | escape }}')">
                    <i class="fas fa-sun"></i> Wake Up
                  </button>
                {% elsif is_store_waking %}
                  <button class="btn btn-sm" disabled style="opacity:0.5; cursor:not-allowed; background:rgba(59,130,246,0.15); color:#93c5fd; border:1px solid rgba(59,130,246,0.2);">
                    <i class="fas fa-spinner fa-spin"></i> Waking…
                  </button>
                {% else %}
                  <button class="btn btn-primary btn-sm" onclick="openManage('{{ store.name | escape }}', '{{ store.collection_handle }}', '{{ store.system.handle }}')">
                    <i class="fas fa-cog"></i> Manage Store
                  </button>
                  <button class="btn btn-warning btn-sm" onclick="sleepStore('{{ store.system.handle }}')">
                    <i class="fas fa-moon"></i> Sleep
                  </button>
                  <button class="btn btn-danger btn-sm" onclick="nukeStore('{{ store.system.handle }}')">
                    <i class="fas fa-radiation"></i> NUKE
                  </button>
                {% endif %}
              </div>
            </div>

          {% endunless %}
        {% endfor %}
      </div>

      <div class="graveyard-section">
        <h3 class="graveyard-title"><i class="fas fa-archive"></i> Closed Stores (Graveyard)</h3>
        <div class="store-grid" id="closedStoreGrid">
          {% for store in shop.metaobjects.custom_shop.values %}
            {% if store.tags contains 'status:closed' %}
              <div class="store-card" data-name="{{ store.name | downcase }}" data-handle="{{ store.system.handle }}" style="border-style:dashed;">
                <div>
                  <div class="store-header">
                    <div class="store-icon"><i class="fas fa-ban"></i></div>
                    <span class="store-status status-closed">Closed</span>
                  </div>
                  <h3 class="store-name" style="color:var(--gray); text-decoration: line-through;">{{ store.name }}</h3>
                  <div class="store-handle">{{ store.system.handle }}</div>
                </div>
                <div class="store-actions">
                  <button class="btn btn-primary btn-sm" onclick="wakeStore('{{ store.system.handle | escape }}')">
                    <i class="fas fa-sun"></i> Wake
                  </button>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </main>
  </div>

  <div id="manageModal" class="modal-overlay">
    <div class="modal">
      <div class="modal-header">
        <h3 id="manageTitle" style="margin:0;">Manage Store</h3>
        <button onclick="closeManage()" style="background:none; border:none; color:white; font-size:20px; cursor:pointer;">&times;</button>
      </div>
      
      <div class="modal-tabs">
        <div class="modal-tab active" onclick="switchTab('inventory')">Inventory</div>
        <div class="modal-tab" onclick="switchTab('members')">Members</div>
        <div class="modal-tab" onclick="switchTab('settings')">Settings</div>
      </div>

      <div class="modal-content">
        <div id="tab-inventory" class="tab-pane active">
          <div id="inventoryList">Loading...</div>
        </div>

        <div id="tab-members" class="tab-pane">
          <div style="background:#0f172a; padding:15px; border-radius:8px; border:1px solid var(--border); margin-bottom:20px;">
            <label class="sa-label">Manage Access</label>
            <div style="display:flex; gap:10px;">
              <input type="email" id="memberEmail" class="sa-input" placeholder="user@example.com">
              <button onclick="handleMember('add')" class="btn btn-primary">Add</button>
              <button onclick="handleMember('remove')" class="btn btn-danger">Remove</button>
            </div>
            <div style="font-size:11px; color:var(--gray); margin-top:5px;">This will tag/untag the customer for this specific store.</div>
            <div id="memberStatus" style="margin-top:10px; font-weight:bold;"></div>
          </div>
        </div>

        <div id="tab-settings" class="tab-pane">
          <div class="setting-row">
            <div>
              <div style="font-weight:700; font-size:14px; color:white;">Store Visibility</div>
              <div style="font-size:11px; color:var(--gray);">Toggle between Public and Private.</div>
            </div>
            <div>
              <button class="btn btn-glass" onclick="toggleVisibility('public')">Make Public</button>
              <button class="btn btn-glass" onclick="toggleVisibility('private')">Make Private</button>
            </div>
          </div>
          <div class="setting-row" style="margin-top:15px;">
            <div>
              <div style="font-weight:700; font-size:14px; color:white;">Sleep Mode</div>
              <div style="font-size:11px; color:var(--gray);">Delete all products. Metaobject and member tags are preserved. Store can be woken up to rebuild.</div>
            </div>
            <div>
              <button class="btn btn-danger" onclick="sleepStore(currentStoreHandle); closeManage();">
                <i class="fas fa-moon"></i> Put to Sleep
              </button>
            </div>
          </div>
        </div>

      </div>
    </div>
  </div>

  <script>
    // --- CONFIGURATION ---
    const RAILWAY_URL = "https://studio-uploader-production.up.railway.app";
    const ADMIN_SECRET = "stellasage-god-mode-2026-xK9mP";

    // STATE
    let currentStoreTag = "";
    let currentStoreHandle = "";
    let currentCollection = "";

    // --- HELPERS ---
    function railwayHeaders() {
      return {
        "Content-Type": "application/json",
        "X-Admin-Secret": ADMIN_SECRET
      };
    }

    function showToast(msg, isError = false) {
      let t = document.getElementById('toast');
      if (!t) {
        t = document.createElement('div');
        t.id = 'toast';
        t.style.cssText = 'position:fixed;bottom:30px;right:30px;padding:12px 20px;border-radius:8px;font-size:13px;font-weight:700;z-index:9999;transition:opacity 0.4s;';
        document.body.appendChild(t);
      }
      t.textContent = msg;
      t.style.background = isError ? '#ef4444' : '#10b981';
      t.style.color = 'white';
      t.style.opacity = '1';
      clearTimeout(t._timeout);
      t._timeout = setTimeout(() => { t.style.opacity = '0'; }, 3500);
    }

    // --- SEARCH FILTER ---
    function filterStores() {
      const filter = document.getElementById('storeSearch').value.toLowerCase();
      document.querySelectorAll('.store-card').forEach(card => {
        card.style.display = card.getAttribute('data-name').includes(filter) ? '' : 'none';
      });
    }

    // --- TAB SORTING ---
    let currentTab = 'all';
    function setTab(tab, evt) {
      currentTab = tab;
      document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
      if (evt && evt.target) evt.target.classList.add('active');
      applyTabFilter();
    }

    function applyTabFilter() {
      const cards = document.querySelectorAll('#activeStoreGrid .store-card');
      cards.forEach(card => {
        const status = card.getAttribute('data-sleep-status') || 'active';
        const sales = parseInt(card.getAttribute('data-sales') || '0', 10);
        let show = true;
        if (currentTab === 'sleeping') show = status === 'sleeping';
        else if (currentTab === 'waking') show = status === 'waking';
        else if (currentTab === 'awake_no_sales') show = status !== 'sleeping' && status !== 'waking' && sales === 0;
        card.style.display = show ? '' : 'none';
      });
      if (currentTab === 'most_sales' || currentTab === 'least_sales') {
        sortCards(currentTab);
      }
    }

    function sortCards(tab) {
      const grid = document.getElementById('activeStoreGrid');
      const cards = Array.from(grid.querySelectorAll('.store-card'));
      cards.sort((a, b) => {
        const sa = parseInt(a.getAttribute('data-sales') || '0', 10);
        const sb = parseInt(b.getAttribute('data-sales') || '0', 10);
        return tab === 'most_sales' ? sb - sa : sa - sb;
      });
      cards.forEach(c => { c.style.display = ''; grid.appendChild(c); });
    }

    // --- MODAL LOGIC ---
    function openManage(name, collection, handle) {
      currentStoreTag = name;
      currentStoreHandle = handle;
      currentCollection = collection;
      document.getElementById('manageTitle').textContent = "Manage: " + name;
      document.getElementById('manageModal').style.display = 'block';
      loadInventory(collection);
    }

    function closeManage() {
      document.getElementById('manageModal').style.display = 'none';
    }

    function switchTab(tabName) {
      document.querySelectorAll('.modal-tab').forEach(t => t.classList.remove('active'));
      document.querySelectorAll('.tab-pane').forEach(p => p.classList.remove('active'));
      document.querySelector(`.modal-tab[onclick="switchTab('${tabName}')"]`).classList.add('active');
      document.getElementById(`tab-${tabName}`).classList.add('active');
    }

    // --- TAB 1: INVENTORY ---
    function loadInventory(collectionHandle) {
      const el = document.getElementById('inventoryList');
      if (!collectionHandle) { el.innerHTML = '<p style="color:var(--gray)">No collection linked.</p>'; return; }
      el.innerHTML = '<p style="color:var(--gray)">Loading inventory...</p>';
      fetch(`/collections/${collectionHandle}/products.json?limit=50`)
        .then(r => r.json())
        .then(data => {
          if (!data.products || !data.products.length) {
            el.innerHTML = '<p style="color:var(--gray)">No products found.</p>';
            return;
          }
          el.innerHTML = data.products.map(p => `
            <div class="modal-row">
              <img src="${p.image ? p.image.src : ''}" class="modal-img" alt="${p.title}" onerror="this.style.display='none'">
              <div style="flex:1">
                <div style="font-weight:700; font-size:13px;">${p.title}</div>
                <div style="font-size:11px; color:var(--gray);">${p.variants.length} variant(s)</div>
              </div>
            </div>`).join('');
        })
        .catch(() => { el.innerHTML = '<p style="color:var(--gray)">Could not load inventory.</p>'; });
    }

    // --- TAB 2: MEMBERS (Add User) ---
    function handleMember(action) {
      const email = document.getElementById('memberEmail').value.trim();
      const statusEl = document.getElementById('memberStatus');
      if (!email) { statusEl.textContent = 'Please enter an email.'; statusEl.style.color = '#ef4444'; return; }
      if (!currentStoreHandle) { statusEl.textContent = 'No store selected.'; statusEl.style.color = '#ef4444'; return; }

      statusEl.textContent = action === 'add' ? 'Adding user...' : 'Removing user...';
      statusEl.style.color = 'var(--gray)';

      fetch(`${RAILWAY_URL}/api/storefront/${currentStoreHandle}/member`, {
        method: 'POST',
        headers: railwayHeaders(),
        body: JSON.stringify({ email: email, action: action })
      })
        .then(r => r.json())
        .then(data => {
          if (data.ok || data.status === 'ok') {
            statusEl.textContent = action === 'add' ? `✅ ${email} added to store.` : `✅ ${email} removed from store.`;
            statusEl.style.color = '#10b981';
            document.getElementById('memberEmail').value = '';
          } else {
            statusEl.textContent = '❌ ' + (data.error || 'Unknown error');
            statusEl.style.color = '#ef4444';
          }
        })
        .catch(e => {
          statusEl.textContent = '❌ Request failed: ' + e.message;
          statusEl.style.color = '#ef4444';
        });
    }

    // --- SLEEP STORE ---
    function sleepStore(handle) {
      if (!confirm(`Put store "${handle}" to sleep? It will be hidden until woken up.`)) return;
      showToast('Putting store to sleep...');

      fetch(`${RAILWAY_URL}/admin/store/${handle}/sleep`, {
        method: 'POST',
        headers: railwayHeaders()
      })
        .then(r => r.json())
        .then(data => {
          if (data.job_id || data.status === 'ok') {
            showToast(`✅ Store "${handle}" is going to sleep.`);
            const card = document.querySelector(`.store-card[data-handle="${handle}"]`);
            if (card) {
              card.setAttribute('data-sleep-status', 'sleeping');
              card.style.opacity = '0.5';
              const statusBadge = card.querySelector('.store-status');
              if (statusBadge) { statusBadge.textContent = '💤 Sleeping'; statusBadge.className = 'store-status status-closed'; }
            }
          } else {
            showToast('❌ ' + (data.error || 'Sleep failed'), true);
          }
        })
        .catch(e => showToast('❌ Request failed: ' + e.message, true));
    }

    // --- WAKE STORE ---
    function wakeStore(handle) {
      if (!confirm(`Wake store "${handle}"? This will re-run Printful Automation to rebuild products.`)) return;
      showToast('Waking store up...');
      fetch(`${RAILWAY_URL}/admin/store/${handle}/wakeup`, {
        method: 'POST',
        headers: railwayHeaders()
      })
        .then(r => r.json())
        .then(data => {
          if (data.job_id || data.status === 'ok') {
            showToast(`✅ Store "${handle}" is waking up. Products will be rebuilt.`);
            const card = document.querySelector(`.store-card[data-handle="${handle}"]`);
            if (card) card.style.opacity = '0.7';
          } else {
            showToast('❌ ' + (data.error || 'Wake failed'), true);
          }
        })
        .catch(e => showToast('❌ Request failed: ' + e.message, true));
    }

    // --- NUKE STORE ---
    function nukeStore(handle) {
      if (!confirm(`☢️ NUKE store "${handle}"?\n\nThis will permanently delete ALL data for this store. This cannot be undone.`)) return;
      if (!confirm(`Are you absolutely sure? Type OK to confirm nuke of "${handle}".`)) return;

      showToast('☢️ Nuking store...');

      fetch(`${RAILWAY_URL}/api/storefront/${handle}/nuke`, {
        method: 'POST',
        headers: railwayHeaders(),
        body: JSON.stringify({})
      })
        .then(r => r.json())
        .then(data => {
          if (data.job_id) {
            showToast(`☢️ Nuke job started for "${handle}". Job: ${data.job_id}`);
            pollNukeJob(data.job_id, handle);
          } else {
            showToast('❌ ' + (data.error || 'Nuke failed'), true);
          }
        })
        .catch(e => showToast('❌ Request failed: ' + e.message, true));
    }

    function pollNukeJob(jobId, handle) {
      let attempts = 0;
      const interval = setInterval(() => {
        attempts++;
        fetch(`${RAILWAY_URL}/api/job/${jobId}`, { headers: railwayHeaders() })
          .then(r => r.json())
          .then(data => {
            if (data.status === 'done') {
              clearInterval(interval);
              showToast(`✅ Store "${handle}" has been nuked.`);
              const card = document.querySelector(`.store-card[data-handle="${handle}"]`);
              if (card) card.remove();
            } else if (data.status === 'error') {
              clearInterval(interval);
              showToast('❌ Nuke failed: ' + (data.error || 'unknown'), true);
            }
          })
          .catch(() => {});
        if (attempts > 30) { clearInterval(interval); showToast('⚠️ Nuke job status check timed out.', true); }
      }, 3000);
    }

    // --- GLOBAL PRICE OVERRIDE ---
    document.getElementById('btnUpdatePrice').addEventListener('click', function () {
      const tag = document.getElementById('targetTag').value.trim();
      const price = document.getElementById('newPrice').value.trim();
      const statusEl = document.getElementById('priceStatus');
      if (!tag || !price) { statusEl.textContent = 'Please fill in both fields.'; statusEl.style.color = '#ef4444'; return; }

      statusEl.textContent = 'Updating prices...';
      statusEl.style.color = 'var(--gray)';

      fetch(`${RAILWAY_URL}/admin/price-override`, {
        method: 'POST',
        headers: railwayHeaders(),
        body: JSON.stringify({ tag: tag, price: parseFloat(price) })
      })
        .then(r => r.json())
        .then(data => {
          if (data.ok || data.status === 'ok') {
            statusEl.textContent = '✅ Prices updated!';
            statusEl.style.color = '#10b981';
          } else {
            statusEl.textContent = '❌ ' + (data.error || 'Failed');
            statusEl.style.color = '#ef4444';
          }
        })
        .catch(e => { statusEl.textContent = '❌ ' + e.message; statusEl.style.color = '#ef4444'; });
    });

    // --- SLEEP ALL INACTIVE ---
    function sleepAllInactive() {
      if (!confirm('Put ALL inactive stores to sleep? This will call /admin/sleep-check on the backend.')) return;
      const statusEl = document.getElementById('sleepAllStatus');
      statusEl.textContent = 'Running sleep check...';
      statusEl.style.color = 'var(--gray)';
      fetch(`${RAILWAY_URL}/admin/sleep-check`, {
        method: 'POST',
        headers: railwayHeaders()
      })
        .then(r => r.json())
        .then(data => {
          if (data.ok || data.status === 'ok' || data.slept !== undefined) {
            statusEl.textContent = `✅ Done. ${data.slept !== undefined ? data.slept + ' store(s) slept.' : ''}`;
            statusEl.style.color = '#10b981';
          } else {
            statusEl.textContent = '❌ ' + (data.error || 'Failed');
            statusEl.style.color = '#ef4444';
          }
        })
        .catch(e => { statusEl.textContent = '❌ ' + e.message; statusEl.style.color = '#ef4444'; });
    }

    // --- RUN PRINTFUL BY HANDLE ---
    function runPrintful() {
      const handle = document.getElementById('printfulHandle').value.trim();
      const statusEl = document.getElementById('printfulStatus');
      if (!handle) { statusEl.textContent = 'Enter a store handle.'; statusEl.style.color = '#ef4444'; return; }
      statusEl.textContent = 'Waking/rebuilding...';
      statusEl.style.color = 'var(--gray)';
      fetch(`${RAILWAY_URL}/admin/store/${encodeURIComponent(handle)}/wakeup`, {
        method: 'POST',
        headers: railwayHeaders()
      })
        .then(r => r.json())
        .then(data => {
          if (data.job_id || data.status === 'ok') {
            statusEl.textContent = `✅ Printful run started for "${handle}".`;
            statusEl.style.color = '#10b981';
          } else {
            statusEl.textContent = '❌ ' + (data.error || 'Failed');
            statusEl.style.color = '#ef4444';
          }
        })
        .catch(e => { statusEl.textContent = '❌ ' + e.message; statusEl.style.color = '#ef4444'; });
    }

    // --- SETTINGS TAB ---
    function toggleVisibility(vis) {
      if (!currentStoreHandle) return;
      fetch(`${RAILWAY_URL}/admin/store/${currentStoreHandle}/visibility`, {
        method: 'POST',
        headers: railwayHeaders(),
        body: JSON.stringify({ visibility: vis })
      })
        .then(r => r.json())
        .then(data => {
          if (data.ok || data.status === 'ok') showToast(`✅ Store set to ${vis}`);
          else showToast('❌ ' + (data.error || 'Failed'), true);
        })
        .catch(e => showToast('❌ ' + e.message, true));
    }
  </script>

{% else %}
  <div style="height:100vh; display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center;">
    <div style="font-size:40px; margin-bottom:20px;">🔒</div>
    <h1 style="color:white; margin:0;">Restricted</h1>
    <a href="{{ routes.root_url }}" style="color:var(--accent); text-decoration:none; font-weight:700; margin-top:20px;">Return Home</a>
  </div>
{% endif %}

</body>
</html>