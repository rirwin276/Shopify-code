{% layout none %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Stella & Sage — God Mode</title>
<style>
  :root {
    --bg: #f5f5f7;
    --card: #ffffff;
    --border: #d1d1d6;
    --text: #1c1c1e;
    --gray: #6e6e73;
    --accent: #0071e3;
    --danger: #ff3b30;
    --warning: #ff9f0a;
    --success: #34c759;
    --radius: 14px;
    --font: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    padding: 0 0 100px;
  }

  .gm-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 14px 70px;
  }

  .gm-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(245, 245, 247, 0.96);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
    margin-bottom: 12px;
  }

  .gm-header-inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 10px 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }

  .gm-title {
    margin: 0;
    font-size: 20px;
    font-weight: 800;
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .gm-count-badge {
    background: var(--card);
    border: 1px solid var(--border);
    color: var(--gray);
    border-radius: 99px;
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 700;
  }

  .gm-search-icon {
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--text);
    border-radius: 10px;
    min-height: 44px;
    min-width: 44px;
    padding: 0;
    font-size: 18px;
    cursor: pointer;
  }

  .gm-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px;
    margin-bottom: 12px;
  }

  .gm-banner-title {
    margin: 0 0 10px;
    font-size: 18px;
    font-weight: 800;
  }

  .gm-banner-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 10px;
  }

  .gm-banner-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 10px;
  }

  .gm-banner-name {
    font-size: 14px;
    font-weight: 700;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .gm-pill-row,
  .gm-filter-tabs {
    display: flex;
    gap: 8px;
    overflow-x: auto;
    padding-bottom: 2px;
    -webkit-overflow-scrolling: touch;
  }

  .gm-pill,
  .gm-filter-tab {
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--text);
    border-radius: 999px;
    min-height: 44px;
    padding: 0 14px;
    white-space: nowrap;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .is-active-filter {
    background: var(--text);
    color: #fff;
    border-color: var(--text);
  }

  .gm-search-input {
    width: 100%;
    border: 1px solid var(--border);
    background: var(--card);
    color: var(--text);
    border-radius: 12px;
    min-height: 44px;
    padding: 0 14px;
    font-size: 15px;
    margin-bottom: 10px;
  }

  .gm-store-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .gm-store-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px;
  }

  .gm-store-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 10px;
    margin-bottom: 10px;
  }

  .gm-store-name {
    margin: 0;
    font-size: 20px;
    font-weight: 800;
    line-height: 1.15;
  }

  .gm-store-handle {
    margin-top: 4px;
    color: var(--gray);
    font-size: 12px;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
  }

  .gm-badge {
    border-radius: 999px;
    border: 1px solid var(--border);
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
  }

  .gm-badge.active { color: var(--success); border-color: rgba(52,199,89,0.35); background: rgba(52,199,89,0.08); }
  .gm-badge.sleeping { color: #5856d6; border-color: rgba(88,86,214,0.35); background: rgba(88,86,214,0.08); }
  .gm-badge.waking { color: var(--accent); border-color: rgba(0,113,227,0.35); background: rgba(0,113,227,0.08); }
  .gm-badge.private { color: var(--warning); border-color: rgba(255,159,10,0.35); background: rgba(255,159,10,0.08); }
  .gm-badge.closed { color: var(--gray); }

  .gm-card-actions {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 8px;
  }

  .gm-btn {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--card);
    color: var(--text);
    min-height: 44px;
    padding: 0 12px;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
  }

  .gm-btn-primary { background: var(--accent); border-color: var(--accent); color: #fff; }
  .gm-btn-danger { background: var(--danger); border-color: var(--danger); color: #fff; }
  .gm-btn-warning { background: #fff7ed; border-color: #fed7aa; color: #9a3412; }

  .gm-section-title {
    margin: 0 0 10px;
    font-size: 15px;
    font-weight: 800;
  }

  .gm-graveyard-toggle {
    width: 100%;
  }

  .gm-graveyard-content[hidden] { display: none; }

  .gm-closed-card {
    opacity: 0.7;
    border-style: dashed;
  }

  .gm-sheet-overlay {
    position: fixed;
    inset: 0;
    background: rgba(28,28,30,0.35);
    z-index: 90;
    display: none;
  }

  .gm-sheet-overlay.show { display: block; }

  .gm-sheet {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--card);
    border-top: 1px solid var(--border);
    border-radius: 16px 16px 0 0;
    z-index: 100;
    transform: translateY(102%);
    transition: transform .22s ease;
    max-height: 88vh;
    overflow: auto;
    padding: 14px;
  }

  .gm-sheet.show { transform: translateY(0); }

  .gm-sheet-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 10px;
  }

  .gm-sheet-title {
    margin: 0;
    font-size: 18px;
    font-weight: 800;
    line-height: 1.15;
  }

  .gm-sheet-sub {
    margin: 4px 0 0;
    color: var(--gray);
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 12px;
  }

  .gm-close {
    border: 1px solid var(--border);
    background: var(--card);
    border-radius: 10px;
    min-height: 44px;
    min-width: 44px;
    font-size: 20px;
    cursor: pointer;
  }

  .gm-sheet-tabs {
    display: flex;
    gap: 8px;
    margin-bottom: 10px;
  }

  .gm-sheet-tab {
    flex: 1;
    min-height: 44px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--card);
    font-weight: 700;
    cursor: pointer;
  }

  .gm-sheet-tab.active {
    background: var(--text);
    border-color: var(--text);
    color: #fff;
  }

  .gm-tab-pane { display: none; }
  .gm-tab-pane.active { display: block; }

  .gm-field { margin-bottom: 10px; }
  .gm-label { display: block; margin-bottom: 6px; font-size: 12px; color: var(--gray); font-weight: 700; }

  .gm-input,
  .gm-select {
    width: 100%;
    min-height: 44px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--card);
    color: var(--text);
    padding: 0 12px;
    font-size: 14px;
  }

  .gm-member-grid,
  .gm-setting-grid,
  .gm-tools-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }

  .gm-status-text {
    margin-top: 8px;
    min-height: 18px;
    font-size: 12px;
    color: var(--gray);
  }

  .gm-member-list {
    margin-top: 12px;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }

  .gm-member-row {
    display: flex;
    justify-content: space-between;
    gap: 10px;
    padding: 10px;
    border-bottom: 1px solid var(--border);
    font-size: 13px;
  }

  .gm-member-row:last-child { border-bottom: none; }

  .gm-copy-row {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px;
    margin-bottom: 8px;
  }

  .gm-copy-label {
    font-size: 11px;
    color: var(--gray);
    font-weight: 700;
    margin-bottom: 4px;
  }

  .gm-copy-value {
    word-break: break-all;
    font-size: 13px;
    margin-bottom: 8px;
  }

  .gm-fab {
    position: fixed;
    right: 14px;
    bottom: 14px;
    z-index: 50;
    min-width: 52px;
    min-height: 52px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--text);
    color: #fff;
    font-size: 22px;
    cursor: pointer;
  }

  .gm-tools-desktop { display: none; }

  .gm-toast {
    position: fixed;
    left: 50%;
    bottom: 76px;
    transform: translateX(-50%);
    background: var(--text);
    color: #fff;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 13px;
    z-index: 120;
    display: none;
  }

  @media (min-width: 901px) {
    .gm-page {
      max-width: 1200px;
      padding-right: 320px;
    }

    .gm-header-inner {
      max-width: 1200px;
      padding-right: 334px;
    }

    .gm-store-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }

    .gm-sheet {
      left: 50%;
      right: auto;
      width: min(680px, calc(100vw - 40px));
      transform: translate(-50%, 102%);
      border-radius: 16px;
      border: 1px solid var(--border);
      bottom: 20px;
      box-shadow: 0 16px 44px rgba(0,0,0,0.16);
    }

    .gm-sheet.show { transform: translate(-50%, 0); }

    .gm-member-grid { grid-template-columns: 1fr 180px; }

    .gm-fab,
    #toolsSheet { display: none; }

    .gm-tools-desktop {
      display: block;
      position: fixed;
      top: 82px;
      right: 14px;
      width: 280px;
      z-index: 20;
    }
  }
</style>
</head>
<body>

{% assign is_super = false %}
{% if customer %}
  {% if customer.email == 'ryan.irwin@stellaandsagecompany.com' %}{% assign is_super = true %}{% endif %}
  {% for t in customer.tags %}
    {% if t contains 'super-admin' %}{% assign is_super = true %}{% endif %}
  {% endfor %}
{% endif %}
{% unless is_super %}
  <script>window.location.replace('/pages/portal');</script>
{% endunless %}

{% if is_super %}
  {% assign total_stores = 0 %}
  {% assign active_count = 0 %}
  {% assign sleeping_count = 0 %}
  {% assign waking_count = 0 %}
  {% assign closed_count = 0 %}

  {% for store in shop.metaobjects.custom_shop.values %}
    {% assign total_stores = total_stores | plus: 1 %}
    {% assign _status = '' %}
    {% for f in store.fields %}
      {% if f.key == 'status' %}{% assign _status = f.value %}{% endif %}
    {% endfor %}
    {% if _status == blank %}{% assign _status = store.status.value | default: store.status | default: '' %}{% endif %}
    {% assign _status = _status | strip | downcase %}
    {% if store.tags contains 'status:closed' %}
      {% assign closed_count = closed_count | plus: 1 %}
    {% elsif _status == 'sleeping' %}
      {% assign sleeping_count = sleeping_count | plus: 1 %}
    {% elsif _status == 'waking' %}
      {% assign waking_count = waking_count | plus: 1 %}
    {% else %}
      {% assign active_count = active_count | plus: 1 %}
    {% endif %}
  {% endfor %}

  <header class="gm-header">
    <div class="gm-header-inner">
      <h1 class="gm-title">⚡ God Mode <span class="gm-count-badge">{{ total_stores }} stores</span></h1>
      <button class="gm-search-icon" type="button" id="focusSearch" aria-label="Focus search">⌕</button>
    </div>
  </header>

  <div class="gm-page">
    <div class="gm-card" id="newStoreBanner" style="display:none;">
      <h2 class="gm-banner-title" id="newStoreTitle"></h2>
      <div class="gm-banner-list" id="newStoreList"></div>
      <button type="button" class="gm-btn gm-btn-primary" id="markAllSeenBtn">Mark all seen ✓</button>
    </div>

    <section class="gm-card">
      <h2 class="gm-section-title">Stats</h2>
      <div class="gm-pill-row" id="statsPills">
        <button type="button" class="gm-pill is-active-filter" data-stat-filter="all">Total <span>{{ total_stores }}</span></button>
        <button type="button" class="gm-pill" data-stat-filter="active">Active <span>{{ active_count }}</span></button>
        <button type="button" class="gm-pill" data-stat-filter="sleeping">Sleeping <span>{{ sleeping_count }}</span></button>
        <button type="button" class="gm-pill" data-stat-filter="waking">Waking <span>{{ waking_count }}</span></button>
        <button type="button" class="gm-pill" data-stat-filter="closed">Closed <span>{{ closed_count }}</span></button>
      </div>
    </section>

    <section class="gm-card">
      <input class="gm-search-input" id="storeSearch" type="text" placeholder="Search stores...">
      <div class="gm-filter-tabs" id="storeFilterTabs">
        <button type="button" class="gm-filter-tab is-active-filter" data-grid-filter="all">All</button>
        <button type="button" class="gm-filter-tab" data-grid-filter="active">Active</button>
        <button type="button" class="gm-filter-tab" data-grid-filter="sleeping">Sleeping</button>
        <button type="button" class="gm-filter-tab" data-grid-filter="waking">Waking</button>
        <button type="button" class="gm-filter-tab" data-grid-filter="closed">Closed</button>
        <button type="button" class="gm-filter-tab" data-grid-filter="no-sales">No Sales</button>
      </div>
    </section>

    <section>
      <div class="gm-store-grid" id="activeStoreGrid">
        {% for store in shop.metaobjects.custom_shop.values %}
          {% unless store.tags contains 'status:closed' %}
            {% assign _status = '' %}
            {% for f in store.fields %}
              {% if f.key == 'status' %}{% assign _status = f.value %}{% endif %}
            {% endfor %}
            {% if _status == blank %}{% assign _status = store.status.value | default: store.status | default: '' %}{% endif %}
            {% assign _status = _status | strip | downcase %}
            {% assign _is_sleeping = false %}
            {% assign _is_waking = false %}
            {% assign _is_private = false %}
            {% if _status == 'sleeping' %}{% assign _is_sleeping = true %}{% endif %}
            {% if _status == 'waking' %}{% assign _is_waking = true %}{% endif %}
            {% if store.tags contains 'status:private' %}{% assign _is_private = true %}{% endif %}
            {% assign _collection_handle = store.collection_handle | default: store.system.handle %}
            {% assign _collection = collections[_collection_handle] %}
            {% assign _products_count = 0 %}
            {% if _collection %}{% assign _products_count = _collection.products_count | default: 0 %}{% endif %}

            <article
              class="gm-store-card"
              data-name="{{ store.name | default: store.system.handle | escape | downcase }}"
              data-handle="{{ store.system.handle | escape }}"
              data-collection="{{ _collection_handle | escape }}"
              data-status="{% if _is_sleeping %}sleeping{% elsif _is_waking %}waking{% else %}active{% endif %}"
              data-private="{% if _is_private %}true{% else %}false{% endif %}"
              data-products="{{ _products_count }}"
              data-store-name="{{ store.name | default: store.system.handle | escape }}">
              <div class="gm-store-top">
                <div>
                  <h3 class="gm-store-name">{{ store.name | default: store.system.handle }}</h3>
                  <div class="gm-store-handle">{{ store.system.handle }}</div>
                </div>
                {% if _is_sleeping %}
                  <span class="gm-badge sleeping">Sleeping</span>
                {% elsif _is_waking %}
                  <span class="gm-badge waking">Waking</span>
                {% elsif _is_private %}
                  <span class="gm-badge private">Private</span>
                {% else %}
                  <span class="gm-badge active">Active</span>
                {% endif %}
              </div>
              <div class="gm-card-actions">
                <a class="gm-btn gm-btn-primary" href="/pages/admin-powers?shop={{ store.system.handle | url_encode }}" target="_blank" rel="noopener">Admin →</a>
                <a class="gm-btn" href="/collections/{{ _collection_handle | url_encode }}" target="_blank" rel="noopener">Visit ↗</a>
                <button type="button" class="gm-btn" data-open-manage="true">Manage ▾</button>
              </div>
            </article>
          {% endunless %}
        {% endfor %}
      </div>
    </section>

    <section class="gm-card">
      <button type="button" class="gm-btn gm-graveyard-toggle" id="toggleGraveyard">Show Closed Stores ({{ closed_count }})</button>
      <div class="gm-graveyard-content" id="graveyardContent" hidden>
        <div class="gm-store-grid" id="closedStoreGrid" style="margin-top:10px;">
          {% for store in shop.metaobjects.custom_shop.values %}
            {% if store.tags contains 'status:closed' %}
              {% assign _collection_handle = store.collection_handle | default: store.system.handle %}
              <article class="gm-store-card gm-closed-card" data-name="{{ store.name | default: store.system.handle | escape | downcase }}" data-status="closed" data-handle="{{ store.system.handle | escape }}" data-products="0">
                <div class="gm-store-top">
                  <div>
                    <h3 class="gm-store-name">{{ store.name | default: store.system.handle }}</h3>
                    <div class="gm-store-handle">{{ store.system.handle }}</div>
                  </div>
                  <span class="gm-badge closed">Closed</span>
                </div>
                <div class="gm-card-actions" style="grid-template-columns:1fr;">
                  <button type="button" class="gm-btn gm-btn-primary" onclick="wakeStore('{{ store.system.handle | escape }}')">Wake Up ☀️</button>
                </div>
              </article>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </section>
  </div>

  <aside class="gm-tools-desktop">
    <div class="gm-card">
      <h2 class="gm-section-title">Tools</h2>
      <div class="gm-tools-grid">
        <label class="gm-label">Target Tag</label>
        <input id="targetTag" class="gm-input" type="text" placeholder="e.g. bella-3006-blk">
        <label class="gm-label">New Price ($)</label>
        <input id="newPrice" class="gm-input" type="number" step="0.01" placeholder="0.00">
        <button id="btnUpdatePrice" class="gm-btn gm-btn-primary" type="button">Price Override</button>
        <div id="priceStatus" class="gm-status-text"></div>

        <label class="gm-label">Run Printful (handle)</label>
        <input id="printfulHandle" class="gm-input" type="text" placeholder="store-handle">
        <button class="gm-btn" type="button" onclick="runPrintful('printfulHandle','printfulStatus')">Run Printful</button>
        <div id="printfulStatus" class="gm-status-text"></div>

        <button class="gm-btn gm-btn-warning" type="button" onclick="sleepAllInactive()">Sleep All Inactive</button>
        <div id="sleepAllStatus" class="gm-status-text"></div>

        <a class="gm-btn" href="/admin/products" target="_blank" rel="noopener">Shopify Admin</a>
        <a class="gm-btn" href="/pages/portal">Back to Portal</a>
      </div>
    </div>
  </aside>

  <button class="gm-fab" id="openToolsFab" type="button" aria-label="Open tools">⚙️</button>

  <div class="gm-sheet-overlay" id="sheetOverlay"></div>

  <section class="gm-sheet" id="manageSheet" aria-hidden="true">
    <div class="gm-sheet-head">
      <div>
        <h3 class="gm-sheet-title" id="manageTitle">Manage Store</h3>
        <p class="gm-sheet-sub" id="manageHandle"></p>
      </div>
      <button class="gm-close" type="button" id="closeManage">×</button>
    </div>

    <div class="gm-sheet-tabs">
      <button type="button" class="gm-sheet-tab active" data-manage-tab="members">Members</button>
      <button type="button" class="gm-sheet-tab" data-manage-tab="settings">Settings</button>
      <button type="button" class="gm-sheet-tab" data-manage-tab="info">Info</button>
    </div>

    <div class="gm-tab-pane active" data-pane="members">
      <div class="gm-member-grid">
        <div class="gm-field" style="margin-bottom:0;">
          <label class="gm-label">Email address</label>
          <input id="memberEmail" type="email" class="gm-input" placeholder="user@example.com">
        </div>
        <div class="gm-field" style="margin-bottom:0;">
          <label class="gm-label">Role</label>
          <select id="memberRole" class="gm-select">
            <option value="member">Member</option>
            <option value="admin">Admin</option>
          </select>
        </div>
      </div>
      <div class="gm-setting-grid" style="margin-top:8px;">
        <button type="button" class="gm-btn gm-btn-primary" id="addMemberBtn">Add</button>
        <button type="button" class="gm-btn" id="removeMemberBtn">Remove Member</button>
        <button type="button" class="gm-btn" id="removeAdminBtn">Remove Admin</button>
      </div>
      <div class="gm-status-text" id="memberStatus"></div>
      <div class="gm-member-list" id="memberList"></div>
    </div>

    <div class="gm-tab-pane" data-pane="settings">
      <div class="gm-setting-grid">
        <button type="button" class="gm-btn" id="makePublicBtn">Make Public</button>
        <button type="button" class="gm-btn" id="makePrivateBtn">Make Private</button>
        <button type="button" class="gm-btn gm-btn-warning" id="sleepStoreBtn">Put to Sleep 💤</button>
        <button type="button" class="gm-btn gm-btn-primary" id="wakeStoreBtn">Wake Up ☀️</button>
        <a class="gm-btn gm-btn-primary" id="openFullAdminBtn" target="_blank" rel="noopener">Open Full Admin →</a>
        <button type="button" class="gm-btn gm-btn-danger" id="nukeStoreBtn">NUKE</button>
      </div>
      <div class="gm-status-text" id="settingsStatus"></div>
    </div>

    <div class="gm-tab-pane" data-pane="info">
      <div class="gm-copy-row">
        <div class="gm-copy-label">Store Handle</div>
        <div class="gm-copy-value" id="infoHandle"></div>
        <button type="button" class="gm-btn" id="copyHandleBtn">Copy handle</button>
      </div>
      <div class="gm-copy-row">
        <div class="gm-copy-label">Join Link</div>
        <div class="gm-copy-value" id="infoJoinLink"></div>
        <button type="button" class="gm-btn" id="copyJoinBtn">Copy join link</button>
      </div>
      <div class="gm-copy-row">
        <div class="gm-copy-label">Product Count</div>
        <div class="gm-copy-value" id="infoProductCount"></div>
      </div>
      <a class="gm-btn" id="infoVisitBtn" target="_blank" rel="noopener">Visit storefront ↗</a>
    </div>
  </section>

  <section class="gm-sheet" id="toolsSheet" aria-hidden="true">
    <div class="gm-sheet-head">
      <h3 class="gm-sheet-title">Tools</h3>
      <button class="gm-close" type="button" id="closeTools">×</button>
    </div>
    <div class="gm-tools-grid">
      <label class="gm-label">Target Tag</label>
      <input id="targetTag_m" class="gm-input" type="text" placeholder="e.g. bella-3006-blk">
      <label class="gm-label">New Price ($)</label>
      <input id="newPrice_m" class="gm-input" type="number" step="0.01" placeholder="0.00">
      <button id="btnUpdatePrice_m" class="gm-btn gm-btn-primary" type="button">Price Override</button>
      <div id="priceStatus_m" class="gm-status-text"></div>

      <label class="gm-label">Run Printful (handle)</label>
      <input id="printfulHandle_m" class="gm-input" type="text" placeholder="store-handle">
      <button class="gm-btn" type="button" onclick="runPrintful('printfulHandle_m','printfulStatus_m')">Run Printful</button>
      <div id="printfulStatus_m" class="gm-status-text"></div>

      <button class="gm-btn gm-btn-warning" type="button" onclick="sleepAllInactive()">Sleep All Inactive</button>
      <div id="sleepAllStatus_m" class="gm-status-text"></div>

      <a class="gm-btn" href="/admin/products" target="_blank" rel="noopener">Shopify Admin</a>
      <a class="gm-btn" href="/pages/portal">Back to Portal</a>
    </div>
  </section>

  <div class="gm-toast" id="gmToast"></div>

  <script>
    const RAILWAY_URL = "https://studio-uploader-production.up.railway.app";
    const ADMIN_SECRET = "stellasage-god-mode-2026-xK9mP";

    window.GM_ALL_STORES = [
      {% for store in shop.metaobjects.custom_shop.values %}
        {
          handle: {{ store.system.handle | json }},
          name: {{ store.name | default: store.system.handle | json }},
          collection_handle: {{ store.collection_handle | default: store.system.handle | json }}
        },
      {% endfor %}
    ];

    const GM_STATE = {
      activeGridFilter: 'all',
      activeStatFilter: 'all',
      currentStore: null
    };

    function railwayHeaders() {
      return {
        'Content-Type': 'application/json',
        'X-Admin-Secret': ADMIN_SECRET
      };
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function setStatus(id, text, color) {
      var el = document.getElementById(id);
      if (!el) return;
      el.textContent = text;
      if (color) el.style.color = color;
    }

    function showToast(msg, isError) {
      var el = document.getElementById('gmToast');
      if (!el) return;
      el.textContent = msg;
      el.style.background = isError ? 'var(--danger)' : 'var(--text)';
      el.style.display = 'block';
      clearTimeout(el._t);
      el._t = setTimeout(function(){ el.style.display = 'none'; }, 3200);
    }

    function getSeenStores() {
      return (localStorage.getItem('gm-seen-stores') || '').split(',').map(function(v){ return v.trim(); }).filter(Boolean);
    }

    function saveSeenStores(handles) {
      localStorage.setItem('gm-seen-stores', handles.join(','));
    }

    function markStoreSeen(handle) {
      var seen = getSeenStores();
      if (seen.indexOf(handle) === -1) {
        seen.push(handle);
        saveSeenStores(seen);
      }
      renderNewStoreBanner();
    }

    function markAllStoresSeen() {
      var allHandles = (window.GM_ALL_STORES || []).map(function(s){ return String(s.handle || '').trim(); }).filter(Boolean);
      saveSeenStores(allHandles);
      renderNewStoreBanner();
    }

    function renderNewStoreBanner() {
      var banner = document.getElementById('newStoreBanner');
      var list = document.getElementById('newStoreList');
      var title = document.getElementById('newStoreTitle');
      if (!banner || !list || !title) return;

      var seen = getSeenStores();
      var newStores = (window.GM_ALL_STORES || []).filter(function(store){
        var h = String(store.handle || '').trim();
        return h && seen.indexOf(h) === -1;
      });

      if (!newStores.length) {
        banner.style.display = 'none';
        list.innerHTML = '';
        return;
      }

      title.textContent = '🆕  ' + newStores.length + ' New Stores Built';
      list.innerHTML = newStores.map(function(store){
        var collectionHandle = store.collection_handle || store.handle;
        return '<div class="gm-banner-row">'
          + '<div class="gm-banner-name">' + escapeHtml(store.name || store.handle) + '</div>'
          + '<button type="button" class="gm-btn gm-btn-primary" data-peek-store="' + escapeHtml(store.handle) + '" data-peek-collection="' + escapeHtml(collectionHandle) + '">Peek →</button>'
          + '</div>';
      }).join('');

      banner.style.display = '';
    }

    function applyStoreFilters() {
      var search = String((document.getElementById('storeSearch') || {}).value || '').toLowerCase().trim();
      var allCards = Array.prototype.slice.call(document.querySelectorAll('.gm-store-card'));
      allCards.forEach(function(card){
        var name = String(card.getAttribute('data-name') || '').toLowerCase();
        var status = String(card.getAttribute('data-status') || 'active');
        var isPrivate = card.getAttribute('data-private') === 'true';
        var products = parseInt(card.getAttribute('data-products') || '0', 10);
        var inClosedGrid = card.closest('#closedStoreGrid') !== null;

        var statusMatches = true;
        if (GM_STATE.activeGridFilter === 'closed' || GM_STATE.activeStatFilter === 'closed') {
          statusMatches = inClosedGrid;
        } else if (GM_STATE.activeGridFilter === 'sleeping' || GM_STATE.activeStatFilter === 'sleeping') {
          statusMatches = !inClosedGrid && status === 'sleeping';
        } else if (GM_STATE.activeGridFilter === 'waking' || GM_STATE.activeStatFilter === 'waking') {
          statusMatches = !inClosedGrid && status === 'waking';
        } else if (GM_STATE.activeGridFilter === 'active' || GM_STATE.activeStatFilter === 'active') {
          statusMatches = !inClosedGrid && status !== 'sleeping' && status !== 'waking';
        } else if (GM_STATE.activeGridFilter === 'no-sales') {
          statusMatches = !inClosedGrid && status !== 'sleeping' && status !== 'waking' && !isPrivate && products === 0;
        }

        var matchesSearch = !search || name.indexOf(search) !== -1;
        card.style.display = statusMatches && matchesSearch ? '' : 'none';
      });
    }

    function setActiveClass(selector, targetAttr, value) {
      document.querySelectorAll(selector).forEach(function(btn){
        if (btn.getAttribute(targetAttr) === value) btn.classList.add('is-active-filter');
        else btn.classList.remove('is-active-filter');
      });
    }

    function syncGraveyardVisibilityForFilters() {
      var wantsClosed = GM_STATE.activeGridFilter === 'closed' || GM_STATE.activeStatFilter === 'closed';
      var content = document.getElementById('graveyardContent');
      var toggle = document.getElementById('toggleGraveyard');
      if (!content || !toggle) return;
      if (wantsClosed && content.hasAttribute('hidden')) {
        content.removeAttribute('hidden');
        toggle.textContent = 'Hide Closed Stores ({{ closed_count }})';
      }
    }

    function openSheet(id) {
      var overlay = document.getElementById('sheetOverlay');
      if (overlay) overlay.classList.add('show');
      document.querySelectorAll('.gm-sheet').forEach(function(s){ s.classList.remove('show'); });
      var sheet = document.getElementById(id);
      if (sheet) sheet.classList.add('show');
    }

    function closeSheets() {
      var overlay = document.getElementById('sheetOverlay');
      if (overlay) overlay.classList.remove('show');
      document.querySelectorAll('.gm-sheet').forEach(function(s){ s.classList.remove('show'); });
    }

    function switchManageTab(tab) {
      document.querySelectorAll('.gm-sheet-tab[data-manage-tab]').forEach(function(btn){
        btn.classList.toggle('active', btn.getAttribute('data-manage-tab') === tab);
      });
      document.querySelectorAll('.gm-tab-pane[data-pane]').forEach(function(pane){
        pane.classList.toggle('active', pane.getAttribute('data-pane') === tab);
      });
      if (tab === 'members') loadMembers();
    }

    function openManageFromCard(card) {
      if (!card) return;
      var handle = card.getAttribute('data-handle') || '';
      var collection = card.getAttribute('data-collection') || handle;
      var name = card.getAttribute('data-store-name') || handle;
      var products = parseInt(card.getAttribute('data-products') || '0', 10);

      GM_STATE.currentStore = {
        handle: handle,
        collection_handle: collection,
        name: name,
        products: products
      };

      document.getElementById('manageTitle').textContent = name;
      document.getElementById('manageHandle').textContent = '@' + handle;
      document.getElementById('openFullAdminBtn').href = '/pages/admin-powers?shop=' + encodeURIComponent(handle);
      document.getElementById('infoHandle').textContent = handle;
      document.getElementById('infoJoinLink').textContent = 'https://stellasageco.com/pages/join-store?shop=' + handle;
      document.getElementById('infoProductCount').textContent = String(products);
      document.getElementById('infoVisitBtn').href = '/collections/' + encodeURIComponent(collection || handle);
      switchManageTab('members');
      openSheet('manageSheet');
    }

    function copyText(text, successMsg) {
      if (!navigator.clipboard || !navigator.clipboard.writeText) {
        showToast('Clipboard not available', true);
        return;
      }
      navigator.clipboard.writeText(String(text || '')).then(function(){
        showToast(successMsg || 'Copied');
      }).catch(function(){
        showToast('Copy failed', true);
      });
    }

    function handleMemberAction(mode) {
      var store = GM_STATE.currentStore;
      if (!store || !store.handle) return;
      var email = String((document.getElementById('memberEmail') || {}).value || '').trim();
      if (!email) {
        setStatus('memberStatus', 'Please enter an email.', 'var(--danger)');
        return;
      }

      var role = String((document.getElementById('memberRole') || {}).value || 'member');
      var endpoint = '';
      if (mode === 'add') endpoint = role === 'admin' ? '/admin/store/' + encodeURIComponent(store.handle) + '/add-admin' : '/admin/store/' + encodeURIComponent(store.handle) + '/add-member';
      if (mode === 'remove-member') endpoint = '/admin/store/' + encodeURIComponent(store.handle) + '/remove-member';
      if (mode === 'remove-admin') endpoint = '/admin/store/' + encodeURIComponent(store.handle) + '/remove-admin';

      setStatus('memberStatus', 'Saving member changes...', 'var(--gray)');
      fetch(RAILWAY_URL + endpoint, {
        method: 'POST',
        headers: railwayHeaders(),
        body: JSON.stringify({ email: email })
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (data.ok || data.status === 'ok') {
          setStatus('memberStatus', '✅ Member update complete.', 'var(--success)');
          document.getElementById('memberEmail').value = '';
          loadMembers();
        } else {
          setStatus('memberStatus', '❌ ' + (data.error || 'Request failed'), 'var(--danger)');
        }
      })
      .catch(function(err){
        setStatus('memberStatus', '❌ ' + err.message, 'var(--danger)');
      });
    }

    function loadMembers() {
      var list = document.getElementById('memberList');
      var store = GM_STATE.currentStore;
      if (!list || !store || !store.handle) return;
      list.innerHTML = '<div class="gm-member-row"><span>Loading members...</span></div>';
      fetch(RAILWAY_URL + '/admin/store/' + encodeURIComponent(store.handle) + '/members', {
        method: 'GET',
        headers: railwayHeaders()
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        var rows = [];
        var members = [];
        if (Array.isArray(data.members)) members = data.members;
        else if (Array.isArray(data.items)) members = data.items;
        else if (Array.isArray(data.data)) members = data.data;

        members.forEach(function(item){
          var email = item.email || item.customer_email || item.value || '';
          if (!email) return;
          var role = 'Member';
          if (item.role) role = item.role;
          else if (item.is_admin) role = 'Admin';
          rows.push('<div class="gm-member-row"><span>' + escapeHtml(email) + '</span><strong>' + escapeHtml(role) + '</strong></div>');
        });

        if (!rows.length) rows.push('<div class="gm-member-row"><span>No members found.</span></div>');
        list.innerHTML = rows.join('');
      })
      .catch(function(){
        list.innerHTML = '<div class="gm-member-row"><span>Could not load members.</span></div>';
      });
    }

    function updateVisibility(visibility) {
      var store = GM_STATE.currentStore;
      if (!store || !store.handle) return;
      setStatus('settingsStatus', 'Updating visibility...', 'var(--gray)');
      fetch(RAILWAY_URL + '/admin/store/' + encodeURIComponent(store.handle) + '/visibility', {
        method: 'POST',
        headers: railwayHeaders(),
        body: JSON.stringify({ visibility: visibility })
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (data.ok || data.status === 'ok') setStatus('settingsStatus', '✅ Visibility updated.', 'var(--success)');
        else setStatus('settingsStatus', '❌ ' + (data.error || 'Failed'), 'var(--danger)');
      })
      .catch(function(err){ setStatus('settingsStatus', '❌ ' + err.message, 'var(--danger)'); });
    }

    function sleepStore(handle) {
      if (!handle || !confirm('Put store "' + handle + '" to sleep?')) return;
      fetch(RAILWAY_URL + '/admin/store/' + encodeURIComponent(handle) + '/sleep', {
        method: 'POST',
        headers: railwayHeaders()
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (data.job_id || data.status === 'ok') {
          showToast('✅ Store put to sleep.');
          window.location.reload();
        } else {
          showToast('❌ ' + (data.error || 'Sleep failed'), true);
        }
      })
      .catch(function(err){ showToast('❌ ' + err.message, true); });
    }

    function wakeStore(handle) {
      if (!handle || !confirm('Wake store "' + handle + '" now?')) return;
      fetch(RAILWAY_URL + '/admin/store/' + encodeURIComponent(handle) + '/wakeup', {
        method: 'POST',
        headers: railwayHeaders()
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (data.job_id || data.status === 'ok') {
          showToast('✅ Store waking up.');
          window.location.reload();
        } else {
          showToast('❌ ' + (data.error || 'Wake failed'), true);
        }
      })
      .catch(function(err){ showToast('❌ ' + err.message, true); });
    }

    function nukeStore(handle) {
      if (!handle) return;
      if (!confirm('☢️ NUKE store "' + handle + '"? This cannot be undone.')) return;
      fetch(RAILWAY_URL + '/api/storefront/' + encodeURIComponent(handle) + '/nuke', {
        method: 'POST',
        headers: railwayHeaders(),
        body: JSON.stringify({})
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (!data.job_id) {
          showToast('❌ ' + (data.error || 'Nuke failed'), true);
          return;
        }
        showToast('☢️ Nuke started.');
        var tries = 0;
        var timer = setInterval(function(){
          tries += 1;
          fetch(RAILWAY_URL + '/api/job/' + encodeURIComponent(data.job_id), { headers: railwayHeaders() })
            .then(function(r){ return r.json(); })
            .then(function(job){
              if (job.status === 'done') {
                clearInterval(timer);
                showToast('✅ Store nuked.');
                window.location.reload();
              } else if (job.status === 'error') {
                clearInterval(timer);
                showToast('❌ ' + (job.error || 'Nuke failed'), true);
              }
            })
            .catch(function(){});
          if (tries > 35) {
            clearInterval(timer);
            showToast('⚠️ Nuke status timed out.', true);
          }
        }, 3000);
      })
      .catch(function(err){ showToast('❌ ' + err.message, true); });
    }

    function runPrintful(inputId, statusId) {
      var handle = String((document.getElementById(inputId) || {}).value || '').trim();
      if (!handle) {
        setStatus(statusId, 'Enter a store handle.', 'var(--danger)');
        return;
      }
      setStatus(statusId, 'Running Printful wake...', 'var(--gray)');
      fetch(RAILWAY_URL + '/admin/store/' + encodeURIComponent(handle) + '/wakeup', {
        method: 'POST',
        headers: railwayHeaders()
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        if (data.job_id || data.status === 'ok') setStatus(statusId, '✅ Printful started for ' + handle, 'var(--success)');
        else setStatus(statusId, '❌ ' + (data.error || 'Failed'), 'var(--danger)');
      })
      .catch(function(err){ setStatus(statusId, '❌ ' + err.message, 'var(--danger)'); });
    }

    function sleepAllInactive() {
      if (!confirm('Run sleep-check for inactive stores?')) return;
      setStatus('sleepAllStatus', 'Running...', 'var(--gray)');
      setStatus('sleepAllStatus_m', 'Running...', 'var(--gray)');
      fetch(RAILWAY_URL + '/admin/sleep-check', {
        method: 'POST',
        headers: railwayHeaders()
      })
      .then(function(r){ return r.json(); })
      .then(function(data){
        var msg = (data.ok || data.status === 'ok' || data.slept !== undefined)
          ? ('✅ Done' + (data.slept !== undefined ? '. ' + data.slept + ' slept.' : '.'))
          : ('❌ ' + (data.error || 'Failed'));
        var color = (data.ok || data.status === 'ok' || data.slept !== undefined) ? 'var(--success)' : 'var(--danger)';
        setStatus('sleepAllStatus', msg, color);
        setStatus('sleepAllStatus_m', msg, color);
      })
      .catch(function(err){
        setStatus('sleepAllStatus', '❌ ' + err.message, 'var(--danger)');
        setStatus('sleepAllStatus_m', '❌ ' + err.message, 'var(--danger)');
      });
    }

    function bindPriceOverride(buttonId, tagId, priceId, statusId) {
      var button = document.getElementById(buttonId);
      if (!button) return;
      button.addEventListener('click', function(){
        var tag = String((document.getElementById(tagId) || {}).value || '').trim();
        var price = String((document.getElementById(priceId) || {}).value || '').trim();
        if (!tag || !price) {
          setStatus(statusId, 'Please fill in tag and price.', 'var(--danger)');
          return;
        }
        setStatus(statusId, 'Updating prices...', 'var(--gray)');
        fetch(RAILWAY_URL + '/admin/price-override', {
          method: 'POST',
          headers: railwayHeaders(),
          body: JSON.stringify({ tag: tag, price: parseFloat(price) })
        })
        .then(function(r){ return r.json(); })
        .then(function(data){
          if (data.ok || data.status === 'ok') setStatus(statusId, '✅ Prices updated.', 'var(--success)');
          else setStatus(statusId, '❌ ' + (data.error || 'Failed'), 'var(--danger)');
        })
        .catch(function(err){ setStatus(statusId, '❌ ' + err.message, 'var(--danger)'); });
      });
    }

    document.getElementById('focusSearch').addEventListener('click', function(){
      var input = document.getElementById('storeSearch');
      if (input) input.focus();
    });

    document.getElementById('storeSearch').addEventListener('input', applyStoreFilters);

    document.querySelectorAll('[data-grid-filter]').forEach(function(btn){
      btn.addEventListener('click', function(){
        GM_STATE.activeGridFilter = btn.getAttribute('data-grid-filter') || 'all';
        setActiveClass('[data-grid-filter]', 'data-grid-filter', GM_STATE.activeGridFilter);
        syncGraveyardVisibilityForFilters();
        applyStoreFilters();
      });
    });

    document.querySelectorAll('[data-stat-filter]').forEach(function(btn){
      btn.addEventListener('click', function(){
        GM_STATE.activeStatFilter = btn.getAttribute('data-stat-filter') || 'all';
        setActiveClass('[data-stat-filter]', 'data-stat-filter', GM_STATE.activeStatFilter);
        syncGraveyardVisibilityForFilters();
        applyStoreFilters();
      });
    });

    document.getElementById('toggleGraveyard').addEventListener('click', function(){
      var content = document.getElementById('graveyardContent');
      var isHidden = content.hasAttribute('hidden');
      if (isHidden) {
        content.removeAttribute('hidden');
        this.textContent = 'Hide Closed Stores ({{ closed_count }})';
      } else {
        content.setAttribute('hidden', 'hidden');
        this.textContent = 'Show Closed Stores ({{ closed_count }})';
      }
      applyStoreFilters();
    });

    document.getElementById('activeStoreGrid').addEventListener('click', function(event){
      var target = event.target.closest('[data-open-manage]');
      if (!target) return;
      var card = target.closest('.gm-store-card');
      openManageFromCard(card);
    });

    document.getElementById('sheetOverlay').addEventListener('click', closeSheets);
    document.getElementById('closeManage').addEventListener('click', closeSheets);
    document.getElementById('openToolsFab').addEventListener('click', function(){ openSheet('toolsSheet'); });
    document.getElementById('closeTools').addEventListener('click', closeSheets);

    document.querySelectorAll('.gm-sheet-tab[data-manage-tab]').forEach(function(tabBtn){
      tabBtn.addEventListener('click', function(){ switchManageTab(tabBtn.getAttribute('data-manage-tab')); });
    });

    document.getElementById('addMemberBtn').addEventListener('click', function(){ handleMemberAction('add'); });
    document.getElementById('removeMemberBtn').addEventListener('click', function(){ handleMemberAction('remove-member'); });
    document.getElementById('removeAdminBtn').addEventListener('click', function(){ handleMemberAction('remove-admin'); });

    document.getElementById('makePublicBtn').addEventListener('click', function(){ updateVisibility('public'); });
    document.getElementById('makePrivateBtn').addEventListener('click', function(){ updateVisibility('private'); });
    document.getElementById('sleepStoreBtn').addEventListener('click', function(){ if (GM_STATE.currentStore) sleepStore(GM_STATE.currentStore.handle); });
    document.getElementById('wakeStoreBtn').addEventListener('click', function(){ if (GM_STATE.currentStore) wakeStore(GM_STATE.currentStore.handle); });
    document.getElementById('nukeStoreBtn').addEventListener('click', function(){ if (GM_STATE.currentStore) nukeStore(GM_STATE.currentStore.handle); });

    document.getElementById('copyHandleBtn').addEventListener('click', function(){
      if (!GM_STATE.currentStore) return;
      copyText(GM_STATE.currentStore.handle, 'Handle copied');
    });

    document.getElementById('copyJoinBtn').addEventListener('click', function(){
      if (!GM_STATE.currentStore) return;
      copyText('https://stellasageco.com/pages/join-store?shop=' + GM_STATE.currentStore.handle, 'Join link copied');
    });

    document.getElementById('newStoreBanner').addEventListener('click', function(event){
      var peekBtn = event.target.closest('[data-peek-store]');
      if (!peekBtn) return;
      var storeHandle = peekBtn.getAttribute('data-peek-store') || '';
      var collection = peekBtn.getAttribute('data-peek-collection') || storeHandle;
      if (collection) window.open('/collections/' + encodeURIComponent(collection), '_blank', 'noopener');
      if (storeHandle) markStoreSeen(storeHandle);
    });

    document.getElementById('markAllSeenBtn').addEventListener('click', markAllStoresSeen);

    bindPriceOverride('btnUpdatePrice', 'targetTag', 'newPrice', 'priceStatus');
    bindPriceOverride('btnUpdatePrice_m', 'targetTag_m', 'newPrice_m', 'priceStatus_m');

    renderNewStoreBanner();
    applyStoreFilters();
  </script>
