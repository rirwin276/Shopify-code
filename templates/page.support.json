self: flex-start;\n  }\n\n  .ss-action-card:hover .ss-btn-link {\n    border-color: #111;\n  }\n\n  /* --- META INFO (Status) --- */\n  .ss-meta-info {\n    margin-top: 60px;\n    padding-top: 30px;\n    border-top: 1px solid #eaeaea;\n    display: flex;\n    justify-content: space-between;\n    font-size: 13px;\n    color: #888;\n  }\n  \n  .ss-status-live {\n    color: #10b981;\n    font-weight: 600;\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n  \n  .ss-dot {\n    width: 6px; height: 6px; background: #10b981; border-radius: 50%;\n  }\n\n  @media (max-width: 768px) {\n    .ss-power-grid { grid-template-columns: 1fr; }\n    .ss-action-card { height: auto; }\n    .ss-meta-info { flex-direction: column; gap: 10px; }\n  }\n</style>\n\n<div class=\"ss-contact-wrapper\">\n\n  <div class=\"ss-header-group\">\n    <h1 class=\"ss-h1-large\">Support & Access</h1>\n    <p class=\"ss-sub-text\">Route your inquiry to the relevant department. <br>Response times for non-urgent matters average 24 hours.</p>\n  </div>\n\n  <div class=\"ss-power-grid\">\n\n    <div class=\"ss-action-card\">\n      <div>\n        <svg class=\"ss-svg-icon\" viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><polygon points=\"12 2 2 7 12 12 22 7 12 2\"></polygon><polyline points=\"2 17 12 22 22 17\"></polyline><polyline points=\"2 12 12 17 22 12\"></polyline></svg>\n        <div class=\"ss-card-head\">Launch a Studio</div>\n        <div class=\"ss-card-body\">Initialize a new private storefront for your organization. Request access to the platform infrastructure.</div>\n      </div>\n      <a href=\"/pages/private-storefronts\" class=\"ss-btn-link\">Initialize Request &rarr;</a>\n    </div>\n\n    <div class=\"ss-action-card\">\n      <div>\n        <svg class=\"ss-svg-icon\" viewBox=\"0 0 24 24\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><circle cx=\"12\" cy=\"12\" r=\"4\"></circle><line x1=\"4.93\" y1=