{
  "sections": {
    "custom_liquid_tzawyJ": {
      "type": "custom-liquid",
      "name": "back button custom liquid",
      "settings": {
        "custom_liquid": "{%- comment -%}\n  SS — Back Buttons (Product Page)\n  1. Checks URL param ?shop=handle\n  2. Fallback: Checks product.collections for context\n{%- endcomment -%}\n\n{%- assign dashboard_url = '/pages/portal' -%}\n{%- assign back_shop_url = '/' -%}\n{%- assign back_shop_label = '← Back to shop' -%}\n\n{%- comment -%} --- STEP 1: CHECK URL PARAM --- {%- endcomment -%}\n{%- assign shop_handle = request.params.shop | default: '' | strip -%}\n{%- if shop_handle == blank -%}\n  {%- assign _cfh = content_for_header -%}\n  {%- assign _url_part = _cfh | split: '\"pageurl\":\"' | last | split: '\"' | first | replace: '\\u0026', '&' -%}\n  {%- if _url_part contains '?' -%}\n    {%- assign _qs = _url_part | split: '?' | last | split: '&' -%}\n    {%- for p in _qs -%}\n      {%- assign kv = p | split: '=' -%}\n      {%- if kv[0] == 'shop' or kv[0] == 'sh' -%}\n        {%- assign shop_handle = kv[1] | strip -%}\n      {%- endif -%}\n    {%- endfor -%}\n  {%- endif -%}\n{%- endif -%}\n\n{%- if shop_handle != blank -%}\n  {%- assign back_shop_url = '/collections/' | append: shop_handle -%}\n  {%- assign back_shop_label = '← Back to store' -%}\n{%- elsif product.collections.size > 0 -%}\n  {%- comment -%} --- STEP 2: FALLBACK TO COLLECTION --- {%- endcomment -%}\n  {%- assign target_col = product.collections.first -%}\n  {%- for col in product.collections -%}\n     {%- if col.handle != 'all' and col.handle != 'frontpage' -%}\n        {%- assign target_col = col -%}\n        {%- break -%}\n     {%- endif -%}\n  {%- endfor -%}\n  {%- assign back_shop_url = target_col.url -%}\n  {%- assign back_shop_label = '← Back to ' | append: target_col.title -%}\n{%- endif -%}\n\n<div class=\"ss-backbar\" role=\"navigation\" aria-label=\"Back links\">\n  <a class=\"ss-backbtn ss-backbtn--ghost\" href=\"{{ back_shop_url }}\">{{ back_shop_label }}</a>\n  <a class=\"ss-backbtn ss-backbtn--solid\" href=\"{{ dashboard_url }}\">Dashboard</a>\n</div>\n\n<style>\n  .ss-backbar{\n    max-width: 1200px;\n    margin: 14px auto 10px;\n    padding: 0 16px;\n    display:flex;\n    gap:10px;\n    flex-wrap:wrap;\n    align-items:center;\n  }\n  .ss-backbtn{\n    display:inline-flex;\n    align-items:center;\n    justify-content:center;\n    padding:10px 14px;\n    border-radius:999px;\n    text-decoration:none;\n    font-weight:800;\n    border:1px solid rgba(0,0,0,.12);\n    background:#fff;\n    color:#111;\n    line-height:1;\n    transition: 0.2s;\n  }\n  .ss-backbtn:hover { opacity: 0.8; }\n  .ss-backbtn--solid{\n    background:#111;\n    color:#fff;\n    border-color:#111;\n  }\n  .ss-backbtn--ghost{\n    background:#fff;\n    color:#111;\n  }\n</style>",
        "color_scheme": "",
        "section_width": "page-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
