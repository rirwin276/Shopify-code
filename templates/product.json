            "custom_liquid_fRk8bW": {
              "type": "custom-liquid",
              "name": "t:names.custom_liquid",
              "disabled": true,
              "settings": {
                "custom_liquid": "{%- liquid\n  assign pos = product.metafields.custom.logo_position\n  assign store_handle = ''\n\n  # -------------------------------------------------------\n  # 1. URL SCRAPING (Finds ?sh=xxxxx)\n  # -------------------------------------------------------\n  assign _cfh = content_for_header\n  assign _pageurl = _cfh | split: '\"pageurl\":\"' | last | split: '\"' | first\n  assign _pageurl = _pageurl | replace: '\\u0026', '&'\n\n  if _pageurl contains 'sh='\n    assign store_handle = _pageurl | split: 'sh=' | last | split: '&' | first\n  endif\n\n  # -------------------------------------------------------\n  # 2. PIXELCUT ONLY (No Old Logo Allowed)\n  # -------------------------------------------------------\n  assign logo_url = ''\n  if store_handle != blank\n    assign shop_entry = shop.metaobjects.custom_shop[store_handle]\n    if shop_entry != blank\n      # Pull ONLY the clean URL.\n      assign logo_url = shop_entry.logo_clean_url.value | default: shop_entry.logo_clean_url\n    endif\n  endif\n\n  # -------------------------------------------------------\n  # 3. ZONE LOGIC\n  # -------------------------------------------------------\n  assign zone_style = \"top: 20%; left: 20%; width: 60%; height: 60%;\"\n  for tag in product.tags\n    if tag contains 'zone:'\n      assign zone_parts = tag | remove: 'zone:' | split: '-'\n      if zone_parts.size == 4\n        capture zone_style\n          echo \"top:\" | append: zone_parts[0] | append: \"%; \"\n          echo \"left:\" | append: zone_parts[1] | append: \"%; \"\n          echo \"width:\" | append: zone_parts[2] | append: \"%; \"\n          echo \"height:\" | append: zone_parts[3] | append: \"%;\"\n        endcapture\n        break\n      endif\n    endif\n  endfor\n-%}\n\n{%- if logo_url != blank -%}\n<style>\n  .ss-master-box {\n    position: relative !important;\n    display: flex !important;\n    justify-content: center !important;\n    align-items: flex-start !important;\n    width: 100% !important;\n    padding: 0 0 20px 0 !important;\n    background: transparent !important; /* Force Clear */\n  }\n\n  .ss-inner-wrap {\n    position: relative !important;\n    width: 85% !important;\n    max-width: 550px !important;\n    display: block !important;\n    background: transparent !important; /* Force Clear */\n  }\n\n  .ss-shirt-static {\n    position: relative !important;\n    display: block !important;\n    width: 100% !important;\n    height: auto !important;\n    z-index: 1;\n  }\n\n  .ss-zone-box {\n    position: absolute !important;\n    {{ zone_style }}\n    z-index: 10;\n    pointer-events: none;\n    overflow: hidden !important;\n    background: transparent !important; /* Force Clear */\n    border: none !important;\n    box-shadow: none !important;\n  }\n\n  .ss-logo-img {\n    position: absolute !important;\n    width: auto !important;\n    max-width: 100% !important;\n    height: auto !important;\n    {{ pos | replace: '|', ';' }} !important;\n    \n    /* THE CSS NUKE: Forces the image to have NO background color */\n    background: transparent !important; \n    background-color: transparent !important;\n    box-shadow: none !important;\n    border: none !important;\n  }\n</style>\n\n<script>\n  (function() {\n    // Timestamp forces browser to fetch the new image, not the cached one\n    const rawUrl = {{ logo_url | json }};\n    const LOGO_URL = rawUrl.includes('?') ? `${rawUrl}&v=${Date.now()}` : `${rawUrl}?v=${Date.now()}`;\n\n    console.log(\"------------------------------------------\");\n    console.log(\"STELLA LOGO DEBUG\");\n    console.log(\"Handle Detected:\", \"{{ store_handle }}\");\n    console.log(\"Logo Source URL:\", LOGO_URL);\n    console.log(\"------------------------------------------\");\n\n    function initMasterSync() {\n      const wrappers = document.querySelectorAll('.product__media, .product-media, .product-single__media');\n\n      wrappers.forEach(wrapper => {\n        const img = wrapper.querySelector('img');\n        if (!img || wrapper.querySelector('.ss-master-box')) return;\n\n        const altText = img.getAttribute('alt') || '';\n        if (!altText.toLowerCase().includes('front')) return;\n\n        const src = img.getAttribute('src') || img.getAttribute('data-src');\n        if(!src) return;\n\n        const masterBox = document.createElement('div');\n        masterBox.className = 'ss-master-box';\n        masterBox.innerHTML = `\n          <div class=\"ss-inner-wrap\">\n            <img src=\"${src}\" class=\"ss-shirt-static\" alt=\"${altText}\">\n            <div class=\"ss-zone-box\">\n              <img src=\"${LOGO_URL}\" class=\"ss-logo-img\" crossorigin=\"anonymous\">\n            </div>\n          </div>\n        `;\n\n        Array.from(wrapper.children).forEach(c => c.style.display = 'none');\n        wrapper.appendChild(masterBox);\n      });\n    }\n    \n    // Aggressive interval to catch slow loads\n    setInterval(initMasterSync, 100);\n  })();\n</script>\n{%- endif -%}"
              },
