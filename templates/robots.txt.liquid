{%- comment -%}
  Custom robots.txt — keeps all of Shopify's default rules, then explicitly
  welcomes AI/LLM crawlers so the site is discoverable by AI assistants and
  answer engines. Blog + pages stay fully crawlable.
{%- endcomment -%}
{%- for group in robots.default_groups -%}
  {{- group.user_agent }}
{% for rule in group.rules -%}
  {{ rule }}
{% endfor -%}
  {%- if group.sitemap != blank -%}
    {{ group.sitemap }}
  {%- endif -%}
{% endfor %}

